<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ROSRA | UN-Habitat</title>
    <link rel="icon" type="image/png" href="~/images/LogoFavicon.png" />
    <link rel="apple-touch-icon" href="~/images/LogoFavicon.png" />
    <!-- Google Fonts - Roboto (UN-Habitat Primary Typeface) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,300;0,400;0,500;0,700;0,900;1,300;1,400;1,500;1,700;1,900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/navbar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/footer.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RosraApp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @inject UserManager<ApplicationUser> UserManager
    @inject RoleManager<IdentityRole> RoleManager
    <header>
        <!-- Main Navigation Bar -->
        <nav class="navbar navbar-expand-lg navbar-light main-navbar" id="mainNavbar">
            <div class="container">
                <!-- Left Logo (UN-Habitat) -->
                <div class="logo-container">
                    <a asp-area="" asp-controller="Home" asp-action="Index">
                        <img src="~/images/Light-theme-logo.png" alt="ROSRA UN-Habitat Logo" />
                    </a>
                </div>

                <!-- Mobile Toggle -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Navigation Content -->
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav main-nav-links ms-auto me-2">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")"
                               asp-area="" asp-controller="Home" asp-action="Index">
                                @SharedLocalizer["Nav_Home"]
                            </a>
                        </li>

                        <!-- About ROSRA Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="aboutDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                @SharedLocalizer["Nav_About"]
                            </a>
                            <ul class="dropdown-menu dropdown-menu-about" aria-labelledby="aboutDropdown">
                                <li><a class="dropdown-item" href="/#what-is-rosra">
                                    <i class="fas fa-info-circle me-2"></i> @SharedLocalizer["Nav_WhatIsRosra"]
                                </a></li>
                                <li><a class="dropdown-item" href="/#what-is-osr">
                                    <i class="fas fa-coins me-2"></i> @SharedLocalizer["Nav_WhatIsOsr"]
                                </a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/#why-un-habitat">
                                    <i class="fas fa-globe me-2"></i> @SharedLocalizer["Nav_WhyUnHabitat"]
                                </a></li>
                            </ul>
                        </li>

                        <!-- Why Optimize Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="whyDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                @SharedLocalizer["Nav_WhyOptimize"]
                            </a>
                            <ul class="dropdown-menu dropdown-menu-why" aria-labelledby="whyDropdown">
                                <li><a class="dropdown-item" href="/#why-optimize">
                                    <i class="fas fa-coins me-2"></i> @SharedLocalizer["Nav_IncreasesResources"]
                                </a></li>
                                <li><a class="dropdown-item" href="/#why-optimize">
                                    <i class="fas fa-balance-scale me-2"></i> @SharedLocalizer["Nav_IncreasesAutonomy"]
                                </a></li>
                                <li><a class="dropdown-item" href="/#why-optimize">
                                    <i class="fas fa-handshake me-2"></i> @SharedLocalizer["Nav_StrengthensContract"]
                                </a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/#why-optimize">
                                    <i class="fas fa-building me-2"></i> @SharedLocalizer["Nav_ImprovesCapacity"]
                                </a></li>
                                <li><a class="dropdown-item" href="/#why-optimize">
                                    <i class="fas fa-chart-line me-2"></i> @SharedLocalizer["Nav_EnablesLeveraging"]
                                </a></li>
                                <li><a class="dropdown-item" href="/#why-optimize">
                                    <i class="fas fa-star me-2"></i> @SharedLocalizer["Nav_IncreasesCreditworthiness"]
                                </a></li>
                            </ul>
                        </li>

                        <!-- How It Works Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="howDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                @SharedLocalizer["Nav_HowItWorks"]
                            </a>
                            <ul class="dropdown-menu dropdown-menu-how" aria-labelledby="howDropdown">
                                <li><a class="dropdown-item" href="/#who-is-rosra-for">
                                    <i class="fas fa-users me-2"></i> @SharedLocalizer["Nav_WhoIsRosraFor"]
                                </a></li>
                                <li><a class="dropdown-item" href="/#how-it-works">
                                    <i class="fas fa-cogs me-2"></i> @SharedLocalizer["Nav_AnalysisProcess"]
                                </a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/#data-requirements">
                                    <i class="fas fa-database me-2"></i> @SharedLocalizer["Nav_DataRequirements"]
                                </a></li>
                                <li><a class="dropdown-item" href="/#data-requirements">
                                    <i class="fas fa-shield-alt me-2"></i> @SharedLocalizer["Nav_DataPrivacy"]
                                </a></li>
                            </ul>
                        </li>

                        <!-- Resources Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="resourcesDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                @SharedLocalizer["Nav_Resources"]
                            </a>
                            <ul class="dropdown-menu dropdown-menu-resources" aria-labelledby="resourcesDropdown">
                                <li><a class="dropdown-item" asp-controller="Rosra" asp-action="Index">
                                    <i class="fas fa-file-alt me-2"></i> @SharedLocalizer["Nav_SampleReport"]
                                </a></li>
                                <li><a class="dropdown-item" href="/#testimonials">
                                    <i class="fas fa-quote-left me-2"></i> @SharedLocalizer["Nav_Testimonials"]
                                </a></li>
                                <li><a class="dropdown-item" asp-controller="Home" asp-action="JobAid">
                                    <i class="fas fa-book-reader me-2"></i> User Guide
                                </a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="https://unhabitat.org" target="_blank">
                                    <i class="fas fa-external-link-alt me-2"></i> @SharedLocalizer["Nav_UnHabitatWebsite"]
                                </a></li>
                                <li><a class="dropdown-item" href="https://sdgs.un.org/goals/goal11" target="_blank">
                                    <i class="fas fa-city me-2"></i> @SharedLocalizer["Nav_Sdg11"]
                                </a></li>
                            </ul>
                        </li>

                    </ul>

                    <!-- Right Side: Auth & CTA -->
                    <div class="nav-right-section">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            var user = await UserManager.GetUserAsync(User);
                            <div class="user-menu dropdown">
                                <a class="user-dropdown-toggle" href="#" id="userDropdown" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-user-circle"></i>
                                    <span class="user-name">@SharedLocalizer["Nav_MyDashboard"]</span>
                                    <i class="fas fa-chevron-down ms-1"></i>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item" asp-controller="Dashboard" asp-action="Index">
                                        <i class="fas fa-tachometer-alt me-2"></i> @SharedLocalizer["Nav_MyDashboard"]
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Home" asp-action="JobAid">
                                        <i class="fas fa-book-reader me-2"></i> User Guide
                                    </a></li>
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                        <i class="fas fa-user-cog me-2"></i> My Profile
                                    </a></li>
                                    @if (user != null && await UserManager.IsInRoleAsync(user, "Admin"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li class="dropdown-header">@SharedLocalizer["Nav_Admin"]</li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">
                                            <i class="fas fa-tachometer-alt me-2"></i> @SharedLocalizer["Nav_Dashboard"]
                                        </a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users">
                                            <i class="fas fa-users-cog me-2"></i> @SharedLocalizer["Nav_ManageUsers"]
                                        </a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="DataUpload">
                                            <i class="fas fa-cloud-upload-alt me-2"></i> @SharedLocalizer["Nav_DataUpload"]
                                        </a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="DataManagement">
                                            <i class="fas fa-database me-2"></i> Data Management
                                        </a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="CreateRole">
                                            <i class="fas fa-user-shield me-2"></i> @SharedLocalizer["Nav_CreateRole"]
                                        </a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Home" asp-action="AdminGuide">
                                            <i class="fas fa-book me-2"></i> Admin Guide
                                        </a></li>
                                        <li><a class="dropdown-item" asp-controller="Home" asp-action="DevGuide">
                                            <i class="fas fa-code me-2"></i> Developer Guide
                                        </a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="fas fa-sign-out-alt me-2"></i> @SharedLocalizer["Nav_Logout"]
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn-auth-login" asp-controller="Account" asp-action="Login">
                                <i class="fas fa-sign-in-alt me-1"></i> @SharedLocalizer["Nav_Login"]
                            </a>
                        }

                        @await Html.PartialAsync("_LanguageSwitcher")

                        <!-- Primary CTA Button -->
                        @if (ViewContext.RouteData.Values["controller"]?.ToString() != "Dashboard")
                        {
                            <a class="btn-create-report" asp-controller="Rosra" asp-action="NewReport">
                                <i class="fas fa-plus-circle me-1"></i> @SharedLocalizer["Nav_CreateReport"]
                            </a>
                        }
                    </div>
                </div>

                <!-- Right Logo (Norad) -->
                <div class="logo-container logo-right d-none d-lg-block">
                    <a asp-area="" asp-controller="Home" asp-action="Index">
                        <img src="~/images/Light-theme-norad.png" alt="Norad Logo" />
                    </a>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-top">
                    <div class="footer-logo">
                        <img src="~/images/Light-theme-logo.png" alt="RosraApp Logo" />
                    </div>
                    <div class="sdg-goals">
                        <a href="https://sdgs.un.org/goals/goal11" target="_blank" title="SDG 11: Sustainable Cities and Communities">
                            <img src="~/images/sdg/sdg-11.svg" alt="SDG 11" />
                        </a>
                        <a href="https://sdgs.un.org/goals/goal16" target="_blank" title="SDG 16: Peace, Justice and Strong Institutions">
                            <img src="~/images/sdg/sdg-16.svg" alt="SDG 16" />
                        </a>
                        <a href="https://sdgs.un.org/goals/goal17" target="_blank" title="SDG 17: Partnerships for the Goals">
                            <img src="~/images/sdg/sdg-17.svg" alt="SDG 17" />
                        </a>
                        <a href="https://sdgs.un.org/goals" target="_blank" title="All Sustainable Development Goals">
                            <img src="~/images/sdg/sdg-logo.svg" alt="SDG Logo" />
                        </a>
                    </div>
                </div>
                <div class="footer-bottom">
                    <div class="footer-info">
                        &copy; @DateTime.Now.Year - RosraApp - @SharedLocalizer["Footer_Tagline"]
                    </div>
                    <div class="footer-links">
                        <a asp-area="" asp-controller="Home" asp-action="Privacy">@SharedLocalizer["Footer_Privacy"]</a>
                        <a asp-area="" asp-controller="Home" asp-action="Index">@SharedLocalizer["Footer_ContactUs"]</a>
                        <a href="https://www.un.org/sustainabledevelopment/sustainable-development-goals/" target="_blank">@SharedLocalizer["Footer_SdgGoals"]</a>
                    </div>
                    <div class="footer-social">
                        <a href="#" target="_blank" aria-label="UN Habitat Twitter"><i class="fab fa-twitter"></i></a>
                        <a href="#" target="_blank" aria-label="UN Habitat Facebook"><i class="fab fa-facebook"></i></a>
                        <a href="#" target="_blank" aria-label="UN Habitat LinkedIn"><i class="fab fa-linkedin"></i></a>
                        <a href="#" target="_blank" aria-label="UN Habitat YouTube"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </footer>
    @* Global JS translations injected from server-side resources *@
    <script>
        window.AppTranslations = {
            common: {
                save: '@Html.Raw(SharedLocalizer["Common_Save"].Value)',
                cancel: '@Html.Raw(SharedLocalizer["Common_Cancel"].Value)',
                delete_: '@Html.Raw(SharedLocalizer["Common_Delete"].Value)',
                edit: '@Html.Raw(SharedLocalizer["Common_Edit"].Value)',
                close: '@Html.Raw(SharedLocalizer["Common_Close"].Value)',
                yes: '@Html.Raw(SharedLocalizer["Common_Yes"].Value)',
                no: '@Html.Raw(SharedLocalizer["Common_No"].Value)',
                export_: '@Html.Raw(SharedLocalizer["Common_Export"].Value)',
            },
            alerts: {
                pleaseEnterName: '@Html.Raw(SharedLocalizer["JS_PleaseEnterName"].Value)',
                categoryExists: '@Html.Raw(SharedLocalizer["JS_CategoryExists"].Value)',
                errorOccurred: '@Html.Raw(SharedLocalizer["JS_ErrorOccurred"].Value)',
                confirmDelete: '@Html.Raw(SharedLocalizer["JS_ConfirmDelete"].Value)',
                confirmReset: '@Html.Raw(SharedLocalizer["JS_ConfirmReset"].Value)',
                confirmClear: '@Html.Raw(SharedLocalizer["JS_ConfirmClear"].Value)',
                copiedToClipboard: '@Html.Raw(SharedLocalizer["JS_CopiedToClipboard"].Value)',
                selectCountryFirst: '@Html.Raw(SharedLocalizer["JS_SelectCountryFirst"].Value)',
                selectFileFirst: '@Html.Raw(SharedLocalizer["JS_SelectFileFirst"].Value)',
                invalidCsvFormat: '@Html.Raw(SharedLocalizer["JS_InvalidCsvFormat"].Value)',
                dataUploadSuccess: '@Html.Raw(SharedLocalizer["JS_DataUploadSuccess"].Value)',
                noDataAvailable: '@Html.Raw(SharedLocalizer["JS_NoDataAvailable"].Value)',
            },
            chart: {
                currentRevenue: '@Html.Raw(SharedLocalizer["Chart_CurrentRevenue"].Value)',
                potentialRevenue: '@Html.Raw(SharedLocalizer["Chart_PotentialRevenue"].Value)',
                revenueGap: '@Html.Raw(SharedLocalizer["Chart_RevenueGap"].Value)',
                complianceGap: '@Html.Raw(SharedLocalizer["Chart_ComplianceGap"].Value)',
                coverageGap: '@Html.Raw(SharedLocalizer["Chart_CoverageGap"].Value)',
                valuationGap: '@Html.Raw(SharedLocalizer["Chart_ValuationGap"].Value)',
                liabilityGap: '@Html.Raw(SharedLocalizer["Chart_LiabilityGap"].Value)',
                mixedGap: '@Html.Raw(SharedLocalizer["Chart_MixedGap"].Value)',
                totalGap: '@Html.Raw(SharedLocalizer["Chart_TotalGap"].Value)',
                peers: '@Html.Raw(SharedLocalizer["Chart_Peers"].Value)',
                frontier: '@Html.Raw(SharedLocalizer["Chart_Frontier"].Value)',
                actual: '@Html.Raw(SharedLocalizer["Chart_Actual"].Value)',
                estimated: '@Html.Raw(SharedLocalizer["Chart_Estimated"].Value)',
            }
        };
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/rosraStateManager.js" asp-append-version="true"></script>
    <script src="~/js/chartExportHelper.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/propertyTaxCategoryModal.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
