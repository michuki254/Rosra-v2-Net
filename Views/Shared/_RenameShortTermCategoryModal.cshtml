<!-- Rename Category Modal -->
<div class="modal" id="renameShortTermCategoryModal" tabindex="-1" aria-labelledby="renameShortTermCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title d-flex align-items-center" id="renameShortTermCategoryModalLabel">
                    <i class="bi bi-pencil-fill me-2"></i>
                    Rename Category
                </h5>
                <button type="button" class="btn-close btn-close-white stable-btn" id="closeRenameShortTermModalBtn" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="form-group mb-3">
                    <label for="newShortTermCategoryName" class="form-label">New Category Name</label>
                    <input type="text" class="form-control" id="newShortTermCategoryName" placeholder="Enter new category name">
                </div>
                <input type="hidden" id="shortTermCategoryToRenameId" value="">
            </div>
            <div class="modal-footer border-0 bg-light">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4 stable-btn" id="cancelRenameShortTermBtn">
                    <i class="bi bi-x-circle me-2"></i> Cancel
                </button>
                <button type="button" class="btn btn-primary rounded-pill px-4 stable-btn" id="saveShortTermCategoryNameBtn">
                    <i class="bi bi-check-circle me-2"></i> Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Modal styles */
    .bg-primary {
        background-color: #0d6efd;
    }
    
    /* Stable buttons with no transitions or transforms */
    .stable-btn {
        position: relative;
        transform: translateZ(0);
        -webkit-font-smoothing: subpixel-antialiased;
        backface-visibility: hidden;
    }
    
    .stable-btn:hover {
        background-image: none !important;
    }
    
    /* Static hover state for primary button */
    .btn-primary.stable-btn:hover {
        background-color: #0b5ed7;
        border-color: #0a58ca;
    }
    
    /* Static hover state for outline button */
    .btn-outline-secondary.stable-btn:hover {
        background-color: #6c757d;
        color: #fff;
    }
    
    /* Remove outline on buttons */
    .btn:focus, .btn:active, .btn-close:focus {
        outline: none !important;
        box-shadow: none !important;
    }
    
    /* Prevent page shift */
    body.modal-open {
        overflow: hidden;
        padding-right: 0 !important;
    }
    
    /* Modal backdrop */
    .modal-backdrop {
        opacity: 0.5 !important;
    }
    
    /* Hardware acceleration to prevent flickering */
    .modal-content {
        transform: translateZ(0);
        -webkit-font-smoothing: subpixel-antialiased;
        backface-visibility: hidden;
    }
    
    /* Global style for no transitions */
    .no-transitions * {
        transition: none !important;
        animation: none !important;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Get modal element
        const renameModal = document.getElementById('renameShortTermCategoryModal');
        if (!renameModal) return;
        
        // Create modal instance without animation
        const bsModal = new bootstrap.Modal(renameModal, {
            backdrop: true,
            keyboard: true,
            focus: true
        });
        
        // Function to handle category renaming
        function handleRenameCategory(categoryCard) {
            if (!categoryCard) return;
            
            // Get category name and ID
            const categoryName = categoryCard.querySelector('.category-title')?.textContent || '';
            const categoryId = categoryCard.getAttribute('id') || '';
            
            // Set data to modal
            document.getElementById('newShortTermCategoryName').value = categoryName;
            document.getElementById('shortTermCategoryToRenameId').value = categoryId;
            
            // Show modal
            bsModal.show();
        }
        
        // Event delegation for edit buttons
        document.addEventListener('click', function(e) {
            const button = e.target.closest('.edit-category-btn');
            if (!button) return;
            
            // Check if this is a short term category edit button
            const shortTermContainer = button.closest('.gap-analysis-tab-content');
            if (!shortTermContainer || !shortTermContainer.querySelector('#addShortTermCategoryModal')) return;
            
            e.preventDefault();
            e.stopPropagation();
            
            // Find the category card
            const categoryCard = button.closest('.category-card');
            handleRenameCategory(categoryCard);
        });
        
        // Button handlers
        document.getElementById('closeRenameShortTermModalBtn').addEventListener('click', function() {
            bsModal.hide();
        });
        
        document.getElementById('cancelRenameShortTermBtn').addEventListener('click', function() {
            bsModal.hide();
        });
        
        document.getElementById('saveShortTermCategoryNameBtn').addEventListener('click', function() {
            const newName = document.getElementById('newShortTermCategoryName').value.trim();
            const categoryId = document.getElementById('shortTermCategoryToRenameId').value;
            
            console.log('Short Term Rename attempt:', { newName, categoryId }); // Debug log
            
            if (!newName) {
                alert('Please enter a category name.');
                return;
            }
            
            if (!categoryId) {
                alert('No category selected for renaming.');
                return;
            }
            
            // Check for duplicates
            const existingCategories = [];
            
            // Check default categories
            existingCategories.push('Category A', 'Category B', 'Category C');
            
            // Check other dynamic categories (excluding the current one being renamed)
            const dynamicCategoryElements = document.querySelectorAll('#dynamicShortTermCategoriesContainer .category-card .category-title');
            dynamicCategoryElements.forEach(element => {
                const categoryCard = element.closest('.category-card');
                if (categoryCard && categoryCard.id !== categoryId) {
                    const name = element.textContent.trim();
                    if (name && name !== 'New Category') {
                        existingCategories.push(name);
                    }
                }
            });
            
            // Check for duplicates
            const isDuplicate = existingCategories.some(name => name.toLowerCase() === newName.toLowerCase());
            
            if (isDuplicate) {
                alert('A category with this name already exists. Please choose a different name.');
                return;
            }
            
            const card = document.getElementById(categoryId);
            if (card) {
                console.log('Found card for renaming:', card); // Debug log
                
                // Update the category title
                const titleElement = card.querySelector('.category-title');
                if (titleElement) {
                    console.log('Updating title from:', titleElement.textContent, 'to:', newName); // Debug log
                    titleElement.textContent = newName;
                }
                
                // Update the hidden input value if it exists
                const hiddenInput = card.querySelector('input[type="hidden"][name*="Name"]');
                if (hiddenInput) {
                    console.log('Updating hidden input from:', hiddenInput.value, 'to:', newName); // Debug log
                    hiddenInput.value = newName;
                }
                
                // Close modal
                bsModal.hide();
                
                // Trigger recalculation if needed
                if (typeof updateCalculations === 'function') {
                    updateCalculations();
                }
            } else {
                console.error('Category card not found for ID:', categoryId);
                alert('Category not found. Please try again.');
            }
        });
        
        // Clear form on modal hide
        renameModal.addEventListener('hidden.bs.modal', function() {
            document.getElementById('newShortTermCategoryName').value = '';
            document.getElementById('shortTermCategoryToRenameId').value = '';
        });
        
        // Disable all CSS transitions when hovering to prevent flickering
        const disableTransitions = function() {
            document.body.classList.add('no-transitions');
        };
        
        const enableTransitions = function() {
            document.body.classList.remove('no-transitions');
        };
        
        // Add transition disabling on modal interaction
        renameModal.addEventListener('mouseenter', disableTransitions, { passive: true });
        renameModal.addEventListener('mouseleave', enableTransitions, { passive: true });
        
        // Expose the handle function for external usage if needed
        window.handleRenameShortTermCategory = handleRenameCategory;
    });
</script> 