@model RosraApp.Models.ViewModels.GenericStreamViewModel
@{
    bool isViewMode = ViewData["ViewMode"] != null && (bool)ViewData["ViewMode"];
    var streamIndex = Model.StreamIndex;
    var streamId = $"stream{streamIndex}";
    var currencySymbol = ViewData["CurrencySymbol"]?.ToString() ?? "$";
}

<!-- Include Chart.js -->
<script src="~/lib/chart.js/chart-3.7.1.min.js" asp-append-version="true"></script>

<div class="generic-stream-gap-analysis" data-stream-index="@streamIndex" data-subgroup="@(Model.Subgroup ?? "")" data-subtype="@(Model.Subtype ?? "")" id="@(streamId)-container">
    <!-- Stream Header with Name Editor, Classification Badge, and Delete Button -->
    <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
        <div class="d-flex align-items-center gap-3">
            <i class="bi bi-bar-chart-line fs-4 text-primary"></i>
            <div class="stream-name-editor">
                <input type="text" class="form-control form-control-lg border-0 fw-bold"
                       id="@(streamId)Name" name="GenericStreams[@streamIndex].StreamName"
                       value="@Model.StreamName" placeholder="@Localizer["EnterStreamName"]"
                       style="font-size: 1.25rem; background: transparent; width: auto; min-width: 250px;"
                       @(isViewMode ? "readonly" : "")>
                <small class="text-muted ms-2">@Localizer["ClickToEditStreamName"]</small>
                @if (!string.IsNullOrEmpty(Model.Subgroup))
                {
                    var badgeColor = Model.Subgroup switch { "A" => "#2196F3", "B" => "#FF9800", "C" => "#4CAF50", _ => "#666" };
                    var badgeText = Model.Subgroup switch { "A" => "Business Licences & Permits", "B" => "Service Fees & Billed Charges", "C" => "Daily / Point-of-Collection", _ => "Unclassified" };
                    <span class="badge ms-2" style="background-color: @badgeColor; font-size: 0.75rem;">@badgeText</span>
                }
            </div>
        </div>
        @if (!isViewMode)
        {
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-primary btn-sm"
                        onclick="openEditMetaModal(@streamIndex)" title="Edit stream classification">
                    <i class="bi bi-pencil-square"></i> Edit Classification
                </button>
                <button type="button" class="btn btn-outline-danger btn-sm delete-stream-btn"
                        data-stream-index="@streamIndex" title="Delete this stream">
                    <i class="bi bi-trash"></i> @Localizer["DeleteStream"]
                </button>
            </div>
        }
    </div>

    <!-- Hidden fields for stream identification -->
    <input type="hidden" name="GenericStreams[@streamIndex].StreamIndex" value="@streamIndex" />
    <input type="hidden" name="GenericStreams[@streamIndex].StreamId" value="@streamId" />
    <!-- Stream classification fields -->
    <input type="hidden" name="GenericStreams[@streamIndex].Subgroup" value="@(Model.Subgroup ?? "")" />
    <input type="hidden" name="GenericStreams[@streamIndex].Subtype" value="@(Model.Subtype ?? "")" />
    <input type="hidden" name="GenericStreams[@streamIndex].LocalStreamName" value="@(Model.LocalStreamName ?? Model.StreamName)" />

    <div class="row">
        <!-- Left Column - Data Input Section -->
        <div class="col-lg-4">
            <!-- Required Data + Derived Metrics -->
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0"><i class="bi bi-input-cursor-text me-2"></i>@Localizer["EntryOfRequiredInfo"]</h6>
                </div>
                <div class="card-body">
                    <p class="small text-muted mb-3">@Localizer["EntryOfRequiredInfo_Help"]</p>

                    <!-- User Input Fields -->
                    <div class="mb-3">
                        <label for="@(streamId)RegisteredUnits" class="form-label fw-bold">
                            @Localizer["RegisteredUnits"]
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["RegisteredUnits_Tooltip"]"></i>
                        </label>
                        <input type="text" class="form-control number-format bg-light fw-bold" id="@(streamId)RegisteredUnits"
                               name="GenericStreams[@streamIndex].RegisteredUnits" value="@(Model.RegisteredUnits?.ToString("N0") ?? "")"
                               placeholder="@Localizer["EnterValue"]" @(isViewMode ? "readonly" : "") data-input="true">
                    </div>

                    <div class="mb-3">
                        <label for="@(streamId)EstimatedUnregisteredPercent" class="form-label fw-bold">
                            @Localizer["EstUnregisteredPercent"]
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["EstUnregisteredPercent_Tooltip"]"></i>
                        </label>
                        <div class="input-group">
                            <input type="text" class="form-control number-format bg-light fw-bold" id="@(streamId)EstimatedUnregisteredPercent"
                                   name="GenericStreams[@streamIndex].EstimatedUnregisteredPercent" value="@(Model.EstimatedUnregisteredPercent?.ToString("N1") ?? "")"
                                   placeholder="%" @(isViewMode ? "readonly" : "") data-input="true">
                            <span class="input-group-text">%</span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="@(streamId)TotalEstimatedUnits" class="form-label text-primary">
                            @Localizer["TotalEstimatedUnits"]
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["TotalEstimatedUnits_Tooltip"]"></i>
                        </label>
                        <input type="text" class="form-control number-format" id="@(streamId)TotalEstimatedUnits"
                               readonly value="0" style="background-color: #e8f4fc;">
                    </div>

                    <div class="mb-3">
                        <label for="@(streamId)CompliantUnits" class="form-label text-primary">
                            @Localizer["CompliantUnits"]
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["CompliantUnits_Tooltip"]"></i>
                        </label>
                        <input type="text" class="form-control number-format" id="@(streamId)CompliantUnits"
                               readonly value="0" style="background-color: #e8f4fc;">
                        <small class="text-muted">@Localizer["CompliantUnits_Formula"]</small>
                    </div>

                    <div class="mb-3">
                        <label for="@(streamId)BilledAmount" class="form-label fw-bold">
                            @Localizer["BilledAmount"] (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["BilledAmount_Tooltip"]"></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format bg-light fw-bold" id="@(streamId)BilledAmount"
                                   name="GenericStreams[@streamIndex].BilledAmount" value="@(Model.BilledAmount?.ToString("N0") ?? "")"
                                   placeholder="@Localizer["EnterValue"]" @(isViewMode ? "readonly" : "") data-input="true">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="@(streamId)OutstandingAmount" class="form-label fw-bold">
                            @Localizer["OutstandingAmount"] (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["OutstandingAmount_Tooltip"]"></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format bg-light fw-bold" id="@(streamId)OutstandingAmount"
                                   name="GenericStreams[@streamIndex].OutstandingAmount" value="@(Model.OutstandingAmount?.ToString("N0") ?? "")"
                                   placeholder="@Localizer["EnterValue"]" @(isViewMode ? "readonly" : "") data-input="true">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="@(streamId)RevenueToDate" class="form-label text-primary">
                            @Localizer["RevenueToDate"] (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["RevenueToDate_Tooltip"]"></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format" id="@(streamId)RevenueToDate"
                                   readonly value="0" style="background-color: #e8f4fc;">
                        </div>
                        <small class="text-muted">@Localizer["RevenueToDate_Formula"]</small>
                    </div>
                </div>
            </div>

            <!-- Useful Average Values -->
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0"><i class="bi bi-calculator me-2"></i>@Localizer["UsefulAverageValues"]</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="@(streamId)StatutoryAverageBilled" class="form-label fw-bold">
                            @Localizer["StatutoryAvgBilled"] (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["StatutoryAvgBilled_Tooltip"]"></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format bg-light fw-bold" id="@(streamId)StatutoryAverageBilled"
                                   name="GenericStreams[@streamIndex].StatutoryAverageBilled" value="@(Model.StatutoryAverageBilled?.ToString("N0") ?? "")"
                                   placeholder="@Localizer["EnterValue"]" @(isViewMode ? "readonly" : "") data-input="true">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="@(streamId)RealisticImprovementPercent" class="form-label fw-bold">
                            @Localizer["RealisticImprovementPercent"]
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["RealisticImprovementPercent_Tooltip"]"></i>
                        </label>
                        <div class="input-group">
                            <input type="text" class="form-control number-format bg-light fw-bold" id="@(streamId)RealisticImprovementPercent"
                                   name="GenericStreams[@streamIndex].RealisticImprovementPercent" value="@(Model.RealisticImprovementPercent?.ToString("N1") ?? "")"
                                   placeholder="%" @(isViewMode ? "readonly" : "") data-input="true">
                            <span class="input-group-text">%</span>
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small text-primary">
                            @Localizer["AverageBilledAmount"]
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["AverageBilledAmount_Tooltip"]"></i>
                        </label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control" id="@(streamId)AvgBilledAmount" readonly style="background-color: #e8f4fc;">
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small text-primary">
                            @Localizer["AchievableAvgBill"]
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["AchievableAvgBill_Tooltip"]"></i>
                        </label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control" id="@(streamId)AchievableAvgBill" readonly style="background-color: #e8f4fc;">
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small text-primary">
                            @Localizer["DeltaA"]
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["DeltaA_Tooltip"]"></i>
                        </label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control" id="@(streamId)DeltaA" readonly style="background-color: #e8f4fc;">
                        </div>
                    </div>
                </div>
            </div>

            <!-- KPI Ratios -->
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-warning">
                    <h6 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>@Localizer["KPIRatios"]</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label small mb-0">
                                @Localizer["ComplianceRatio"]
                                <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                   title="@Localizer["ComplianceRatio_Tooltip"]"></i>
                            </label>
                            <span id="@(streamId)ComplianceRatioValue" class="badge bg-success">0%</span>
                        </div>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar" role="progressbar" id="@(streamId)ComplianceRatioBar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <small class="text-muted">@Localizer["ComplianceRatio_Formula"]</small>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label small mb-0">
                                @Localizer["CoverageRatio"]
                                <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                   title="@Localizer["CoverageRatio_Tooltip"]"></i>
                            </label>
                            <span id="@(streamId)CoverageRatioValue" class="badge bg-info">0%</span>
                        </div>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar" role="progressbar" id="@(streamId)CoverageRatioBar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <small class="text-muted">@Localizer["CoverageRatio_Formula"]</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column - Results Section -->
        <div class="col-lg-8">
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-success text-white">
                    <h6 class="mb-0"><i class="bi bi-graph-up me-2"></i>@Localizer["GraphicalRepresentation"]</h6>
                </div>
                <div class="card-body">
                    <!-- Potential Revenue Breakdown Table -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">@Localizer["PotentialRevenueBreakdown"]</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>@Localizer["RevenueAndAdminGaps"]</th>
                                        <th class="text-end">@Localizer["Amount"] (<span class="currency-label">@currencySymbol</span>)</th>
                                        <th class="text-end">@Localizer["SharePercent"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="table-success">
                                        <td>@Localizer["RevenueToDateLabel"]</td>
                                        <td class="text-end" id="@(streamId)TableRevenueToDate">0</td>
                                        <td class="text-end" id="@(streamId)TableRevenueToDatePct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            @Localizer["ComplianceGap"]
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="@Localizer["ComplianceGap_Tooltip"]"></i>
                                        </td>
                                        <td class="text-end" id="@(streamId)TableComplianceGap">0</td>
                                        <td class="text-end" id="@(streamId)TableComplianceGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            @Localizer["CoverageGap"]
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="@Localizer["CoverageGap_Tooltip"]"></i>
                                        </td>
                                        <td class="text-end" id="@(streamId)TableCoverageGap">0</td>
                                        <td class="text-end" id="@(streamId)TableCoverageGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            @Localizer["LiabilityGap"]
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="@Localizer["LiabilityGap_Tooltip"]"></i>
                                        </td>
                                        <td class="text-end" id="@(streamId)TableLiabilityGap">0</td>
                                        <td class="text-end" id="@(streamId)TableLiabilityGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            @Localizer["MixedGapCompLiab"]
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="@Localizer["MixedGapCompLiab_Tooltip"]"></i>
                                        </td>
                                        <td class="text-end" id="@(streamId)TableMixedCompliance">0</td>
                                        <td class="text-end" id="@(streamId)TableMixedCompliancePct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            @Localizer["MixedGapCovLiab"]
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="@Localizer["MixedGapCovLiab_Tooltip"]"></i>
                                        </td>
                                        <td class="text-end" id="@(streamId)TableMixedCoverage">0</td>
                                        <td class="text-end" id="@(streamId)TableMixedCoveragePct">0%</td>
                                    </tr>
                                    <tr class="table-secondary fw-bold">
                                        <td>@Localizer["TotalPotentialRevenue"]</td>
                                        <td class="text-end" id="@(streamId)TableTotalPotential">0</td>
                                        <td class="text-end">100%</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Revenue and Administrative Gaps Pie Chart -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">@Localizer["RevenueAndAdminGapsChart"]</h6>
                        <div class="d-flex justify-content-center">
                            <div style="height: 300px; width: 450px; position: relative;">
                                <canvas id="@(streamId)PotentialRevenueChart"></canvas>
                            </div>
                        </div>
                        <p class="small text-muted mt-2 text-center">
                            <strong>@Localizer["Description"]</strong> @Localizer["PieChartDescription"]
                        </p>
                    </div>

                    <hr>

                    <!-- Matrix Gap Analysis Dashboard -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">@Model.StreamName @Localizer["GapAnalysisDashboard"]</h6>
                        <div class="row g-3 align-items-stretch">
                            <!-- Matrix Visualization -->
                            <div class="col-12">
                                <div class="matrix-container position-relative" style="height: 320px; min-height: 320px; border-radius: 8px; overflow: hidden; background: #fff;">
                                    <!-- Y-axis Title (rotated) -->
                                    <div class="position-absolute d-flex align-items-center justify-content-center" style="left: 0; top: 0; bottom: 30px; width: 20px; background: #f8f9fa;">
                                        <span style="transform: rotate(-90deg); white-space: nowrap; font-size: 0.6rem; color: #666;">@Localizer["NumberOfUnits"]</span>
                                    </div>

                                    <!-- Y-axis Labels Container - labels positioned at row BOUNDARIES -->
                                    <div class="matrix-y-labels position-absolute" id="@(streamId)MatrixYLabelsContainer" style="left: 20px; top: 0; bottom: 30px; width: 55px; font-size: 0.6rem; background: #f8f9fa; position: relative;">
                                        <!-- Estimated label at TOP boundary (top of matrix) -->
                                        <div class="y-label-item" id="@(streamId)YLabelEstimated" style="position: absolute; right: 3px; top: 0; text-align: right; transform: translateY(-50%);">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">@Localizer["Estimated"]</small>
                                            <span id="@(streamId)MatrixEstimatedLabel" class="fw-bold" style="font-size: 0.65rem;">0</span>
                                        </div>
                                        <!-- Registered label at boundary between Row1 and Row2 -->
                                        <div class="y-label-item" id="@(streamId)YLabelRegistered" style="position: absolute; right: 3px; text-align: right; transform: translateY(-50%);">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">@Localizer["Registered"]</small>
                                            <span id="@(streamId)MatrixRegisteredLabel" class="fw-bold" style="font-size: 0.65rem;">0</span>
                                        </div>
                                        <!-- Compliant label at boundary between Row2 and Row3 -->
                                        <div class="y-label-item" id="@(streamId)YLabelCompliant" style="position: absolute; right: 3px; text-align: right; transform: translateY(-50%);">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">@Localizer["Compliant"]</small>
                                            <span id="@(streamId)MatrixCompliantLabel" class="fw-bold" style="font-size: 0.65rem;">0</span>
                                        </div>
                                    </div>

                                    <!-- Matrix Grid Area -->
                                    <div class="matrix-grid position-absolute" id="@(streamId)MatrixGridArea" style="left: 75px; top: 0; right: 0; bottom: 30px; display: flex; flex-direction: column;">
                                        <!-- Row 1: Unregistered (Estimated - Registered) -->
                                        <div class="matrix-row d-flex" id="@(streamId)MatrixRowUnreg" style="flex: 1; min-height: 30px;">
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="@(streamId)MatrixCoverageGap"
                                                 style="background-color: #FF9800; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">@Localizer["CoverageGap"]</small><br>
                                                    <span id="@(streamId)MatrixCoverageGapVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="@(streamId)MatrixMixedCoverage"
                                                 style="background-color: #E91E63; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">@Localizer["MixedGapCovLiab"]</small><br>
                                                    <span id="@(streamId)MatrixMixedCoverageVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- Row 2: Non-Compliant Registered (Registered - Compliant) -->
                                        <div class="matrix-row d-flex" id="@(streamId)MatrixRowNonCompliant" style="flex: 1; min-height: 30px;">
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="@(streamId)MatrixComplianceGap"
                                                 style="background-color: #F44336; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">@Localizer["ComplianceGap"]</small><br>
                                                    <span id="@(streamId)MatrixComplianceGapVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="@(streamId)MatrixMixedCompliance"
                                                 style="background-color: #9C27B0; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">@Localizer["MixedGapCompLiab"]</small><br>
                                                    <span id="@(streamId)MatrixMixedComplianceVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- Row 3: Compliant -->
                                        <div class="matrix-row d-flex" id="@(streamId)MatrixRowCompliant" style="flex: 1; min-height: 30px;">
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="@(streamId)MatrixActualRevenue"
                                                 style="background-color: #4CAF50; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">@Localizer["ActualRevenue"]</small><br>
                                                    <span id="@(streamId)MatrixActualRevenueVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="@(streamId)MatrixLiabilityGap"
                                                 style="background-color: #2196F3; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">@Localizer["LiabilityGap"]</small><br>
                                                    <span id="@(streamId)MatrixLiabilityGapVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- X-axis Labels - positioned at column BOUNDARIES -->
                                    <div class="matrix-x-axis position-absolute" id="@(streamId)MatrixXAxisContainer" style="left: 75px; right: 0; bottom: 0; height: 30px; background: #f8f9fa;">
                                        <!-- X-axis label at left edge (origin = 0) -->
                                        <div class="x-label-item" id="@(streamId)XLabelOrigin" style="position: absolute; left: 0; bottom: 2px; transform: translateX(0%); text-align: left; font-size: 0.6rem;">
                                            <span id="@(streamId)MatrixOriginLabel" class="fw-bold" style="font-size: 0.65rem;">@currencySymbol 0</span>
                                        </div>
                                        <!-- X-axis label at column boundary (between left and right columns) -->
                                        <div class="x-label-item" id="@(streamId)XLabelAvgBilled" style="position: absolute; bottom: 2px; transform: translateX(-50%); text-align: center; font-size: 0.6rem;">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">@Localizer["AvgBilled"]</small>
                                            <span id="@(streamId)MatrixAvgBilledLabel" class="fw-bold" style="font-size: 0.65rem;">@currencySymbol 0</span>
                                        </div>
                                        <!-- X-axis label at right edge -->
                                        <div class="x-label-item" id="@(streamId)XLabelAchievable" style="position: absolute; right: 0; bottom: 2px; transform: translateX(0%); text-align: right; font-size: 0.6rem;">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">@Localizer["AchievableAvg"]</small>
                                            <span id="@(streamId)MatrixAchievableLabel" class="fw-bold" style="font-size: 0.65rem;">@currencySymbol 0</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div><!-- end row -->
                        <p class="small text-muted mt-3 text-center">
                            <strong>@Localizer["Description"]</strong> @Localizer["MatrixDescription"]
                        </p>
                    </div>

                    <hr>

                    <!-- Administrative Gap Breakdown Table -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">@Localizer["AdminGapBreakdown"] (<span class="currency-label">@currencySymbol</span>)</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>@Localizer["AdministrativeGaps"]</th>
                                        <th class="text-end">@Localizer["Amount"] (<span class="currency-label">@currencySymbol</span>)</th>
                                        <th class="text-end">@Localizer["SharePercent"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            @Localizer["ComplianceGap"]
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="@Localizer["ComplianceGapAdmin_Tooltip"]"></i>
                                        </td>
                                        <td class="text-end" id="@(streamId)GapComplianceGap">0</td>
                                        <td class="text-end" id="@(streamId)GapComplianceGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            @Localizer["CoverageGap"]
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="@Localizer["CoverageGapAdmin_Tooltip"]"></i>
                                        </td>
                                        <td class="text-end" id="@(streamId)GapCoverageGap">0</td>
                                        <td class="text-end" id="@(streamId)GapCoverageGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            @Localizer["LiabilityGap"]
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="@Localizer["LiabilityGapAdmin_Tooltip"]"></i>
                                        </td>
                                        <td class="text-end" id="@(streamId)GapLiabilityGap">0</td>
                                        <td class="text-end" id="@(streamId)GapLiabilityGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            @Localizer["MixedGapCompLiab"]
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="@Localizer["MixedGapCompLiabAdmin_Tooltip"]"></i>
                                        </td>
                                        <td class="text-end" id="@(streamId)GapMixedCompliance">0</td>
                                        <td class="text-end" id="@(streamId)GapMixedCompliancePct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            @Localizer["MixedGapCovLiab"]
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="@Localizer["MixedGapCovLiabAdmin_Tooltip"]"></i>
                                        </td>
                                        <td class="text-end" id="@(streamId)GapMixedCoverage">0</td>
                                        <td class="text-end" id="@(streamId)GapMixedCoveragePct">0%</td>
                                    </tr>
                                    <tr class="table-secondary fw-bold">
                                        <td>@Localizer["TotalAdminGap"]</td>
                                        <td class="text-end" id="@(streamId)TotalFunctionalGap">0</td>
                                        <td class="text-end">100%</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Breakdown of Administrative Gaps Pie Chart -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">@Localizer["BreakdownAdminGaps"]</h6>
                        <div class="d-flex justify-content-center">
                            <div style="height: 300px; width: 450px; position: relative;">
                                <canvas id="@(streamId)GapBreakdownChart"></canvas>
                            </div>
                        </div>
                        <p class="small text-muted mt-2 text-center">
                            <strong>@Localizer["Description"]</strong> @Localizer["BreakdownPieChartDescription"]
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .generic-stream-gap-analysis .card {
        border-radius: 8px;
    }

    .generic-stream-gap-analysis .card-header {
        border-radius: 8px 8px 0 0;
    }

    .generic-stream-gap-analysis .form-control[readonly] {
        cursor: default;
    }

    .generic-stream-gap-analysis .progress {
        border-radius: 10px;
    }

    .generic-stream-gap-analysis .progress-bar {
        border-radius: 10px;
        transition: width 0.3s ease-in-out;
    }

    .generic-stream-gap-analysis .table th,
    .generic-stream-gap-analysis .table td {
        vertical-align: middle;
        font-size: 0.875rem;
    }

    /* Ensure table header text is visible with white color on dark background */
    .generic-stream-gap-analysis .table thead.table-dark th {
        color: #ffffff !important;
        background-color: #212529 !important;
    }

    /* KPI Ratio badges should display as normal Bootstrap badges */
    .generic-stream-gap-analysis .card-body > .mb-3 .badge {
        width: auto;
        height: auto;
        border-radius: 0.25rem;
        padding: 0.35em 0.65em;
        font-size: 0.75em;
    }

    .generic-stream-gap-analysis .input-group-sm .form-control,
    .generic-stream-gap-analysis .input-group-sm .input-group-text {
        font-size: 0.8rem;
    }
</style>

<script>
(function() {
    // Stream-specific variables
    const streamId = '@streamId';
    const streamIndex = @streamIndex;
    let potentialRevenueChart = null;
    let gapBreakdownChart = null;

    // Get currency symbol from AppContext
    function getCurrencySymbol() {
        if (window.AppContext) {
            return window.AppContext.get('currencySymbol') || '@currencySymbol';
        }
        return '@currencySymbol';
    }

    // Update currency displays for this stream
    function updateStreamCurrencySymbols() {
        const symbol = getCurrencySymbol();
        const container = document.getElementById(streamId + '-container');
        if (!container) return;

        container.querySelectorAll('.currency-prefix-display').forEach(el => {
            el.textContent = symbol;
        });
        container.querySelectorAll('.currency-label').forEach(el => {
            el.textContent = symbol;
        });
    }

    // Helper function to parse number from formatted string
    function parseNumber(value) {
        if (!value) return 0;
        return parseFloat(value.toString().replace(/[^0-9.-]/g, '')) || 0;
    }

    // Format currency with commas
    function formatCurrency(value) {
        if (isNaN(value) || value === null) return '0';
        return new Intl.NumberFormat('en-US', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        }).format(value);
    }

    // Format percentage
    function formatPercentage(value) {
        if (isNaN(value) || value === null) return '0.00%';
        return value.toFixed(2) + '%';
    }

    // Format compact number (for matrix labels)
    function formatCompact(value) {
        const currencySymbol = getCurrencySymbol();
        if (value >= 1000000000) {
            return currencySymbol + ' ' + (value / 1000000000).toFixed(1) + 'B';
        } else if (value >= 1000000) {
            return currencySymbol + ' ' + (value / 1000000).toFixed(1) + 'M';
        }
        return currencySymbol + ' ' + formatCurrency(value);
    }

    function formatUnitCount(value) {
        if (value >= 1000000) {
            return (value / 1000000).toFixed(1) + 'M';
        }
        return Math.round(value).toLocaleString();
    }

    // Update KPI progress bar with color coding
    function updateKPIBar(name, value) {
        const bar = document.getElementById(streamId + name + 'Bar');
        const valueSpan = document.getElementById(streamId + name + 'Value');
        const cappedValue = Math.min(Math.max(value, 0), 100);

        // Determine color based on value: >80% Green, 60-80% Yellow, <60% Red
        let colorClass, badgeClass;
        if (value >= 80) {
            colorClass = 'bg-success';
            badgeClass = 'bg-success';
        } else if (value >= 60) {
            colorClass = 'bg-warning';
            badgeClass = 'bg-warning text-dark';
        } else {
            colorClass = 'bg-danger';
            badgeClass = 'bg-danger';
        }

        if (bar) {
            bar.style.width = cappedValue + '%';
            bar.setAttribute('aria-valuenow', cappedValue);
            bar.classList.remove('bg-success', 'bg-warning', 'bg-danger', 'bg-info', 'bg-primary');
            bar.classList.add(colorClass);
        }
        if (valueSpan) {
            valueSpan.textContent = value.toFixed(0) + '%';
            valueSpan.classList.remove('bg-success', 'bg-warning', 'bg-danger', 'bg-info', 'bg-primary', 'text-dark');
            badgeClass.split(' ').forEach(cls => valueSpan.classList.add(cls));
        }
    }

    // Main calculation function
    function calculateGaps() {
        // Get input values
        const registeredUnits = parseNumber(document.getElementById(streamId + 'RegisteredUnits')?.value);
        const estimatedUnregisteredPercent = parseNumber(document.getElementById(streamId + 'EstimatedUnregisteredPercent')?.value);
        const billedAmount = parseNumber(document.getElementById(streamId + 'BilledAmount')?.value);
        const outstandingAmount = parseNumber(document.getElementById(streamId + 'OutstandingAmount')?.value);
        const statutoryAverageBilled = parseNumber(document.getElementById(streamId + 'StatutoryAverageBilled')?.value);
        const realisticImprovementPercent = parseNumber(document.getElementById(streamId + 'RealisticImprovementPercent')?.value);

        // Calculate derived values
        const totalEstimatedUnits = registeredUnits * (1 + estimatedUnregisteredPercent / 100);
        const revenueToDate = billedAmount - outstandingAmount;
        const compliantUnits = registeredUnits > 0 && billedAmount > 0
            ? registeredUnits * (revenueToDate / billedAmount)
            : 0;
        const nonCompliantUnits = registeredUnits - compliantUnits;
        const unregisteredUnits = totalEstimatedUnits - registeredUnits;
        const avgBilledAmount = registeredUnits > 0 ? billedAmount / registeredUnits : 0;
        const achievableAvgBill = avgBilledAmount + (realisticImprovementPercent / 100) * Math.max(0, statutoryAverageBilled - avgBilledAmount);
        const deltaA = achievableAvgBill - avgBilledAmount;

        // Calculate gaps (Liability Gap model - not Valuation Gap)
        const complianceGap = outstandingAmount;
        const coverageGap = unregisteredUnits * avgBilledAmount;
        const liabilityGap = compliantUnits * deltaA;
        const mixedGapCompliance = nonCompliantUnits * deltaA;
        const mixedGapCoverage = unregisteredUnits * deltaA;
        const totalPotentialRevenue = revenueToDate + complianceGap + coverageGap + liabilityGap + mixedGapCompliance + mixedGapCoverage;
        const totalFunctionalGap = complianceGap + coverageGap + liabilityGap + mixedGapCompliance + mixedGapCoverage;

        // Calculate KPIs
        const complianceRatio = billedAmount > 0 ? (revenueToDate / billedAmount) * 100 : 0;
        const coverageRatio = totalEstimatedUnits > 0 ? (registeredUnits / totalEstimatedUnits) * 100 : 0;

        // Calculate percentages for potential revenue
        const revenueToDatePct = totalPotentialRevenue > 0 ? (revenueToDate / totalPotentialRevenue) * 100 : 0;
        const complianceGapPct = totalPotentialRevenue > 0 ? (complianceGap / totalPotentialRevenue) * 100 : 0;
        const coverageGapPct = totalPotentialRevenue > 0 ? (coverageGap / totalPotentialRevenue) * 100 : 0;
        const liabilityGapPct = totalPotentialRevenue > 0 ? (liabilityGap / totalPotentialRevenue) * 100 : 0;
        const mixedCompliancePct = totalPotentialRevenue > 0 ? (mixedGapCompliance / totalPotentialRevenue) * 100 : 0;
        const mixedCoveragePct = totalPotentialRevenue > 0 ? (mixedGapCoverage / totalPotentialRevenue) * 100 : 0;

        // Calculate percentages for admin gaps
        const gapCompliancePct = totalFunctionalGap > 0 ? (complianceGap / totalFunctionalGap) * 100 : 0;
        const gapCoveragePct = totalFunctionalGap > 0 ? (coverageGap / totalFunctionalGap) * 100 : 0;
        const gapLiabilityPct = totalFunctionalGap > 0 ? (liabilityGap / totalFunctionalGap) * 100 : 0;
        const gapMixedCompliancePct = totalFunctionalGap > 0 ? (mixedGapCompliance / totalFunctionalGap) * 100 : 0;
        const gapMixedCoveragePct = totalFunctionalGap > 0 ? (mixedGapCoverage / totalFunctionalGap) * 100 : 0;

        // Update derived metrics display
        document.getElementById(streamId + 'TotalEstimatedUnits').value = formatCurrency(totalEstimatedUnits).replace('.00', '');
        document.getElementById(streamId + 'RevenueToDate').value = formatCurrency(revenueToDate);
        document.getElementById(streamId + 'CompliantUnits').value = formatCurrency(compliantUnits).replace('.00', '');
        document.getElementById(streamId + 'AvgBilledAmount').value = formatCurrency(avgBilledAmount);
        document.getElementById(streamId + 'AchievableAvgBill').value = formatCurrency(achievableAvgBill);
        document.getElementById(streamId + 'DeltaA').value = formatCurrency(deltaA);

        // Update KPI progress bars
        updateKPIBar('ComplianceRatio', complianceRatio);
        updateKPIBar('CoverageRatio', coverageRatio);

        // Update Potential Revenue Breakdown Table
        document.getElementById(streamId + 'TableRevenueToDate').textContent = formatCurrency(revenueToDate);
        document.getElementById(streamId + 'TableRevenueToDatePct').textContent = formatPercentage(revenueToDatePct);
        document.getElementById(streamId + 'TableComplianceGap').textContent = formatCurrency(complianceGap);
        document.getElementById(streamId + 'TableComplianceGapPct').textContent = formatPercentage(complianceGapPct);
        document.getElementById(streamId + 'TableCoverageGap').textContent = formatCurrency(coverageGap);
        document.getElementById(streamId + 'TableCoverageGapPct').textContent = formatPercentage(coverageGapPct);
        document.getElementById(streamId + 'TableLiabilityGap').textContent = formatCurrency(liabilityGap);
        document.getElementById(streamId + 'TableLiabilityGapPct').textContent = formatPercentage(liabilityGapPct);
        document.getElementById(streamId + 'TableMixedCompliance').textContent = formatCurrency(mixedGapCompliance);
        document.getElementById(streamId + 'TableMixedCompliancePct').textContent = formatPercentage(mixedCompliancePct);
        document.getElementById(streamId + 'TableMixedCoverage').textContent = formatCurrency(mixedGapCoverage);
        document.getElementById(streamId + 'TableMixedCoveragePct').textContent = formatPercentage(mixedCoveragePct);
        document.getElementById(streamId + 'TableTotalPotential').textContent = formatCurrency(totalPotentialRevenue);

        // Update Administrative Gap Breakdown Table
        document.getElementById(streamId + 'GapComplianceGap').textContent = formatCurrency(complianceGap);
        document.getElementById(streamId + 'GapComplianceGapPct').textContent = formatPercentage(gapCompliancePct);
        document.getElementById(streamId + 'GapCoverageGap').textContent = formatCurrency(coverageGap);
        document.getElementById(streamId + 'GapCoverageGapPct').textContent = formatPercentage(gapCoveragePct);
        document.getElementById(streamId + 'GapLiabilityGap').textContent = formatCurrency(liabilityGap);
        document.getElementById(streamId + 'GapLiabilityGapPct').textContent = formatPercentage(gapLiabilityPct);
        document.getElementById(streamId + 'GapMixedCompliance').textContent = formatCurrency(mixedGapCompliance);
        document.getElementById(streamId + 'GapMixedCompliancePct').textContent = formatPercentage(gapMixedCompliancePct);
        document.getElementById(streamId + 'GapMixedCoverage').textContent = formatCurrency(mixedGapCoverage);
        document.getElementById(streamId + 'GapMixedCoveragePct').textContent = formatPercentage(gapMixedCoveragePct);
        document.getElementById(streamId + 'TotalFunctionalGap').textContent = formatCurrency(totalFunctionalGap);

        // Update Charts
        updateCharts(revenueToDate, complianceGap, coverageGap, liabilityGap, mixedGapCompliance, mixedGapCoverage);

        // Update Matrix Dashboard
        updateMatrixDashboard({
            totalEstimatedUnits,
            registeredUnits,
            compliantUnits,
            nonCompliantUnits,
            unregisteredUnits,
            avgBilledAmount,
            achievableAvgBill,
            revenueToDate,
            complianceGap,
            coverageGap,
            liabilityGap,
            mixedGapCompliance,
            mixedGapCoverage,
            totalPotentialRevenue
        });

        // Store values using RosraStateManager (preferred) for proper state management
        // This enables the Prioritization module to access all dynamic streams
        storeGenericStreamValues(
            streamIndex,
            revenueToDate,
            totalPotentialRevenue,
            totalFunctionalGap,
            complianceGap,
            coverageGap,
            liabilityGap,
            mixedGapCompliance,
            mixedGapCoverage,
            complianceRatio,
            coverageRatio
        );
    }

    // Store generic stream values to RosraStateManager + localStorage fallback
    function storeGenericStreamValues(index, revenueToDate, totalPotentialRevenue, totalFunctionalGap,
                                       complianceGap, coverageGap, liabilityGap,
                                       mixedGapCompliance, mixedGapCoverage,
                                       complianceRatio, coverageRatio) {
        // Get stream name from the input field
        const streamNameInput = document.getElementById(streamId + 'Name');
        const streamName = streamNameInput ? streamNameInput.value : ('Generic Stream ' + (index + 1));

        // Use RosraStateManager if available (preferred method)
        if (typeof RosraStateManager !== 'undefined') {
            RosraStateManager.updateGenericStream(index, {
                name: streamName,
                currentRevenue: revenueToDate,
                potentialRevenue: totalPotentialRevenue,
                totalFunctionalGap: totalFunctionalGap,
                complianceGap: complianceGap,
                coverageGap: coverageGap,
                liabilityGap: liabilityGap,
                mixedGapCompliance: mixedGapCompliance,
                mixedGapCoverage: mixedGapCoverage,
                complianceRatio: complianceRatio,
                coverageRatio: coverageRatio,
                included: true
            });
            console.log('RosraStateManager: Updated Generic Stream ' + index + ' (' + streamName + ')');
        }

        // Also keep localStorage for backward compatibility
        localStorage.setItem(streamId + 'CurrentValue', revenueToDate);
        localStorage.setItem(streamId + 'PotentialValue', totalPotentialRevenue);
        localStorage.setItem(streamId + 'GapValue', totalFunctionalGap);
        localStorage.setItem(streamId + 'Name', streamName);
        localStorage.setItem(streamId + 'ComplianceGap', complianceGap);
        localStorage.setItem(streamId + 'CoverageGap', coverageGap);
        localStorage.setItem(streamId + 'LiabilityGap', liabilityGap);
        localStorage.setItem(streamId + 'ComplianceRatio', complianceRatio);
        localStorage.setItem(streamId + 'CoverageRatio', coverageRatio);
    }

    // Initialize charts
    function initializeCharts() {
        // Potential Revenue Pie Chart
        const ctx1 = document.getElementById(streamId + 'PotentialRevenueChart');
        if (ctx1) {
            potentialRevenueChart = new Chart(ctx1.getContext('2d'), {
                type: 'pie',
                data: {
                    labels: ['Revenue to date', 'Compliance Gap', 'Coverage Gap', 'Liability Gap', 'Mixed (Comp.+Liab.)', 'Mixed (Cov.+Liab.)'],
                    datasets: [{
                        data: [0, 0, 0, 0, 0, 0],
                        backgroundColor: ['#4CAF50', '#F44336', '#FF9800', '#2196F3', '#9C27B0', '#E91E63'],
                        borderWidth: 2,
                        borderColor: '#ffffff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'right',
                            labels: {
                                boxWidth: 12,
                                font: { size: 10 },
                                generateLabels: function(chart) {
                                    const data = chart.data;
                                    if (data.labels.length && data.datasets.length) {
                                        const total = data.datasets[0].data.reduce((a, b) => a + b, 0);
                                        return data.labels.map((label, i) => {
                                            const value = data.datasets[0].data[i];
                                            const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                            return {
                                                text: label + ' (' + percentage + '%)',
                                                fillStyle: data.datasets[0].backgroundColor[i],
                                                hidden: false,
                                                index: i
                                            };
                                        });
                                    }
                                    return [];
                                }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const value = context.raw || 0;
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                    return context.label + ': ' + formatCurrency(value) + ' (' + percentage + '%)';
                                }
                            }
                        }
                    }
                }
            });
            if (window.registerChart) registerChart(streamId + 'PotentialRevenueChart', potentialRevenueChart);
        }

        // Administrative Gap Pie Chart
        const ctx2 = document.getElementById(streamId + 'GapBreakdownChart');
        if (ctx2) {
            gapBreakdownChart = new Chart(ctx2.getContext('2d'), {
                type: 'pie',
                data: {
                    labels: ['Compliance Gap', 'Coverage Gap', 'Liability Gap', 'Mixed (Comp.+Liab.)', 'Mixed (Cov.+Liab.)'],
                    datasets: [{
                        data: [0, 0, 0, 0, 0],
                        backgroundColor: ['#F44336', '#FF9800', '#2196F3', '#9C27B0', '#E91E63'],
                        borderWidth: 2,
                        borderColor: '#ffffff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'right',
                            labels: {
                                boxWidth: 12,
                                font: { size: 10 },
                                generateLabels: function(chart) {
                                    const data = chart.data;
                                    if (data.labels.length && data.datasets.length) {
                                        const total = data.datasets[0].data.reduce((a, b) => a + b, 0);
                                        return data.labels.map((label, i) => {
                                            const value = data.datasets[0].data[i];
                                            const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                            return {
                                                text: label + ' (' + percentage + '%)',
                                                fillStyle: data.datasets[0].backgroundColor[i],
                                                hidden: false,
                                                index: i
                                            };
                                        });
                                    }
                                    return [];
                                }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const value = context.raw || 0;
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                    return context.label + ': ' + formatCurrency(value) + ' (' + percentage + '%)';
                                }
                            }
                        }
                    }
                }
            });
            if (window.registerChart) registerChart(streamId + 'GapBreakdownChart', gapBreakdownChart);
        }
    }

    // Update pie charts
    function updateCharts(revenueToDate, complianceGap, coverageGap, liabilityGap, mixedCompliance, mixedCoverage) {
        if (potentialRevenueChart) {
            potentialRevenueChart.data.datasets[0].data = [
                Math.max(0, revenueToDate),
                Math.max(0, complianceGap),
                Math.max(0, coverageGap),
                Math.max(0, liabilityGap),
                Math.max(0, mixedCompliance),
                Math.max(0, mixedCoverage)
            ];
            potentialRevenueChart.update();
        }

        if (gapBreakdownChart) {
            gapBreakdownChart.data.datasets[0].data = [
                Math.max(0, complianceGap),
                Math.max(0, coverageGap),
                Math.max(0, liabilityGap),
                Math.max(0, mixedCompliance),
                Math.max(0, mixedCoverage)
            ];
            gapBreakdownChart.update();
        }
    }

    // Update matrix dashboard
    function updateMatrixDashboard(data) {
        const currencySymbol = getCurrencySymbol();

        // Update Y-axis labels (unit counts)
        const estLabel = document.getElementById(streamId + 'MatrixEstimatedLabel');
        const regLabel = document.getElementById(streamId + 'MatrixRegisteredLabel');
        const compLabel = document.getElementById(streamId + 'MatrixCompliantLabel');

        if (estLabel) estLabel.textContent = formatUnitCount(data.totalEstimatedUnits);
        if (regLabel) regLabel.textContent = formatUnitCount(data.registeredUnits);
        if (compLabel) compLabel.textContent = formatUnitCount(data.compliantUnits);

        // Update X-axis labels (average billing amounts)
        const avgBilledLabel = document.getElementById(streamId + 'MatrixAvgBilledLabel');
        const avgAchievableLabel = document.getElementById(streamId + 'MatrixAchievableLabel');
        const originLabel = document.getElementById(streamId + 'MatrixOriginLabel');

        if (avgBilledLabel) avgBilledLabel.textContent = formatCompact(data.avgBilledAmount);
        if (avgAchievableLabel) avgAchievableLabel.textContent = formatCompact(data.achievableAvgBill);
        if (originLabel) originLabel.textContent = currencySymbol + ' 0';

        // Update matrix cell values
        const matrixActualRevenue = document.getElementById(streamId + 'MatrixActualRevenueVal');
        const matrixLiabilityGap = document.getElementById(streamId + 'MatrixLiabilityGapVal');
        const matrixComplianceGap = document.getElementById(streamId + 'MatrixComplianceGapVal');
        const matrixMixedCompliance = document.getElementById(streamId + 'MatrixMixedComplianceVal');
        const matrixCoverageGap = document.getElementById(streamId + 'MatrixCoverageGapVal');
        const matrixMixedCoverage = document.getElementById(streamId + 'MatrixMixedCoverageVal');

        if (matrixActualRevenue) matrixActualRevenue.textContent = formatCompact(data.revenueToDate);
        if (matrixLiabilityGap) matrixLiabilityGap.textContent = formatCompact(data.liabilityGap);
        if (matrixComplianceGap) matrixComplianceGap.textContent = formatCompact(data.complianceGap);
        if (matrixMixedCompliance) matrixMixedCompliance.textContent = formatCompact(data.mixedGapCompliance);
        if (matrixCoverageGap) matrixCoverageGap.textContent = formatCompact(data.coverageGap);
        if (matrixMixedCoverage) matrixMixedCoverage.textContent = formatCompact(data.mixedGapCoverage);

        // === DYNAMIC ROW HEIGHTS (proportional to unit counts) ===
        const totalUnits = data.totalEstimatedUnits || 1;
        const unregUnits = Math.max(0, data.unregisteredUnits || 0);
        const nonCompliantUnits = Math.max(0, data.nonCompliantUnits || 0);
        const compliantUnits = Math.max(0, data.compliantUnits || 0);

        // Calculate flex ratios with minimum 30% to ensure text visibility
        const minFlex = 0.3;
        const unregRatio = unregUnits / totalUnits;
        const nonCompliantRatio = nonCompliantUnits / totalUnits;
        const compliantRatio = compliantUnits / totalUnits;

        const unregFlex = Math.max(minFlex, unregRatio);
        const nonCompliantFlex = Math.max(minFlex, nonCompliantRatio);
        const compliantFlex = Math.max(minFlex, compliantRatio);

        const rowUnreg = document.getElementById(streamId + 'MatrixRowUnreg');
        const rowNonCompliant = document.getElementById(streamId + 'MatrixRowNonCompliant');
        const rowCompliant = document.getElementById(streamId + 'MatrixRowCompliant');

        if (rowUnreg) rowUnreg.style.flex = unregFlex.toString();
        if (rowNonCompliant) rowNonCompliant.style.flex = nonCompliantFlex.toString();
        if (rowCompliant) rowCompliant.style.flex = compliantFlex.toString();

        // === DYNAMIC COLUMN WIDTHS (proportional to billing amounts) ===
        const totalBilling = data.achievableAvgBill || 1;
        const avgBilled = data.avgBilledAmount || 0;
        const liabilityDiff = Math.max(0, (data.achievableAvgBill || 0) - (data.avgBilledAmount || 0));

        // Calculate column width ratios (min 30% to ensure text visibility)
        const minColWidth = 0.3;
        const leftColRatio = avgBilled / totalBilling;
        const rightColRatio = liabilityDiff / totalBilling;

        const leftColFlex = Math.max(minColWidth, leftColRatio);
        const rightColFlex = Math.max(minColWidth, rightColRatio);

        // Apply to all row cells
        const allRows = document.querySelectorAll('#' + streamId + 'MatrixGridArea .matrix-row');
        allRows.forEach(row => {
            const cells = row.querySelectorAll('.matrix-cell');
            if (cells.length >= 2) {
                cells[0].style.flex = leftColFlex.toString();
                cells[1].style.flex = rightColFlex.toString();
            }
        });

        // === POSITION Y-AXIS LABELS AT ROW BOUNDARIES ===
        const gridArea = document.getElementById(streamId + 'MatrixGridArea');
        const yAxisContainer = document.getElementById(streamId + 'MatrixYLabelsContainer');

        if (gridArea && yAxisContainer) {
            const gridHeight = gridArea.offsetHeight;
            const totalFlex = unregFlex + nonCompliantFlex + compliantFlex;

            // Calculate row heights in pixels
            const row1Height = (unregFlex / totalFlex) * gridHeight;
            const row2Height = (nonCompliantFlex / totalFlex) * gridHeight;

            // Position labels at boundaries
            const yLabelEstimated = document.getElementById(streamId + 'YLabelEstimated');
            const yLabelRegistered = document.getElementById(streamId + 'YLabelRegistered');
            const yLabelCompliant = document.getElementById(streamId + 'YLabelCompliant');

            // Estimated at top (0px from top)
            if (yLabelEstimated) {
                yLabelEstimated.style.top = '0px';
            }
            // Registered at boundary between row1 and row2
            if (yLabelRegistered) {
                yLabelRegistered.style.top = row1Height + 'px';
            }
            // Compliant at boundary between row2 and row3
            if (yLabelCompliant) {
                yLabelCompliant.style.top = (row1Height + row2Height) + 'px';
            }
        }

        // === POSITION X-AXIS LABEL AT COLUMN BOUNDARY ===
        const xAxisContainer = document.getElementById(streamId + 'MatrixXAxisContainer');
        const xLabelAvgBilled = document.getElementById(streamId + 'XLabelAvgBilled');

        if (xAxisContainer && xLabelAvgBilled) {
            const totalColFlex = leftColFlex + rightColFlex;
            const leftColPercent = (leftColFlex / totalColFlex) * 100;

            // Position the "Avg. Billed" label at the column boundary
            xLabelAvgBilled.style.left = leftColPercent + '%';
        }
    }

    // Initialize on DOM ready
    document.addEventListener('DOMContentLoaded', function() {
        // Subscribe to AppContext currency changes
        if (window.AppContext) {
            window.AppContext.subscribe('currencySymbol', function(newSymbol) {
                updateStreamCurrencySymbols();
                calculateGaps();
            });
        }

        // Initial currency update
        updateStreamCurrencySymbols();

        // Initialize Bootstrap tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('#' + streamId + '-container [data-bs-toggle="tooltip"]'));
        tooltipTriggerList.forEach(function(tooltipTriggerEl) {
            new bootstrap.Tooltip(tooltipTriggerEl);
        });

        // Initialize charts
        initializeCharts();

        // Add event listeners to input fields
        const inputFields = document.querySelectorAll('#' + streamId + '-container input[data-input="true"]');
        inputFields.forEach(function(input) {
            input.addEventListener('input', calculateGaps);
            input.addEventListener('change', calculateGaps);
        });

        // Add listener for stream name changes
        const streamNameInput = document.getElementById(streamId + 'Name');
        if (streamNameInput) {
            streamNameInput.addEventListener('input', calculateGaps);
            streamNameInput.addEventListener('change', calculateGaps);
        }

        // Add listener for delete button to remove from RosraStateManager
        const deleteBtn = document.querySelector('#' + streamId + '-container .delete-stream-btn');
        if (deleteBtn) {
            deleteBtn.addEventListener('click', function() {
                // Remove from RosraStateManager when stream is deleted
                if (typeof RosraStateManager !== 'undefined') {
                    const genericStreamId = 'generic-stream-' + streamIndex;
                    RosraStateManager.removeStream(genericStreamId);
                    console.log('RosraStateManager: Removed Generic Stream ' + streamIndex);
                }
                // Clear localStorage values
                localStorage.removeItem(streamId + 'CurrentValue');
                localStorage.removeItem(streamId + 'PotentialValue');
                localStorage.removeItem(streamId + 'GapValue');
                localStorage.removeItem(streamId + 'Name');
                localStorage.removeItem(streamId + 'ComplianceGap');
                localStorage.removeItem(streamId + 'CoverageGap');
                localStorage.removeItem(streamId + 'LiabilityGap');
                localStorage.removeItem(streamId + 'ComplianceRatio');
                localStorage.removeItem(streamId + 'CoverageRatio');
            });
        }

        // Initial calculation
        calculateGaps();

        // Delayed update for currency (after country data loads)
        setTimeout(function() {
            updateStreamCurrencySymbols();
        }, 1000);
    });

    // Expose calculate function globally
    window['calculate' + streamId + 'Gaps'] = calculateGaps;

    // Expose remove function globally for external deletion handling
    window['remove' + streamId + 'FromStateManager'] = function() {
        if (typeof RosraStateManager !== 'undefined') {
            const genericStreamId = 'generic-stream-' + streamIndex;
            RosraStateManager.removeStream(genericStreamId);
        }
    };
})();
</script>
