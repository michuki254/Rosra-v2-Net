<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Add Chart.js library dynamically if not already loaded
        if (typeof Chart === 'undefined') {
            const chartScript = document.createElement('script');
            chartScript.src = 'https://cdn.jsdelivr.net/npm/chart.js';
            chartScript.onload = initializeCharts;
            document.head.appendChild(chartScript);
        } else {
            initializeCharts();
        }
        
        // Function to initialize charts
        function initializeCharts() {
            // Initialize the Top 5 OSR Potential chart if the element exists
            const chartCanvas = document.getElementById('top5PotentialChart');
            if (chartCanvas) {
                createTop5PotentialChart(chartCanvas);
            }
        }
        
        // Function to create the Top 5 OSR Potential chart
        function createTop5PotentialChart(canvas) {
            // If Chart.js is not available, we can't create the chart
            if (typeof Chart === 'undefined') return;
            
            // Use the total potential revenue from all tabs instead of just top 5 OSR table
            const currentTotal = parseStoredValue('totalCurrentRevenue') || 0;
            const potentialTotal = parseStoredValue('totalPotentialRevenue') || 0;
            const collectionRate = potentialTotal > 0 ? (currentTotal / potentialTotal) * 100 : 0;
            const gap = potentialTotal - currentTotal;
            
            console.log('Top 5 OSR Potential Chart Values:', {
                currentTotal,
                potentialTotal,
                collectionRate,
                gap
            });
            
            // Update the text displays
            const currentCompare = document.getElementById('top5OSRCurrentCompare');
            const potentialCompare = document.getElementById('top5OSRPotentialCompare');
            const gapCompare = document.getElementById('top5OSRGapCompare');
            const rateDisplay = document.getElementById('top5CollectionRate');
            
            if (currentCompare) currentCompare.textContent = formatNumber(currentTotal);
            if (potentialCompare) potentialCompare.textContent = formatNumber(potentialTotal);
            if (gapCompare) gapCompare.textContent = formatNumber(gap);
            if (rateDisplay) rateDisplay.textContent = formatNumber(collectionRate, 1) + '%';
            
            // Also update the simplified display
            updateTotalPotentialDisplay(potentialTotal);
            
            // Create the doughnut chart
            const data = {
                datasets: [{
                    data: [currentTotal, gap],
                    backgroundColor: ['#0d6efd', '#f0f0f0'],
                    borderWidth: 0
                }]
            };
            
            const options = {
                cutout: '70%',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                const label = context.index === 0 ? 'Current' : 'Gap';
                                const value = formatNumber(context.raw);
                                return `${label}: ${value}`;
                            }
                        }
                    }
                }
            };
            
            // Check if there's an existing chart instance and destroy it
            if (window.top5Chart) {
                window.top5Chart.destroy();
            }
            
            // Create new chart instance
            window.top5Chart = new Chart(canvas, {
                type: 'doughnut',
                data: data,
                options: options
            });
        }
        
        // Function to update the simplified Total Potential Revenue display
        function updateTotalPotentialDisplay(potentialTotal) {
            const potentialCompare = document.getElementById('top5OSRPotentialCompare');
            const totalPotentialDisplay = document.getElementById('totalPotentialDisplay');
            
            if (potentialCompare) potentialCompare.textContent = formatNumber(potentialTotal);
            if (totalPotentialDisplay) totalPotentialDisplay.textContent = formatNumber(potentialTotal);
            
            console.log('Updated Total Potential Revenue display:', potentialTotal);
        }
        
        // Function to parse formatted number
        function parseFormattedNumber(value) {
            if (!value) return 0;
            
            // Remove any non-numeric characters except for dots (decimal points)
            const cleanValue = value.toString()
                .replace(/[^0-9.-]/g, '')  // Remove all non-numeric characters except dots and minus signs
                .replace(/(\.[^.]*)\..*/, '$1'); // Keep only the first decimal point
            
            const parsedValue = parseFloat(cleanValue);
            return isNaN(parsedValue) ? 0 : parsedValue;
        }
        
        // Function to parse values from localStorage
        function parseStoredValue(key) {
            try {
                const storedValue = localStorage.getItem(key);
                if (!storedValue) {
                    return 0;
                }
                
                console.log(`Found value in localStorage for key ${key}:`, storedValue);
                
                // Try parsing as JSON first (in case it's a stringified object)
                try {
                    const jsonValue = JSON.parse(storedValue);
                    if (typeof jsonValue === 'object' && jsonValue !== null) {
                        // If it's an object, try to find a numeric property
                        for (const prop in jsonValue) {
                            if (!isNaN(jsonValue[prop])) {
                                console.log(`  - Using numeric property ${prop}:`, jsonValue[prop]);
                                return parseFloat(jsonValue[prop]);
                            }
                        }
                    } else if (!isNaN(jsonValue)) {
                        // If it's a simple number
                        console.log(`  - Parsed as JSON number:`, jsonValue);
                        return parseFloat(jsonValue);
                    }
                } catch (jsonError) {
                    // Not a valid JSON string, continue with other parsing methods
                    console.log(`  - Not valid JSON, continuing with other parsing methods`);
                }
                
                // Clean the value (remove commas, currency symbols, etc.)
                const cleanValue = storedValue.toString().replace(/[^\d.-]/g, '');
                const parsedValue = parseFloat(cleanValue);
                console.log(`  - Parsed as regular number:`, parsedValue);
                
                return isNaN(parsedValue) ? 0 : parsedValue;
            } catch (e) {
                console.error('Error parsing stored value for key ' + key + ':', e);
                return 0;
            }
        }
        
        // Function to format number with commas
        function formatNumber(number, decimals = 2) {
            if (isNaN(number)) return "0";
            return number.toLocaleString('en-US', { 
                minimumFractionDigits: decimals,
                maximumFractionDigits: decimals
            });
        }
        
        // Calculate totals from all tabs
        function calculateTotals() {
            console.log('Calculating totals...');
            
            // Log localStorage state for debugging
            const localStorageKeys = Object.keys(localStorage).filter(key => 
                key.includes('Current') || 
                key.includes('Potential') || 
                key.includes('Gap') ||
                key.includes('license') ||
                key.includes('longTerm') ||
                key.includes('shortTerm')
            );
            console.log('Available LocalStorage keys:', localStorageKeys);
            localStorageKeys.forEach(key => {
                console.log(`${key}: ${localStorage.getItem(key)}`);
            });
            
            // Get values from all tabs - first try localStorage for more reliability
            const propertyTaxCurrent = parseStoredValue('propertyTaxCurrentValue');
            const licenseCurrent = parseStoredValue('licenseCurrentValue');
            const shortTermCurrent = parseStoredValue('shortTermCurrentValue');
            const longTermCurrent = parseStoredValue('longTermCurrent');
            const mixedCurrent = parseStoredValue('mixedCurrent');
            
            const propertyTaxPotential = parseStoredValue('propertyTaxPotentialValue');
            const licensePotential = parseStoredValue('licensePotentialValue');
            const shortTermPotential = parseStoredValue('shortTermPotentialValue');
            const longTermPotential = parseStoredValue('longTermPotential');
            const mixedPotential = parseStoredValue('mixedPotential');
            
            console.log('Retrieved values for total calculations:', {
                propertyTaxCurrent,
                licenseCurrent,
                shortTermCurrent,
                longTermCurrent,
                mixedCurrent,
                propertyTaxPotential,
                licensePotential,
                shortTermPotential,
                longTermPotential,
                mixedPotential
            });
            
            // Calculate totals
            const totalCurrent = propertyTaxCurrent + licenseCurrent + shortTermCurrent + longTermCurrent + mixedCurrent;
            const totalPotential = propertyTaxPotential + licensePotential + shortTermPotential + longTermPotential + mixedPotential;
            const totalGap = totalPotential - totalCurrent;
            
            console.log('Calculated totals:', {
                totalCurrent,
                totalPotential,
                totalGap
            });
            
            // Update total fields
            const totalCurrentRevenueInput = document.getElementById('totalCurrentRevenue');
            const totalPotentialRevenueInput = document.getElementById('totalPotentialRevenue');
            const totalRevenueGapInput = document.getElementById('totalRevenueGap');
            const totalCurrentValueInput = document.getElementById('totalCurrentValue');
            const totalPotentialValueInput = document.getElementById('totalPotentialValue');
            const totalGapInput = document.getElementById('totalGap');
            
            if (totalCurrentRevenueInput) totalCurrentRevenueInput.value = formatNumber(totalCurrent);
            if (totalPotentialRevenueInput) totalPotentialRevenueInput.value = formatNumber(totalPotential);
            if (totalRevenueGapInput) totalRevenueGapInput.value = formatNumber(totalGap);
            if (totalCurrentValueInput) totalCurrentValueInput.value = formatNumber(totalCurrent);
            if (totalPotentialValueInput) totalPotentialValueInput.value = formatNumber(totalPotential);
            if (totalGapInput) totalGapInput.value = formatNumber(totalGap);
            
            // Calculate and update percentage realized
            const percentageRealized = document.getElementById('percentageRealized');
            if (percentageRealized) {
                const percentage = totalPotential > 0 ? (totalCurrent / totalPotential) * 100 : 0;
                percentageRealized.value = formatNumber(percentage, 1) + "%";
            }
            
            // Get population from the _PotentialEstimates.cshtml if it exists
            const population = parseFormattedNumber(document.getElementById('population')?.value) || 0;
            
            // Calculate per capita metrics
            const perCapitaCurrentRevenue = document.getElementById('perCapitaCurrentRevenue');
            const perCapitaPotentialRevenue = document.getElementById('perCapitaPotentialRevenue');
            
            if (perCapitaCurrentRevenue && population > 0) {
                perCapitaCurrentRevenue.value = formatNumber(totalCurrent / population);
            }
            
            if (perCapitaPotentialRevenue && population > 0) {
                perCapitaPotentialRevenue.value = formatNumber(totalPotential / population);
            }
            
            // Calculate individual gaps
            const propertyTaxGap = propertyTaxPotential - propertyTaxCurrent;
            const licenseGap = licensePotential - licenseCurrent;
            const shortTermGap = shortTermPotential - shortTermCurrent;
            const longTermGap = longTermPotential - longTermCurrent;
            const mixedGap = mixedPotential - mixedCurrent;
            
            console.log('Individual gaps:', {
                propertyTaxGap,
                licenseGap,
                shortTermGap,
                longTermGap,
                mixedGap
            });
            
            // Ensure these gap values are stored in localStorage
            if (propertyTaxGap) localStorage.setItem('propertyTaxGap', propertyTaxGap);
            if (licenseGap) localStorage.setItem('licenseGap', licenseGap);
            if (shortTermGap) localStorage.setItem('shortTermGap', shortTermGap);
            if (longTermGap) localStorage.setItem('longTermGap', longTermGap);
            if (mixedGap) localStorage.setItem('mixedGap', mixedGap);
            
            // Populate the potential revenue by source table
            updatePotentialRevenueTable(
                propertyTaxCurrent, propertyTaxPotential,
                licenseCurrent, licensePotential,
                shortTermCurrent, shortTermPotential,
                longTermCurrent, longTermPotential,
                mixedCurrent, mixedPotential
            );
            
            // Populate the Top 5 OSR table
            populateTop5OsrTable(totalCurrent, totalPotential, totalGap);
            
            // Store the calculated totals in localStorage for potential use in other components
            storeCalculatedTotals(totalCurrent, totalPotential, totalGap);
            
            // Update the simplified Total Potential Revenue display
            updateTotalPotentialDisplay(totalPotential);
            
            // Calculate and store the gap categories in localStorage
            // Note: The UI elements for these have been removed, but we still store the data
            updateGapCategories(totalGap);
            
            // Explicitly check for and update the largest gap display
            const gapValues = [
                { value: propertyTaxGap, name: 'Property Tax' },
                { value: licenseGap, name: 'License' },
                { value: shortTermGap, name: 'Short Term' },
                { value: longTermGap, name: 'Long Term' },
                { value: mixedGap, name: 'Mixed' }
            ];
            
            // Find the actual largest gap
            const largestGap = gapValues.reduce((prev, current) => {
                return (prev.value > current.value) ? prev : current;
            });
            
            console.log('Identified largest gap in calculateTotals:', largestGap);
            
            // Store the largest gap source in localStorage, but don't show the element
            localStorage.setItem('largestGapSource', largestGap.name);
            localStorage.setItem('largestGapValue', largestGap.value);
            
            // Make sure the largest gap highlight section is always hidden
            const largestGapHighlight = document.getElementById('largestGapHighlight');
            if (largestGapHighlight) {
                largestGapHighlight.style.display = 'none';
            }
        }
        
        // Function to calculate and update gap categories
        function updateGapCategories(totalGap) {
            if (totalGap <= 0) return;
            
            console.log('Calculating gap categories with total gap:', totalGap);
            
            // Use simplified proportions for gap categories since UI elements are removed
            // Default distributions
            const registrationGap = 0.3 * totalGap; // 30% of total gap 
            const complianceGap = 0.25 * totalGap;  // 25% of total gap
            const assessmentGap = 0.35 * totalGap;  // 35% of total gap
