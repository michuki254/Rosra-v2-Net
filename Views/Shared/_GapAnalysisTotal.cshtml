                { value: licenseGap, cardId: 'licenseGapCard', name: 'License' },
                { value: shortTermGap, cardId: 'shortTermGapCard', name: 'Short Term' },
                { value: longTermGap, cardId: 'longTermGapCard', name: 'Long Term' },
