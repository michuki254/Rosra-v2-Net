        updateDetailedGapBreakdownRow(licenseRow, licenseRegistrationGap, licenseComplianceGap, licenseAssessmentGap, licenseCombinedGap, licenseRateGap, licenseTotalGap);
        updateDetailedGapBreakdownRow(shortTermRow, shortRegistrationGap, shortComplianceGap, shortAssessmentGap, shortCombinedGap, shortRateGap, shortTotalGap);
