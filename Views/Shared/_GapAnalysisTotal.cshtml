        updateDetailedGapBreakdownRow(mixedRow, mixedRegistrationGap, mixedComplianceGap, mixedAssessmentGap, mixedCombinedGap, mixedRateGap, mixedTotalGap);
        
        // Calculate totals
        const totalRegistrationGap = propertyRegistrationGap + licenseRegistrationGap + shortRegistrationGap + longRegistrationGap + mixedRegistrationGap;
        const totalComplianceGap = propertyComplianceGap + licenseComplianceGap + shortComplianceGap + longComplianceGap + mixedComplianceGap;
        const totalAssessmentGap = propertyAssessmentGap + licenseAssessmentGap + shortAssessmentGap + longAssessmentGap + mixedAssessmentGap;
        const totalRateGap = propertyRateGap + licenseRateGap + shortRateGap + longRateGap + mixedRateGap;
        const totalCombinedGap = propertyCombinedGap + licenseCombinedGap + shortCombinedGap + longCombinedGap + mixedCombinedGap;
        const totalGap = propertyTotalGap + licenseTotalGap + shortTotalGap + longTotalGap + mixedTotalGap;
        
        // Update the total row with the aggregated values
        updateDetailedGapBreakdownRow(totalRow, totalRegistrationGap, totalComplianceGap, totalAssessmentGap, totalCombinedGap, totalRateGap, totalGap);
    }

