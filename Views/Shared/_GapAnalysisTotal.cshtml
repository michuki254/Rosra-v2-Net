        // Helper function to round percentages to ensure they sum to a specific total
        function roundPercentagesToTotal(percentages, targetTotal) {
            if (!percentages || percentages.length === 0) return [];
            
            // Calculate the current sum
            const sum = percentages.reduce((acc, val) => acc + val, 0);
            
            // If sum is zero, distribute evenly
            if (sum === 0) {
                const evenPercentage = targetTotal / percentages.length;
                return percentages.map(() => evenPercentage);
            }
            
            // Adjust each percentage proportionally
            const scaleFactor = targetTotal / sum;
            const scaledPercentages = percentages.map(p => p * scaleFactor);
            
            // Round to 1 decimal place
            const roundedPercentages = scaledPercentages.map(p => Math.round(p * 10) / 10);
            
            // Handle any rounding errors by adjusting the largest value
            const roundedSum = roundedPercentages.reduce((acc, val) => acc + val, 0);
            if (roundedSum !== targetTotal) {
                const diff = targetTotal - roundedSum;
                const maxIndex = roundedPercentages.indexOf(Math.max(...roundedPercentages));
                roundedPercentages[maxIndex] += diff;
            }
            
            return roundedPercentages;
        }
        
