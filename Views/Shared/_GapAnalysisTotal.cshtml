<script>
    // Format currency helper function
    function formatCurrency(value) {
        return '$' + parseFloat(value).toLocaleString('en-US', { 
            minimumFractionDigits: 2, 
            maximumFractionDigits: 2 
        });
    }
    
    // Function to parse a formatted number from a string
    function parseFormattedNumber(value) {
        if (!value || value === '-') return 0;
        return parseFloat(value.toString().replace(/[^0-9.-]/g, '')) || 0;
    }

    // Add this helper function for extracting numeric values from formatted currency strings
    function extractNumericValue(str) {
        if (!str || str === '-') return 0;
        
        // Log the original input for debugging
        console.log('Extracting numeric value from:', str);
        
        // First attempt: try to match and extract a numeric pattern with optional $ and commas
        const numericMatch = str.match(/[\$]?[\s]*([0-9,]+(\.[0-9]+)?)/);
        if (numericMatch && numericMatch[1]) {
            // Remove commas before converting to float
            const cleanNum = numericMatch[1].replace(/,/g, '');
            const result = parseFloat(cleanNum);
            console.log('Extracted via regex match:', result);
            return result || 0;
        }
        
        // Fallback: Remove currency symbol, commas, and any other non-numeric characters except decimal point and minus
        const cleanValue = str.toString().replace(/[^0-9.-]/g, '');
        const result = parseFloat(cleanValue);
        console.log('Extracted via fallback method:', result);
        return result || 0;
    }
</script>