            ];
            
            console.log('Gap values for comparison:', gapValues.map(item => `${item.name}: ${item.value}`));
            
            // Find the largest gap
            const largestGap = gapValues.reduce((prev, current) => {
                console.log(`Comparing ${prev.name}(${prev.value}) with ${current.name}(${current.value})`);
                return (prev.value > current.value) ? prev : current;
            });
            
            console.log('Largest gap identified:', largestGap);
            
            // Show the indicator on the card with the largest gap
            if (largestGap.value > 0) {
                const card = document.getElementById(largestGap.cardId);
                if (card) {
                    const indicator = card.querySelector('.largest-gap-indicator');
                    if (indicator) {
                        indicator.style.display = 'block';
                    }
                    
                    // Also update the badge in the heading
                    const badge = document.querySelector('.largest-gap-badge');
                    if (badge) {
                        badge.textContent = largestGap.name + ' has the largest gap';
                        badge.style.display = 'inline-block';
                    }
                    
                    // Store the largest gap data in localStorage
                    localStorage.setItem('largestGapSource', largestGap.name);
                    localStorage.setItem('largestGapValue', largestGap.value);
                }
            }
            
            // Always ensure the largest gap highlight section is hidden
            const largestGapHighlight = document.getElementById('largestGapHighlight');
            if (largestGapHighlight) {
                largestGapHighlight.style.display = 'none';
            }
        }
        
        // Function to populate the Top 5 OSR table
        function populateTop5OsrTable(totalCurrentRevenue, totalPotentialRevenue, totalRevenueGap) {
            const top5OsrTable = document.getElementById('top5OsrTable');
            const top5CurrentTotal = document.getElementById('top5CurrentTotal');
            const top5PotentialTotal = document.getElementById('top5PotentialTotal');
            const top5GapTotal = document.getElementById('top5GapTotal');
            
            if (!top5OsrTable) return;
            
            // Clear the table
            top5OsrTable.innerHTML = '';
            
            // Check if we have OSR data in localStorage
            const osrDataString = localStorage.getItem('topOsrConfig');
            
            if (!osrDataString) {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td colspan="5" class="text-center">No OSR data available. Please configure Top 5 OSR sources.</td>
                `;
                top5OsrTable.appendChild(row);
                return;
            }
            
            const osrData = JSON.parse(osrDataString);
            const otherRevenue = parseFormattedNumber(localStorage.getItem('otherRevenue')) || 0;
            
            // For calculating actual to potential ratio
            const ratio = totalCurrentRevenue > 0 ? totalPotentialRevenue / totalCurrentRevenue : 1;
            
            let currentTotal = 0;
            let potentialTotal = 0;
            let gapTotal = 0;
            
            // Add rows for each OSR item
            osrData.forEach(item => {
                const current = parseFloat(item.revenue) || 0;
                // Calculate potential based on the ratio of total potential to total current
                const potential = current * ratio;
                const gap = potential - current;
                
                currentTotal += current;
                potentialTotal += potential;
                gapTotal += gap;
                
                // Calculate percentage of total gap
                const percentOfGap = totalRevenueGap > 0 ? (gap / totalRevenueGap) * 100 : 0;
                
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>${item.name}</td>
                    <td class="text-end">${formatNumber(current)}</td>
                    <td class="text-end">${formatNumber(potential)}</td>
                    <td class="text-end">${formatNumber(gap)}</td>
                    <td class="text-end">${formatNumber(percentOfGap, 1)}%</td>
                `;
                top5OsrTable.appendChild(row);
            });
            
            // Add other revenue row
            const otherRow = document.createElement('tr');
            otherRow.innerHTML = `
                    <td>Other Revenue</td>
                    <td class="text-end">${formatNumber(otherRevenue)}</td>
                <td class="text-end">${formatNumber(otherRevenue)}</td>
                <td class="text-end">0</td>
                <td class="text-end">0%</td>
            `;
            top5OsrTable.appendChild(otherRow);
            
            // Update totals
            top5CurrentTotal.textContent = formatNumber(currentTotal);
            top5PotentialTotal.textContent = formatNumber(potentialTotal);
            top5GapTotal.textContent = formatNumber(gapTotal);
            
            // Store the top5 totals for calculations
            localStorage.setItem('top5CurrentTotal', currentTotal);
            localStorage.setItem('top5PotentialTotal', potentialTotal);
            localStorage.setItem('top5GapTotal', gapTotal);
            
            // Update the Top 5 OSRs chart if Chart.js is loaded
            if (typeof Chart !== 'undefined' && document.getElementById('top5PotentialChart')) {
                createTop5PotentialChart(document.getElementById('top5PotentialChart'));
            }
            
            // Make sure gap values are positive for percentage calculation
            const positiveGapTotal = Math.abs(gapTotal);
            
            // Calculate average gap specifically for Top 5 OSRs (Gap Total / Potential Total)
            // This ratio represents what percentage of potential revenue is not being collected
            const top5AverageGap = potentialTotal > 0 ? (positiveGapTotal / potentialTotal) * 100 : 0;
            
            // Convert to decimal for formula calculation (e.g., 25% becomes 0.25)
            const gapRatio = top5AverageGap / 100;
            
            // Calculate Total Potential of Other OSRs
            // Formula: Other Revenue / (1 - Average Gap Across Top 5 OSRs)
            let otherPotentialRevenue = 0;
            if (gapRatio < 1) { // Ensure we don't divide by zero or negative
                otherPotentialRevenue = otherRevenue / (1 - gapRatio);
            } else {
                // If gap ratio is 100% or more, we can't calculate accurately
                otherPotentialRevenue = otherRevenue * 2; // Use a reasonable fallback
            }
            
            // Calculate potential gap for other revenue
            const otherGap = otherPotentialRevenue - otherRevenue;
            
            console.log('Other OSR Potential Calculation:', {
                otherRevenue,
                gapRatio,
                formula: `${otherRevenue} / (1 - ${gapRatio})`,
                otherPotentialRevenue,
                otherGap
            });
            
            // Store these values for display in the card
            localStorage.setItem('otherPotentialRevenue', otherPotentialRevenue);
            localStorage.setItem('otherGap', otherGap);
            
            console.log('Top 5 OSR Average Gap Calculation:', {
                currentTotal,
                potentialTotal,
                gapTotal,
                positiveGapTotal,
                calculatedAverageGap: top5AverageGap,
                gapToCurrentRatio: currentTotal > 0 ? (positiveGapTotal / currentTotal) * 100 : 0
            });
            
            // Update the average gap visual indicator
            updateAverageGapIndicator(top5AverageGap);
            
            // Update the other OSR potential card
            updateOtherOSRPotentialCard(otherRevenue, otherPotentialRevenue, otherGap, gapRatio);
            
            // Update the Total OSR Potential card
            updateTotalOSRPotential(otherPotentialRevenue);
        }
        
