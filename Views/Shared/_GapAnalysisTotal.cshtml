                // Medium gap - needs attention
                color = '#ffc107'; // Yellow/warning
                descriptionText = 'Moderate Revenue Gap';
                descriptionClass = 'mb-0 small fw-bold text-warning';
            } else {
                // High gap - problematic
                color = '#dc3545'; // Red/danger
                descriptionText = 'Significant Revenue Gap';
                descriptionClass = 'mb-0 small fw-bold text-danger';
            }
            
            console.log('Indicator settings:', { gapPercentage, color, descriptionText });
            
            // Apply the settings
            indicator.style.backgroundColor = color;
            description.textContent = descriptionText;
            description.className = descriptionClass;
