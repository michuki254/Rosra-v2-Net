@model RosraApp.Models.ViewModels.RosraFormViewModel
@{
    bool isViewMode = ViewData["ViewMode"] != null && (bool)ViewData["ViewMode"];
}

<div class="gap-analysis-tab-content">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm rounded-3 border-0">
                <div class="card-header bg-gradient-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-chart-pie me-2"></i>
                        Total Revenue Gap Analysis
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <div class="form-floating">
                                <input type="text" class="form-control @(isViewMode ? "bg-light" : "")" id="totalDescription" name="TotalEstimate.Description" value="@Model.TotalEstimate.Description" placeholder="Enter description" @(isViewMode ? "readonly" : "")>
                                <label for="totalDescription">Description</label>
                            </div>
                        </div>
                    </div>

                    <!-- Revenue Summary Cards -->
                    <div class="row g-3 mb-4">
                        <!-- Current Revenue Card -->
                        <div class="col-md-4">
                            <div class="card h-100 border-primary border-start border-4">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h6 class="card-title text-primary mb-0">
                                            <i class="fas fa-money-bill-wave me-2"></i>
                                            Total Current Revenue
                                        </h6>
                                        <span class="badge rounded-pill bg-primary">Actual</span>
                                    </div>
                                    <div class="form-floating">
                                        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" id="totalCurrentRevenue" name="TotalEstimate.TotalCurrentRevenue" value="@(Model.TotalEstimate.TotalCurrentRevenue?.ToString("#,##0.##"))" placeholder="Enter total current revenue" @(isViewMode ? "readonly" : "")>
                                        <label for="totalCurrentRevenue">Current Revenue</label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Potential Revenue Card -->
                        <div class="col-md-4">
                            <div class="card h-100 border-success border-start border-4">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h6 class="card-title text-success mb-0">
                                            <i class="fas fa-chart-line me-2"></i>
                                            Total Potential Revenue
                                        </h6>
                                        <span class="badge rounded-pill bg-success">Potential</span>
                                    </div>
                                    <div class="form-floating">
                                        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" id="totalPotentialRevenue" name="TotalEstimate.TotalPotentialRevenue" value="@(Model.TotalEstimate.TotalPotentialRevenue?.ToString("#,##0.##"))" placeholder="Enter total potential revenue" @(isViewMode ? "readonly" : "")>
                                        <label for="totalPotentialRevenue">Potential Revenue</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Revenue Gap Card -->
                        <div class="col-md-4">
                            <div class="card h-100 border-danger border-start border-4">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h6 class="card-title text-danger mb-0">
                                            <i class="fas fa-chart-bar me-2"></i>
                                            Total Revenue Gap
                                        </h6>
                                        <span class="badge rounded-pill bg-danger">Gap</span>
                                    </div>
                                    <div class="form-floating">
                                        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" id="totalRevenueGap" name="TotalEstimate.TotalRevenueGap" value="@(Model.TotalEstimate.TotalRevenueGap?.ToString("#,##0.##"))" placeholder="Enter total revenue gap" @(isViewMode ? "readonly" : "")>
                                        <label for="totalRevenueGap">Revenue Gap</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Largest Gap Highlight -->
                    <div class="row mb-4" id="largestGapHighlight" style="display: none !important;">
                        <div class="col-12">
                            <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, #fff5f5 0%, #ffe8e8 100%);">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0">
                                            <div class="icon-circle bg-danger-subtle me-3" style="width: 48px; height: 48px;">
                                                <i class="fas fa-crown fa-lg text-danger"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1">
                                            <h5 class="mb-1 text-danger" id="largestGapTitle">Largest Revenue Gap</h5>
                                            <p class="mb-0 text-dark" id="largestGapDescription">
                                                The <span id="largestGapSource" class="fw-bold">-</span> revenue source represents the largest opportunity with a gap of <span id="largestGapAmount" class="fw-bold">-</span>.
                                            </p>
                                        </div>
                                        <div class="flex-shrink-0 ms-3 text-center">
                                            <h3 class="mb-0 text-danger" id="largestGapValue">-</h3>
                                            <p class="mb-0 small text-muted">Largest Gap</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Revenue Gap by Source Cards -->
                    <div class="row g-3 mb-4" id="gapCardsRow">
                        <div class="col-12">
                            <h6 class="mb-3 fw-light d-flex align-items-center">
                                <i class="fas fa-chart-bar me-2 text-danger"></i>
                                Revenue Gap Analysis by Source
                                <span class="badge bg-danger ms-2 largest-gap-badge" style="display: none;">
                                    <i class="fas fa-exclamation-circle me-1"></i>Largest Gap
                                </span>
                            </h6>
                        </div>
                        <div class="col-md-2 col-sm-4 col-6">
                            <div class="card h-100 border-0 shadow-sm position-relative" id="propertyTaxGapCard">
                                <div class="card-body p-3 text-center">
                                    <div class="icon-circle bg-primary-subtle mx-auto mb-2" style="width: 40px; height: 40px; opacity: 0.8;">
                                        <i class="fas fa-building text-primary"></i>
                                    </div>
                                    <p class="card-subtitle text-muted mb-2 small">Property Tax</p>
                                    <h5 class="mb-0 fw-bold text-danger" id="gapCard-propertyTax">-</h5>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger largest-gap-indicator" style="display: none;">
                                        <i class="fas fa-crown"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2 col-sm-4 col-6">
                            <div class="card h-100 border-0 shadow-sm position-relative" id="licenseGapCard">
                                <div class="card-body p-3 text-center">
                                    <div class="icon-circle bg-success-subtle mx-auto mb-2" style="width: 40px; height: 40px; opacity: 0.8;">
                                        <i class="fas fa-certificate text-success"></i>
                                    </div>
                                    <p class="card-subtitle text-muted mb-2 small">License</p>
                                    <h5 class="mb-0 fw-bold text-danger" id="gapCard-license">-</h5>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger largest-gap-indicator" style="display: none;">
                                        <i class="fas fa-crown"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2 col-sm-4 col-6">
                            <div class="card h-100 border-0 shadow-sm position-relative" id="shortTermGapCard">
                                <div class="card-body p-3 text-center">
                                    <div class="icon-circle bg-info-subtle mx-auto mb-2" style="width: 40px; height: 40px; opacity: 0.8;">
                                        <i class="fas fa-clock text-info"></i>
                                    </div>
                                    <p class="card-subtitle text-muted mb-2 small">Short Term</p>
                                    <h5 class="mb-0 fw-bold text-danger" id="gapCard-shortTerm">-</h5>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger largest-gap-indicator" style="display: none;">
                                        <i class="fas fa-crown"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2 col-sm-4 col-6">
                            <div class="card h-100 border-0 shadow-sm position-relative" id="longTermGapCard">
                                <div class="card-body p-3 text-center">
                                    <div class="icon-circle bg-warning-subtle mx-auto mb-2" style="width: 40px; height: 40px; opacity: 0.8;">
                                        <i class="fas fa-calendar-alt text-warning"></i>
                                    </div>
                                    <p class="card-subtitle text-muted mb-2 small">Long Term</p>
                                    <h5 class="mb-0 fw-bold text-danger" id="gapCard-longTerm">-</h5>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger largest-gap-indicator" style="display: none;">
                                        <i class="fas fa-crown"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2 col-sm-4 col-6">
                            <div class="card h-100 border-0 shadow-sm position-relative" id="mixedGapCard">
                                <div class="card-body p-3 text-center">
                                    <div class="icon-circle bg-danger-subtle mx-auto mb-2" style="width: 40px; height: 40px; opacity: 0.8;">
                                        <i class="fas fa-random text-danger"></i>
                                    </div>
                                    <p class="card-subtitle text-muted mb-2 small">Mixed</p>
                                    <h5 class="mb-0 fw-bold text-danger" id="gapCard-mixed">-</h5>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger largest-gap-indicator" style="display: none;">
                                        <i class="fas fa-crown"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2 col-sm-4 col-6">
                            <div class="card h-100 border-0 shadow-sm" style="background: linear-gradient(135deg, #f8d7da 0%, #f5c2c7 100%);">
                                <div class="card-body p-3 text-center">
                                    <div class="icon-circle bg-white mx-auto mb-2" style="width: 40px; height: 40px;">
                                        <i class="fas fa-exclamation text-danger"></i>
                                    </div>
                                    <p class="card-subtitle mb-2 small fw-medium text-dark">Total Gap</p>
                                    <h5 class="mb-0 fw-bold text-danger" id="gapCard-total">-</h5>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Potential Revenue By Tab Section -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">
                                        <i class="fas fa-coins me-2 text-success"></i>
                                        Potential Revenue By Source
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-hover">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Revenue Source</th>
                                                    <th class="text-end">Current Revenue</th>
                                                    <th class="text-end">Potential Revenue</th>
                                                    <th class="text-end">Gap</th>
                                                    <th class="text-end">% of Potential Realized</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <div class="icon-circle bg-primary-subtle me-2" style="width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                                                <i class="fas fa-building text-primary"></i>
                                                            </div>
                                                            <span>Property Tax</span>
                                                        </div>
                                                    </td>
                                                    <td class="text-end property-current">-</td>
                                                    <td class="text-end property-potential">-</td>
                                                    <td class="text-end property-gap">-</td>
                                                    <td class="text-end property-percentage">-</td>
                                                </tr>
                                                <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <div class="icon-circle bg-success-subtle me-2" style="width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                                                <i class="fas fa-certificate text-success"></i>
                                                            </div>
                                                            <span>License</span>
                                                        </div>
                                                    </td>
                                                    <td class="text-end license-current">-</td>
                                                    <td class="text-end license-potential">-</td>
                                                    <td class="text-end license-gap">-</td>
                                                    <td class="text-end license-percentage">-</td>
                                                </tr>
                                                <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <div class="icon-circle bg-info-subtle me-2" style="width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                                                <i class="fas fa-clock text-info"></i>
                                                            </div>
                                                            <span>Short Term</span>
                                                        </div>
                                                    </td>
                                                    <td class="text-end short-current">-</td>
                                                    <td class="text-end short-potential">-</td>
                                                    <td class="text-end short-gap">-</td>
                                                    <td class="text-end short-percentage">-</td>
                                                </tr>
                                                <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <div class="icon-circle bg-warning-subtle me-2" style="width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                                                <i class="fas fa-calendar-alt text-warning"></i>
                                                            </div>
                                                            <span>Long Term</span>
                                                        </div>
                                                    </td>
                                                    <td class="text-end long-current">-</td>
                                                    <td class="text-end long-potential">-</td>
                                                    <td class="text-end long-gap">-</td>
                                                    <td class="text-end long-percentage">-</td>
                                                </tr>
                                                <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <div class="icon-circle bg-danger-subtle me-2" style="width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                                                                <i class="fas fa-random text-danger"></i>
                                                            </div>
                                                            <span>Mixed</span>
                                                        </div>
                                                    </td>
                                                    <td class="text-end mixed-current">-</td>
                                                    <td class="text-end mixed-potential">-</td>
                                                    <td class="text-end mixed-gap">-</td>
                                                    <td class="text-end mixed-percentage">-</td>
                                                </tr>
                                            </tbody>
                                            <tfoot class="table-light">
                                                <tr class="fw-bold">
                                                    <td>Total</td>
                                                    <td id="potential-current-total" class="text-end">0</td>
                                                    <td id="potential-potential-total" class="text-end">0</td>
                                                    <td id="potential-gap-total" class="text-end">0</td>
                                                    <td id="potential-percentage-total" class="text-end">0%</td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Top 5 OSR Gap Analysis -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">
                                        <i class="fas fa-star me-2 text-warning"></i>
                                        Top 5 OSR Gap Analysis
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-hover">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Revenue Source</th>
                                                    <th class="text-end">Current Revenue</th>
                                                    <th class="text-end">Potential Revenue</th>
                                                    <th class="text-end">Gap</th>
                                                    <th class="text-end">% of Gap</th>
                                                </tr>
                                            </thead>
                                            <tbody id="top5OsrTable">
                                                <!-- This will be populated dynamically -->
                                            </tbody>
                                            <tfoot class="table-light">
                                                <tr class="fw-bold">
                                                    <td>Total</td>
                                                    <td id="top5CurrentTotal" class="text-end">0</td>
                                                    <td id="top5PotentialTotal" class="text-end">0</td>
                                                    <td id="top5GapTotal" class="text-end">0</td>
                                                    <td class="text-end">100%</td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Detailed Gap Breakdown by Revenue Type -->
                    <div class="card mb-4">
                        <div class="card-header bg-light">
                            <h6 class="mb-0 d-flex align-items-center">
                                <i class="fas fa-chart-bar me-2 text-primary"></i>
                                Detailed Gap Breakdown by Revenue Type
                            </h6>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-bordered table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Revenue Source</th>
                                            <th>Registration Gap</th>
                                            <th>Compliance Gap</th>
                                            <th>Assessment Gap</th>
                                            <th>Rate Gap</th>
                                            <th>Combined Gap</th>
                                            <th>Total Gap</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr id="property-tax-row">
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="icon-circle bg-blue me-2">
                                                        <i class="fas fa-building text-white"></i>
                                                    </div>
                                                    <span>Property Tax</span>
                                                </div>
                                            </td>
                                            <td class="property-registration-gap">$0.00</td>
                                            <td class="property-compliance-gap">$0.00</td>
                                            <td class="property-assessment-gap">$0.00</td>
                                            <td class="property-rate-gap">$0.00</td>
                                            <td class="property-combined-gap">$0.00</td>
                                            <td class="property-gap">-</td>
                                        </tr>
                                        <tr id="license-row">
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="icon-circle bg-teal me-2">
                                                        <i class="fas fa-id-card text-white"></i>
                                                    </div>
                                                    <span>License</span>
                                                </div>
                                            </td>
                                            <td class="license-registration-gap">$0.00</td>
                                            <td class="license-compliance-gap">$0.00</td>
                                            <td class="license-assessment-gap">$0.00</td>
                                            <td class="license-rate-gap">$0.00</td>
                                            <td class="license-combined-gap">$0.00</td>
                                            <td class="license-gap">-</td>
                                        </tr>
                                        <tr id="short-term-row">
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="icon-circle bg-cyan me-2">
                                                        <i class="fas fa-clock text-white"></i>
                                                    </div>
                                                    <span>Short Term</span>
                                                </div>
                                            </td>
                                            <td class="short-registration-gap">$0.00</td>
                                            <td class="short-compliance-gap">$0.00</td>
                                            <td class="short-assessment-gap">$0.00</td>
                                            <td class="short-rate-gap">$0.00</td>
                                            <td class="short-combined-gap">$0.00</td>
                                            <td class="short-gap">-</td>
                                        </tr>
                                        <tr id="long-term-row">
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="icon-circle bg-amber me-2">
                                                        <i class="fas fa-calendar-alt text-white"></i>
                                                    </div>
                                                    <span>Long Term</span>
                                                </div>
                                            </td>
                                            <td class="long-registration-gap">$0.00</td>
                                            <td class="long-compliance-gap">$0.00</td>
                                            <td class="long-assessment-gap">$0.00</td>
                                            <td class="long-rate-gap">$0.00</td>
                                            <td class="long-combined-gap">$0.00</td>
                                            <td class="long-gap">-</td>
                                        </tr>
                                        <tr id="mixed-row">
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="icon-circle bg-pink me-2">
                                                        <i class="fas fa-chart-pie text-white"></i>
                                                    </div>
                                                    <span>Mixed</span>
                                                </div>
                                            </td>
                                            <td class="mixed-registration-gap">-</td>
                                            <td class="mixed-compliance-gap">-</td>
                                            <td class="mixed-assessment-gap">-</td>
                                            <td class="mixed-rate-gap">-</td>
                                            <td class="mixed-combined-gap">-</td>
                                            <td class="mixed-gap">-</td>
                                        </tr>
                                    </tbody>
                                    <tfoot class="table-secondary">
                                        <tr id="total-row">
                                            <td class="fw-bold">Total</td>
                                            <td id="total-registration-gap">0</td>
                                            <td id="total-compliance-gap">0</td>
                                            <td id="total-assessment-gap">0</td>
                                            <td id="total-rate-gap">0</td>
                                            <td id="total-combined-gap">0</td>
                                            <td id="potential-gap-total">0</td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>
                    
                    <!-- New Simpler Gap Chart -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">
                                        <i class="fas fa-chart-bar me-2 text-danger"></i>
                                        Total Gap by Revenue Source
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <div class="chart-container" style="position: relative; height: 400px;">
                                        <canvas id="totalGapChart"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- New Stacked Bar Graph for Gap Types -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">
                                        <i class="fas fa-chart-bar me-2 text-primary"></i>
                                        Gap Analysis Visualization
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <div class="chart-container" style="position: relative; height: 400px;">
                                        <canvas id="gapBreakdownChart"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Additional metrics -->
                    <div class="row g-3 mb-4">
                        <!-- Average Gap Across Top 5 OSRs - Moved to top for prominence -->
                        <div class="col-md-12 mb-3">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">
                                        <i class="fas fa-chart-pie me-2 text-primary"></i>
                                        Average Gap Analysis
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div id="averageGapIndicator" class="rounded-circle me-4 d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; background-color: #f8f9fa; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
                                            <span id="averageGapValue" class="fs-3 fw-bold text-white">0%</span>
                                        </div>
                                        <div>
