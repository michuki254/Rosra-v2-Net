        // Function to find and highlight the largest gap
        function highlightLargestGap(propertyTaxGap, licenseGap, shortTermGap, longTermGap, mixedGap) {
            // Reset previous highlights
            document.querySelectorAll('.largest-gap-indicator').forEach(indicator => {
