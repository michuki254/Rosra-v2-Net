@model RosraApp.Models.ViewModels.RosraFormViewModel
@{
    bool isViewMode = ViewData["ViewMode"] != null && (bool)ViewData["ViewMode"];
    string currencySymbol = string.IsNullOrEmpty(Model.CurrencySymbol) ? "$" : Model.CurrencySymbol;
}

<!-- Include Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@3.7.1/dist/chart.min.js"></script>

<div class="business-license-gap-analysis">
    <div class="row">
        <!-- Left Column - Data Input Section -->
        <div class="col-lg-4">
            <!-- Required Data + Derived Metrics -->
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0"><i class="bi bi-input-cursor-text me-2"></i>Entry of required information + Processed Metrics</h6>
                </div>
                <div class="card-body">
                    <p class="small text-muted mb-3">For proper execution of the analysis, you are required to complete only the cells shaded in gray and in bold.</p>

                    <!-- User Input Fields (6 inputs) -->
                    <div class="mb-3">
                        <label for="blRegisteredBusinesses" class="form-label fw-bold">
                            Registered Businesses
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="How many businesses are currently on the municipal register for this revenue stream."></i>
                        </label>
                        <input type="text" class="form-control number-format bg-light fw-bold" id="blRegisteredBusinesses"
                               name="License.RegisteredBusinesses" value="@(Model.License.RegisteredBusinesses?.ToString("N0") ?? "451")"
                               placeholder="Enter value" @(isViewMode ? "readonly" : "") data-input="true">
                    </div>

                    <div class="mb-3">
                        <label for="blEstimatedUnregisteredPercent" class="form-label fw-bold">
                            Estimated % Unregistered Businesses
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Best estimate of how many active businesses are not on the register."></i>
                        </label>
                        <div class="input-group">
                            <input type="number" class="form-control bg-light fw-bold" id="blEstimatedUnregisteredPercent"
                                   name="License.EstimatedUnregisteredPercent" value="@(Model.License.EstimatedUnregisteredPercent ?? 3)"
                                   placeholder="Enter %" min="0" max="100" step="0.1" @(isViewMode ? "readonly" : "") data-input="true">
                            <span class="input-group-text">%</span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="blTotalEstimatedBusinesses" class="form-label text-primary">
                            Total Estimated Businesses
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Total estimated active businesses in the jurisdiction. Formula: Registered × (1 + Unregistered %)"></i>
                        </label>
                        <input type="text" class="form-control number-format" id="blTotalEstimatedBusinesses"
                               readonly value="0" style="background-color: #e8f4fc;">
                        <small class="text-muted">= Registered × (1 + Unregistered %)</small>
                    </div>

                    <div class="mb-3">
                        <label for="blBilledAmount" class="form-label fw-bold">
                            Billed Amount (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Total value of invoices/assessments issued to registered businesses during the year."></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format bg-light fw-bold" id="blBilledAmount"
                                   name="License.BilledAmount" value="@(Model.License.BilledAmount?.ToString("N0") ?? "233,073,733")"
                                   placeholder="Enter value" @(isViewMode ? "readonly" : "") data-input="true">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="blOutstandingAmount" class="form-label fw-bold">
                            Outstanding Amount (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Total billed but not yet paid (arrears on the current year bill). Also equals the pure compliance gap at current fees."></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format bg-light fw-bold" id="blOutstandingAmount"
                                   name="License.OutstandingAmount" value="@(Model.License.OutstandingAmount?.ToString("N0") ?? "55,623,018")"
                                   placeholder="Enter value" @(isViewMode ? "readonly" : "") data-input="true">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="blRevenueToDate" class="form-label text-primary">
                            Revenue to Date (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="What has actually been collected in cash so far in the year. Formula: Billed - Outstanding."></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format" id="blRevenueToDate"
                                   name="License.RevenueToDate" value="@Model.License.RevenueToDate"
                                   readonly style="background-color: #e8f4fc;">
                        </div>
                        <small class="text-muted">= Billed Amount - Outstanding Amount</small>
                    </div>

                    <div class="mb-3">
                        <label for="blCompliantBusinesses" class="form-label text-primary">
                            Compliant Businesses
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Estimated using proxy formula: Registered × (Revenue to Date / Billed). Accounts for partial payments across fiscal year."></i>
                        </label>
                        <input type="text" class="form-control number-format" id="blCompliantBusinesses"
                               name="License.CompliantBusinesses" value="@Model.License.CompliantBusinesses"
                               readonly style="background-color: #e8f4fc;">
                        <small class="text-muted">= Registered × (Revenue to Date / Billed Amount)</small>
                    </div>

                    <div class="mb-3">
                        <label for="blStatutoryAverageBilled" class="form-label fw-bold">
                            Statutory Average Billed Amount (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="The average annual bill implied by the official fee schedule as written in law, without applying waivers, discounts, or exemptions. It represents the policy reference level."></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format bg-light fw-bold" id="blStatutoryAverageBilled"
                                   name="License.StatutoryAverageBilled" value="@(Model.License.StatutoryAverageBilled?.ToString("N0") ?? "680,500")"
                                   placeholder="Enter value" @(isViewMode ? "readonly" : "") data-input="true">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="blRealisticImprovementPercent" class="form-label fw-bold">
                            Realistic Improvement %
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="The share of the gap between today's average bill and the statutory average that you believe can realistically be closed through policy or administrative reforms (not full enforcement). Input as % (0-100)."></i>
                        </label>
                        <div class="input-group">
                            <input type="number" class="form-control bg-light fw-bold" id="blRealisticImprovementPercent"
                                   name="License.RealisticImprovementPercent" value="@(Model.License.RealisticImprovementPercent ?? 15)"
                                   placeholder="Enter %" min="0" max="100" step="1" @(isViewMode ? "readonly" : "") data-input="true">
                            <span class="input-group-text">%</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Useful Average Values -->
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0"><i class="bi bi-calculator me-2"></i>Useful Average Values for Analysis</h6>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <label class="form-label small text-primary">
                            Average Billed Amount
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="The mean annual bill actually issued to each registered business under today's billing practice. It's the anchor for the 'today' side of the matrix. Formula: Billed amount ÷ Registered businesses."></i>
                        </label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control" id="blAvgBilledAmount" readonly style="background-color: #e8f4fc;">
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small text-primary">
                            Achievable Average Bill (Potential)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="The projected average bill after applying the realistic improvement toward the statutory level. Powers the right-hand 'liability' column of the matrix. Formula: Avg Billed + (Realistic improvement % × (Statutory Avg - Avg Billed))."></i>
                        </label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control" id="blAchievableAvgBill" readonly style="background-color: #e8f4fc;">
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small text-primary">
                            ΔA (Delta A - Billing Improvement)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="The achievable increase in billing per business. Formula: Realistic improvement % × MAX(0, Statutory average − Average billed)."></i>
                        </label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control" id="blDeltaA" readonly style="background-color: #e8f4fc;">
                        </div>
                    </div>
                </div>
            </div>

            <!-- KPI Ratios -->
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-warning">
                    <h6 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>Key Performance Indicators (KPI) Ratios</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label small mb-0">
                                Compliance Ratio
                                <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                   title="Provides a proxy indicator of the compliance system performance for this stream. Formula: Revenue to Date / Billed Amount. >80% Green, 60-80% Yellow, <60% Red."></i>
                            </label>
                            <span id="blComplianceRatioValue" class="badge bg-success">0%</span>
                        </div>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar" role="progressbar" id="blComplianceRatioBar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <small class="text-muted">Revenue to Date / Billed Amount</small>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label small mb-0">
                                Coverage Ratio
                                <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                   title="Provides a proxy indicator of the coverage system performance for this stream. Formula: Registered / Total Estimated businesses. >80% Green, 60-80% Yellow, <60% Red."></i>
                            </label>
                            <span id="blCoverageRatioValue" class="badge bg-info">0%</span>
                        </div>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar" role="progressbar" id="blCoverageRatioBar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <small class="text-muted">Registered Businesses / Total Estimated Businesses</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column - Results Section -->
        <div class="col-lg-8">
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-success text-white">
                    <h6 class="mb-0"><i class="bi bi-graph-up me-2"></i>Graphical Representation of Analyzed Data</h6>
                </div>
                <div class="card-body">
                    <!-- Potential Revenue Breakdown Table -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">Potential Revenue Breakdown (Actual Revenue + Gap breakdown)</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Revenue & Functional Gaps</th>
                                        <th class="text-end">Amount (<span class="currency-label">@currencySymbol</span>)</th>
                                        <th class="text-end">Share (%)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="table-success">
                                        <td>
                                            Revenue to date
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="This is the cash actually collected so far in the year from registered businesses. It is the 'actual revenue' slice in the chart and the bottom-left cell of the matrix."></i>
                                        </td>
                                        <td class="text-end" id="blTableRevenueToDate">0</td>
                                        <td class="text-end" id="blTableRevenueToDatePct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Compliance Gap
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="The amount already billed to registered businesses that remains unpaid (arrears for the year). Captures non-payment among those on the register at today's billing level. Formula: Outstanding amount."></i>
                                        </td>
                                        <td class="text-end" id="blTableComplianceGap">0</td>
                                        <td class="text-end" id="blTableComplianceGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Coverage Gap
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="Revenue not collected because some active businesses are not registered and therefore were not billed at all—valued at today's average bill. Formula: (Total estimated - Registered) × Average billed amount."></i>
                                        </td>
                                        <td class="text-end" id="blTableCoverageGap">0</td>
                                        <td class="text-end" id="blTableCoverageGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Liability Gap
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="Additional revenue you could obtain from businesses that already pay if billing were improved part-way toward the statutory level (realistic improvement). Formula: Compliant businesses × ΔA."></i>
                                        </td>
                                        <td class="text-end" id="blTableLiabilityGap">0</td>
                                        <td class="text-end" id="blTableLiabilityGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Mixed Gap (Compliance + Liability)
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="Extra revenue that would appear only if both (i) non-payers among the registered start paying AND (ii) billing is raised by the realistic improvement toward the statutory average. Formula: (Registered - Compliant) × ΔA."></i>
                                        </td>
                                        <td class="text-end" id="blTableMixedGapCompliance">0</td>
                                        <td class="text-end" id="blTableMixedGapCompliancePct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Mixed Gap (Coverage + Liability)
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="Extra revenue that would appear only if both (i) unregistered businesses are brought onto the register AND (ii) billing is raised by the realistic improvement toward the statutory average. Formula: (Total estimated - Registered) × ΔA."></i>
                                        </td>
                                        <td class="text-end" id="blTableMixedGapCoverage">0</td>
                                        <td class="text-end" id="blTableMixedGapCoveragePct">0%</td>
                                    </tr>
                                    <tr class="table-secondary fw-bold">
                                        <td>TOTAL (Potential Revenue)</td>
                                        <td class="text-end" id="blTableTotalPotential">0</td>
                                        <td class="text-end">100%</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Revenue and Functional Gaps Pie Chart -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">Potential Revenue (Actual Revenue + Gap breakdown)</h6>
                        <div class="d-flex justify-content-center">
                            <div style="height: 300px; width: 450px; position: relative;">
                                <canvas id="blPotentialRevenueChart"></canvas>
                            </div>
                        </div>
                        <p class="small text-muted mt-2 text-center">
                            <strong>DESCRIPTION:</strong> This pie chart illustrates the percentage distribution of the total potential revenue from the billing system. It visually shows the share corresponding to the revenue actually collected during the year, as well as the contribution of each type of gap (uncollected or lost revenue) to that total.
                        </p>
                    </div>

                    <hr>

                    <!-- Matrix Gap Analysis Dashboard -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">Business License Gap Analysis - Dashboard</h6>
                        <div class="row g-3 align-items-stretch">
                            <!-- Matrix Visualization -->
                            <div class="col-12">
                                <div class="matrix-container position-relative" style="height: 320px; min-height: 320px; border-radius: 8px; overflow: hidden; background: #fff;">
                                    <!-- Y-axis Title (rotated) -->
                                    <div class="position-absolute d-flex align-items-center justify-content-center" style="left: 0; top: 0; bottom: 30px; width: 20px; background: #f8f9fa;">
                                        <span style="transform: rotate(-90deg); white-space: nowrap; font-size: 0.6rem; color: #666;"># of Businesses</span>
                                    </div>

                                    <!-- Y-axis Labels Container - labels positioned at row BOUNDARIES -->
                                    <div class="matrix-y-labels position-absolute" id="blMatrixYLabelsContainer" style="left: 20px; top: 0; bottom: 30px; width: 55px; font-size: 0.6rem; background: #f8f9fa;">
                                        <!-- Estimated label at TOP boundary (top of matrix) -->
                                        <div class="y-label-item" id="blYLabelEstimated" style="position: absolute; right: 3px; top: 0; text-align: right; transform: translateY(-50%);">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">Estimated</small>
                                            <span id="blMatrixEstimatedLabel" class="fw-bold" style="font-size: 0.65rem;">0</span>
                                        </div>
                                        <!-- Registered label at boundary between Row1 and Row2 -->
                                        <div class="y-label-item" id="blYLabelRegistered" style="position: absolute; right: 3px; text-align: right; transform: translateY(-50%);">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">Registered</small>
                                            <span id="blMatrixRegisteredLabel" class="fw-bold" style="font-size: 0.65rem;">0</span>
                                        </div>
                                        <!-- Compliant label at boundary between Row2 and Row3 -->
                                        <div class="y-label-item" id="blYLabelCompliant" style="position: absolute; right: 3px; text-align: right; transform: translateY(-50%);">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">Compliant</small>
                                            <span id="blMatrixCompliantLabel" class="fw-bold" style="font-size: 0.65rem;">0</span>
                                        </div>
                                    </div>

                                    <!-- Matrix Grid Area -->
                                    <div class="matrix-grid position-absolute" id="blMatrixGridArea" style="left: 75px; top: 0; right: 0; bottom: 30px; display: flex; flex-direction: column;">
                                        <!-- Row 1: Unregistered (Estimated - Registered) -->
                                        <div class="matrix-row d-flex" id="blMatrixRowUnreg" style="flex: 1; min-height: 30px;">
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="blMatrixCoverageGap"
                                                 style="background-color: #FF9800; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">Coverage Gap</small><br>
                                                    <span id="blMatrixCoverageGapVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="blMatrixMixedCoverage"
                                                 style="background-color: #E91E63; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">Mixed (Cov.+Liab.)</small><br>
                                                    <span id="blMatrixMixedCoverageVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- Row 2: Non-Compliant Registered (Registered - Compliant) -->
                                        <div class="matrix-row d-flex" id="blMatrixRowNonCompliant" style="flex: 1; min-height: 30px;">
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="blMatrixComplianceGap"
                                                 style="background-color: #F44336; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">Compliance Gap</small><br>
                                                    <span id="blMatrixComplianceGapVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="blMatrixMixedCompliance"
                                                 style="background-color: #9C27B0; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">Mixed (Comp.+Liab.)</small><br>
                                                    <span id="blMatrixMixedComplianceVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- Row 3: Compliant -->
                                        <div class="matrix-row d-flex" id="blMatrixRowCompliant" style="flex: 1; min-height: 30px;">
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="blMatrixActualRevenue"
                                                 style="background-color: #4CAF50; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">Actual Revenue</small><br>
                                                    <span id="blMatrixActualRevenueVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="blMatrixLiabilityGap"
                                                 style="background-color: #2196F3; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">Liability Gap</small><br>
                                                    <span id="blMatrixLiabilityGapVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- X-axis Labels - positioned at column BOUNDARIES -->
                                    <div class="matrix-x-axis position-absolute" id="blMatrixXAxisContainer" style="left: 75px; right: 0; bottom: 0; height: 30px; background: #f8f9fa;">
                                        <!-- X-axis label at left edge (origin = 0) -->
                                        <div class="x-label-item" id="blXLabelOrigin" style="position: absolute; left: 0; bottom: 2px; transform: translateX(0%); text-align: left; font-size: 0.6rem;">
                                            <span id="blMatrixOriginLabel" class="fw-bold" style="font-size: 0.65rem;">@currencySymbol 0</span>
                                        </div>
                                        <!-- X-axis label at column boundary (between left and right columns) -->
                                        <div class="x-label-item" id="blXLabelAvgBilled" style="position: absolute; bottom: 2px; transform: translateX(-50%); text-align: center; font-size: 0.6rem;">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">Avg. Billed</small>
                                            <span id="blMatrixAvgBilledLabel" class="fw-bold" style="font-size: 0.65rem;">@currencySymbol 0</span>
                                        </div>
                                        <!-- X-axis label at right edge -->
                                        <div class="x-label-item" id="blXLabelAchievable" style="position: absolute; right: 0; bottom: 2px; transform: translateX(0%); text-align: right; font-size: 0.6rem;">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">Achievable Avg.</small>
                                            <span id="blMatrixAchievableLabel" class="fw-bold" style="font-size: 0.65rem;">@currencySymbol 0</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div><!-- end row -->
                        <p class="small text-muted mt-3 text-center">
                            <strong>DESCRIPTION:</strong> This matrix visualization shows the business license gap analysis across two dimensions: the number of businesses (vertical axis from Compliant to Estimated) and the billing level (horizontal axis from average billed to achievable billing). Each colored cell represents a different type of gap or revenue component.
                        </p>
                    </div>

                    <hr>

                    <!-- Gap Breakdown Table -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">Gap Breakdown (<span class="currency-label">@currencySymbol</span>)</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Functional Gaps</th>
                                        <th class="text-end">Amount (<span class="currency-label">@currencySymbol</span>)</th>
                                        <th class="text-end">Share (%)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            Compliance Gap
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="The amount already billed to registered businesses that remains unpaid (arrears for the year). Captures non-payment among those on the register at today's billing level."></i>
                                        </td>
                                        <td class="text-end" id="blGapComplianceGap">0</td>
                                        <td class="text-end" id="blGapComplianceGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Coverage Gap
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="Revenue not collected because some active businesses are not registered and therefore were not billed at all—valued at today's average bill."></i>
                                        </td>
                                        <td class="text-end" id="blGapCoverageGap">0</td>
                                        <td class="text-end" id="blGapCoverageGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Liability Gap
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="Additional revenue you could obtain from businesses that already pay if billing were improved part-way toward the statutory level (realistic improvement)."></i>
                                        </td>
                                        <td class="text-end" id="blGapLiabilityGap">0</td>
                                        <td class="text-end" id="blGapLiabilityGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Mixed Gap (Compliance + Liability)
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="Extra revenue that would appear only if both (i) non-payers among the registered start paying AND (ii) billing is raised by the realistic improvement toward the statutory average."></i>
                                        </td>
                                        <td class="text-end" id="blGapMixedGapCompliance">0</td>
                                        <td class="text-end" id="blGapMixedGapCompliancePct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Mixed Gap (Coverage + Liability)
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="Extra revenue that would appear only if both (i) unregistered businesses are brought onto the register AND (ii) billing is raised by the realistic improvement toward the statutory average."></i>
                                        </td>
                                        <td class="text-end" id="blGapMixedGapCoverage">0</td>
                                        <td class="text-end" id="blGapMixedGapCoveragePct">0%</td>
                                    </tr>
                                    <tr class="table-secondary fw-bold">
                                        <td>Total Functional Gap</td>
                                        <td class="text-end" id="blTableTotalFunctionalGap">0</td>
                                        <td class="text-end">100%</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Gap Breakdown Pie Chart -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">Gap Breakdown</h6>
                        <div class="d-flex justify-content-center">
                            <div style="height: 300px; width: 450px; position: relative;">
                                <canvas id="blGapBreakdownChart"></canvas>
                            </div>
                        </div>
                        <p class="small text-muted mt-2 text-center">
                            <strong>DESCRIPTION:</strong> This pie chart illustrates the percentage distribution of the revenue gaps. It visually shows the contribution of each type of gap to the total uncollected revenue, helping to identify which gaps are the most significant.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
