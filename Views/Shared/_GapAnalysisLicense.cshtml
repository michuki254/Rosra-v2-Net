@model RosraApp.Models.ViewModels.RosraFormViewModel
@{
    bool isViewMode = ViewData["ViewMode"] != null && (bool)ViewData["ViewMode"];
    string currencySymbol = string.IsNullOrEmpty(Model.CurrencySymbol) ? "$" : Model.CurrencySymbol;
}

<!-- Include Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@3.7.1/dist/chart.min.js"></script>

<div class="business-license-gap-analysis" id="license-container" data-subgroup="@(Model.License.Subgroup ?? "")" data-subtype="@(Model.License.Subtype ?? "")">
    <!-- Stream classification hidden fields -->
    <input type="hidden" name="License.Subgroup" id="licenseSubgroup" value="@(Model.License.Subgroup ?? "")" />
    <input type="hidden" name="License.Subtype" id="licenseSubtype" value="@(Model.License.Subtype ?? "")" />

    <!-- Classification Header -->
    @if (!isViewMode)
    {
        <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-file-earmark-text fs-4 text-primary"></i>
                <span class="fw-bold fs-5" id="licenseHeaderName">@Model.BusinessLicenseDisplayName</span>
                @if (!string.IsNullOrEmpty(Model.License.Subgroup))
                {
                    var badgeColor = Model.License.Subgroup switch { "A" => "#2196F3", "B" => "#FF9800", "C" => "#4CAF50", _ => "#666" };
                    var badgeText = Model.License.Subgroup switch { "A" => "Business Licences & Permits", "B" => "Service Fees & Billed Charges", "C" => "Daily / Point-of-Collection", _ => "Unclassified" };
                    <span class="badge ms-2" style="background-color: @badgeColor; font-size: 0.75rem;" id="licenseSubgroupBadge">@badgeText</span>
                }
                else
                {
                    <span class="badge ms-2 bg-secondary" style="font-size: 0.75rem;" id="licenseSubgroupBadge">Not classified</span>
                }
            </div>
            <button type="button" class="btn btn-outline-primary btn-sm"
                    onclick="openEditLicenseMetaModal()" title="Edit stream classification">
                <i class="bi bi-pencil-square"></i> Edit Classification
            </button>
        </div>
    }

    <div class="row">
        <!-- Left Column - Data Input Section -->
        <div class="col-lg-4">
            <!-- Required Data + Derived Metrics -->
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0"><i class="bi bi-input-cursor-text me-2"></i>@Localizer["DataEntry_Title"]</h6>
                </div>
                <div class="card-body">
                    <p class="small text-muted mb-3">@Localizer["DataEntry_Instructions"]</p>

                    <!-- User Input Fields (6 inputs) -->
                    <div class="mb-3">
                        <label for="blRegisteredBusinesses" class="form-label fw-bold">
                            @Localizer["RegisteredBusinesses"]
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["RegisteredBusinesses_Tooltip"]"></i>
                        </label>
                        <input type="text" class="form-control number-format bg-light fw-bold" id="blRegisteredBusinesses"
                               name="License.RegisteredBusinesses" value="@(Model.License.RegisteredBusinesses?.ToString("N0") ?? "")"
                               placeholder="@Localizer["EnterValue"]" @(isViewMode ? "readonly" : "") data-input="true">
                    </div>

                    <div class="mb-3">
                        <label for="blEstimatedUnregisteredPercent" class="form-label fw-bold">
                            @Localizer["EstimatedUnregisteredPercent"]
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["EstimatedUnregisteredPercent_Tooltip"]"></i>
                        </label>
                        <div class="input-group">
                            <input type="number" class="form-control bg-light fw-bold" id="blEstimatedUnregisteredPercent"
                                   name="License.EstimatedUnregisteredPercent" value="@(Model.License.EstimatedUnregisteredPercent ?? 3)"
                                   placeholder="@Localizer["EnterPercent"]" min="0" max="100" step="0.1" @(isViewMode ? "readonly" : "") data-input="true">
                            <span class="input-group-text">%</span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="blTotalEstimatedBusinesses" class="form-label text-primary">
                            @Localizer["TotalEstimatedBusinesses"]
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["TotalEstimatedBusinesses_Tooltip"]"></i>
                        </label>
                        <input type="text" class="form-control number-format" id="blTotalEstimatedBusinesses"
                               readonly value="0" style="background-color: #e8f4fc;">
                        <small class="text-muted">@Localizer["TotalEstimatedBusinesses_Formula"]</small>
                    </div>

                    <div class="mb-3">
                        <label for="blBilledAmount" class="form-label fw-bold">
                            @Localizer["BilledAmount"] (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["BilledAmount_Tooltip"]"></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format bg-light fw-bold" id="blBilledAmount"
                                   name="License.BilledAmount" value="@(Model.License.BilledAmount?.ToString("N0") ?? "")"
                                   placeholder="@Localizer["EnterValue"]" @(isViewMode ? "readonly" : "") data-input="true">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="blOutstandingAmount" class="form-label fw-bold">
                            @Localizer["OutstandingAmount"] (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["OutstandingAmount_Tooltip"]"></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format bg-light fw-bold" id="blOutstandingAmount"
                                   name="License.OutstandingAmount" value="@(Model.License.OutstandingAmount?.ToString("N0") ?? "")"
                                   placeholder="@Localizer["EnterValue"]" @(isViewMode ? "readonly" : "") data-input="true">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="blRevenueToDate" class="form-label text-primary">
                            @Localizer["RevenueToDate"] (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["RevenueToDate_Tooltip"]"></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format" id="blRevenueToDate"
                                   name="License.RevenueToDate" value="@Model.License.RevenueToDate"
                                   readonly style="background-color: #e8f4fc;">
                        </div>
                        <small class="text-muted">@Localizer["RevenueToDate_Formula"]</small>
                    </div>

                    <div class="mb-3">
                        <label for="blCompliantBusinesses" class="form-label text-primary">
                            @Localizer["CompliantBusinesses"]
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["CompliantBusinesses_Tooltip"]"></i>
                        </label>
                        <input type="text" class="form-control number-format" id="blCompliantBusinesses"
                               name="License.CompliantBusinesses" value="@Model.License.CompliantBusinesses"
                               readonly style="background-color: #e8f4fc;">
                        <small class="text-muted">@Localizer["CompliantBusinesses_Formula"]</small>
                    </div>

                    <div class="mb-3">
                        <label for="blStatutoryAverageBilled" class="form-label fw-bold">
                            @Localizer["StatutoryAverageBilled"] (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["StatutoryAverageBilled_Tooltip"]"></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format bg-light fw-bold" id="blStatutoryAverageBilled"
                                   name="License.StatutoryAverageBilled" value="@(Model.License.StatutoryAverageBilled?.ToString("N0") ?? "")"
                                   placeholder="@Localizer["EnterValue"]" @(isViewMode ? "readonly" : "") data-input="true">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="blRealisticImprovementPercent" class="form-label fw-bold">
                            @Localizer["RealisticImprovementPercent"]
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["RealisticImprovementPercent_Tooltip"]"></i>
                        </label>
                        <div class="input-group">
                            <input type="number" class="form-control bg-light fw-bold" id="blRealisticImprovementPercent"
                                   name="License.RealisticImprovementPercent" value="@(Model.License.RealisticImprovementPercent ?? 15)"
                                   placeholder="@Localizer["EnterPercent"]" min="0" max="100" step="1" @(isViewMode ? "readonly" : "") data-input="true">
                            <span class="input-group-text">%</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Useful Average Values -->
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0"><i class="bi bi-calculator me-2"></i>@Localizer["AvgValues_Title"]</h6>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <label class="form-label small text-primary">
                            @Localizer["AvgBilledAmount"]
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["AvgBilledAmount_Tooltip"]"></i>
                        </label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control" id="blAvgBilledAmount" readonly style="background-color: #e8f4fc;">
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small text-primary">
                            @Localizer["AchievableAvgBill"]
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["AchievableAvgBill_Tooltip"]"></i>
                        </label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control" id="blAchievableAvgBill" readonly style="background-color: #e8f4fc;">
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small text-primary">
                            @Localizer["DeltaA"]
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="@Localizer["DeltaA_Tooltip"]"></i>
                        </label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control" id="blDeltaA" readonly style="background-color: #e8f4fc;">
                        </div>
                    </div>
                </div>
            </div>

            <!-- KPI Ratios -->
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-warning">
                    <h6 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>@Localizer["KPI_Title"]</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label small mb-0">
                                @Localizer["ComplianceRatio"]
                                <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                   title="@Localizer["ComplianceRatio_Tooltip"]"></i>
                            </label>
                            <span id="blComplianceRatioValue" class="badge bg-success">0%</span>
                        </div>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar" role="progressbar" id="blComplianceRatioBar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <small class="text-muted">@Localizer["ComplianceRatio_Formula"]</small>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label small mb-0">
                                @Localizer["CoverageRatio"]
                                <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                   title="@Localizer["CoverageRatio_Tooltip"]"></i>
                            </label>
                            <span id="blCoverageRatioValue" class="badge bg-info">0%</span>
                        </div>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar" role="progressbar" id="blCoverageRatioBar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <small class="text-muted">@Localizer["CoverageRatio_Formula"]</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column - Results Section -->
        <div class="col-lg-8">
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-success text-white">
                    <h6 class="mb-0"><i class="bi bi-graph-up me-2"></i>@Localizer["Results_Title"]</h6>
                </div>
                <div class="card-body">
                    <!-- Potential Revenue Breakdown Table -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">@Localizer["PotentialRevenue_Title"]</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>@Localizer["Table_RevenueAndGaps"]</th>
                                        <th class="text-end">@Localizer["Table_Amount"] (<span class="currency-label">@currencySymbol</span>)</th>
                                        <th class="text-end">@Localizer["Table_Share"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="table-success">
                                        <td>
                                            @Localizer["RevenueToDate_Label"]
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="@Localizer["RevenueToDate_TableTooltip"]"></i>
                                        </td>
                                        <td class="text-end" id="blTableRevenueToDate">0</td>
                                        <td class="text-end" id="blTableRevenueToDatePct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            @Localizer["ComplianceGap"]
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="@Localizer["ComplianceGap_Tooltip"]"></i>
                                        </td>
                                        <td class="text-end" id="blTableComplianceGap">0</td>
                                        <td class="text-end" id="blTableComplianceGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            @Localizer["CoverageGap"]
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="@Localizer["CoverageGap_Tooltip"]"></i>
                                        </td>
                                        <td class="text-end" id="blTableCoverageGap">0</td>
                                        <td class="text-end" id="blTableCoverageGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            @Localizer["LiabilityGap"]
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="@Localizer["LiabilityGap_Tooltip"]"></i>
                                        </td>
                                        <td class="text-end" id="blTableLiabilityGap">0</td>
                                        <td class="text-end" id="blTableLiabilityGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            @Localizer["MixedGapComplianceLiability"]
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="@Localizer["MixedGapComplianceLiability_Tooltip"]"></i>
                                        </td>
                                        <td class="text-end" id="blTableMixedGapCompliance">0</td>
                                        <td class="text-end" id="blTableMixedGapCompliancePct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            @Localizer["MixedGapCoverageLiability"]
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="@Localizer["MixedGapCoverageLiability_Tooltip"]"></i>
                                        </td>
                                        <td class="text-end" id="blTableMixedGapCoverage">0</td>
                                        <td class="text-end" id="blTableMixedGapCoveragePct">0%</td>
                                    </tr>
                                    <tr class="table-secondary fw-bold">
                                        <td>@Localizer["TotalPotentialRevenue"]</td>
                                        <td class="text-end" id="blTableTotalPotential">0</td>
                                        <td class="text-end">100%</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Revenue and Functional Gaps Pie Chart -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">@Localizer["PotentialRevenuePie_Title"]</h6>
                        <div class="d-flex justify-content-center">
                            <div style="height: 300px; width: 450px; position: relative;">
                                <canvas id="blPotentialRevenueChart"></canvas>
                            </div>
                        </div>
                        <p class="small text-muted mt-2 text-center">
                            <strong>@Localizer["Description_Label"]</strong> @Localizer["PotentialRevenuePie_Description"]
                        </p>
                    </div>

                    <hr>

                    <!-- Matrix Gap Analysis Dashboard -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">@Localizer["MatrixDashboard_Title"]</h6>
                        <div class="row g-3 align-items-stretch">
                            <!-- Matrix Visualization -->
                            <div class="col-12">
                                <div class="matrix-container position-relative" style="height: 320px; min-height: 320px; border-radius: 8px; overflow: visible; background: #fff; margin-top: 15px;">
                                    <!-- Y-axis Title (rotated) -->
                                    <div class="position-absolute d-flex align-items-center justify-content-center" style="left: 0; top: 0; bottom: 30px; width: 20px; background: #f8f9fa;">
                                        <span style="transform: rotate(-90deg); white-space: nowrap; font-size: 0.6rem; color: #666;">@Localizer["Matrix_YAxisTitle"]</span>
                                    </div>

                                    <!-- Y-axis Labels Container - labels positioned at row BOUNDARIES -->
                                    <div class="matrix-y-labels position-absolute" id="blMatrixYLabelsContainer" style="left: 20px; top: 0; bottom: 30px; width: 55px; font-size: 0.6rem; background: #f8f9fa;">
                                        <!-- Estimated label at TOP boundary (top of matrix) -->
                                        <div class="y-label-item" id="blYLabelEstimated" style="position: absolute; right: 3px; top: 0; text-align: right; transform: translateY(-50%);">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">@Localizer["Matrix_Estimated"]</small>
                                            <span id="blMatrixEstimatedLabel" class="fw-bold" style="font-size: 0.65rem;">0</span>
                                        </div>
                                        <!-- Registered label at boundary between Row1 and Row2 -->
                                        <div class="y-label-item" id="blYLabelRegistered" style="position: absolute; right: 3px; text-align: right; transform: translateY(-50%);">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">@Localizer["Matrix_Registered"]</small>
                                            <span id="blMatrixRegisteredLabel" class="fw-bold" style="font-size: 0.65rem;">0</span>
                                        </div>
                                        <!-- Compliant label at boundary between Row2 and Row3 -->
                                        <div class="y-label-item" id="blYLabelCompliant" style="position: absolute; right: 3px; text-align: right; transform: translateY(-50%);">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">@Localizer["Matrix_Compliant"]</small>
                                            <span id="blMatrixCompliantLabel" class="fw-bold" style="font-size: 0.65rem;">0</span>
                                        </div>
                                    </div>

                                    <!-- Matrix Grid Area -->
                                    <div class="matrix-grid position-absolute" id="blMatrixGridArea" style="left: 75px; top: 0; right: 0; bottom: 30px; display: flex; flex-direction: column;">
                                        <!-- Row 1: Unregistered (Estimated - Registered) -->
                                        <div class="matrix-row d-flex" id="blMatrixRowUnreg" style="flex: 1; min-height: 30px;">
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="blMatrixCoverageGap"
                                                 style="background-color: #FF9800; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">@Localizer["Matrix_CoverageGap"]</small><br>
                                                    <span id="blMatrixCoverageGapVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="blMatrixMixedCoverage"
                                                 style="background-color: #E91E63; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">@Localizer["Matrix_MixedCovLiab"]</small><br>
                                                    <span id="blMatrixMixedCoverageVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- Row 2: Non-Compliant Registered (Registered - Compliant) -->
                                        <div class="matrix-row d-flex" id="blMatrixRowNonCompliant" style="flex: 1; min-height: 30px;">
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="blMatrixComplianceGap"
                                                 style="background-color: #F44336; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">@Localizer["Matrix_ComplianceGap"]</small><br>
                                                    <span id="blMatrixComplianceGapVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="blMatrixMixedCompliance"
                                                 style="background-color: #9C27B0; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">@Localizer["Matrix_MixedCompLiab"]</small><br>
                                                    <span id="blMatrixMixedComplianceVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- Row 3: Compliant -->
                                        <div class="matrix-row d-flex" id="blMatrixRowCompliant" style="flex: 1; min-height: 30px;">
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="blMatrixActualRevenue"
                                                 style="background-color: #4CAF50; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">@Localizer["Matrix_ActualRevenue"]</small><br>
                                                    <span id="blMatrixActualRevenueVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="blMatrixLiabilityGap"
                                                 style="background-color: #2196F3; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">@Localizer["Matrix_LiabilityGap"]</small><br>
                                                    <span id="blMatrixLiabilityGapVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- X-axis Labels - positioned at column BOUNDARIES -->
                                    <div class="matrix-x-axis position-absolute" id="blMatrixXAxisContainer" style="left: 75px; right: 0; bottom: 0; height: 30px; background: #f8f9fa;">
                                        <!-- X-axis label at left edge (origin = 0) -->
                                        <div class="x-label-item" id="blXLabelOrigin" style="position: absolute; left: 0; bottom: 2px; transform: translateX(0%); text-align: left; font-size: 0.6rem;">
                                            <span id="blMatrixOriginLabel" class="fw-bold" style="font-size: 0.65rem;">@currencySymbol 0</span>
                                        </div>
                                        <!-- X-axis label at column boundary (between left and right columns) -->
                                        <div class="x-label-item" id="blXLabelAvgBilled" style="position: absolute; bottom: 2px; transform: translateX(-50%); text-align: center; font-size: 0.6rem;">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">@Localizer["Matrix_AvgBilled"]</small>
