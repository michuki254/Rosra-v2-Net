    /* KPI Ratio badges */
    .business-license-gap-analysis .card-body > .mb-3 .badge {
        width: auto;
        height: auto;
        border-radius: 0.25rem;
        padding: 0.35em 0.65em;
        font-size: 0.75em;
    }

    .business-license-gap-analysis .input-group-sm .form-control,
    .business-license-gap-analysis .input-group-sm .input-group-text {
        font-size: 0.8rem;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Chart instances
        let potentialRevenueChart = null;
        let gapBreakdownChart = null;

        // Get currency symbol from AppContext (single source of truth)
        function getCurrencySymbol() {
            if (window.AppContext) {
                return window.AppContext.get('currencySymbol') || '$';
            }
            return '$';
        }

        // Update all currency displays in Business License section
        function updateBusinessLicenseCurrencySymbols() {
            const symbol = getCurrencySymbol();
            console.log('Updating Business License currency symbols to:', symbol);

            // Update input group prefixes
            document.querySelectorAll('.business-license-gap-analysis .currency-prefix-display').forEach(el => {
                el.textContent = symbol;
            });

            // Update labels with currency
            document.querySelectorAll('.business-license-gap-analysis .currency-label').forEach(el => {
                el.textContent = symbol;
            });
        }

        // Subscribe to AppContext currency changes
        if (window.AppContext) {
            window.AppContext.subscribe('currencySymbol', function(newSymbol) {
                console.log('Business License received currency change via AppContext:', newSymbol);
                updateBusinessLicenseCurrencySymbols();
                calculateBusinessLicenseGaps();
            });
        }

        // Initial currency update
        updateBusinessLicenseCurrencySymbols();

        // Delayed updates for when currency is loaded from API
        setTimeout(function() {
            updateBusinessLicenseCurrencySymbols();
        }, 1000);

        setTimeout(function() {
            updateBusinessLicenseCurrencySymbols();
        }, 2000);

        // Initialize Bootstrap tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });

        // Initialize charts
        initializeCharts();

        // Add event listeners to all input fields
        const inputFields = document.querySelectorAll('.business-license-gap-analysis input[data-input="true"]');
        inputFields.forEach(field => {
            field.addEventListener('input', function() {
                calculateBusinessLicenseGaps();
            });
            field.addEventListener('change', function() {
                calculateBusinessLicenseGaps();
            });
        });

        // Initial calculation
        calculateBusinessLicenseGaps();

        function initializeCharts() {
            // Potential Revenue Pie Chart
            const ctx1 = document.getElementById('blPotentialRevenueChart');
            if (ctx1) {
                potentialRevenueChart = new Chart(ctx1.getContext('2d'), {
                    type: 'pie',
                    data: {
                        labels: ['Revenue to date', 'Compliance Gap', 'Coverage Gap', 'Liability Gap', 'Mixed (Comp.+Liab.)', 'Mixed (Cov.+Liab.)'],
                        datasets: [{
                            data: [0, 0, 0, 0, 0, 0],
                            backgroundColor: ['#4CAF50', '#F44336', '#FF9800', '#2196F3', '#9C27B0', '#E91E63'],
                            borderWidth: 2,
                            borderColor: '#ffffff'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'right',
                                labels: {
                                    boxWidth: 12,
                                    font: { size: 10 },
                                    generateLabels: function(chart) {
                                        const data = chart.data;
                                        if (data.labels.length && data.datasets.length) {
                                            const total = data.datasets[0].data.reduce((a, b) => a + b, 0);
                                            return data.labels.map((label, i) => {
                                                const value = data.datasets[0].data[i];
                                                const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                                return {
                                                    text: label + ' (' + percentage + '%)',
                                                    fillStyle: data.datasets[0].backgroundColor[i],
                                                    hidden: false,
                                                    index: i
                                                };
                                            });
                                        }
                                        return [];
                                    }
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const value = context.raw || 0;
                                        const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                        const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                        return context.label + ': ' + formatCurrency(value) + ' (' + percentage + '%)';
                                    }
                                }
                            }
                        }
                    }
                });
            }

            // Gap Breakdown Pie Chart
            const ctx2 = document.getElementById('blGapBreakdownChart');
            if (ctx2) {
                gapBreakdownChart = new Chart(ctx2.getContext('2d'), {
                    type: 'pie',
                    data: {
                        labels: ['Compliance Gap', 'Coverage Gap', 'Liability Gap', 'Mixed (Comp.+Liab.)', 'Mixed (Cov.+Liab.)'],
                        datasets: [{
                            data: [0, 0, 0, 0, 0],
                            backgroundColor: ['#F44336', '#FF9800', '#2196F3', '#9C27B0', '#E91E63'],
                            borderWidth: 2,
                            borderColor: '#ffffff'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'right',
                                labels: {
                                    boxWidth: 12,
                                    font: { size: 10 },
                                    generateLabels: function(chart) {
                                        const data = chart.data;
                                        if (data.labels.length && data.datasets.length) {
                                            const total = data.datasets[0].data.reduce((a, b) => a + b, 0);
                                            return data.labels.map((label, i) => {
                                                const value = data.datasets[0].data[i];
                                                const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                                return {
                                                    text: label + ' (' + percentage + '%)',
                                                    fillStyle: data.datasets[0].backgroundColor[i],
                                                    hidden: false,
                                                    index: i
                                                };
                                            });
                                        }
                                        return [];
                                    }
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const value = context.raw || 0;
                                        const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                        const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                        return context.label + ': ' + formatCurrency(value) + ' (' + percentage + '%)';
                                    }
                                }
                            }
                        }
                    }
                });
            }
        }

        function parseNumber(value) {
            if (!value) return 0;
            const cleaned = String(value).replace(/[^0-9.-]/g, '');
            return parseFloat(cleaned) || 0;
        }

        function formatCurrency(value) {
            if (isNaN(value) || value === null) return '0';
            return new Intl.NumberFormat('en-US', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            }).format(value);
        }

        function formatPercentage(value) {
            if (isNaN(value) || value === null) return '0.00%';
            return value.toFixed(2) + '%';
        }

        // Default values for Business License (from spec)
        const DEFAULTS = {
            registeredBusinesses: 451,
            estimatedUnregisteredPercent: 3,
            billedAmount: 233073733,
            outstandingAmount: 55623018,
            statutoryAverageBilled: 680500,
            realisticImprovementPercent: 15
        };

        function calculateBusinessLicenseGaps() {
            // Get input values (6 user inputs) with defaults
            let registeredBusinesses = parseNumber(document.getElementById('blRegisteredBusinesses')?.value);
            let estimatedUnregisteredPercent = parseFloat(document.getElementById('blEstimatedUnregisteredPercent')?.value);
            let billedAmount = parseNumber(document.getElementById('blBilledAmount')?.value);
            let outstandingAmount = parseNumber(document.getElementById('blOutstandingAmount')?.value);
            let statutoryAverageBilled = parseNumber(document.getElementById('blStatutoryAverageBilled')?.value);
            let realisticImprovementPercent = parseFloat(document.getElementById('blRealisticImprovementPercent')?.value);

            // Apply defaults if values are zero or NaN (first load with empty model)
            if (!registeredBusinesses || registeredBusinesses === 0) {
                registeredBusinesses = DEFAULTS.registeredBusinesses;
                document.getElementById('blRegisteredBusinesses').value = registeredBusinesses.toLocaleString();
            }
            if (isNaN(estimatedUnregisteredPercent) || estimatedUnregisteredPercent === 0) {
                estimatedUnregisteredPercent = DEFAULTS.estimatedUnregisteredPercent;
                document.getElementById('blEstimatedUnregisteredPercent').value = estimatedUnregisteredPercent;
            }
            if (!billedAmount || billedAmount === 0) {
                billedAmount = DEFAULTS.billedAmount;
                document.getElementById('blBilledAmount').value = formatCurrency(billedAmount).replace('.00', '');
            }
            if (!outstandingAmount || outstandingAmount === 0) {
                outstandingAmount = DEFAULTS.outstandingAmount;
                document.getElementById('blOutstandingAmount').value = formatCurrency(outstandingAmount).replace('.00', '');
            }
            if (!statutoryAverageBilled || statutoryAverageBilled === 0) {
                statutoryAverageBilled = DEFAULTS.statutoryAverageBilled;
                document.getElementById('blStatutoryAverageBilled').value = formatCurrency(statutoryAverageBilled).replace('.00', '');
            }
            if (isNaN(realisticImprovementPercent) || realisticImprovementPercent === 0) {
                realisticImprovementPercent = DEFAULTS.realisticImprovementPercent;
                document.getElementById('blRealisticImprovementPercent').value = realisticImprovementPercent;
            }

            // Calculate Auto-Calculated Fields
            const totalEstimatedBusinesses = registeredBusinesses * (1 + estimatedUnregisteredPercent / 100);
            const revenueToDate = billedAmount - outstandingAmount;
            const compliantBusinesses = billedAmount > 0 ? registeredBusinesses * (revenueToDate / billedAmount) : 0;
            const avgBilledAmount = registeredBusinesses > 0 ? billedAmount / registeredBusinesses : 0;

            // ΔA = Realistic improvement % × MAX(0, Statutory average − Average billed)
            const deltaA = (realisticImprovementPercent / 100) * Math.max(0, statutoryAverageBilled - avgBilledAmount);

            // Achievable average bill = Avg Billed + ΔA
            const achievableAvgBill = avgBilledAmount + deltaA;

            // Calculate KPI Ratios
            const complianceRatio = billedAmount > 0 ? (revenueToDate / billedAmount) * 100 : 0;
            const coverageRatio = totalEstimatedBusinesses > 0 ? (registeredBusinesses / totalEstimatedBusinesses) * 100 : 0;

            // Calculate Gaps
            const complianceGap = outstandingAmount;
            const coverageGap = (totalEstimatedBusinesses - registeredBusinesses) * avgBilledAmount;
            const liabilityGap = compliantBusinesses * deltaA;
            const mixedGapCompliance = (registeredBusinesses - compliantBusinesses) * deltaA;
            const mixedGapCoverage = (totalEstimatedBusinesses - registeredBusinesses) * deltaA;

            // Calculate Totals
            const totalPotentialRevenue = revenueToDate + complianceGap + coverageGap + liabilityGap + mixedGapCompliance + mixedGapCoverage;
            const totalFunctionalGap = complianceGap + coverageGap + liabilityGap + mixedGapCompliance + mixedGapCoverage;

            // Calculate percentages for potential revenue
            const revenueToDatePct = totalPotentialRevenue > 0 ? (revenueToDate / totalPotentialRevenue) * 100 : 0;
            const complianceGapPct = totalPotentialRevenue > 0 ? (complianceGap / totalPotentialRevenue) * 100 : 0;
            const coverageGapPct = totalPotentialRevenue > 0 ? (coverageGap / totalPotentialRevenue) * 100 : 0;
            const liabilityGapPct = totalPotentialRevenue > 0 ? (liabilityGap / totalPotentialRevenue) * 100 : 0;
            const mixedGapCompliancePct = totalPotentialRevenue > 0 ? (mixedGapCompliance / totalPotentialRevenue) * 100 : 0;
            const mixedGapCoveragePct = totalPotentialRevenue > 0 ? (mixedGapCoverage / totalPotentialRevenue) * 100 : 0;

            // Calculate percentages for gap breakdown
            const gapComplianceGapPct = totalFunctionalGap > 0 ? (complianceGap / totalFunctionalGap) * 100 : 0;
            const gapCoverageGapPct = totalFunctionalGap > 0 ? (coverageGap / totalFunctionalGap) * 100 : 0;
            const gapLiabilityGapPct = totalFunctionalGap > 0 ? (liabilityGap / totalFunctionalGap) * 100 : 0;
            const gapMixedGapCompliancePct = totalFunctionalGap > 0 ? (mixedGapCompliance / totalFunctionalGap) * 100 : 0;
            const gapMixedGapCoveragePct = totalFunctionalGap > 0 ? (mixedGapCoverage / totalFunctionalGap) * 100 : 0;

            // Update auto-calculated displays
            document.getElementById('blTotalEstimatedBusinesses').value = formatCurrency(totalEstimatedBusinesses).replace('.00', '');
            document.getElementById('blRevenueToDate').value = formatCurrency(revenueToDate);
            document.getElementById('blCompliantBusinesses').value = formatCurrency(compliantBusinesses).replace('.00', '');
            document.getElementById('blAvgBilledAmount').value = formatCurrency(avgBilledAmount);
            document.getElementById('blAchievableAvgBill').value = formatCurrency(achievableAvgBill);
            document.getElementById('blDeltaA').value = formatCurrency(deltaA);

            // Update KPI progress bars
            updateKPIBar('blComplianceRatio', complianceRatio);
            updateKPIBar('blCoverageRatio', coverageRatio);

            // Update Potential Revenue Breakdown Table
            document.getElementById('blTableRevenueToDate').textContent = formatCurrency(revenueToDate);
            document.getElementById('blTableRevenueToDatePct').textContent = formatPercentage(revenueToDatePct);
            document.getElementById('blTableComplianceGap').textContent = formatCurrency(complianceGap);
            document.getElementById('blTableComplianceGapPct').textContent = formatPercentage(complianceGapPct);
            document.getElementById('blTableCoverageGap').textContent = formatCurrency(coverageGap);
            document.getElementById('blTableCoverageGapPct').textContent = formatPercentage(coverageGapPct);
            document.getElementById('blTableLiabilityGap').textContent = formatCurrency(liabilityGap);
            document.getElementById('blTableLiabilityGapPct').textContent = formatPercentage(liabilityGapPct);
            document.getElementById('blTableMixedGapCompliance').textContent = formatCurrency(mixedGapCompliance);
            document.getElementById('blTableMixedGapCompliancePct').textContent = formatPercentage(mixedGapCompliancePct);
            document.getElementById('blTableMixedGapCoverage').textContent = formatCurrency(mixedGapCoverage);
            document.getElementById('blTableMixedGapCoveragePct').textContent = formatPercentage(mixedGapCoveragePct);
            document.getElementById('blTableTotalPotential').textContent = formatCurrency(totalPotentialRevenue);

            // Update Gap Breakdown Table
            document.getElementById('blGapComplianceGap').textContent = formatCurrency(complianceGap);
            document.getElementById('blGapComplianceGapPct').textContent = formatPercentage(gapComplianceGapPct);
            document.getElementById('blGapCoverageGap').textContent = formatCurrency(coverageGap);
            document.getElementById('blGapCoverageGapPct').textContent = formatPercentage(gapCoverageGapPct);
            document.getElementById('blGapLiabilityGap').textContent = formatCurrency(liabilityGap);
            document.getElementById('blGapLiabilityGapPct').textContent = formatPercentage(gapLiabilityGapPct);
            document.getElementById('blGapMixedGapCompliance').textContent = formatCurrency(mixedGapCompliance);
            document.getElementById('blGapMixedGapCompliancePct').textContent = formatPercentage(gapMixedGapCompliancePct);
            document.getElementById('blGapMixedGapCoverage').textContent = formatCurrency(mixedGapCoverage);
            document.getElementById('blGapMixedGapCoveragePct').textContent = formatPercentage(gapMixedGapCoveragePct);
            document.getElementById('blTableTotalFunctionalGap').textContent = formatCurrency(totalFunctionalGap);

            // Update Charts
            updateCharts(revenueToDate, complianceGap, coverageGap, liabilityGap, mixedGapCompliance, mixedGapCoverage);

            // Update Matrix Dashboard
            updateMatrixDashboard({
                totalEstimatedBusinesses,
                registeredBusinesses,
                compliantBusinesses,
                avgBilledAmount,
                achievableAvgBill,
                revenueToDate,
                complianceGap,
                coverageGap,
                liabilityGap,
                mixedGapCompliance,
                mixedGapCoverage,
                totalPotentialRevenue,
                revenueToDatePct,
                complianceGapPct,
                coverageGapPct,
                liabilityGapPct,
                mixedGapCompliancePct,
                mixedGapCoveragePct
            });

            // Store values in localStorage for Total tab and Prioritization tab
            storeBusinessLicenseValues(revenueToDate, totalPotentialRevenue, totalFunctionalGap, complianceGap, coverageGap, liabilityGap, mixedGapCompliance, mixedGapCoverage, complianceRatio, coverageRatio);
        }

        function updateKPIBar(name, value) {
            const bar = document.getElementById(name + 'Bar');
            const valueSpan = document.getElementById(name + 'Value');
            const cappedValue = Math.min(Math.max(value, 0), 100);

            let colorClass, badgeClass;
            if (value >= 80) {
                colorClass = 'bg-success';
                badgeClass = 'bg-success';
            } else if (value >= 60) {
                colorClass = 'bg-warning';
                badgeClass = 'bg-warning text-dark';
            } else {
                colorClass = 'bg-danger';
                badgeClass = 'bg-danger';
            }

            if (bar) {
                bar.style.width = cappedValue + '%';
                bar.setAttribute('aria-valuenow', cappedValue);
                bar.classList.remove('bg-success', 'bg-warning', 'bg-danger', 'bg-info', 'bg-primary');
                bar.classList.add(colorClass);
            }
            if (valueSpan) {
                valueSpan.textContent = value.toFixed(1) + '%';
                valueSpan.classList.remove('bg-success', 'bg-warning', 'bg-danger', 'bg-info', 'bg-primary', 'text-dark');
                badgeClass.split(' ').forEach(cls => valueSpan.classList.add(cls));
            }
        }

        function updateCharts(revenueToDate, complianceGap, coverageGap, liabilityGap, mixedGapCompliance, mixedGapCoverage) {
            // Update Potential Revenue Chart
            if (potentialRevenueChart) {
                potentialRevenueChart.data.datasets[0].data = [
                    Math.max(0, revenueToDate),
                    Math.max(0, complianceGap),
                    Math.max(0, coverageGap),
                    Math.max(0, liabilityGap),
                    Math.max(0, mixedGapCompliance),
                    Math.max(0, mixedGapCoverage)
                ];
                potentialRevenueChart.update();
            }

            // Update Gap Breakdown Chart
            if (gapBreakdownChart) {
                gapBreakdownChart.data.datasets[0].data = [
                    Math.max(0, complianceGap),
                    Math.max(0, coverageGap),
                    Math.max(0, liabilityGap),
                    Math.max(0, mixedGapCompliance),
                    Math.max(0, mixedGapCoverage)
                ];
                gapBreakdownChart.update();
            }
        }

        function updateMatrixDashboard(data) {
            const currencySymbol = getCurrencySymbol();

            function formatCompact(value) {
                if (value >= 1000000000) {
                    return currencySymbol + ' ' + (value / 1000000000).toFixed(1) + 'B';
                } else if (value >= 1000000) {
                    return currencySymbol + ' ' + (value / 1000000).toFixed(1) + 'M';
                } else if (value >= 1000) {
                    return currencySymbol + ' ' + (value / 1000).toFixed(1) + 'K';
                }
                return currencySymbol + ' ' + formatCurrency(value);
            }

            function formatBusinessCount(value) {
                if (value >= 1000000) {
                    return (value / 1000000).toFixed(1) + 'M';
                } else if (value >= 1000) {
                    return (value / 1000).toFixed(1) + 'K';
                }
                return Math.round(value).toLocaleString();
            }

            // Update Y-axis labels (business counts)
            const estLabel = document.getElementById('blMatrixEstimatedLabel');
            const regLabel = document.getElementById('blMatrixRegisteredLabel');
            const compLabel = document.getElementById('blMatrixCompliantLabel');

            if (estLabel) estLabel.textContent = formatBusinessCount(data.totalEstimatedBusinesses);
            if (regLabel) regLabel.textContent = formatBusinessCount(data.registeredBusinesses);
            if (compLabel) compLabel.textContent = formatBusinessCount(data.compliantBusinesses);

            // Update X-axis labels
            const avgBilledLabel = document.getElementById('blMatrixAvgBilledLabel');
            const achievableLabel = document.getElementById('blMatrixAchievableLabel');
            const originLabel = document.getElementById('blMatrixOriginLabel');

            if (avgBilledLabel) avgBilledLabel.textContent = formatCompact(data.avgBilledAmount);
            if (achievableLabel) achievableLabel.textContent = formatCompact(data.achievableAvgBill);
            if (originLabel) originLabel.textContent = currencySymbol + ' 0';

            // Update matrix cell values
            const matrixActualRevenue = document.getElementById('blMatrixActualRevenueVal');
            const matrixLiabilityGap = document.getElementById('blMatrixLiabilityGapVal');
            const matrixComplianceGap = document.getElementById('blMatrixComplianceGapVal');
            const matrixMixedCompliance = document.getElementById('blMatrixMixedComplianceVal');
            const matrixCoverageGap = document.getElementById('blMatrixCoverageGapVal');
            const matrixMixedCoverage = document.getElementById('blMatrixMixedCoverageVal');

            if (matrixActualRevenue) matrixActualRevenue.textContent = formatCompact(data.revenueToDate);
            if (matrixLiabilityGap) matrixLiabilityGap.textContent = formatCompact(data.liabilityGap);
            if (matrixComplianceGap) matrixComplianceGap.textContent = formatCompact(data.complianceGap);
            if (matrixMixedCompliance) matrixMixedCompliance.textContent = formatCompact(data.mixedGapCompliance);
            if (matrixCoverageGap) matrixCoverageGap.textContent = formatCompact(data.coverageGap);
            if (matrixMixedCoverage) matrixMixedCoverage.textContent = formatCompact(data.mixedGapCoverage);

            // === DYNAMIC ROW HEIGHTS (proportional to business counts) ===
            const totalBiz = data.totalEstimatedBusinesses || 1;
            const unregBiz = Math.max(0, data.totalEstimatedBusinesses - data.registeredBusinesses);
            const nonCompliantBiz = Math.max(0, data.registeredBusinesses - data.compliantBusinesses);
            const compliantBiz = Math.max(0, data.compliantBusinesses);

            // Calculate flex ratios with minimum 30% to ensure text visibility
            const minFlex = 0.3;
            const unregRatio = unregBiz / totalBiz;
            const nonCompliantRatio = nonCompliantBiz / totalBiz;
            const compliantRatio = compliantBiz / totalBiz;

            const unregFlex = Math.max(minFlex, unregRatio);
            const nonCompliantFlex = Math.max(minFlex, nonCompliantRatio);
            const compliantFlex = Math.max(minFlex, compliantRatio);

            const rowUnreg = document.getElementById('blMatrixRowUnreg');
            const rowNonCompliant = document.getElementById('blMatrixRowNonCompliant');
            const rowCompliant = document.getElementById('blMatrixRowCompliant');

            if (rowUnreg) rowUnreg.style.flex = unregFlex.toString();
            if (rowNonCompliant) rowNonCompliant.style.flex = nonCompliantFlex.toString();
            if (rowCompliant) rowCompliant.style.flex = compliantFlex.toString();

            // === DYNAMIC COLUMN WIDTHS (proportional to billing amounts) ===
            const totalBilling = data.achievableAvgBill || 1;
            const avgBilled = data.avgBilledAmount || 0;
            const liabilityDiff = Math.max(0, data.achievableAvgBill - data.avgBilledAmount);

            // Calculate column width ratios (min 30% to ensure text visibility)
            const minColWidth = 0.3;
            const leftColRatio = avgBilled / totalBilling;
            const rightColRatio = liabilityDiff / totalBilling;

            const leftColFlex = Math.max(minColWidth, leftColRatio);
            const rightColFlex = Math.max(minColWidth, rightColRatio);

            // Apply to all row cells
            const allRows = document.querySelectorAll('#blMatrixGridArea .matrix-row');
            allRows.forEach(row => {
                const cells = row.querySelectorAll('.matrix-cell');
                if (cells.length >= 2) {
                    cells[0].style.flex = leftColFlex.toString();
                    cells[1].style.flex = rightColFlex.toString();
                }
            });

            // === POSITION Y-AXIS LABELS AT ROW BOUNDARIES (percentage-based) ===
            const totalFlex = unregFlex + nonCompliantFlex + compliantFlex;
            const row1Pct = (unregFlex / totalFlex) * 100;
            const row2Pct = (nonCompliantFlex / totalFlex) * 100;

            const yLabelEstimated = document.getElementById('blYLabelEstimated');
            const yLabelRegistered = document.getElementById('blYLabelRegistered');
            const yLabelCompliant = document.getElementById('blYLabelCompliant');

            // Estimated at top (0%)
            if (yLabelEstimated) {
                yLabelEstimated.style.top = '0%';
            }
            // Registered at boundary between row1 and row2
            if (yLabelRegistered) {
                yLabelRegistered.style.top = row1Pct + '%';
            }
            // Compliant at boundary between row2 and row3
            if (yLabelCompliant) {
                yLabelCompliant.style.top = (row1Pct + row2Pct) + '%';
            }

            // === POSITION X-AXIS LABEL AT COLUMN BOUNDARY ===
            const xAxisContainer = document.getElementById('blMatrixXAxisContainer');
            const xLabelAvgBilled = document.getElementById('blXLabelAvgBilled');

            if (xAxisContainer && xLabelAvgBilled) {
                const totalColFlex = leftColFlex + rightColFlex;
                const leftColPercent = (leftColFlex / totalColFlex) * 100;

                // Position the "Avg. Billed" label at the column boundary
                xLabelAvgBilled.style.left = leftColPercent + '%';
            }
        }

        function storeBusinessLicenseValues(revenueToDate, totalPotentialRevenue, totalFunctionalGap, complianceGap, coverageGap, liabilityGap, mixedGapCompliance, mixedGapCoverage, complianceRatio, coverageRatio) {
            try {
                // Use RosraStateManager if available (preferred method)
                if (typeof RosraStateManager !== 'undefined') {
                    RosraStateManager.updateBusinessLicense({
                        currentRevenue: revenueToDate,
                        potentialRevenue: totalPotentialRevenue,
                        totalFunctionalGap: totalFunctionalGap,
                        complianceGap: complianceGap,
                        coverageGap: coverageGap,
                        liabilityGap: liabilityGap,
                        mixedGapCompliance: mixedGapCompliance,
                        mixedGapCoverage: mixedGapCoverage,
                        complianceRatio: complianceRatio,
                        coverageRatio: coverageRatio
                    });
                    console.log('Business License: Updated via RosraStateManager');
                }

                // Also keep localStorage for backward compatibility
                localStorage.setItem('licenseCurrentValue', revenueToDate);
                localStorage.setItem('licensePotentialValue', totalPotentialRevenue);
                localStorage.setItem('licenseGapValue', totalFunctionalGap);
                localStorage.setItem('licenseGap', totalFunctionalGap);
                localStorage.setItem('licenseComplianceGap', complianceGap);
                localStorage.setItem('licenseCoverageGap', coverageGap);
                localStorage.setItem('licenseLiabilityGap', liabilityGap);
                localStorage.setItem('licenseMixedGapCompliance', mixedGapCompliance);
                localStorage.setItem('licenseMixedGapCoverage', mixedGapCoverage);
                localStorage.setItem('licenseComplianceRatio', complianceRatio);
                localStorage.setItem('licenseCoverageRatio', coverageRatio);

                const licenseValuesUpdated = new CustomEvent('licenseValuesUpdated', {
                    detail: {
                        current: revenueToDate,
                        potential: totalPotentialRevenue,
                        gap: totalFunctionalGap
                    }
                });
                document.dispatchEvent(licenseValuesUpdated);
            } catch (e) {
                console.error('Error storing Business License values in localStorage:', e);
            }
        }

        // Expose function globally
        window.calculateBusinessLicenseGaps = calculateBusinessLicenseGaps;
    });
</script>
