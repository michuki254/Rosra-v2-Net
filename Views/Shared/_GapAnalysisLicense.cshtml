                        </div>
                    </div>

                    <!-- Gap Breakdown Pie Chart -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">@Localizer["GapBreakdownPie_Title"]</h6>
                        <div class="d-flex justify-content-center">
                            <div style="height: 300px; width: 450px; position: relative;">
                                <canvas id="blGapBreakdownChart"></canvas>
                            </div>
                        </div>
                        <p class="small text-muted mt-2 text-center">
                            <strong>@Localizer["Description_Label"]</strong> @Localizer["GapBreakdownPie_Description"]
