                    <hr>

                    <!-- Gap Breakdown Table -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">@Localizer["GapBreakdown_Title"] (<span class="currency-label">@currencySymbol</span>)</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>@Localizer["Table_FunctionalGaps"]</th>
                                        <th class="text-end">@Localizer["Table_Amount"] (<span class="currency-label">@currencySymbol</span>)</th>
