<script>
    // Apply anti-flickering immediately when script loads
    document.body.classList.add('no-transitions');
    
    // Initialize global variables and functions BEFORE DOMContentLoaded for immediate availability
    window.longTermCategoryCounter = @(Model.LongTermUserCharge.DynamicCategories != null ? Model.LongTermUserCharge.DynamicCategories.Count : 0) + 1;
    
    // Function to create a new category (Long Term specific) - globally accessible immediately
    window.createNewLongTermCategory = function(categoryName) {
        console.log('createNewLongTermCategory called with:', categoryName);
        
        // Clone the template
        const template = document.getElementById('categoryTemplate');
        if (!template) {
            console.error('Category template not found');
            alert('Error: Category template not found. Please refresh the page.');
            return;
        }
        
        const templateCard = template.querySelector('.category-card');
        if (!templateCard) {
            console.error('Category card not found in template');
            alert('Error: Category template is invalid. Please refresh the page.');
            return;
        }
        
        const newCategory = templateCard.cloneNode(true);
        
        // Generate unique IDs
        const categoryId = 'longterm-category-' + window.longTermCategoryCounter;
        const collapseId = 'longterm-collapse-' + window.longTermCategoryCounter;
        
        // Update IDs and attributes
        newCategory.id = categoryId;
        newCategory.querySelector('.card-header').setAttribute('data-bs-target', '#' + collapseId);
        newCategory.querySelector('.card-header').setAttribute('aria-controls', collapseId);
        newCategory.querySelector('.collapse').id = collapseId;
        
        // Set the user-provided category name
        const titleElement = newCategory.querySelector('.category-title');
        if (titleElement) {
            titleElement.textContent = categoryName;
        }
        
        // Update input names for form submission
        const inputs = newCategory.querySelectorAll('input');
        inputs.forEach(function(input, index) {
            if (input.classList.contains('number-format')) {
                const fieldName = index === 0 ? 'EstimatedMonthlyLeasees' : 
                                index === 1 ? 'ActualMonthlyLeasees' : 
                                index === 2 ? 'PotentialRatePayable' : 'ActualRatePaid';
                input.name = `LongTermUserCharge.DynamicCategories[${window.longTermCategoryCounter - 1}].${fieldName}`;
                
                // Set a unique ID for the input
                input.id = `longTermDynamic_${window.longTermCategoryCounter}_${fieldName}`;
                
                // Add event listeners for number formatting and calculations
                input.addEventListener('blur', function() {
                    const value = parseFloat(this.value.replace(/,/g, '')) || 0;
                    this.value = value.toLocaleString('en-US');
                    if (typeof window.updateCalculations === 'function') {
                        window.updateCalculations();
                    }
                });
                
                input.addEventListener('change', function() {
                    if (typeof window.updateCalculations === 'function') {
                        window.updateCalculations();
                    }
                });
            }
        });
        
        // Add hidden input for category name
        const hiddenInput = document.createElement('input');
        hiddenInput.type = 'hidden';
        hiddenInput.name = `LongTermUserCharge.DynamicCategories[${window.longTermCategoryCounter - 1}].Name`;
        hiddenInput.value = categoryName;
        const cardBody = newCategory.querySelector('.card-body');
        if (cardBody) {
            cardBody.appendChild(hiddenInput);
        }
        
        // Add to container
        const container = document.getElementById('dynamicCategoriesContainer');
        if (container) {
            container.appendChild(newCategory);
        } else {
            console.error('Dynamic categories container not found');
            alert('Error: Cannot add category. Please refresh the page.');
            return;
        }
        
        // Increment counter for next category
        window.longTermCategoryCounter++;
        
        // Show the collapse
        const collapseElement = document.getElementById(collapseId);
        if (collapseElement && typeof bootstrap !== 'undefined') {
            new bootstrap.Collapse(collapseElement).show();
        }
        
        // Update calculations
        if (typeof window.updateCalculations === 'function') {
            window.updateCalculations();
        }
        
        console.log('Category created successfully:', categoryName);
    };
    
    // Function to update indices for dynamic categories after deletion - globally accessible
    window.updateLongTermDynamicCategoryIndices = function() {
        const container = document.getElementById('dynamicCategoriesContainer');
        if (container) {
            const dynamicCategories = container.querySelectorAll('.category-card');
            dynamicCategories.forEach(function(category, index) {
                const inputs = category.querySelectorAll('input');
                inputs.forEach(function(input) {
                    if (input.name && input.name.includes('DynamicCategories[')) {
                        input.name = input.name.replace(/DynamicCategories\[\d+\]/, `DynamicCategories[${index}]`);
                    }
                });
            });
        }
    };

    document.addEventListener('DOMContentLoaded', function() {
        // Re-enable transitions after page is fully loaded
        setTimeout(() => {
            document.body.classList.remove('no-transitions');
        }, 500);
        
        // Modal instance for add category modal
        let addLongTermModalInstance = null;
        
        // Variable to store current category being edited/deleted (Long Term specific)
        let currentLongTermCategory = null;
        
        // Note: Modal logic is handled by the _AddLongTermCategoryModal partial view
        // The createNewLongTermCategory function below is called by the modal
        
        
        // Debounce function to limit how often a function is called
        function debounce(func, wait) {
            let timeout;
            return function() {
                const context = this;
                const args = arguments;
                clearTimeout(timeout);
                timeout = setTimeout(() => {
                    func.apply(context, args);
                }, wait);
            };
        }
        
        // Initialize number formatting for the input fields
        const numberFormatInputs = document.querySelectorAll('.number-format');
        if (numberFormatInputs && numberFormatInputs.length > 0) {
            numberFormatInputs.forEach(input => {
                input.addEventListener('blur', function() {
                    const value = parseFloat(this.value.replace(/,/g, '')) || 0;
                    this.value = value.toLocaleString('en-US');
                    
                    // Update calculations when input changes
                    updateCalculations();
                });
            });
        }
        
        // Initialize event listeners for existing categories
        document.querySelectorAll('.category-card').forEach(category => {
            // Input event listeners for number formatting and calculations
            const inputs = category.querySelectorAll('input');
            inputs.forEach(input => {
                if (input.classList.contains('number-format')) {
                    input.addEventListener('blur', function() {
                        if (this.value) {
                            const value = parseFloat(this.value.replace(/,/g, ''));
                            this.value = isNaN(value) ? '' : value.toLocaleString('en-US');
                        }
                        updateCalculations();
                    });
                    
                    input.addEventListener('focus', function() {
                        this.value = this.value.replace(/,/g, '');
                    });
                    
                    input.addEventListener('change', updateCalculations);
                }
            });
        });

        

        
        // Toggle chevron icon when collapsing/expanding categories
        const categoryHeaders = document.querySelectorAll('[data-bs-toggle="collapse"]');
        
        categoryHeaders.forEach(header => {
            header.addEventListener('click', function() {
                const chevron = this.querySelector('.fas.fa-chevron-down');
                const collapseId = this.getAttribute('data-bs-target');
                const collapseElement = document.querySelector(collapseId);
                
                // Check if the collapse is currently shown
                if (collapseElement.classList.contains('show')) {
                    chevron.style.transform = 'rotate(0deg)';
                } else {
                    chevron.style.transform = 'rotate(180deg)';
                }
            });
        });
        
        // Function to parse numeric value from formatted string
        function parseNumeric(value) {
            if (typeof value === 'string') {
                return parseFloat(value.replace(/,/g, '')) || 0;
            }
            return parseFloat(value) || 0;
        }

        // Function to format currency values
        function formatCurrency(value) {
            return '$' + value.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        // Function to format percentage values
        function formatPercentage(value) {
            return value.toLocaleString('en-US', { minimumFractionDigits: 1, maximumFractionDigits: 1 }) + '%';
        }

        // Function to format number values with commas
        function formatNumber(value) {
            return value.toLocaleString('en-US');
        }
        
        // Function to update the gap chart for LT
        function updateRevenueGapChartLT(actualRevenue, totalGap) {
            try {
                console.log("Updating gap chart with:", { actualRevenue, totalGap });
                
                // Find the maximum value to scale the bars properly
                const totalHeight = actualRevenue + totalGap;
                const maxValue = Math.max(totalHeight, 975000); // Use at least 975,000 as max scale
                
                if (maxValue <= 0) {
                    // Handle case where both values are 0
                    $('#actualRevenueBarLT').css('height', '0%');
                    $('#gapBarLT').css('height', '0%');
                    $('#totalValueDisplayLT').text('$0');
                    
                    // Update y-axis labels for 0 case
                    updateYAxisLabelsLT(0);
                    return;
                }
                
                // Calculate percentage heights based on the max value (80% of container height max)
                const actualRevenuePercent = (actualRevenue / maxValue) * 80;
                const gapPercent = (totalGap / maxValue) * 80;
                
                // Update the bars - for stacked bar, position matters
                $('#actualRevenueBarLT').css('height', actualRevenuePercent + '%');
                $('#gapBarLT').css('height', gapPercent + '%');
                
                // Format numbers for display
                const totalFormatted = formatCurrencyCompact(totalHeight);
                
                // Update the total value display
                $('#totalValueDisplayLT').text(totalFormatted);
                
                // Update y-axis labels based on maxValue
                updateYAxisLabelsLT(maxValue);
                
                // Hide error message if it was showing
                $('#chartErrorMessageLT').addClass('d-none');
            } catch (error) {
                console.error("Error updating gap chart:", error);
                $('#chartErrorMessageLT').removeClass('d-none');
            }
        }
        
        // Function to update the gap breakdown chart for LT
        function updateGapBreakdownChartLT(complianceGap, rateGap, combinedGap) {
            try {
                console.log("Updating breakdown chart with:", { complianceGap, rateGap, combinedGap });
                
                // Total height of all gaps
                const totalGaps = complianceGap + rateGap + combinedGap;
                
                // Find the maximum value to scale the bars properly
                const maxValue = Math.max(totalGaps, 600000); // Use at least 600,000 as max scale
                
                if (maxValue <= 0) {
                    // Handle case where all values are 0
                    $('#complianceGapBarLT').css('height', '0%');
                    $('#rateGapBarLT').css('height', '0%');
                    $('#combinedGapBarLT').css('height', '0%');
                    
                    // Hide error message if it was showing
                    $('#breakdownChartErrorMessageLT').addClass('d-none');
                    return;
                }
                
                // Calculate percentage heights based on the max value (80% of container height max)
                const compliancePercent = (complianceGap / maxValue) * 80;
                const ratePercent = (rateGap / maxValue) * 80;
                const combinedPercent = (combinedGap / maxValue) * 80;
                
                // Update the bars - order matters for stacked bars
                $('#complianceGapBarLT').css('height', compliancePercent + '%');
                $('#rateGapBarLT').css('height', ratePercent + '%');
                $('#combinedGapBarLT').css('height', combinedPercent + '%');
                
                // Hide error message if it was showing
                $('#breakdownChartErrorMessageLT').addClass('d-none');
            } catch (error) {
                console.error("Error updating breakdown chart:", error);
                $('#breakdownChartErrorMessageLT').removeClass('d-none');
            }
        }
        
        // Function to format currency in a compact way for display
        function formatCurrencyCompact(value) {
            if (value >= 1000000) {
                return '$' + (value / 1000000).toFixed(1) + 'M';
            } else if (value >= 1000) {
                return '$' + (value / 1000).toFixed(1) + 'K';
            }
            return '$' + value.toFixed(0);
        }
        
        // Function to update y-axis labels based on max value for LT charts
        function updateYAxisLabelsLT(maxValue) {
            if (maxValue <= 0) maxValue = 975000; // Default scale
            
            const yLabels = document.querySelectorAll('.stacked-bar-chart .y-axis-labels .y-axis-label');
            const step = maxValue / 4; // 4 intervals for 5 labels
            
            yLabels.forEach((label, index) => {
                const value = index * step;
                if (value >= 1000000) {
                    label.textContent = (value / 1000000).toFixed(1) + 'M';
                } else if (value >= 1000) {
                    label.textContent = (value / 1000).toFixed(0) + 'K';
                } else {
                    label.textContent = value.toFixed(0);
                }
            });
        }
        
        // Main function to update all calculations - make it globally accessible
        window.updateCalculations = function updateCalculations() {
            // Get values for Category A
            let categoryAEstimatedLeasees = parseNumeric(document.querySelector('input[name="LongTermUserCharge.EstimatedMonthlyLeaseesCategoryA"]').value);
            let categoryAActualLeasees = parseNumeric(document.querySelector('input[name="LongTermUserCharge.ActualMonthlyLeaseesCategoryA"]').value);
            let categoryAPotentialRate = parseNumeric(document.querySelector('input[name="LongTermUserCharge.PotentialRatePayableByCategoryA"]').value);
            let categoryAActualRate = parseNumeric(document.querySelector('input[name="LongTermUserCharge.ActualRatePaidByCategoryA"]').value);
            
            // Get values for Category B
            let categoryBEstimatedLeasees = parseNumeric(document.querySelector('input[name="LongTermUserCharge.EstimatedMonthlyLeaseesCategoryB"]').value);
            let categoryBActualLeasees = parseNumeric(document.querySelector('input[name="LongTermUserCharge.ActualMonthlyLeaseesCategoryB"]').value);
            let categoryBPotentialRate = parseNumeric(document.querySelector('input[name="LongTermUserCharge.PotentialRatePayableByCategoryB"]').value);
            let categoryBActualRate = parseNumeric(document.querySelector('input[name="LongTermUserCharge.ActualRatePaidByCategoryB"]').value);
            
            // Get values for Category C
            let categoryCEstimatedLeasees = parseNumeric(document.querySelector('input[name="LongTermUserCharge.EstimatedMonthlyLeaseesCategoryC"]').value);
            let categoryCActualLeasees = parseNumeric(document.querySelector('input[name="LongTermUserCharge.ActualMonthlyLeaseesCategoryC"]').value);
            let categoryCPotentialRate = parseNumeric(document.querySelector('input[name="LongTermUserCharge.PotentialRatePayableByCategoryC"]').value);
            let categoryCActualRate = parseNumeric(document.querySelector('input[name="LongTermUserCharge.ActualRatePaidByCategoryC"]').value);
            
            // Calculate Actual Revenue for each category: (ActualLeasees * ActualRate * 12)
            let categoryAActualRevenue = categoryAActualLeasees * categoryAActualRate * 12;
            let categoryBActualRevenue = categoryBActualLeasees * categoryBActualRate * 12;
            let categoryCActualRevenue = categoryCActualLeasees * categoryCActualRate * 12;
            
            // Calculate Total Potential Revenue for each category: (EstimatedLeasees * PotentialRate * 12)
            let categoryAPotentialRevenue = categoryAEstimatedLeasees * categoryAPotentialRate * 12;
            let categoryBPotentialRevenue = categoryBEstimatedLeasees * categoryBPotentialRate * 12;
            let categoryCPotentialRevenue = categoryCEstimatedLeasees * categoryCPotentialRate * 12;
            
            // Calculate dynamic categories revenue
            let dynamicCategoriesActualRevenue = 0;
            let dynamicCategoriesPotentialRevenue = 0;
            
            document.querySelectorAll('#dynamicCategoriesContainer .category-card').forEach(function(category) {
                const estimatedLeasees = parseNumeric(category.querySelector('input[name*=".EstimatedMonthlyLeasees"]').value);
                const actualLeasees = parseNumeric(category.querySelector('input[name*=".ActualMonthlyLeasees"]').value);
                const potentialRate = parseNumeric(category.querySelector('input[name*=".PotentialRatePayable"]').value);
                const actualRate = parseNumeric(category.querySelector('input[name*=".ActualRatePaid"]').value);
                
                dynamicCategoriesActualRevenue += actualLeasees * actualRate * 12;
                dynamicCategoriesPotentialRevenue += estimatedLeasees * potentialRate * 12;
            });
            
            // Calculate Total Actual Revenue
            let totalActualRevenue = categoryAActualRevenue + categoryBActualRevenue + categoryCActualRevenue + dynamicCategoriesActualRevenue;
            
            // Calculate Total Potential Revenue
            let totalPotentialRevenue = categoryAPotentialRevenue + categoryBPotentialRevenue + categoryCPotentialRevenue + dynamicCategoriesPotentialRevenue;
            
            // Calculate Total Gap: Potential Revenue - Actual Revenue
            let totalGap = totalPotentialRevenue - totalActualRevenue;
            
            // Calculate Percentage of Potential Leveraged: (Actual Revenue / Potential Revenue) * 100
            let percentageLeveraged = 0;
            if (totalPotentialRevenue > 0) {
                percentageLeveraged = (totalActualRevenue / totalPotentialRevenue) * 100;
            }
            
            // Calculate Compliance Gap: Sum of ((Estimated - Actual) × Actual Rate × 12)
            let complianceGapA = (categoryAEstimatedLeasees - categoryAActualLeasees) * categoryAActualRate * 12;
            let complianceGapB = (categoryBEstimatedLeasees - categoryBActualLeasees) * categoryBActualRate * 12;
            let complianceGapC = (categoryCEstimatedLeasees - categoryCActualLeasees) * categoryCActualRate * 12;
            
            // Calculate Rate Gap: Sum of ((Potential Rate - Actual Rate) × Actual Leasees × 12)
            let rateGapA = (categoryAPotentialRate - categoryAActualRate) * categoryAActualLeasees * 12;
            let rateGapB = (categoryBPotentialRate - categoryBActualRate) * categoryBActualLeasees * 12;
            let rateGapC = (categoryCPotentialRate - categoryCActualRate) * categoryCActualLeasees * 12;
            
            // Calculate dynamic categories gaps
            let dynamicCategoriesComplianceGap = 0;
            let dynamicCategoriesRateGap = 0;
            
            document.querySelectorAll('#dynamicCategoriesContainer .category-card').forEach(function(category) {
                const estimatedLeasees = parseNumeric(category.querySelector('input[name*=".EstimatedMonthlyLeasees"]').value);
                const actualLeasees = parseNumeric(category.querySelector('input[name*=".ActualMonthlyLeasees"]').value);
                const potentialRate = parseNumeric(category.querySelector('input[name*=".PotentialRatePayable"]').value);
                const actualRate = parseNumeric(category.querySelector('input[name*=".ActualRatePaid"]').value);
                
                // Compliance Gap for dynamic category
                dynamicCategoriesComplianceGap += (estimatedLeasees - actualLeasees) * actualRate * 12;
                
                // Rate Gap for dynamic category
                dynamicCategoriesRateGap += (potentialRate - actualRate) * actualLeasees * 12;
            });
            
            // Total Compliance Gap
            let totalComplianceGap = complianceGapA + complianceGapB + complianceGapC + dynamicCategoriesComplianceGap;
            
            // Total Rate Gap
            let totalRateGap = rateGapA + rateGapB + rateGapC + dynamicCategoriesRateGap;
            
            // Combined Gaps: Total Gap - (Compliance Gap + Rate Gap)
            let combinedGaps = totalGap - (totalComplianceGap + totalRateGap);
            
            // Ensure combinedGaps is not negative due to rounding errors
            combinedGaps = Math.max(0, combinedGaps);
            
            // Update the summary card values
            document.getElementById('actualRevenueLT').textContent = formatNumber(totalActualRevenue);
            document.getElementById('potentialRevenueLT').textContent = formatNumber(totalPotentialRevenue);
            document.getElementById('totalGapLT').textContent = formatNumber(totalGap);
            document.getElementById('percentageLeveragedLT').textContent = formatNumber(percentageLeveraged);
            
            // Update the detailed cards
            document.getElementById('actualRevenueDetailLT').textContent = formatCurrency(totalActualRevenue);
            document.getElementById('potentialRevenueDetailLT').textContent = formatCurrency(totalPotentialRevenue);
            document.getElementById('totalGapDetailLT').textContent = formatCurrency(totalGap);
            document.getElementById('percentageLeveragedDetailLT').textContent = formatPercentage(percentageLeveraged);
            
            // Update the gap components summary
            document.getElementById('complianceGapSummaryLT').textContent = formatNumber(totalComplianceGap);
            document.getElementById('rateGapSummaryLT').textContent = formatNumber(totalRateGap);
            document.getElementById('combinedGapsSummaryLT').textContent = formatNumber(combinedGaps);
            
            // Update the gap visualization charts - replace the old Chart.js calls
            // initializeGapChartLT(totalActualRevenue, totalGap);
            // initializeGapComponentsChartLT(totalComplianceGap, totalRateGap, combinedGaps);
            
            // Update with new direct DOM manipulation charts
            updateRevenueGapChartLT(totalActualRevenue, totalGap);
            updateGapBreakdownChartLT(totalComplianceGap, totalRateGap, combinedGaps);
            
            // Calculate and update category gaps
            calculateCategoryGaps(
                categoryAEstimatedLeasees, categoryAActualLeasees, categoryAPotentialRate, categoryAActualRate,
                categoryBEstimatedLeasees, categoryBActualLeasees, categoryBPotentialRate, categoryBActualRate,
                categoryCEstimatedLeasees, categoryCActualLeasees, categoryCPotentialRate, categoryCActualRate
            );
            
            // Update the gap analysis text
            updateGapAnalysisTextLT(percentageLeveraged);
        }
        
        // Function to calculate category gaps
        function calculateCategoryGaps(
            catAEst, catAActual, catAPotRate, catAActRate,
            catBEst, catBActual, catBPotRate, catBActRate,
            catCEst, catCActual, catCPotRate, catCActRate
        ) {
            // Calculate gap for each category
            const gapA = (catAEst * catAPotRate * 12) - (catAActual * catAActRate * 12);
            const gapB = (catBEst * catBPotRate * 12) - (catBActual * catBActRate * 12);
            const gapC = (catCEst * catCPotRate * 12) - (catCActual * catCActRate * 12);
            
            // Update the category gap values in the table
            document.getElementById('gapCategoryALT').textContent = formatCurrency(gapA);
            document.getElementById('gapCategoryBLT').textContent = formatCurrency(gapB);
            document.getElementById('gapCategoryCLT').textContent = formatCurrency(gapC);
            
            // Find the largest gap
            const gaps = [
                { category: 'A', value: gapA },
                { category: 'B', value: gapB },
                { category: 'C', value: gapC }
            ];
            
            // Sort gaps by value in descending order
            gaps.sort((a, b) => b.value - a.value);
            
            // Determine the largest gap type
            let largestGapType = 'Compliance Gap';
            if (gaps[0].category === 'A') {
                document.getElementById('largestGapLT').textContent = largestGapType;
                document.getElementById('categoryWithLargestGapLT').textContent = 'Gap Category Category A';
            } else if (gaps[0].category === 'B') {
                document.getElementById('largestGapLT').textContent = largestGapType;
                document.getElementById('categoryWithLargestGapLT').textContent = 'Gap Category Category B';
            } else {
                document.getElementById('largestGapLT').textContent = largestGapType;
                document.getElementById('categoryWithLargestGapLT').textContent = 'Gap Category Category C';
            }
        }
        
        // Function to update the gap analysis text based on the percentage of potential leveraged
        function updateGapAnalysisTextLT(percentLeveraged) {
            const alertElement = document.getElementById('gapAnalysisAlertLT');
            const textElement = document.getElementById('gapAnalysisTextLT');
            const percentValue = percentLeveraged.toFixed(1) + '%';
            
            // Remove existing alert classes
            alertElement.classList.remove('alert-danger', 'alert-warning', 'alert-success');
            
            // Set alert class and text based on percentage value
            if (percentLeveraged < 30) {
                alertElement.classList.add('alert-danger');
                textElement.innerHTML = `
                    <strong>Critical Revenue Gap:</strong> The Long-term User Charge Revenue Collection (GOA) faces a significant challenge as the percentage of potential leveraged revenue falls below 30% at the value <strong>${percentValue}</strong>. This indicates a substantial gap between the revenue collected and the total estimated potential revenue. To close the gap, a comprehensive analysis of existing revenue channels, revisions of pricing structures may be required.
                `;
            } else if (percentLeveraged >= 30 && percentLeveraged < 70) {
                alertElement.classList.add('alert-warning');
                textElement.innerHTML = `
                    <strong>Moderate Revenue Performance:</strong> While the Long-term User Charge Revenue Collection (GOA) captures a substantial portion of the estimated potential revenue with a percentage between 30% and 70%, at the value of <strong>${percentValue}</strong>. This indicates that current policies are moderately effective, but there is still room for improvement.
                `;
            } else {
                alertElement.classList.add('alert-success');
                textElement.innerHTML = `
                    <strong>Strong Revenue Performance:</strong> The Long-term User Charge Revenue Collection (GOA) excels in revenue generation, with a percentage of potential leveraged revenue exceeding 70%, at the value of <strong>${percentValue}</strong>. This achievement underscores the effectiveness of government's existing strategies and practices. Government should keep monitoring market and customers to maintain its performance.
                `;
            }
        }
        
        // Initial calculation on page load
        updateCalculations();
        
        // Add event listeners to inputs to recalculate on change
        document.querySelectorAll('input.number-format').forEach(function(input) {
            input.addEventListener('input', debounce(updateCalculations, 300));
        });

        // Function to update the UI for gap categories
        function updateLocalStorageValues() {
            try {
                // Get the current values from the summary cards
                const actualRevenue = parseNumeric(document.getElementById('actualRevenueLT').textContent);
                const potentialRevenue = parseNumeric(document.getElementById('potentialRevenueLT').textContent);
                const totalGap = parseNumeric(document.getElementById('totalGapLT').textContent);
                
                // Get the gap breakdown values
                const complianceGap = parseNumeric(document.getElementById('complianceGapSummaryLT').textContent);
                const rateGap = parseNumeric(document.getElementById('rateGapSummaryLT').textContent);
                const combinedGap = parseNumeric(document.getElementById('combinedGapsSummaryLT').textContent);
                
                // Store values in localStorage with consistent key names
                localStorage.setItem('longTermCurrent', actualRevenue);
                localStorage.setItem('longTermPotential', potentialRevenue);
                localStorage.setItem('longTermGap', totalGap);
                
                // Store the detailed gap breakdown values with keys matching our Total tab format
                localStorage.setItem('longTermComplianceGap', complianceGap);
                localStorage.setItem('longTermRateGap', rateGap);
                localStorage.setItem('longTermCombinedGap', combinedGap);
                
                // Also store with standard keys for the detailed breakdown table
                localStorage.setItem('longRegistrationGap', 0); // Long term doesn't track registration gap
                localStorage.setItem('longComplianceGap', complianceGap); 
                localStorage.setItem('longAssessmentGap', 0); // Long term doesn't track assessment gap
                localStorage.setItem('longRateGap', rateGap);
                localStorage.setItem('longCombinedGap', combinedGap);
                
                console.log('Stored Long Term values in localStorage:', {
                    actualRevenue,
                    potentialRevenue,
                    totalGap,
                    gapBreakdown: {
                        complianceGap,
                        rateGap,
                        combinedGap
                    }
                });
                
                // Create and dispatch a custom event to notify other components
                const event = new CustomEvent('longTermValuesUpdated', {
                    detail: {
                        current: actualRevenue,
                        potential: potentialRevenue,
                        gap: totalGap,
                        gapBreakdown: {
                            complianceGap,
                            rateGap,
                            combinedGap
                        }
                    }
                });
                document.dispatchEvent(event);
                
                // Update hidden inputs for the Total tab to use
                updateHiddenInputs(actualRevenue, potentialRevenue, totalGap);
            } catch (e) {
                console.error('Error updating localStorage:', e);
            }
        }
        
        // Function to update hidden inputs if they exist
        function updateHiddenInputs(current, potential, gap) {
            // Create hidden inputs if they don't exist
            createOrUpdateHiddenInput('longTermCurrentValue', current);
            createOrUpdateHiddenInput('longTermPotentialValue', potential);
            createOrUpdateHiddenInput('longTermGap', gap);
        }
        
        // Helper function to create or update hidden inputs
        function createOrUpdateHiddenInput(id, value) {
            let input = document.getElementById(id);
            if (!input) {
                input = document.createElement('input');
                input.type = 'hidden';
                input.id = id;
                document.body.appendChild(input);
            }
            input.value = value;
        }
        
        // Add this to the existing updateCalculations function
        const originalUpdateCalculations = updateCalculations;
        updateCalculations = function() {
            originalUpdateCalculations();
            updateLocalStorageValues();
        };
        
        // Listen for the tab shown event to update localStorage again
        document.addEventListener('tabShown', function(e) {
            if (e.detail && e.detail.tabId === 'long-term') {
                console.log('Long Term tab shown, updating localStorage...');
                setTimeout(updateLocalStorageValues, 100);
            }
        });
        
        // Initial update to localStorage
        setTimeout(updateLocalStorageValues, 500);
    });
</script>

