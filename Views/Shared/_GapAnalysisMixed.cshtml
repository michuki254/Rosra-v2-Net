                    <!-- Gap Breakdown Visualization Card -->
                    <div class="card mb-3">
                        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">Breakdown</h6>
                            <span class="badge bg-light text-primary rounded-pill">Chart</span>
                        </div>
                        <div class="card-body">
                            <div id="breakdownChartErrorMessage" class="alert alert-danger d-none">
                                Error loading breakdown chart. Please check console for details.
                            </div>
                            
                            <div class="stacked-bar-chart" style="height: 300px; position: relative;">
                                <div class="d-flex justify-content-center align-items-end h-100 pb-5">
                                    <div class="stacked-bar-container text-center" style="width: 60%; max-width: 300px;">
                                        <div id="combinedGapBar" class="bar bg-secondary" style="height: 0%; transition: height 0.5s ease;"></div>
                                        <div id="rateGapBar" class="bar bg-warning" style="height: 0%; transition: height 0.5s ease;"></div>
                                        <div id="complianceGapBar" class="bar bg-primary" style="height: 0%; transition: height 0.5s ease;"></div>
                                        <div class="y-axis-labels">
                                            <div class="y-axis-label" style="bottom: 0%;">0</div>
                                            <div class="y-axis-label" style="bottom: 25%;">150K</div>
                                            <div class="y-axis-label" style="bottom: 50%;">300K</div>
                                            <div class="y-axis-label" style="bottom: 75%;">450K</div>
                                            <div class="y-axis-label" style="bottom: 100%;">600K</div>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Legend -->
                                <div class="legend d-flex justify-content-center mt-3">
                                    <div class="legend-item me-3">
                                        <span class="legend-color bg-primary"></span>
                                        <span class="legend-text">Compliance Gap</span>
                                    </div>
                                    <div class="legend-item me-3">
                                        <span class="legend-color bg-warning"></span>
                                        <span class="legend-text">Rate Gap</span>
                                    </div>
                                    <div class="legend-item">
                                        <span class="legend-color bg-secondary"></span>
                                        <span class="legend-text">Combined Gaps</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Debounce function to limit how often a function is called
        function debounce(func, wait) {
            let timeout;
            return function() {
                const context = this;
                const args = arguments;
                clearTimeout(timeout);
                timeout = setTimeout(() => {
                    func.apply(context, args);
                }, wait);
            };
        }
        
        // Function to parse numeric values from formatted strings
        function parseNumeric(value) {
            if (typeof value === 'string') {
                return parseFloat(value.replace(/,/g, '')) || 0;
            }
            return parseFloat(value) || 0;
        }
        
        // Function to format currency values
        function formatCurrency(value) {
            if (value >= 1000000) {
                return '$' + (value / 1000000).toFixed(1) + 'M';
            } else if (value >= 1000) {
                return '$' + (value / 1000).toFixed(1) + 'K';
            }
            return '$' + value.toFixed(2);
        }
        
        // Function to format percentage values
        function formatPercentage(value) {
            return value.toLocaleString('en-US', { minimumFractionDigits: 1, maximumFractionDigits: 1 });
        }
        
        // Function to format number values with commas
        function formatNumber(value) {
            return value.toLocaleString('en-US');
        }
        
        // Function to create and update the revenue gap chart
        function updateRevenueGapChart(actualRevenue, totalGap) {
            try {
                console.log("Updating chart with:", { actualRevenue, totalGap });
                
                // Find the maximum value to scale the bars properly
                const totalHeight = actualRevenue + totalGap;
                const maxValue = Math.max(totalHeight, 975000); // Use at least 975,000 as max scale
                
                if (maxValue <= 0) {
                    // Handle case where both values are 0
                    $('#actualRevenueBar').css('height', '0%');
                    $('#gapBar').css('height', '0%');
                    $('#totalValueDisplay').text('$0');
                    
                    // Update y-axis labels for 0 case
                    updateYAxisLabels(0);
                    return;
                }
                
                // Calculate percentage heights based on the max value (80% of container height max)
                const actualRevenuePercent = (actualRevenue / maxValue) * 80;
                const gapPercent = (totalGap / maxValue) * 80;
                
                // Update the bars - for stacked bar, position matters
                $('#actualRevenueBar').css('height', actualRevenuePercent + '%');
                $('#gapBar').css('height', gapPercent + '%');
                
                // Format numbers for display
                const totalFormatted = formatCurrencyCompact(totalHeight);
                
                // Update the total value display
                $('#totalValueDisplay').text(totalFormatted);
                
                // Update y-axis labels based on maxValue
                updateYAxisLabels(maxValue);
                
                // Hide error message if it was showing
                $('#chartErrorMessage').addClass('d-none');
            } catch (error) {
                console.error("Error updating chart:", error);
                $('#chartErrorMessage').removeClass('d-none');
            }
        }
        
        // Function to format currency in a compact way for display (e.g., 300.9K)
        function formatCurrencyCompact(value) {
            if (value >= 1000000) {
                return '$' + (value / 1000000).toFixed(1) + 'M';
            } else if (value >= 1000) {
                return '$' + (value / 1000).toFixed(1) + 'K';
            }
            return '$' + value.toFixed(0);
        }
        
        // Function to update y-axis labels based on max value
        function updateYAxisLabels(maxValue) {
            if (maxValue <= 0) maxValue = 975000; // Default scale
            
            const yLabels = document.querySelectorAll('.y-axis-label');
            const step = maxValue / (yLabels.length - 1);
            
            yLabels.forEach((label, index) => {
                const value = index * step;
                if (value >= 1000000) {
                    label.textContent = (value / 1000000).toFixed(1) + 'M';
                } else if (value >= 1000) {
                    label.textContent = (value / 1000).toFixed(0) + 'K';
                } else {
                    label.textContent = value.toFixed(0);
                }
            });
        }
        
        // Function to update the gap breakdown chart
        function updateGapBreakdownChart(complianceGap, rateGap, combinedGap) {
            try {
                console.log("Updating breakdown chart with:", { complianceGap, rateGap, combinedGap });
                
                // Total height of all gaps
                const totalGaps = complianceGap + rateGap + combinedGap;
                
                // Find the maximum value to scale the bars properly
                const maxValue = Math.max(totalGaps, 600000); // Use at least 600,000 as max scale
                
                if (maxValue <= 0) {
                    // Handle case where all values are 0
                    $('#complianceGapBar').css('height', '0%');
                    $('#rateGapBar').css('height', '0%');
                    $('#combinedGapBar').css('height', '0%');
                    
                    // Hide error message if it was showing
                    $('#breakdownChartErrorMessage').addClass('d-none');
                    return;
                }
                
                // Calculate percentage heights based on the max value (80% of container height max)
                const compliancePercent = (complianceGap / maxValue) * 80;
                const ratePercent = (rateGap / maxValue) * 80;
                const combinedPercent = (combinedGap / maxValue) * 80;
                
                // Update the bars - order matters for stacked bars
                $('#complianceGapBar').css('height', compliancePercent + '%');
                $('#rateGapBar').css('height', ratePercent + '%');
                $('#combinedGapBar').css('height', combinedPercent + '%');
                
                // Hide error message if it was showing
                $('#breakdownChartErrorMessage').addClass('d-none');
            } catch (error) {
                console.error("Error updating breakdown chart:", error);
                $('#breakdownChartErrorMessage').removeClass('d-none');
            }
        }
        
        // Calculate Mixed User Charge Revenue and Gap
        function calculateMixedRevenue() {
            // Get daily users values
            const estimatedDailyUsers = parseNumeric(document.getElementById('estimatedDailyUsers').value);
            const actualDailyUsers = parseNumeric(document.getElementById('actualDailyUsers').value);
            const averageDailyUserFee = parseNumeric(document.getElementById('averageDailyUserFee').value);
            const actualDailyUserFee = parseNumeric(document.getElementById('actualDailyUserFee').value);
            
            // Get monthly users values
            const availableMonthlyUsers = parseNumeric(document.getElementById('numberOfAvailableMonthlyUsers').value);
            const payingMonthlyUsers = parseNumeric(document.getElementById('numberOfPayingMonthlyUsers').value);
            const averageMonthlyRate = parseNumeric(document.getElementById('averageMonthlyRate').value);
            const actualMonthlyRate = parseNumeric(document.getElementById('actualMonthlyRate').value);
            
            // Calculate daily revenue components
            const actualDailyRevenue = (actualDailyUsers * actualDailyUserFee) * 365;
            const potentialDailyRevenue = (estimatedDailyUsers * averageDailyUserFee) * 365;
            
            // Calculate monthly revenue components
            const actualMonthlyRevenue = payingMonthlyUsers * actualMonthlyRate * 12;
            const potentialMonthlyRevenue = availableMonthlyUsers * averageMonthlyRate * 12;
            
            // Calculate total revenue
            const actualRevenue = actualDailyRevenue + actualMonthlyRevenue;
            const potentialRevenue = potentialDailyRevenue + potentialMonthlyRevenue;
            
            // Calculate gaps
            const totalGap = potentialRevenue - actualRevenue;
            const percentageLeveraged = potentialRevenue > 0 ? (actualRevenue / potentialRevenue) * 100 : 0;
            
            // Calculate daily and monthly gaps
            const dailyGap = potentialDailyRevenue - actualDailyRevenue;
            const monthlyGap = potentialMonthlyRevenue - actualMonthlyRevenue;
            
            // Calculate specific gaps as shown in the spreadsheet
            // Daily User Fee Gap (B93)
            const dailyUserFeeGap = potentialDailyRevenue - actualDailyRevenue;
            
            // Monthly User Fee Gap (B94)
            const monthlyUserFeeGap = potentialMonthlyRevenue - actualMonthlyRevenue;
            
            // Calculate compliance gaps exactly as in the spreadsheet
            // Compliance Gap =((B77-B78)*B80*365)+((B81-B82)*B84)
            const complianceGapDaily = (estimatedDailyUsers - actualDailyUsers) * actualDailyUserFee * 365;
            const complianceGapMonthly = (availableMonthlyUsers - payingMonthlyUsers) * actualMonthlyRate;
            const complianceGapTotal = complianceGapDaily + complianceGapMonthly;
            
            // Calculate rate gaps exactly as in the spreadsheet
            // Rate Gap =((B79-B80)*B78*365)+((B83-B84)*B82*12)
            const rateGapDaily = (averageDailyUserFee - actualDailyUserFee) * actualDailyUsers * 365;
            const rateGapMonthly = (averageMonthlyRate - actualMonthlyRate) * payingMonthlyUsers * 12;
            const rateGapTotal = rateGapDaily + rateGapMonthly;
            
            // Calculate combined gaps exactly as in the spreadsheet
            // Combined gaps =B87-SUM(B90+B91)
            const combinedGapsTotal = totalGap - (complianceGapTotal + rateGapTotal);
            
            // Update UI with calculated values
            document.getElementById('actualRevenueMixed').textContent = formatNumber(actualRevenue);
            document.getElementById('potentialRevenueMixed').textContent = formatNumber(potentialRevenue);
            document.getElementById('totalGapMixed').textContent = formatNumber(totalGap);
            document.getElementById('percentageLeveragedMixed').textContent = formatPercentage(percentageLeveraged);
            
            // Update the simple card UI elements
            document.getElementById('actualRevenueMixedSimple').textContent = formatNumber(actualRevenue);
            document.getElementById('potentialRevenueMixedSimple').textContent = formatNumber(potentialRevenue);
            document.getElementById('totalGapMixedSimple').textContent = formatNumber(totalGap);
            document.getElementById('percentageLeveragedMixedSimple').textContent = formatPercentage(percentageLeveraged);
            
            document.getElementById('complianceGapMixed').textContent = formatCurrency(complianceGapTotal);
            document.getElementById('rateGapMixed').textContent = formatCurrency(rateGapTotal);
            document.getElementById('combinedGapsMixed').textContent = formatCurrency(combinedGapsTotal);
            
            document.getElementById('dailyGapMixed').textContent = formatCurrency(dailyGap);
            document.getElementById('monthlyGapMixed').textContent = formatCurrency(monthlyGap);
            
            // Update cleaner-style card elements with the same values
            document.getElementById('complianceGapMixedClean').textContent = formatCurrency(complianceGapTotal);
            document.getElementById('rateGapMixedClean').textContent = formatCurrency(rateGapTotal);
            document.getElementById('combinedGapsMixedClean').textContent = formatCurrency(combinedGapsTotal);
            document.getElementById('dailyGapMixedClean').textContent = 'Daily: ' + formatCurrency(dailyGap);
            document.getElementById('monthlyGapMixedClean').textContent = 'Monthly: ' + formatCurrency(monthlyGap);
            
            // Update category gaps analysis table
            document.getElementById('dailyUserFeeGapDetail').textContent = formatCurrency(dailyUserFeeGap);
            document.getElementById('monthlyUserFeeGapDetail').textContent = formatCurrency(monthlyUserFeeGap);
            
            // Determine largest gap
            const largestGapType = dailyGap > monthlyGap ? 'Daily User Fee Gap' : 'Monthly User Fee Gap';
            document.getElementById('largestGapMixed').textContent = 'Rate Gap';
            
            // Update hidden fields for form submission
            document.querySelector('input[name="MixedUserCharge.CurrentValue"]').value = actualRevenue;
            document.querySelector('input[name="MixedUserCharge.PotentialValue"]').value = potentialRevenue;
            document.querySelector('input[name="MixedUserCharge.Gap"]').value = totalGap;
            
            // Update the revenue gap chart
            updateRevenueGapChart(actualRevenue, totalGap);
            
            // Update the gap breakdown chart
            updateGapBreakdownChart(complianceGapTotal, rateGapTotal, combinedGapsTotal);
            
            // Store values in localStorage and update the Total tab
            storeValuesAndNotify(actualRevenue, potentialRevenue, totalGap, complianceGapTotal, rateGapTotal, combinedGapsTotal);
        }
        
        // Function to store values in localStorage and trigger events
        function storeValuesAndNotify(actualRevenue, potentialRevenue, totalGap, complianceGapTotal, rateGapTotal, combinedGapsTotal) {
            try {
                // Store values in localStorage with consistent naming
                localStorage.setItem('mixedCurrent', actualRevenue);
                localStorage.setItem('mixedPotential', potentialRevenue);
                localStorage.setItem('mixedGap', totalGap);
                
                // Store the detailed gap breakdown values with standard keys
                localStorage.setItem('mixedComplianceGap', complianceGapTotal);
                localStorage.setItem('mixedRateGap', rateGapTotal);
                localStorage.setItem('mixedCombinedGap', combinedGapsTotal);
                
                // Store with alternative keys for compatibility
                localStorage.setItem('mixedRegistrationGap', 0); // Mixed doesn't have registration gaps
                
                console.log('Stored Mixed values in localStorage:', {
                    actualRevenue,
                    potentialRevenue,
                    totalGap,
                    gapBreakdown: {
                        complianceGap: complianceGapTotal,
                        rateGap: rateGapTotal,
                        combinedGap: combinedGapsTotal
                    }
                });
                
                // Create and dispatch a custom event to notify other components
                const event = new CustomEvent('mixedValuesUpdated', {
                    detail: {
                        current: actualRevenue,
                        potential: potentialRevenue,
                        gap: totalGap,
                        gapBreakdown: {
                            complianceGap: complianceGapTotal,
                            rateGap: rateGapTotal,
                            combinedGap: combinedGapsTotal
                        }
                    }
                });
                document.dispatchEvent(event);
                
                // Update hidden inputs for form submission
                updateHiddenInputs(actualRevenue, potentialRevenue, totalGap);
            } catch (e) {
                console.error('Error updating localStorage:', e);
            }
        }
        
        // Function to update hidden inputs
        function updateHiddenInputs(current, potential, gap) {
            // Create or update hidden inputs
            createOrUpdateHiddenInput('mixedCurrentValue', current);
            createOrUpdateHiddenInput('mixedPotentialValue', potential);
            createOrUpdateHiddenInput('mixedGap', gap);
        }
        
        // Helper function to create or update hidden inputs
        function createOrUpdateHiddenInput(id, value) {
            let input = document.getElementById(id);
            if (!input) {
                input = document.createElement('input');
                input.type = 'hidden';
                input.id = id;
                document.body.appendChild(input);
            }
            input.value = value;
        }
        
        // Initialize number formatting for the input fields
        const numberFormatInputs = document.querySelectorAll('.number-format');
        if (numberFormatInputs && numberFormatInputs.length > 0) {
            numberFormatInputs.forEach(input => {
                input.addEventListener('blur', function() {
                    const value = parseFloat(this.value.replace(/,/g, '')) || 0;
                    this.value = value.toLocaleString('en-US');
                    
                    // Calculate revenue and gaps when input changes
                    calculateMixedRevenue();
                });
                
                // Add additional event for immediate calculation
                input.addEventListener('input', debounce(calculateMixedRevenue, 300));
            });
        }
        
        // Listen for tab shown event
        document.addEventListener('tabShown', function(e) {
            if (e.detail && e.detail.tabId === 'mixed') {
                console.log('Mixed tab shown, updating calculations...');
                setTimeout(calculateMixedRevenue, 100);
            }
        });
        
        // Initial calculation on page load
        calculateMixedRevenue();
    });
</script>

