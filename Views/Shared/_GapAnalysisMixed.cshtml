                    <!-- Revenue vs Gap Visualization Card -->
                    <div class="card mb-3">
                        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">Gap Analysis</h6>
                            <span class="badge bg-light text-primary rounded-pill">Chart</span>
                        </div>
                        <div class="card-body">
                            <!-- Replace with stacked bar chart -->
                            <div id="chartErrorMessage" class="alert alert-danger d-none">
                                Error loading chart. Please check console for details.
                            </div>
                            
                            <div class="stacked-bar-chart" style="height: 300px; position: relative;">
                                <div class="d-flex justify-content-center align-items-end h-100 pb-5">
                                    <div class="stacked-bar-container text-center" style="width: 60%; max-width: 300px;">
                                        <div id="gapBar" class="bar bg-warning" style="height: 0%; transition: height 0.5s ease;"></div>
