                                                    </div>
                                                    <div>
                                                        <span class="fw-medium">@Localizer["MonthlyUserFeeGap"]</span>
                                                        <small class="d-block text-muted">@Localizer["MonthlyRevenuePotentialGap"]</small>
                                                    </div>
