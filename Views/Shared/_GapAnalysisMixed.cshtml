@model RosraApp.Models.ViewModels.RosraFormViewModel
@{
    bool isViewMode = ViewData["ViewMode"] != null && (bool)ViewData["ViewMode"];
}

<!-- Remove Chart.js and use jQuery UI which should already be available in the project -->
<!-- <script src="https://cdn.jsdelivr.net/npm/chart.js"></script> -->

<div class="gap-analysis-tab-content">
    <div class="row">
        <!-- Left Side (1/3 width) -->
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h6 class="mb-0">@Localizer["MixedInformation"]</h6>
                </div>
                <div class="card-body">
                    <h6 class="mb-3">@Localizer["DailyUsers"]</h6>
                    <div class="mb-3">
                        <div class="form-group">
                            <label for="estimatedDailyUsers">@Localizer["EstimatedDailyUsers"]</label>
                            <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" id="estimatedDailyUsers" name="MixedUserCharge.EstimatedDailyUsers" value="@Model.MixedUserCharge.EstimatedDailyUsers" placeholder="@Localizer["EnterEstimatedDailyUsers"]" @(isViewMode ? "readonly" : "")>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-group">
                            <label for="actualDailyUsers">@Localizer["ActualDailyUsers"]</label>
                            <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" id="actualDailyUsers" name="MixedUserCharge.ActualDailyUsers" value="@Model.MixedUserCharge.ActualDailyUsers" placeholder="@Localizer["EnterActualDailyUsers"]" @(isViewMode ? "readonly" : "")>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-group">
                            <label for="averageDailyUserFee">@Localizer["AverageDailyUserFee"]</label>
                            <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" id="averageDailyUserFee" name="MixedUserCharge.AverageDailyUserFee" value="@Model.MixedUserCharge.AverageDailyUserFee" placeholder="@Localizer["EnterAverageDailyUserFee"]" @(isViewMode ? "readonly" : "")>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-group">
                            <label for="actualDailyUserFee">@Localizer["ActualDailyUserFee"]</label>
                            <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" id="actualDailyUserFee" name="MixedUserCharge.ActualDailyUserFee" value="@Model.MixedUserCharge.ActualDailyUserFee" placeholder="@Localizer["EnterActualDailyUserFee"]" @(isViewMode ? "readonly" : "")>
                        </div>
                    </div>
                    
                    <hr class="my-4">
                    <h6 class="mb-3">@Localizer["MonthlyUsers"]</h6>
                    <div class="mb-3">
                        <div class="form-group">
                            <label for="numberOfAvailableMonthlyUsers">@Localizer["NumberOfAvailableMonthlyUsers"]</label>
                            <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" id="numberOfAvailableMonthlyUsers" name="MixedUserCharge.NumberOfAvailableMonthlyUsers" value="@Model.MixedUserCharge.NumberOfAvailableMonthlyUsers" placeholder="@Localizer["EnterAvailableMonthlyUsers"]" @(isViewMode ? "readonly" : "")>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-group">
                            <label for="numberOfPayingMonthlyUsers">@Localizer["NumberOfPayingMonthlyUsers"]</label>
                            <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" id="numberOfPayingMonthlyUsers" name="MixedUserCharge.NumberOfPayingMonthlyUsers" value="@Model.MixedUserCharge.NumberOfPayingMonthlyUsers" placeholder="@Localizer["EnterPayingMonthlyUsers"]" @(isViewMode ? "readonly" : "")>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-group">
                            <label for="averageMonthlyRate">@Localizer["AverageMonthlyRate"]</label>
                            <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" id="averageMonthlyRate" name="MixedUserCharge.AverageMonthlyRate" value="@Model.MixedUserCharge.AverageMonthlyRate" placeholder="@Localizer["EnterAverageMonthlyRate"]" @(isViewMode ? "readonly" : "")>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-group">
                            <label for="actualMonthlyRate">@Localizer["ActualMonthlyRate"]</label>
                            <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" id="actualMonthlyRate" name="MixedUserCharge.ActualMonthlyRate" value="@Model.MixedUserCharge.ActualMonthlyRate" placeholder="@Localizer["EnterActualMonthlyRate"]" @(isViewMode ? "readonly" : "")>
                        </div>
                    </div>
                    
                    <!-- Hidden fields for backward compatibility -->
                    <input type="hidden" name="MixedUserCharge.NumberOfMixedUsers" value="@Model.MixedUserCharge.NumberOfMixedUsers">
                    <input type="hidden" name="MixedUserCharge.AverageMixedFee" value="@Model.MixedUserCharge.AverageMixedFee">
                    <input type="hidden" name="MixedUserCharge.CurrentValue" value="@Model.MixedUserCharge.CurrentValue">
                    <input type="hidden" name="MixedUserCharge.PotentialValue" value="@Model.MixedUserCharge.PotentialValue">
                    <input type="hidden" name="MixedUserCharge.Gap" value="@Model.MixedUserCharge.Gap">
                </div>
            </div>
        </div>
        
        <!-- Right Side (2/3 width) -->
        <div class="col-md-8">
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h6 class="mb-0">@Localizer["MixedDetails"]</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="form-floating">
                            <input type="text" class="form-control @(isViewMode ? "bg-light" : "")" id="mixedDescription" name="MixedUserCharge.Description" value="@Model.MixedUserCharge.Description" placeholder="Enter description" @(isViewMode ? "readonly" : "")>
                            <label for="mixedDescription">Description</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-floating">
                            <textarea class="form-control @(isViewMode ? "bg-light" : "")" id="mixedNotes" name="MixedUserCharge.Notes" style="height: 200px" placeholder="Enter notes" @(isViewMode ? "readonly" : "")>@Model.MixedUserCharge.Notes</textarea>
                            <label for="mixedNotes">Notes</label>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Gap Analysis Summary Card -->
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0">@Localizer["GapAnalysisSummary"]</h6>
                </div>
                <div class="card-body p-3">
                    <div class="row mb-4 d-none">
                        <div class="col-md-3">
                            <div class="card shadow-sm h-100">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center me-2" style="width: 40px; height: 40px;">
                                            <i class="fas fa-dollar-sign text-white"></i>
                                        </div>
                                        <span class="text-muted text-uppercase small">ACTUAL REVENUE</span>
                                    </div>
                                    <h3 class="mb-1 fw-bold" id="actualRevenueMixed">0.0</h3>
                                    <p class="text-muted small mb-0">Current collected revenue</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card shadow-sm h-100">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="rounded-circle bg-danger d-flex align-items-center justify-content-center me-2" style="width: 40px; height: 40px;">
                                            <i class="fas fa-chart-line text-white"></i>
                                        </div>
                                        <span class="text-muted text-uppercase small">POTENTIAL REVENUE</span>
                                    </div>
                                    <h3 class="mb-1 fw-bold" id="potentialRevenueMixed">0.0</h3>
                                    <p class="text-muted small mb-0">Maximum possible revenue</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card shadow-sm h-100">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center me-2" style="width: 40px; height: 40px;">
                                            <i class="fas fa-calculator text-white"></i>
                                        </div>
                                        <span class="text-muted text-uppercase small">TOTAL GAP</span>
                                    </div>
                                    <h3 class="mb-1 fw-bold" id="totalGapMixed">0.0</h3>
                                    <p class="text-muted small mb-0">Revenue gap to be addressed</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card shadow-sm h-100">
                                <div class="card-body p-3">
                                    <div class="d-flex align-items-center mb-2">
                                        <div class="rounded-circle bg-warning d-flex align-items-center justify-content-center me-2" style="width: 40px; height: 40px;">
                                            <i class="fas fa-percentage text-white"></i>
                                        </div>
                                        <span class="text-muted text-uppercase small">POTENTIAL LEVERAGED</span>
                                    </div>
                                    <h3 class="mb-1 fw-bold"><span id="percentageLeveragedMixed">0.0</span> %</h3>
                                    <p class="text-muted small mb-0">Percentage of potential collected</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Hidden elements for calculations -->
                    <div class="d-none">
                        <span id="complianceGapMixed">0</span>
                        <span id="rateGapMixed">0</span>
                        <span id="combinedGapsMixed">0</span>
                        <span id="dailyGapMixed">0</span>
                        <span id="monthlyGapMixed">0</span>
                    </div>
                    
                    <!-- Revenue Summary Cards - Modern Design -->
                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="fas fa-dollar-sign text-white fs-4"></i>
                                        </div>
                                        <div>
                                            <span class="text-uppercase small fw-bold text-muted">ACTUAL</span>
                                            <span class="d-block text-uppercase small fw-bold text-muted">REVENUE</span>
                                        </div>
                                    </div>
                                    <h2 class="fw-bold" id="actualRevenueMixedSimple">0</h2>
                                    <p class="text-muted mb-0">@Localizer["CurrentCollectedRevenue"]</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-danger d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="fas fa-chart-line text-white fs-4"></i>
                                        </div>
                                        <div>
                                            <span class="text-uppercase small fw-bold text-muted">POTENTIAL</span>
                                            <span class="d-block text-uppercase small fw-bold text-muted">REVENUE</span>
                                        </div>
                                    </div>
                                    <h2 class="fw-bold" id="potentialRevenueMixedSimple">0</h2>
                                    <p class="text-muted mb-0">@Localizer["MaximumPossibleRevenue"]</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="fas fa-calculator text-white fs-4"></i>
                                        </div>
                                        <div>
                                            <span class="text-uppercase small fw-bold text-muted">TOTAL</span>
                                            <span class="d-block text-uppercase small fw-bold text-muted">GAP</span>
                                        </div>
                                    </div>
                                    <h2 class="fw-bold" id="totalGapMixedSimple">0</h2>
                                    <p class="text-muted mb-0">@Localizer["RevenueGapToBeAddressed"]</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-warning d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="fas fa-percentage text-white fs-4"></i>
                                        </div>
                                        <div>
                                            <span class="text-uppercase small fw-bold text-muted">POTENTIAL</span>
                                            <span class="d-block text-uppercase small fw-bold text-muted">LEVERAGED</span>
                                        </div>
                                    </div>
                                    <h2 class="fw-bold"><span id="percentageLeveragedMixedSimple">0</span> %</h2>
                                    <p class="text-muted mb-0">@Localizer["PercentageOfPotentialCollected"]</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Detailed Gap Cards - Cleaner Style -->
                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-warning d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="fas fa-users text-white fs-4"></i>
                                        </div>
                                        <div>
                                            <span class="text-uppercase small fw-bold text-muted">COMPLIANCE</span>
                                            <span class="d-block text-uppercase small fw-bold text-muted">GAP</span>
                                        </div>
                                    </div>
                                    <h2 class="fw-bold" id="complianceGapMixedClean">$0.00</h2>
                                    <p class="text-muted mb-0">@Localizer["GapDueToFewerUsers"]</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-danger d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="fas fa-money-bill-wave text-white fs-4"></i>
                                        </div>
                                        <div>
                                            <span class="text-uppercase small fw-bold text-muted">RATE</span>
                                            <span class="d-block text-uppercase small fw-bold text-muted">GAP</span>
                                        </div>
                                    </div>
                                    <h2 class="fw-bold" id="rateGapMixedClean">$0.00</h2>
                                    <p class="text-muted mb-0">@Localizer["GapDueToLowerRates"]</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-info d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="fas fa-puzzle-piece text-white fs-4"></i>
                                        </div>
                                        <div>
                                            <span class="text-uppercase small fw-bold text-muted">COMBINED</span>
                                            <span class="d-block text-uppercase small fw-bold text-muted">GAPS</span>
                                        </div>
                                    </div>
                                    <h2 class="fw-bold" id="combinedGapsMixedClean">$0.00</h2>
                                    <p class="text-muted mb-0">@Localizer["OtherUncategorizedGaps"]</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body p-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-success d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="fas fa-chart-pie text-white fs-4"></i>
                                        </div>
                                        <div>
                                            <span class="text-uppercase small fw-bold text-muted">GAP</span>
                                            <span class="d-block text-uppercase small fw-bold text-muted">BREAKDOWN</span>
                                        </div>
                                    </div>
                                    <div class="d-flex flex-column">
                                        <span class="text-primary fw-bold mb-1" id="dailyGapMixedClean">Daily: $0.00</span>
                                        <span class="text-purple fw-bold" id="monthlyGapMixedClean">Monthly: $0.00</span>
                                    </div>
                                    <p class="text-muted mt-2 mb-0">@Localizer["DailyVsMonthlyGaps"]</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Collapsible Formulas Sections -->
                    <!-- Revenue Formulas Section -->
                    <div class="card mb-4">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#revenueFormulasCollapse" aria-expanded="false" aria-controls="revenueFormulasCollapse" style="cursor: pointer;">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-calculator me-2"></i>
                                <h6 class="mb-0">Formula Details</h6>
                            </div>
                            <i class="fas fa-chevron-up"></i>
                        </div>
                        <div class="collapse" id="revenueFormulasCollapse">
                            <div class="card-body p-0">
                                <!-- Actual Revenue Formula -->
                                <div class="p-4 border-bottom">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="fas fa-dollar-sign text-white fs-4"></i>
                                        </div>
                                        <h5 class="mb-0">Actual Revenue</h5>
                                    </div>
                                    
                                    <div class="bg-light p-3 rounded mb-3">
                                        <code>((ActualDailyUsers × ActualDailyUserFee) × 365) + (NumberOfPayingMonthlyUsers × ActualMonthlyRate × 12)</code>
                                    </div>
                                    
                                    <div>
                                        <p class="mb-2">Where:</p>
                                        <ul class="list-unstyled ps-3">
                                            <li class="mb-2"><i class="fas fa-circle me-2 text-primary" style="font-size: 8px;"></i> ActualDailyUsers = Actual number of daily users</li>
                                            <li class="mb-2"><i class="fas fa-circle me-2 text-primary" style="font-size: 8px;"></i> ActualDailyUserFee = Current fee charged per daily user</li>
                                            <li class="mb-2"><i class="fas fa-circle me-2 text-primary" style="font-size: 8px;"></i> NumberOfPayingMonthlyUsers = Current number of monthly users</li>
                                            <li><i class="fas fa-circle me-2 text-primary" style="font-size: 8px;"></i> ActualMonthlyRate = Current fee charged per monthly user</li>
                                        </ul>
                                    </div>
                                </div>
                                
                                <!-- Potential Revenue Formula -->
                                <div class="p-4 border-bottom">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-danger d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="fas fa-chart-line text-white fs-4"></i>
                                        </div>
                                        <h5 class="mb-0">Total Potential Revenue</h5>
                                    </div>
                                    
                                    <div class="bg-light p-3 rounded mb-3">
                                        <code>((EstimatedDailyUsers × AverageDailyUserFee) × 365) + (NumberOfAvailableMonthlyUsers × AverageMonthlyRate × 12)</code>
                                    </div>
                                    
                                    <div>
                                        <p class="mb-2">Where:</p>
                                        <ul class="list-unstyled ps-3">
                                            <li class="mb-2"><i class="fas fa-circle me-2 text-danger" style="font-size: 8px;"></i> EstimatedDailyUsers = Estimated total number of potential daily users</li>
                                            <li class="mb-2"><i class="fas fa-circle me-2 text-danger" style="font-size: 8px;"></i> AverageDailyUserFee = Average potential fee for daily users</li>
                                            <li class="mb-2"><i class="fas fa-circle me-2 text-danger" style="font-size: 8px;"></i> NumberOfAvailableMonthlyUsers = Total potential monthly users</li>
                                            <li><i class="fas fa-circle me-2 text-danger" style="font-size: 8px;"></i> AverageMonthlyRate = Average potential fee for monthly users</li>
                                        </ul>
                                    </div>
                                </div>
                                
                                <!-- Total Gap Formula -->
                                <div class="p-4 border-bottom">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="fas fa-calculator text-white fs-4"></i>
                                        </div>
                                        <h5 class="mb-0">Total Gap Mixed User Fees</h5>
                                    </div>
                                    
                                    <div class="bg-light p-3 rounded mb-3">
                                        <code>Total Potential Revenue - Actual Revenue</code>
                                    </div>
                                    
                                    <div>
                                        <p class="mb-2">Simple difference between:</p>
                                        <ul class="list-unstyled ps-3">
                                            <li class="mb-2"><i class="fas fa-circle me-2 text-secondary" style="font-size: 8px;"></i> Total Potential Revenue (calculated above)</li>
                                            <li><i class="fas fa-circle me-2 text-secondary" style="font-size: 8px;"></i> Actual Revenue (calculated above)</li>
                                        </ul>
                                    </div>
                                </div>
                                
                                <!-- % of Potential Leveraged Formula -->
                                <div class="p-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-warning d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="fas fa-percentage text-white fs-4"></i>
                                        </div>
                                        <h5 class="mb-0">% of Potential Leveraged</h5>
                                    </div>
                                    
                                    <div class="bg-light p-3 rounded mb-3">
                                        <code>(Actual Revenue ÷ Total Potential Revenue) × 100%</code>
                                    </div>
                                    
                                    <div>
                                        <p class="mb-2">Interpretation:</p>
                                        <p class="ps-3 mb-0">Represents what percentage of the potential revenue is currently being collected.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Breakdown Formulas Section -->
                    <div class="card mb-4">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#breakdownFormulasCollapse" aria-expanded="false" aria-controls="breakdownFormulasCollapse" style="cursor: pointer;">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-puzzle-piece me-2"></i>
                                <h6 class="mb-0">Breakdown Formulas</h6>
                            </div>
                            <i class="fas fa-chevron-up"></i>
                        </div>
                        <div class="collapse" id="breakdownFormulasCollapse">
                            <div class="card-body p-0">
                                <!-- Compliance Gap Formula -->
                                <div class="p-4 border-bottom">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-warning d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="fas fa-users text-white fs-4"></i>
                                        </div>
                                        <h5 class="mb-0">Compliance Gap</h5>
                                    </div>
                                    
                                    <div class="bg-light p-3 rounded mb-3">
                                        <code>((EstimatedDailyUsers - ActualDailyUsers) × ActualDailyUserFee × 365) + ((AvailableMonthlyUsers - PayingMonthlyUsers) × ActualMonthlyRate)</code>
                                    </div>
                                    
                                    <div>
                                        <p class="mb-2">Where:</p>
                                        <ul class="list-unstyled ps-3">
                                            <li class="mb-2"><i class="fas fa-circle me-2 text-warning" style="font-size: 8px;"></i> This represents the revenue gap due to fewer users than potential</li>
                                            <li><i class="fas fa-circle me-2 text-warning" style="font-size: 8px;"></i> Calculated at current rates for both daily and monthly users</li>
                                        </ul>
                                    </div>
                                </div>
                                
                                <!-- Rate Gap Formula -->
                                <div class="p-4 border-bottom">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-danger d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="fas fa-money-bill-wave text-white fs-4"></i>
                                        </div>
                                        <h5 class="mb-0">Rate Gap</h5>
                                    </div>
                                    
                                    <div class="bg-light p-3 rounded mb-3">
                                        <code>((AverageDailyUserFee - ActualDailyUserFee) × ActualDailyUsers × 365) + ((AverageMonthlyRate - ActualMonthlyRate) × PayingMonthlyUsers × 12)</code>
                                    </div>
                                    
                                    <div>
                                        <p class="mb-2">Where:</p>
                                        <ul class="list-unstyled ps-3">
                                            <li class="mb-2"><i class="fas fa-circle me-2 text-danger" style="font-size: 8px;"></i> This represents the revenue gap due to lower rates than potential</li>
                                            <li><i class="fas fa-circle me-2 text-danger" style="font-size: 8px;"></i> Calculated based on current user numbers for both daily and monthly users</li>
                                        </ul>
                                    </div>
                                </div>
                                
                                <!-- Combined Gaps Formula -->
                                <div class="p-4 border-bottom">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-info d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="fas fa-puzzle-piece text-white fs-4"></i>
                                        </div>
                                        <h5 class="mb-0">Combined Gaps</h5>
                                    </div>
                                    
                                    <div class="bg-light p-3 rounded mb-3">
                                        <code>Total Gap - (Compliance Gap + Rate Gap)</code>
                                    </div>
                                    
                                    <div>
                                        <p class="mb-2">Where:</p>
                                        <ul class="list-unstyled ps-3">
                                            <li><i class="fas fa-circle me-2 text-info" style="font-size: 8px;"></i> This represents other uncategorized revenue gaps that cannot be attributed to just compliance or rate factors</li>
                                        </ul>
                                    </div>
                                </div>
                                
                                <!-- Gap Breakdown Formula -->
                                <div class="p-4">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rounded-circle bg-success d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                                            <i class="fas fa-chart-pie text-white fs-4"></i>
                                        </div>
                                        <h5 class="mb-0">Gap Breakdown</h5>
                                    </div>
                                    
                                    <div>
                                        <p class="mb-2">Daily Gap:</p>
                                        <div class="bg-light p-3 rounded mb-3">
                                            <code>(EstimatedDailyUsers × AverageDailyUserFee × 365) - (ActualDailyUsers × ActualDailyUserFee × 365)</code>
                                        </div>
                                        
                                        <p class="mb-2">Monthly Gap:</p>
                                        <div class="bg-light p-3 rounded mb-3">
                                            <code>(AvailableMonthlyUsers × AverageMonthlyRate × 12) - (PayingMonthlyUsers × ActualMonthlyRate × 12)</code>
                                        </div>
                                        
                                        <p class="mb-2">Where:</p>
                                        <ul class="list-unstyled ps-3">
                                            <li class="mb-2"><i class="fas fa-circle me-2 text-success" style="font-size: 8px;"></i> Daily Gap: Revenue gap specifically from daily user charges</li>
                                            <li><i class="fas fa-circle me-2 text-purple" style="font-size: 8px;"></i> Monthly Gap: Revenue gap specifically from monthly user charges</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Category Gaps Analysis Card -->
                    <div class="card mb-3">
                        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
