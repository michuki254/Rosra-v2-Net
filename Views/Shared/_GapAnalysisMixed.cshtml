                                        <div class="y-axis-labels">
                                            <div class="y-axis-label" style="bottom: 0%;">0</div>
                                            <div class="y-axis-label" style="bottom: 25%;">244K</div>
                                            <div class="y-axis-label" style="bottom: 50%;">488K</div>
                                            <div class="y-axis-label" style="bottom: 75%;">732K</div>
                                            <div class="y-axis-label" style="bottom: 100%;">975K</div>
