        function updateAnalysisResultText(fundingIndex, autonomyIndex) {
            const resultText = document.getElementById('analysisResultText');
            if (!resultText) return;

            const fundingThreshold = 80;
            const autonomyThreshold = 80;
            let template = '';

            if (fundingIndex >= fundingThreshold && autonomyIndex >= autonomyThreshold) {
                template = _ccTemplates.bothHigh;
            } else if (fundingIndex >= fundingThreshold && autonomyIndex < autonomyThreshold) {
                template = _ccTemplates.fundingHighAutLow;
            } else if (fundingIndex < fundingThreshold && autonomyIndex >= autonomyThreshold) {
                template = _ccTemplates.fundingLowAutHigh;
            } else {
                template = _ccTemplates.bothLow;
            }

            resultText.textContent = template
                .replace('{0}', fundingIndex)
                .replace('{1}', autonomyIndex);
        }

