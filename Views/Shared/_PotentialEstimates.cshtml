        // Fetch and display Peer SNG Analysis
        async function fetchPeerSNGAnalysis(sngName) {
            if (!sngName) {
                module2Placeholder.style.display = 'block';
                module2Content.style.display = 'none';
                return;
            }

            try {
                let response;
                const countryCode = getCurrentCountryCode();

                // If custom peer data is available, send it with the request (POST)
                if (customPeerData && customPeerData.customPeers && customPeerData.customPeers.length > 0) {
                    console.log('Using custom peer data for analysis:', customPeerData.customPeers.length, 'peers');
                    response = await fetch('/Rosra/GetPeerSNGAnalysisWithCustomPeers', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            Sng: sngName,
                            CountryCode: countryCode,
                            CustomPeers: customPeerData.customPeers.map(p => ({
                                Sng: p.sng,
                                Osr: p.osr,
                                Gcp: p.gcp,
                                Include: p.include !== false
                            }))
                        })
                    });
                } else {
                    // Use reference data from database (GET)
                    console.log('Using reference data for analysis');
                    const url = countryCode
                        ? `/Rosra/GetPeerSNGAnalysis?sng=${encodeURIComponent(sngName)}&countryCode=${encodeURIComponent(countryCode)}`
                        : `/Rosra/GetPeerSNGAnalysis?sng=${encodeURIComponent(sngName)}`;
                    response = await fetch(url);
                }
                const data = await response.json();

                if (!data.success) {
                    console.warn('Peer SNG Analysis failed:', data.message);
                    module2Placeholder.style.display = 'block';
                    module2Content.style.display = 'none';
                    return;
                }

                // Debug logging - check browser console (F12) to see calculation details
                console.log('=== Peer SNG Analysis Debug ===');
                console.log('Selected SNG:', data.sng);
                console.log('--- KEY VALUES ---');
                console.log('Actual OSR:', data.metrics.actualOSR);
                console.log('Subnational GDP:', data.metrics.subnationalGDP);
                console.log('Peer Frontier Multiplier:', data.metrics.peerFrontierMultiplier);
                console.log('OSR Potential:', data.metrics.osrPotential);
                console.log('OSR Gap:', data.metrics.osrGap);
                console.log('Performance Index:', data.metrics.performanceIndex, '%');
                if (data.debug) {
                    console.log('--- CALCULATION DEBUG ---');
                    console.log('Total peers in DB:', data.debug.totalPeersInDb);
                    console.log('Peers with Include=true:', data.debug.peersWithIncludeTrue);
                    console.log('Peers with valid data:', data.debug.peersWithValidData);
                    console.log('90th percentile threshold:', data.debug.percentile90Threshold);
                    console.log('Top multipliers count:', data.debug.topMultipliersCount);
                    console.log('Top multipliers:', data.debug.topMultipliers.join(', '));
                    console.log('Calculation:', data.debug.calculationSteps.step5_osrPotential);
                }

                if (true) {
                    // Hide placeholder, show content
                    module2Placeholder.style.display = 'none';
                    module2Content.style.display = 'block';

                    // Extract metrics from the nested object
                    const metrics = data.metrics;

                    // Update metric values (format like Excel - multipliers as decimals, performance as decimal)
                    document.getElementById('m2ActualOSRTop').textContent = formatCurrency(metrics.actualOSR);
                    document.getElementById('m2SubnationalGDPTop').textContent = formatCurrency(metrics.subnationalGDP);
                    document.getElementById('m2FrontierMultiplierTop').textContent = metrics.peerFrontierMultiplier.toFixed(6);
                    document.getElementById('m2SubjectMultiplierTop').textContent = metrics.subjectMultiplier.toFixed(6);
                    document.getElementById('m2OSRPotentialTop').textContent = formatCurrency(metrics.osrPotential);
                    document.getElementById('m2OSRGapTop').textContent = formatCurrency(metrics.osrGap);
                    document.getElementById('m2PerformanceIndexTop').textContent = (metrics.performanceIndex / 100).toFixed(6);

                    // Update performance bar (performanceIndex is already a percentage from the API)
                    const performanceBar = document.getElementById('m2PerformanceBarTop');
                    const performancePercent = Math.min(metrics.performanceIndex, 100);
                    performanceBar.style.width = performancePercent + '%';

                    // Transform chartData to expected format (x = gdp, y = osr)
                    const chartDataTransformed = data.chartData.map(p => ({
                        name: p.name,
                        x: p.gdp,
                        y: p.osr
                    }));

                    // Create the Peer Frontier Scatter Chart with helper data for frontier line
                    createPeerFrontierScatterChart(chartDataTransformed, data.frontierSlope, sngName, data.helpers);

                    // Create the Actual vs Potential Bar Chart (including OSR Gap)
                    createActualVsPotentialChart(metrics.actualOSR, metrics.osrPotential, metrics.osrGap);

                    // Update the analysis result text (performanceIndex is already %, so divide by 100)
                    updateModule2ResultText(metrics.performanceIndex / 100, metrics.osrGap, sngName, metrics.actualOSR, metrics.osrPotential);

                    // Update helper values for the modal (if modal elements exist)
                    if (data.helpers) {
                        const h = data.helpers;
                        const setTextIfExists = (id, value) => {
                            const el = document.getElementById(id);
                            if (el) el.textContent = value;
                        };
                        setTextIfExists('helperValidPeers', h.validPeersUsed);
                        setTextIfExists('helperTop20Count', h.top20Count);
                        setTextIfExists('helperFrontierMultiplier', h.frontierMultiplier.toFixed(8));
                        setTextIfExists('helperPercentile80', h.percentile80Threshold.toFixed(8));
                        setTextIfExists('helperMinGDP', formatCurrency(h.minGDP));
                        setTextIfExists('helperMaxGDP', formatCurrency(h.maxGDP));
                        setTextIfExists('helperFrontierYMin', h.frontierYAtMinGDP.toFixed(2));
                        setTextIfExists('helperFrontierYMax', h.frontierYAtMaxGDP.toFixed(2));
                        setTextIfExists('helperSubjectMultiplier', h.subjectMultiplier.toFixed(8));
                        setTextIfExists('helperOSRPotential', h.osrPotential.toFixed(2));
                        setTextIfExists('helperTopPerformers', h.topPerformersUsed);
                        setTextIfExists('helperAbove80th', h.isAbove80thPercentile ? 'Above 80th percentile' : 'Below 80th percentile');
                        setTextIfExists('helperActual', formatCurrency(metrics.actualOSR));
                        setTextIfExists('helperPotential', h.osrPotential.toFixed(2));
                    }

                    console.log('Peer SNG analysis loaded for:', sngName);
                } else {
                    console.log('Peer SNG analysis not available:', data.message);
                    module2Placeholder.innerHTML = `
                        <i class="bi bi-exclamation-circle"></i>
                        <p>${data.message || 'Analysis not available for this subnational government'}</p>
                    `;
                    module2Placeholder.style.display = 'block';
                    module2Content.style.display = 'none';
                }
            } catch (error) {
                console.error('Error fetching peer SNG analysis:', error);
                module2Placeholder.innerHTML = `
                    <i class="bi bi-exclamation-triangle"></i>
                    <p>Error loading peer SNG analysis</p>
                `;
                module2Placeholder.style.display = 'block';
                module2Content.style.display = 'none';
            }
        }

        // Format currency helper
        function formatCurrency(value) {
            if (value === null || value === undefined || isNaN(value)) return '-';
            return value.toLocaleString(undefined, { maximumFractionDigits: 0 });
        }

        // Format percentage helper
        function formatPercentage(value) {
            if (value === null || value === undefined || isNaN(value)) return '-';
            return (value * 100).toFixed(2) + '%';
        }

        // Create Peer Frontier Scatter Chart
        function createPeerFrontierScatterChart(chartData, frontierSlope, selectedSng, helpers) {
            const ctx = document.getElementById('peerSngChartTop');
            if (!ctx) return;

            // Destroy existing chart if it exists
            if (peerFrontierScatterChart) {
                peerFrontierScatterChart.destroy();
            }

            // Separate the selected SNG from other peers
            const otherPeers = chartData.filter(p => p.name !== selectedSng);
            const selectedPeer = chartData.find(p => p.name === selectedSng);

            // Calculate frontier line using helper values (from MinGDP to MaxGDP)
            // This matches Excel: X = {MinGDP, MaxGDP}, Y = {FrontierY@Min, FrontierY@Max}
            const frontierLineData = helpers ? [
                { x: helpers.minGDP, y: helpers.frontierYAtMinGDP },
                { x: helpers.maxGDP, y: helpers.frontierYAtMaxGDP }
            ] : [
                { x: 0, y: 0 },
                { x: Math.max(...chartData.map(p => p.x)) * 1.1, y: Math.max(...chartData.map(p => p.x)) * 1.1 * frontierSlope }
            ];

            peerFrontierScatterChart = new Chart(ctx, {
                type: 'scatter',
                data: {
                    datasets: [
                        // Peers (all peer SNGs except selected)
                        {
                            label: 'Peers',
                            data: otherPeers.map(p => ({ x: p.x, y: p.y, name: p.name })),
                            backgroundColor: 'rgba(68, 114, 196, 0.7)',
                            borderColor: '#4472C4',
                            pointRadius: 6,
                            pointHoverRadius: 8,
                            pointStyle: 'circle',
                            datalabels: {
                                display: false // Don't show labels for all peers
                            }
                        },
                        // Frontier line (Top-20% avg)
                        {
                            label: 'Frontier (Top-20% avg)',
                            data: frontierLineData,
                            borderColor: '#ED7D31',
                            borderWidth: 2,
                            pointRadius: 0,
                            showLine: true,
                            fill: false,
                            tension: 0,
                            datalabels: {
                                display: false
                            }
                        },
                        // Selected SNG (highlighted point)
                        {
                            label: selectedSng,
                            data: selectedPeer ? [{ x: selectedPeer.x, y: selectedPeer.y }] : [],
                            backgroundColor: '#70AD47',
                            borderColor: '#70AD47',
                            pointRadius: 10,
                            pointHoverRadius: 12,
                            pointStyle: 'circle',
                            datalabels: {
                                display: true,
                                align: 'top',
                                anchor: 'end',
                                offset: 5,
                                color: '#70AD47',
                                font: { weight: 'bold', size: 11 },
                                formatter: function(value) {
                                    return selectedSng;
                                }
                            }
                        }
                    ]
                },
                plugins: [ChartDataLabels],
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'bottom',
                            labels: {
                                usePointStyle: true,
                                padding: 10,
                                font: { size: 10 }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    // Skip tooltip for frontier line
                                    if (context.datasetIndex === 1) return null;
                                    const point = context.raw;
                                    // For peers, try to find the name
                                    if (context.datasetIndex === 0) {
                                        const peerIndex = context.dataIndex;
                                        const peerName = otherPeers[peerIndex]?.name || 'Peer';
                                        return `${peerName}: GDP per capita ${point.x.toLocaleString()}, OSR per capita ${point.y.toLocaleString()}`;
                                    }
                                    // For selected SNG
                                    return `${selectedSng}: GDP per capita ${point.x.toLocaleString()}, OSR per capita ${point.y.toLocaleString()}`;
                                }
                            }
                        },
                        datalabels: {
                            display: false // Default off, enabled per dataset
                        }
                    },
                    scales: {
                        x: {
                            title: {
                                display: true,
                                text: 'Subnational GDP per capita (economic base)',
                                font: { size: 12, weight: 'bold' }
                            },
                            ticks: {
                                font: { size: 11, weight: '500' },
                                color: '#333',
                                autoSkip: true,
                                maxTicksLimit: 8,
                                callback: function(value) {
                                    if (value >= 1000000000) return (value / 1000000000).toFixed(1) + 'B';
                                    if (value >= 1000000) return (value / 1000000).toFixed(1) + 'M';
                                    if (value >= 1000) {
                                        var k = value / 1000;
                                        return (k % 1 === 0) ? k.toFixed(0) + 'K' : k.toFixed(1) + 'K';
                                    }
                                    return value.toLocaleString();
                                }
                            },
                            grid: { color: '#e9ecef' },
                            beginAtZero: true,
                            suggestedMax: Math.max(...chartData.map(p => p.x)) * 1.2
                        },
                        y: {
                            title: {
                                display: true,
                                text: 'Own-Source Revenues (OSR) per capita',
                                font: { size: 12, weight: 'bold' }
                            },
                            ticks: {
                                font: { size: 11, weight: '500' },
                                color: '#333',
                                autoSkip: true,
                                maxTicksLimit: 8,
                                callback: function(value) {
                                    if (value >= 1000000000) return (value / 1000000000).toFixed(1) + 'B';
                                    if (value >= 1000000) return (value / 1000000).toFixed(1) + 'M';
                                    if (value >= 1000) {
                                        var k = value / 1000;
                                        return (k % 1 === 0) ? k.toFixed(0) + 'K' : k.toFixed(1) + 'K';
                                    }
                                    return value.toLocaleString();
                                }
                            },
                            grid: { color: '#e9ecef' },
                            beginAtZero: true,
                            suggestedMax: Math.max(...chartData.map(p => p.y)) * 1.2
                        }
                    }
                }
            });
            if (window.registerChart) registerChart('peerSngChartTop', peerFrontierScatterChart);
        }

        // Custom plugin to draw values on bars
        const barValuePlugin = {
            id: 'barValuePlugin',
            afterDatasetsDraw: function(chart) {
                const ctx = chart.ctx;
                const chartData = chart.data;
                const colors = ['#00b2e3', '#0095c0', '#FD9D24'];

                function formatValue(value) {
                    if (value >= 1000000000) return (value / 1000000000).toFixed(2) + 'B';
                    if (value >= 1000000) return (value / 1000000).toFixed(2) + 'M';
                    if (value >= 1000) return (value / 1000).toFixed(1) + 'K';
                    return value.toLocaleString(undefined, { maximumFractionDigits: 0 });
                }

                chart.data.datasets.forEach(function(dataset, datasetIndex) {
                    const meta = chart.getDatasetMeta(datasetIndex);
                    meta.data.forEach(function(bar, index) {
                        const value = dataset.data[index];
                        const formattedValue = formatValue(value);

                        ctx.save();
                        ctx.font = 'bold 12px Arial';
                        ctx.fillStyle = colors[index] || '#333';
                        ctx.textAlign = 'left';
                        ctx.textBaseline = 'middle';

                        // Position text at end of bar + offset
                        const x = bar.x + 10;
                        const y = bar.y;

                        ctx.fillText(formattedValue, x, y);
                        ctx.restore();
                    });
                });
            }
        };

        let actualVsPotentialChart = null;

        // Create Actual vs Potential Bar Chart (Chart.js with custom plugin)
        function createActualVsPotentialChart(actualOSR, osrPotential, osrGap) {
            const ctx = document.getElementById('actualVsPotentialChart');
            if (!ctx) return;

            // Destroy existing chart
            if (actualVsPotentialChart) {
                actualVsPotentialChart.destroy();
            }

            actualVsPotentialChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Current OSR per capita', 'Frontier benchmark per capita', 'Gap to frontier benchmark'],
                    datasets: [{
                        data: [actualOSR, osrPotential, osrGap],
                        backgroundColor: ['#00b2e3', '#0095c0', '#FD9D24'],
                        borderWidth: 0,
                        barThickness: 28
                    }]
                },
                plugins: [barValuePlugin],
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    indexAxis: 'y',
                    layout: {
                        padding: { right: 80 }
                    },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.parsed.x.toLocaleString();
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            display: true,
                            ticks: {
                                font: { size: 11, weight: '500' },
                                color: '#333',
                                autoSkip: true,
                                callback: function(value) {
                                    if (value >= 1000000000) return (value / 1000000000).toFixed(1) + 'B';
                                    if (value >= 1000000) return (value / 1000000).toFixed(1) + 'M';
                                    if (value >= 1000) {
                                        var k = value / 1000;
                                        return (k % 1 === 0) ? k.toFixed(0) + 'K' : k.toFixed(1) + 'K';
                                    }
                                    return value;
                                }
                            },
                            grid: { color: '#e9ecef' },
                            beginAtZero: true
                        },
                        y: {
                            ticks: {
                                font: { size: 11, weight: '500' },
                                color: '#333'
                            },
                            grid: { display: false }
                        }
                    }
                }
            });
            if (window.registerChart) registerChart('actualVsPotentialChart', actualVsPotentialChart);
        }

        // Update Module 2 Analysis Result Text
        // Localized analysis result templates (injected from server-side resources)
        var _resultTemplates = {
            largeGap: '@Html.Raw(Localizer["JS_Result_LargeGap"].Value.Replace("'", "\\'"))',
            meaningfulGap: '@Html.Raw(Localizer["JS_Result_MeaningfulGap"].Value.Replace("'", "\\'"))',
            closeToFrontier: '@Html.Raw(Localizer["JS_Result_CloseToFrontier"].Value.Replace("'", "\\'"))'
        };

        function updateModule2ResultText(performanceIndex, osrGap, sngName, actualOSR, osrPotential) {
            const resultText = document.getElementById('module2ResultTextTop');
            if (!resultText) return;

            const perfPercent = Math.round(performanceIndex * 100);
            const actualFormatted = Math.round(actualOSR).toLocaleString();
            const potentialFormatted = Math.round(osrPotential).toLocaleString();
            const gapFormatted = Math.round(osrGap).toLocaleString();

            let template = '';
            if (performanceIndex < 0.3) {
                template = _resultTemplates.largeGap;
            } else if (performanceIndex < 0.7) {
                template = _resultTemplates.meaningfulGap;
            } else {
                template = _resultTemplates.closeToFrontier;
            }

            // Replace {0},{1},{2},{3} placeholders with actual values
            resultText.textContent = template
                .replace('{0}', perfPercent)
                .replace('{1}', actualFormatted)
                .replace('{2}', potentialFormatted)
                .replace('{3}', gapFormatted);
        }

        // Handle Peer SNG selection change
        peerSngSelect.addEventListener('change', function() {
            fetchPeerSNGAnalysis(this.value);

            // Sync with State/Region dropdown (two-way binding)
            if (this.value && regionSelect) {
                // Check if the value exists in regionSelect
                const matchingOption = Array.from(regionSelect.options).find(opt =>
                    opt.value.toLowerCase() === this.value.toLowerCase() ||
                    opt.text.toLowerCase() === this.value.toLowerCase()
                );
                if (matchingOption && regionSelect.value !== matchingOption.value) {
                    regionSelect.value = matchingOption.value;
                    // Trigger change event on regionSelect to update any dependent logic
                    regionSelect.dispatchEvent(new Event('change', { bubbles: true }));
                    // Update Select2 if used
                    if (typeof $ !== 'undefined' && $.fn.select2 && $(regionSelect).data('select2')) {
                        $(regionSelect).trigger('change.select2');
                    }
                }
            }
        });

        // ========================================
        // SYNC STATE/REGION WITH SUBNATIONAL GOVERNMENT
        // ========================================
        // When State/Region changes, update Subnational Government dropdown
        regionSelect.addEventListener('change', function() {
            // Reset lower levels when Level 1 changes
            if (!this.value) {
                cityInput.value = '';
                govUnitLevel3Input.value = '';
                level1IsFinal.checked = false;
                level2IsFinal.checked = false;
            }
            updateGovernmentUnitVisibility();

            // Sync with PeerSNG dropdown
            if (this.value && peerSngSelect) {
                const matchingOption = Array.from(peerSngSelect.options).find(opt =>
                    opt.value.toLowerCase() === this.value.toLowerCase() ||
                    opt.text.toLowerCase() === this.value.toLowerCase()
                );
                if (matchingOption && peerSngSelect.value !== matchingOption.value) {
                    peerSngSelect.value = matchingOption.value;
                    if (typeof $ !== 'undefined' && $.fn.select2 && $(peerSngSelect).data('select2')) {
                        $(peerSngSelect).trigger('change.select2');
                    }
                    fetchPeerSNGAnalysis(matchingOption.value);
                }
            }
        });

        // ========================================
        // HELPERS MODAL HANDLING (Bootstrap)
        // ========================================
        const viewHelpersBtn = document.getElementById('viewHelpersBtn');
        const helpersModalElement = document.getElementById('helpersModalOverlay');
        let helpersModal = null;

        // Initialize Bootstrap modal
        if (helpersModalElement) {
            helpersModal = new bootstrap.Modal(helpersModalElement);
        }

        // Open modal
        if (viewHelpersBtn && helpersModal) {
            viewHelpersBtn.addEventListener('click', function() {
                helpersModal.show();
            });
        }

        // ========================================
        // FORMULA TOOLTIP HANDLING
        // ========================================
        let activeFormulaPopup = null;

        function showFormulaPopup(button) {
            // Remove any existing popup
            hideFormulaPopup();

            const formula = button.getAttribute('data-formula');
            if (!formula) return;

            // Create popup element
            const popup = document.createElement('div');
            popup.className = 'formula-popup';
            popup.innerHTML = `
                <div class="formula-popup-header">
                    <i class="bi bi-code-slash"></i>
                    <span>Formula</span>
                </div>
                <div class="formula-popup-content">${formula}</div>
            `;

            document.body.appendChild(popup);
            activeFormulaPopup = popup;

            // Position the popup near the button
            const buttonRect = button.getBoundingClientRect();
            const popupRect = popup.getBoundingClientRect();

            // Calculate position
            let left = buttonRect.left + (buttonRect.width / 2) - 20;
            let top = buttonRect.bottom + 8;

            // Check if popup goes off right edge
            if (left + popupRect.width > window.innerWidth - 10) {
                left = window.innerWidth - popupRect.width - 10;
                popup.classList.add('arrow-right');
            }

            // Check if popup goes off bottom edge
            if (top + popupRect.height > window.innerHeight - 10) {
                top = buttonRect.top - popupRect.height - 8;
                popup.style.setProperty('--arrow-position', 'bottom');
            }

            popup.style.left = `${Math.max(10, left)}px`;
            popup.style.top = `${top}px`;
        }

        function hideFormulaPopup() {
            if (activeFormulaPopup) {
                activeFormulaPopup.remove();
                activeFormulaPopup = null;
            }
        }

        // Event delegation for formula tooltip buttons
        document.addEventListener('click', function(e) {
            const tooltipBtn = e.target.closest('.formula-tooltip-btn');

            if (tooltipBtn) {
                e.preventDefault();
                e.stopPropagation();

                // If clicking the same button, toggle off
                if (activeFormulaPopup && tooltipBtn.dataset.popupActive === 'true') {
                    hideFormulaPopup();
                    tooltipBtn.dataset.popupActive = 'false';
                } else {
                    // Remove active state from all buttons
                    document.querySelectorAll('.formula-tooltip-btn').forEach(btn => {
                        btn.dataset.popupActive = 'false';
                    });

                    showFormulaPopup(tooltipBtn);
                    tooltipBtn.dataset.popupActive = 'true';
                }
            } else {
                // Click outside - close popup
                hideFormulaPopup();
                document.querySelectorAll('.formula-tooltip-btn').forEach(btn => {
                    btn.dataset.popupActive = 'false';
                });
            }
        });

        // Close popup on scroll
        document.addEventListener('scroll', hideFormulaPopup, true);

        // Load Select2 dynamically after jQuery is available, then load Peer SNGs
        function loadSelect2ThenPeerSNGs() {
            if (typeof $ !== 'undefined') {
                // Check if Select2 is already loaded
                if ($.fn.select2) {
                    loadPeerSNGs();
                } else {
                    // Load Select2 script dynamically
                    const script = document.createElement('script');
                    script.src = 'https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js';
                    script.onload = function() {
                        loadPeerSNGs();
                    };
                    script.onerror = function() {
                        console.warn('Failed to load Select2, loading Peer SNGs without it');
                        loadPeerSNGs();
                    };
                    document.head.appendChild(script);
                }
            } else {
                // jQuery not loaded yet, wait and retry
                setTimeout(loadSelect2ThenPeerSNGs, 100);
            }
        }

        // Note: loadSelect2ThenPeerSNGs() is now called from loadCountries() after countries are loaded
        // This ensures peer SNGs are loaded after the country dropdown is populated

        // Expose functions to global scope for onclick handlers in HTML
        window.addPeerRow = addPeerRow;
        window.removePeerRow = removePeerRow;
        window.savePeerDataManually = savePeerDataManually;
        window.uploadPeerCSV = uploadPeerCSV;

    });
</script>