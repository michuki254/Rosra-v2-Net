        async function loadPeerSNGs() {
            try {
                const countryCode = getCurrentCountryCode();

                // If custom peer data exists for this country, use it instead of reference data
                if (customPeerData && customPeerData.customPeers && customPeerData.customPeers.length > 0) {
                    // Check if custom data matches current country
                    if (!customPeerData.countryCode || customPeerData.countryCode === countryCode) {
                        console.log('Using custom peer data:', customPeerData.customPeers.length, 'peers');
                        populatePeerDropdownFromCustomData(customPeerData.customPeers);
                        togglePeerDataInputSection(false);

                        // Select saved SNG if available
                        const defaultPeerSNG = savedRegion || customPeerData.customPeers[0]?.sng;
                        if (defaultPeerSNG) {
                            const matchingOption = Array.from(peerSngSelect.options).find(opt =>
                                opt.value.toLowerCase() === defaultPeerSNG.toLowerCase()
                            );
                            if (matchingOption) {
                                peerSngSelect.value = matchingOption.value;
                                if (typeof $ !== 'undefined' && $.fn.select2 && $(peerSngSelect).data('select2')) {
                                    $(peerSngSelect).trigger('change.select2');
                                }
                                fetchPeerSNGAnalysis(matchingOption.value);
                            }
                        }
                        return;
                    } else {
                        // Country changed, clear custom data
                        console.log('Country changed, clearing custom peer data');
                        customPeerData = null;
                    }
                }

                // Fetch reference data from database
                const url = countryCode ? `/Rosra/GetPeerSNGs?countryCode=${countryCode}` : '/Rosra/GetPeerSNGs';
                const response = await fetch(url);
                const peers = await response.json();

                console.log('Loaded', peers.length, 'peer SNGs from reference data for country:', countryCode);

                // Clear existing options except the placeholder
                peerSngSelect.innerHTML = '<option value="">Select a subnational government...</option>';

                // Show/hide peer data input section based on availability
                if (countryCode && countryCode !== 'KEN' && peers.length === 0) {
                    togglePeerDataInputSection(true);
                } else {
                    togglePeerDataInputSection(false);
                }

                // Add peer SNGs to the dropdown
                const defaultPeerSNG = savedRegion || '';
                peers.forEach(peer => {
                    const option = document.createElement('option');
                    option.value = peer.name;
                    option.textContent = peer.name;
                    // Select default SNG
                    if (peer.name === defaultPeerSNG) {
                        option.selected = true;
