        // Save manually entered peer data (to memory, not database)
        async function savePeerDataManually() {
            const countryCode = getCurrentCountryCode();
            if (!countryCode) {
                alert('Please select a country first');
                return;
            }

            const tbody = document.getElementById('peerManualEntryBody');
            const rows = tbody.querySelectorAll('tr');
            const peers = [];

            rows.forEach(row => {
                const inputs = row.querySelectorAll('input');
                const name = inputs[0].value.trim();
                const osr = parseFloat(inputs[1].value) || 0;
                const gcp = parseFloat(inputs[2].value) || 0;

                if (name && (osr > 0 || gcp > 0)) {
                    peers.push({ sng: name, osr: osr, gcp: gcp, include: true });
                }
            });

            if (peers.length === 0) {
                alert('Please enter at least one peer with valid data');
                return;
            }

            try {
                // Validate data with server (no database write)
                const response = await fetch('/Rosra/SavePeerSNGs', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ CountryCode: countryCode, Peers: peers.map(p => ({ SNG: p.sng, OSR: p.osr, GCP: p.gcp })) })
                });
                const result = await response.json();

                if (result.success) {
                    // Store custom data in memory (will be saved with report)
                    customPeerData = {
                        dataSource: 'custom',
                        countryCode: countryCode,
                        customPeers: peers,
                        timestamp: new Date().toISOString()
                    };

                    console.log('Custom peer data stored in memory:', customPeerData);

                    // Populate dropdown from custom data
                    populatePeerDropdownFromCustomData(peers);

                    // Hide input section and show success message
                    togglePeerDataInputSection(false);
                    showPeerDataSuccessMessage(`${peers.length} peers ready. Data will be saved with your report.`);
                } else {
                    alert('Error: ' + result.message);
                }
            } catch (e) {
                console.error('Error validating peer data:', e);
                alert('Error validating data. Please try again.');
            }
        }

