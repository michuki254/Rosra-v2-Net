@model RosraApp.Models.ViewModels.RosraFormViewModel
@inject IHtmlLocalizer<RosraApp.RosraResources> RosraLocalizer
@{
    bool isViewMode = ViewData["ViewMode"] != null && (bool)ViewData["ViewMode"];
    int currentYear = DateTime.Now.Year;
}

<div class="potential-estimates-container">
    <!-- Top-Down Analysis Intro Section -->
    <div class="top-down-intro-section mb-4">
        <div class="intro-text-box">
            <i class="bi bi-info-circle-fill intro-icon"></i>
            <p class="intro-text">@Localizer["Intro_Text"]</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Top Panel - Compact Input Form (Full Width) -->
        <div class="col-12">
            <div class="input-panel">
                <!-- Combined Data Input Card -->
                <div class="input-card compact-card">
                    <div class="input-card-header compact-header collapsible-header" data-bs-toggle="collapse" data-bs-target="#dataInputBody" aria-expanded="true" aria-controls="dataInputBody" style="cursor: pointer;">
                        <div class="header-icon">
                            <i class="bi bi-pencil-square"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h5 class="card-title mb-0">@Localizer["DataInputBlock"]</h5>
                            <p class="card-subtitle mb-0">@Localizer["EnterInfo"]</p>
                        </div>
                        <div class="collapse-toggle-btn">
                            <i class="bi bi-chevron-up collapse-icon"></i>
                        </div>
                    </div>
                    <div class="collapse show" id="dataInputBody">
                    <div class="input-card-body compact-body">
                        <input type="hidden" id="currencySymbol" name="CurrencySymbol" value="@Model.CurrencySymbol">

                        <!-- Row 1: Country & Financial Year -->
                        <div class="compact-row">
                            <div class="compact-field">
                                <label class="compact-label">@Localizer["Country"]</label>
                                <div class="country-select-wrapper">
                                    <img id="country-flag" class="country-flag" src="" alt="" style="display: none;">
                                    <select class="form-select form-select-sm @(isViewMode ? "readonly" : "")" id="country" name="Country" @(isViewMode ? "disabled" : "")>
                                        <option value="">@Localizer["SelectCountry"]</option>
                                    </select>
                                </div>
                            </div>
                            <div class="compact-field">
                                <label class="compact-label">@Localizer["FinancialYear"]</label>
                                <select class="form-select form-select-sm @(isViewMode ? "readonly" : "")" id="financialYear" name="FinancialYear" @(isViewMode ? "disabled" : "")>
                                    <option value="">@Localizer["SelectYear"]</option>
                                </select>
                            </div>
                        </div>

                        <!-- Row 2: Government Unit Level 1 (hidden until country selected) -->
                        <div class="compact-row single" id="govUnitLevel1Row" style="display: none;">
                            <div class="compact-field full-width">
                                <label class="compact-label">@Localizer["GovUnit1"]</label>
                                <small class="gov-unit-helper">@Localizer["GovUnit1Helper"]</small>
                                <select class="form-select form-select-sm @(isViewMode ? "readonly" : "")" id="region" name="Region" @(isViewMode ? "disabled" : "")>
                                    <option value="">@Localizer["SelectLevel1"]</option>
                                </select>
                                <div class="form-check mt-1">
                                    <input class="form-check-input" type="checkbox" id="level1IsFinal" @(isViewMode ? "disabled" : "")>
                                    <label class="form-check-label gov-unit-checkbox-label" for="level1IsFinal">
                                        @Localizer["Level1Final"]
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Row 3: Government Unit Level 2 (hidden until L1 selected & L1 unchecked) -->
                        <div class="compact-row single" id="govUnitLevel2Row" style="display: none;">
                            <div class="compact-field full-width">
                                <label class="compact-label">@Localizer["GovUnit2"]</label>
                                <small class="gov-unit-helper">@Localizer["GovUnit2Helper"]</small>
                                <input type="text" class="form-control form-control-sm @(isViewMode ? "readonly" : "")"
                                       id="city" name="City" value="@Model.City"
                                       placeholder="@Localizer["EnterLevel2"]" @(isViewMode ? "readonly" : "")>
                                <div class="form-check mt-1">
                                    <input class="form-check-input" type="checkbox" id="level2IsFinal" @(isViewMode ? "disabled" : "")>
                                    <label class="form-check-label gov-unit-checkbox-label" for="level2IsFinal">
                                        @Localizer["Level2Final"]
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Row 4: Government Unit Level 3 (hidden until L2 filled & L2 unchecked) -->
                        <div class="compact-row single" id="govUnitLevel3Row" style="display: none;">
                            <div class="compact-field full-width">
                                <label class="compact-label">Government Unit Level 3</label>
                                <small class="gov-unit-helper">e.g. ward, borough, arrondissement, subcounty, zone, neighborhood</small>
                                <input type="text" class="form-control form-control-sm @(isViewMode ? "readonly" : "")"
                                       id="govUnitLevel3" name="GovUnitLevel3" value="@Model.GovUnitLevel3"
                                       placeholder="Enter level 3 unit" @(isViewMode ? "readonly" : "")>
                            </div>
                        </div>

                        <!-- Hidden field for final unit level -->
                        <input type="hidden" id="finalUnitLevel" name="FinalUnitLevel" value="@Model.FinalUnitLevel">

                        <!-- Hierarchy note -->
                        <div class="gov-unit-note" id="hierarchyNote" style="display: none;">
                            <i class="bi bi-info-circle"></i>
                            <span>@Localizer["HierarchyNote"]</span>
                        </div>

                        <!-- Row 5: Currency (auto) & Income Level (auto) -->
                        <div class="compact-row">
                            <div class="compact-field">
                                <label class="compact-label">@Localizer["Currency"]</label>
                                <div class="auto-value-display" id="currency-display">
                                    <span class="currency-badge" id="currency-symbol">@(string.IsNullOrEmpty(Model.CurrencySymbol) ? "-" : Model.CurrencySymbol)</span>
                                    <input type="text" class="form-control form-control-sm readonly-auto"
                                           id="currency" name="Currency" value="@Model.Currency"
                                           placeholder="-" readonly>
                                </div>
                            </div>
                            <div class="compact-field">
                                <label class="compact-label">@Localizer["IncomeLevel"]</label>
                                <input type="text" class="form-control form-control-sm readonly-auto"
                                       id="incomeLevel" name="IncomeLevel" value="@Model.IncomeLevel"
                                       placeholder="-" readonly>
                            </div>
                        </div>

                        <!-- Row 5b: Currency Override Toggle -->
                        <div class="compact-row single" id="currencyOverrideRow">
                            <div class="compact-field full-width">
                                <div class="currency-override-toggle">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" id="useDifferentCurrency" @(isViewMode ? "disabled" : "")>
                                        <label class="form-check-label" for="useDifferentCurrency">
                                            @Localizer["CurrencyOverride"]
                                        </label>
                                    </div>
                                </div>
                                <div class="currency-override-select" id="currencyOverrideSelect" style="display: none;">
                                    <label class="compact-label">@Localizer["OverrideCurrency"]</label>
                                    <select class="form-select form-select-sm" id="overrideCurrency" @(isViewMode ? "disabled" : "")>
                                        <option value="">-- Select currency --</option>
                                        <option value="USD" data-symbol="$" data-name="US Dollar">USD – US Dollar ($)</option>
                                        <option value="EUR" data-symbol="€" data-name="Euro">EUR – Euro (€)</option>
                                        <option value="GBP" data-symbol="£" data-name="British Pound">GBP – British Pound (£)</option>
                                        <option value="JPY" data-symbol="¥" data-name="Japanese Yen">JPY – Japanese Yen (¥)</option>
                                        <option value="CHF" data-symbol="CHF" data-name="Swiss Franc">CHF – Swiss Franc (CHF)</option>
                                        <option value="CAD" data-symbol="CA$" data-name="Canadian Dollar">CAD – Canadian Dollar (CA$)</option>
                                        <option value="AUD" data-symbol="A$" data-name="Australian Dollar">AUD – Australian Dollar (A$)</option>
                                        <option value="CNY" data-symbol="¥" data-name="Chinese Yuan">CNY – Chinese Yuan (¥)</option>
                                        <option value="INR" data-symbol="₹" data-name="Indian Rupee">INR – Indian Rupee (₹)</option>
                                        <option value="ZAR" data-symbol="R" data-name="South African Rand">ZAR – South African Rand (R)</option>
                                        <option value="BRL" data-symbol="R$" data-name="Brazilian Real">BRL – Brazilian Real (R$)</option>
                                        <option value="NGN" data-symbol="₦" data-name="Nigerian Naira">NGN – Nigerian Naira (₦)</option>
                                        <option value="EGP" data-symbol="E£" data-name="Egyptian Pound">EGP – Egyptian Pound (E£)</option>
                                        <option value="SAR" data-symbol="﷼" data-name="Saudi Riyal">SAR – Saudi Riyal (SAR)</option>
                                        <option value="AED" data-symbol="د.إ" data-name="UAE Dirham">AED – UAE Dirham (AED)</option>
                                        <option value="SGD" data-symbol="S$" data-name="Singapore Dollar">SGD – Singapore Dollar (S$)</option>
                                    </select>
                                    <small class="text-muted mt-1 d-block">
                                        <i class="bi bi-info-circle me-1"></i>@Localizer["CurrencyOverrideHelp"]
                                    </small>
                                </div>
                                <input type="hidden" id="overrideCurrencySymbol" name="OverrideCurrencySymbol" value="">
                            </div>
                        </div>

                        <!-- Row 6: Government Type (full width, auto) -->
                        <div class="compact-row single">
                            <div class="compact-field full-width">
                                <label class="compact-label">@Localizer["GovernmentType"]</label>
                                <input type="text" class="form-control form-control-sm readonly-auto"
                                       id="governmentType" name="GovernmentType" value="@Model.GovernmentType"
                                       placeholder="-" readonly>
                            </div>
                        </div>

                        <!-- Financial Metrics Section - Hidden (not useful for Top-Down analysis) -->
                        <div id="financialMetricsSection" style="display: none;">
                            <!-- Divider -->
                            <div class="compact-divider">
                                <span>Financial Metrics <span class="year-display">2024</span></span>
                            </div>

                            <!-- Row 5: Actual OSR & Budgeted OSR -->
                            <div class="compact-row">
                                <div class="compact-field">
                                    <label class="compact-label">Actual OSR</label>
                                    <div class="compact-currency-input">
                                        <span class="currency-prefix" id="actual-osr-currency">@(string.IsNullOrEmpty(Model.CurrencySymbol) ? "" : Model.CurrencySymbol)</span>
                                        <input type="text" class="form-control form-control-sm number-format @(isViewMode ? "readonly" : "")"
                                               id="actualOsr" name="ActualOsr" value="@(Model.ActualOsr?.ToString("#,##0.##"))"
                                               placeholder="0" @(isViewMode ? "readonly" : "")>
                                    </div>
                                </div>
                                <div class="compact-field">
                                    <label class="compact-label">Budgeted OSR</label>
                                    <div class="compact-currency-input">
                                        <span class="currency-prefix" id="budgeted-osr-currency">@(string.IsNullOrEmpty(Model.CurrencySymbol) ? "" : Model.CurrencySymbol)</span>
                                        <input type="text" class="form-control form-control-sm number-format @(isViewMode ? "readonly" : "")"
                                               id="budgetedOsr" name="BudgetedOsr" value="@(Model.BudgetedOsr?.ToString("#,##0.##"))"
                                               placeholder="0" @(isViewMode ? "readonly" : "")>
                                    </div>
                                </div>
                            </div>

                            <!-- Row 6: Population & GDP per capita -->
                            <div class="compact-row">
                                <div class="compact-field">
                                    <label class="compact-label">Population</label>
                                    <div class="compact-currency-input">
                                        <span class="currency-prefix"><i class="bi bi-people-fill"></i></span>
                                        <input type="text" class="form-control form-control-sm number-format @(isViewMode ? "readonly" : "")"
                                               id="population" name="Population" value="@(Model.Population?.ToString("#,##0"))"
                                               placeholder="0" @(isViewMode ? "readonly" : "")>
                                    </div>
                                </div>
                                <div class="compact-field">
                                    <label class="compact-label">GDP per capita <span class="usd-indicator" id="gdpUsdIndicator">(USD)</span></label>
                                    <div class="compact-currency-input">
                                        <span class="currency-prefix">$</span>
                                        <input type="text" class="form-control form-control-sm number-format @(isViewMode ? "readonly" : "")"
                                               id="gdpPerCapita" name="GdpPerCapita" value="@(Model.GdpPerCapita?.ToString("#,##0.##"))"
                                               placeholder="0" @(isViewMode ? "readonly" : "")>
                                    </div>
                                </div>
                            </div>
                        </div><!-- End hidden Financial Metrics Section -->
                    </div>
                    </div> <!-- Close collapse wrapper -->
                </div>
            </div>
        </div>

        <!-- Bottom Panel - Frontier Analysis (Full Width) -->
        <div class="col-12">
            <div class="analysis-panel">
                <!-- Within-Country OSR Frontier Header (PRIMARY) -->
                <div class="frontier-card">
                    <div class="frontier-header">
                        <div class="frontier-header-icon">
                            <i class="bi bi-building"></i>
                        </div>
                        <div class="frontier-header-content">
                            <h4 class="frontier-title">@Localizer["FrontierTitle"]</h4>
                            <p class="frontier-subtitle">@Localizer["FrontierSubtitle"]</p>
                        </div>
                    </div>

                    <!-- Placeholder when no country selected -->
                    <div class="frontier-placeholder" id="frontierPlaceholder">
                        <i class="bi bi-geo-alt"></i>
                        <p>@Localizer["SelectCountryForFrontier"]</p>
                    </div>

                    <!-- Frontier Analysis Content -->
                    <div class="frontier-content" id="frontierContent" style="display: none;">
                        <!-- PRIMARY ANALYSIS: Within-Country OSR Frontier - MOVED TO TOP -->
                        <div class="module2-section" id="withinCountryModuleTop">
                            <div class="module2-header">
                                <span class="module-number">1</span>
                                <div class="module-title-block">
                                    <h5 class="module-title">Within-Country OSR Frontier (Peer SNGs) <span class="badge bg-primary ms-2" style="font-size: 0.65rem;">Primary Analysis</span></h5>
                                    <p class="module-subtitle">Compare against domestic peer subnational governments</p>
                                </div>
                            </div>

                            <!-- SNG Selection -->
                            <div class="module2-selection">
                                <label class="compact-label">@Localizer["SubnationalGov"]</label>
                                <select class="form-select form-select-sm" id="peerSngSelectTop">
                                    <option value="">@Localizer["SelectSng"]</option>
                                </select>
                            </div>

                            <!-- Peer Data Input Section (for non-Kenya countries) -->
                            <div id="peerDataInputSection" class="peer-data-input-section" style="display: none;">
                                <div class="peer-data-alert">
                                    <i class="bi bi-info-circle"></i>
                                    <span>No peer SNG data found for this country. Upload peer data or enter manually below.</span>
                                </div>

                                <!-- CSV Upload Option -->
                                <div class="peer-upload-option mb-3">
                                    <label class="form-label fw-bold small">Option 1: Upload CSV File</label>
                                    <div class="input-group input-group-sm">
                                        <input type="file" class="form-control" id="peerCsvUpload" accept=".csv">
                                        <button type="button" class="btn btn-primary" onclick="uploadPeerCSV()">
                                            <i class="bi bi-upload"></i> Upload
                                        </button>
                                    </div>
                                    <small class="text-muted">CSV format: SNG,OSR,GCP (one row per subnational government)</small>
                                </div>

                                <!-- Manual Entry Option -->
                                <div class="peer-manual-entry">
                                    <label class="form-label fw-bold small">Option 2: Manual Entry</label>
                                    <div class="table-responsive">
                                        <table class="table table-sm table-bordered" id="peerManualEntryTable">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>SNG Name</th>
                                                    <th>OSR</th>
                                                    <th>GCP</th>
                                                    <th style="width: 40px;"></th>
                                                </tr>
                                            </thead>
                                            <tbody id="peerManualEntryBody">
                                                <tr>
                                                    <td><input type="text" class="form-control form-control-sm" placeholder="Name"></td>
                                                    <td><input type="number" class="form-control form-control-sm" placeholder="0" step="any"></td>
                                                    <td><input type="number" class="form-control form-control-sm" placeholder="0" step="any"></td>
                                                    <td><button type="button" class="btn btn-sm btn-outline-danger" onclick="removePeerRow(this)"><i class="bi bi-trash"></i></button></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                    <div class="d-flex gap-2 mt-2">
                                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="addPeerRow()">
                                            <i class="bi bi-plus"></i> Add Row
                                        </button>
                                        <button type="button" class="btn btn-sm btn-primary" onclick="savePeerDataManually()">
                                            <i class="bi bi-save"></i> Save Peer Data
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Module Placeholder -->
                            <div class="module2-placeholder" id="module2PlaceholderTop">
                                <i class="bi bi-geo-alt"></i>
                                <p>@Localizer["SelectSngForAnalysis"]</p>
                            </div>

                            <!-- Module Content (hidden by default) -->
                            <div class="module2-content" id="module2ContentTop" style="display: none;">
                                <!-- Metrics Section -->
                                <div class="module2-metrics">
                                    <div class="metric-row">
                                        <span class="metric-label">
                                            @Localizer["Metric_OSR"]
                                            <button type="button" class="formula-tooltip-btn" data-formula="XLOOKUP(SNG, Peers[SNG], Peers[OSR])">
                                                <i class="bi bi-info-circle"></i>
                                            </button>
                                        </span>
                                        <span class="metric-value" id="m2ActualOSRTop" style="font-size: 0.9rem;">-</span>
                                    </div>
                                    <div class="metric-row">
                                        <span class="metric-label">
                                            @Localizer["Metric_GDP"]
                                            <button type="button" class="formula-tooltip-btn" data-formula="XLOOKUP(SNG, Peers[SNG], Peers[GCP])">
                                                <i class="bi bi-info-circle"></i>
                                            </button>
                                        </span>
                                        <span class="metric-value" id="m2SubnationalGDPTop" style="font-size: 0.9rem;">-</span>
                                    </div>
                                    <div class="metric-row highlight">
                                        <span class="metric-label">
                                            @Localizer["Metric_FrontierMultiplier"]
                                            <button type="button" class="formula-tooltip-btn" data-formula="LET(m, SORT(FILTER(Peers[Mult], Peers[Mult]>0), ,-1), k, MAX(1,ROUNDUP(ROWS(m)*0.2,0)), AVERAGE(TAKE(m,k)))">
                                                <i class="bi bi-info-circle"></i>
                                            </button>
                                        </span>
                                        <span class="metric-value" id="m2FrontierMultiplierTop" style="font-size: 0.9rem;">-</span>
                                    </div>
                                    <div class="metric-row">
                                        <span class="metric-label">
                                            @Localizer["Metric_SubjectMultiplier"]
                                            <button type="button" class="formula-tooltip-btn" data-formula="IFERROR(OSR / GDP, 0)">
                                                <i class="bi bi-info-circle"></i>
                                            </button>
                                        </span>
                                        <span class="metric-value" id="m2SubjectMultiplierTop" style="font-size: 0.9rem;">-</span>
                                    </div>
                                    <div class="metric-row result">
                                        <span class="metric-label bold">
                                            @Localizer["Metric_Benchmark"]
                                            <button type="button" class="formula-tooltip-btn" data-formula="Frontier_Multiplier × Subnational_GDP_per_capita">
                                                <i class="bi bi-info-circle"></i>
                                            </button>
                                        </span>
                                        <span class="metric-value bold" id="m2OSRPotentialTop" style="font-size: 0.9rem;">-</span>
                                    </div>
                                    <div class="metric-row gap">
                                        <span class="metric-label gap-label">
                                            @Localizer["Metric_Gap"]
                                            <button type="button" class="formula-tooltip-btn" data-formula="Frontier_Benchmark - Current_OSR_per_capita">
                                                <i class="bi bi-info-circle"></i>
                                            </button>
                                        </span>
                                        <span class="metric-value gap-value" id="m2OSRGapTop" style="font-size: 0.9rem;">-</span>
                                    </div>
                                    <div class="metric-row with-bar">
                                        <span class="metric-label accent">
                                            @Localizer["Metric_Performance"]
                                            <button type="button" class="formula-tooltip-btn" data-formula="IFERROR(Actual_OSR / OSR_Potential, 0)">
                                                <i class="bi bi-info-circle"></i>
                                            </button>
                                        </span>
                                        <div class="metric-bar-container">
                                            <div class="metric-bar" id="m2PerformanceBarTop" style="width: 0%;"></div>
                                            <span class="metric-bar-value" id="m2PerformanceIndexTop">-</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Peer SNG Chart -->
                                <div class="module2-chart-section">
                                    <h6 class="chart-title">@Localizer["Chart_ScatterTitle"]</h6>
                                    <div class="chart-container" style="height: 350px;">
                                        <canvas id="peerSngChartTop"></canvas>
                                    </div>
                                </div>

                                <!-- Actual vs DFA Potential Bar Chart -->
                                <div class="module2-chart-section" style="margin-top: 2rem;">
                                    <h6 class="chart-title">@Localizer["Chart_BarTitle"]</h6>
                                    <div class="chart-container" style="height: 180px;">
                                        <canvas id="actualVsPotentialChart"></canvas>
                                    </div>
                                </div>

                                <!-- Analysis Result -->
                                <div class="analysis-result-section module2-result">
                                    <div class="analysis-result-header">
                                        <i class="bi bi-lightbulb"></i>
                                        <span>@Localizer["Result_Header"]</span>
                                    </div>
                                    <p class="analysis-result-text" id="module2ResultTextTop">
                                        @Localizer["Result_Placeholder"]
                                    </p>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <!-- OPTIONAL ANALYSIS SECTION HEADER -->
                        <div class="optional-analysis-header mb-3">
                            <h5 class="text-muted"><i class="bi bi-sliders me-2"></i>@Localizer["CrossCountry_Title"]</h5>
                            <p class="small text-muted">@Localizer["CrossCountry_Subtitle"]</p>
                        </div>

                        <!-- Optional Analysis: Funding Decentralization -->
                        <div class="frontier-section" id="fundingDecentralizationSection">
                            <div class="frontier-section-header">
                                <span class="frontier-section-number">A</span>
                                <h5 class="frontier-section-title">@Localizer["Funding_Title"] <span class="badge bg-secondary" style="font-size: 0.6rem;">@Localizer["Funding_Optional"]</span></h5>
                            </div>
                            <div class="frontier-metrics">
                                <div class="frontier-row">
                                    <div class="tooltip-trigger">
                                        <span class="frontier-label">@Localizer["Funding_SngRevenue"]</span>
                                        <button type="button" class="info-btn" data-tooltip-id="tip-sng-rev">
                                            <i class="bi bi-info"></i>
                                        </button>
                                        <div class="formula-tooltip" id="tip-sng-rev">
                                            <div class="tooltip-header">
                                                <i class="bi bi-database"></i>
                                                <span>Data Source</span>
                                            </div>
                                            <div class="formula-content">DB_Countries.SNG_total_rev_pc</div>
                                        </div>
                                    </div>
                                    <span class="frontier-value" id="sngRevenuePerCapita">-</span>
                                </div>
                                <div class="frontier-row highlight">
                                    <div class="tooltip-trigger">
                                        <span class="frontier-label">@Localizer["Funding_PeerBenchmark"]</span>
                                        <button type="button" class="info-btn" data-tooltip-id="tip-peer-funding">
                                            <i class="bi bi-info"></i>
                                        </button>
                                        <div class="formula-tooltip" id="tip-peer-funding">
                                            <div class="tooltip-header">
                                                <i class="bi bi-database"></i>
                                                <span>Data Source</span>
                                            </div>
                                            <div class="formula-content">DB_Frontiers.SNG_total_rev_pc_frontier</div>
                                        </div>
                                    </div>
                                    <span class="frontier-value" id="peerBenchmarkFunding">-</span>
                                </div>
                                <div class="frontier-row with-bar">
                                    <div class="tooltip-trigger">
                                        <span class="frontier-label accent">@Localizer["Funding_Index"]</span>
                                        <button type="button" class="info-btn" data-tooltip-id="tip-funding-index">
                                            <i class="bi bi-info"></i>
                                        </button>
                                        <div class="formula-tooltip" id="tip-funding-index">
                                            <div class="tooltip-header">
                                                <i class="bi bi-calculator"></i>
                                                <span>Formula</span>
                                            </div>
                                            <div class="formula-content">(SNG rev pc ÷ Peer benchmark) × 100</div>
                                        </div>
