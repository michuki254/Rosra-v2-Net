        // Track the auto-assigned (local) currency so we can revert to it
        let localCurrencySymbol = '@(Model.CurrencySymbol ?? "")';
        let localCurrencyName = '@(Model.Currency ?? "")';
        let localCurrencyCode = '';

        // Function to update all currency symbol displays
        function updateCurrencySymbols(symbol) {
            console.log('Setting currency symbol to:', symbol);

            // Store the local (auto-assigned) currency
            localCurrencySymbol = symbol || '';

            // If override is active, don't change the active currency — just update the local option in the dropdown
            const overrideToggle = document.getElementById('useDifferentCurrency');
            if (overrideToggle && overrideToggle.checked) {
                updateLocalCurrencyOption();
                return; // Keep using the override currency
            }

            applyActiveCurrency(symbol);
        }

        // Apply a currency symbol across all displays and AppContext
        function applyActiveCurrency(symbol) {
            const displaySymbol = symbol || '-';
            const valueSymbol = symbol || '';

            // Update AppContext (single source of truth) - this notifies all subscribers
            if (symbol && window.AppContext) {
                window.AppContext.set('currencySymbol', symbol);
            }

            document.getElementById('currencySymbol').value = valueSymbol;
            document.getElementById('currency-symbol').textContent = displaySymbol;
            document.getElementById('actual-osr-currency').textContent = valueSymbol;
            document.getElementById('budgeted-osr-currency').textContent = valueSymbol;

            // Update the hidden override field
            const overrideHidden = document.getElementById('overrideCurrencySymbol');
            if (overrideHidden) {
                const overrideToggle = document.getElementById('useDifferentCurrency');
                overrideHidden.value = (overrideToggle && overrideToggle.checked) ? symbol : '';
            }
        }

        // Update the "Local currency" option in the override dropdown
        function updateLocalCurrencyOption() {
            const dropdown = document.getElementById('overrideCurrency');
            if (!dropdown) return;

            // Remove existing local currency option if present
            const existing = dropdown.querySelector('option[data-local="true"]');
            if (existing) existing.remove();

            // Add the current local currency as the first option after the placeholder
            if (localCurrencySymbol) {
                const countrySelect = document.getElementById('country');
                const selectedOpt = countrySelect ? countrySelect.options[countrySelect.selectedIndex] : null;
                const code = (selectedOpt && selectedOpt.dataset.currencyCode) || localCurrencyCode || localCurrencySymbol;
                const name = localCurrencyName || 'Local Currency';

                const opt = document.createElement('option');
                opt.value = code;
                opt.dataset.symbol = localCurrencySymbol;
                opt.dataset.name = name;
                opt.dataset.local = 'true';
                opt.textContent = code + ' – ' + name + ' (' + localCurrencySymbol + ') ★';

                // Insert after placeholder
                const placeholder = dropdown.querySelector('option[value=""]');
                if (placeholder && placeholder.nextSibling) {
                    dropdown.insertBefore(opt, placeholder.nextSibling);
                } else {
                    dropdown.appendChild(opt);
                }
            }
        }

        // Currency override toggle handler
        document.getElementById('useDifferentCurrency').addEventListener('change', function() {
