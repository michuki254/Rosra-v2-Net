        // Upload peer CSV file (parse client-side, store in memory)
        async function uploadPeerCSV() {
            const fileInput = document.getElementById('peerCsvUpload');
            const countryCode = getCurrentCountryCode();

            if (!fileInput.files || !fileInput.files[0]) {
                alert('Please select a CSV file first');
                return;
            }

            if (!countryCode) {
                alert('Please select a country first');
                return;
            }

            const file = fileInput.files[0];

            try {
                // Parse CSV client-side
                const text = await file.text();
                const lines = text.split('\n').filter(line => line.trim());

                if (lines.length < 2) {
                    alert('CSV file must have at least a header and one data row');
                    return;
                }

                // Parse header to find column indices
                const header = lines[0].split(',').map(h => h.trim().toLowerCase());
                const sngIdx = header.findIndex(h => h === 'sng' || h === 'name');
                const osrIdx = header.findIndex(h => h === 'osr');
                const gcpIdx = header.findIndex(h => h === 'gcp' || h === 'gdp');

                if (sngIdx === -1 || osrIdx === -1 || gcpIdx === -1) {
                    alert('CSV must have columns: SNG (or Name), OSR, GCP (or GDP)');
                    return;
                }

                // Parse data rows
                const peers = [];
                for (let i = 1; i < lines.length; i++) {
                    const cols = lines[i].split(',').map(c => c.trim());
                    if (cols.length > Math.max(sngIdx, osrIdx, gcpIdx)) {
                        const sng = cols[sngIdx];
                        const osr = parseFloat(cols[osrIdx]) || 0;
                        const gcp = parseFloat(cols[gcpIdx]) || 0;

                        if (sng && (osr > 0 || gcp > 0)) {
                            peers.push({ sng: sng, osr: osr, gcp: gcp, include: true });
                        }
                    }
                }

                if (peers.length === 0) {
                    alert('No valid peer data found in CSV');
                    return;
                }

                // Store custom data in memory (will be saved with report)
                customPeerData = {
                    dataSource: 'custom',
                    countryCode: countryCode,
                    customPeers: peers,
                    timestamp: new Date().toISOString()
                };

                console.log('Custom peer data from CSV stored in memory:', customPeerData);

                // Populate dropdown from custom data
                populatePeerDropdownFromCustomData(peers);

                // Hide input section and show success message
                togglePeerDataInputSection(false);
                showPeerDataSuccessMessage(`${peers.length} peers loaded from CSV. Data will be saved with your report.`);

                // Clear file input
                fileInput.value = '';

            } catch (e) {
                console.error('Error parsing CSV:', e);
                alert('Error parsing CSV file. Please check the format and try again.');
            }
        }

