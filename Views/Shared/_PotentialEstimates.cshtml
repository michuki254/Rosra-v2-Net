                // Initialize Select2 for searchable dropdown
                if (typeof $ !== 'undefined' && $.fn.select2) {
                    $(peerSngSelect).select2({
                        theme: 'bootstrap-5',
                        placeholder: 'Search for a subnational government...',
                        allowClear: true,
                        width: '100%'
                    });

                    // Handle Select2 change event
                    $(peerSngSelect).on('select2:select', function(e) {
                        const event = new Event('change', { bubbles: true });
                        peerSngSelect.dispatchEvent(event);
                    });

                    $(peerSngSelect).on('select2:clear', function(e) {
                        const event = new Event('change', { bubbles: true });
                        peerSngSelect.dispatchEvent(event);
                    });
