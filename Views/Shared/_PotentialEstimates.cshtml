        // Tooltip functionality
        const tooltipButtons = document.querySelectorAll('.info-btn[data-tooltip-id]');
        let activeTooltip = null;
        let activeButton = null;

        function positionTooltip(btn, tooltip) {
            const btnRect = btn.getBoundingClientRect();
            const tooltipWidth = 280; // approximate width
            const tooltipHeight = 100; // approximate height
            const padding = 10;

            let left = btnRect.left + btnRect.width / 2;
            let top = btnRect.bottom + 8;

            // Check if tooltip would overflow right edge
            if (left + tooltipWidth / 2 > window.innerWidth - padding) {
                left = window.innerWidth - tooltipWidth - padding;
            }
            // Check if tooltip would overflow left edge
            if (left - tooltipWidth / 2 < padding) {
                left = padding;
            } else {
                left = left - tooltipWidth / 2 + 20; // offset to align with button
            }

            // Check if tooltip would overflow bottom edge
            if (top + tooltipHeight > window.innerHeight - padding) {
                // Position above the button instead
                top = btnRect.top - tooltipHeight - 8;
            }

            tooltip.style.left = Math.max(padding, left) + 'px';
            tooltip.style.top = top + 'px';
        }

        tooltipButtons.forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const tooltipId = this.getAttribute('data-tooltip-id');
                const tooltip = document.getElementById(tooltipId);

                if (!tooltip) return;

                // If clicking the same tooltip, toggle it off
                if (activeTooltip === tooltip) {
                    tooltip.classList.remove('active');
                    activeTooltip = null;
                    activeButton = null;
                    return;
                }

                // Close any open tooltip
                if (activeTooltip) {
                    activeTooltip.classList.remove('active');
                }

                // Position and open the clicked tooltip
                positionTooltip(this, tooltip);
                tooltip.classList.add('active');
                activeTooltip = tooltip;
                activeButton = this;
            });
        });

        // Reposition tooltip on scroll or resize
        window.addEventListener('scroll', function() {
            if (activeTooltip && activeButton) {
                positionTooltip(activeButton, activeTooltip);
            }
        }, true);

        window.addEventListener('resize', function() {
            if (activeTooltip && activeButton) {
                positionTooltip(activeButton, activeTooltip);
            }
        });

        // Close tooltip when clicking outside
        document.addEventListener('click', function(e) {
            if (activeTooltip && !e.target.closest('.tooltip-trigger')) {
                activeTooltip.classList.remove('active');
                activeTooltip = null;
