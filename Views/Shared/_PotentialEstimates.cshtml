        // Fetch GDP per capita from World Bank API based on selected year
        async function fetchGdpPerCapita(countryName, year = null) {
            const isoCode = countryIsoCodes[countryName];
            if (!isoCode) {
                console.log('No ISO code found for country:', countryName);
                return null;
            }

            // Use selected financial year or default to current year
            const selectedYear = year || document.getElementById('financialYear').value || new Date().getFullYear();

            const gdpInput = document.getElementById('gdpPerCapita');
            const originalPlaceholder = gdpInput.placeholder;
            gdpInput.placeholder = 'Loading...';

            try {
                // Fetch GDP for the specific year (with fallback range of ±2 years)
                const startYear = parseInt(selectedYear) - 2;
                const endYear = parseInt(selectedYear) + 2;

                const response = await fetch(
                    `https://api.worldbank.org/v2/country/${isoCode}/indicator/NY.GDP.PCAP.CD?format=json&per_page=10&date=${startYear}:${endYear}`
                );
                const data = await response.json();

                if (data && data[1] && data[1].length > 0) {
                    // First try to find exact year match
                    let gdpEntry = data[1].find(entry => entry.date === selectedYear.toString() && entry.value !== null);

                    // If no exact match, find the closest year with data
                    if (!gdpEntry) {
                        for (const entry of data[1]) {
                            if (entry.value !== null) {
                                gdpEntry = entry;
                                break;
                            }
                        }
                    }

                    if (gdpEntry && gdpEntry.value !== null) {
                        const gdpValue = Math.round(gdpEntry.value);
                        console.log(`GDP per capita for ${countryName} (${gdpEntry.date}): $${gdpValue}`);
                        gdpInput.value = formatNumberWithCommas(gdpValue.toString());
                        gdpInput.placeholder = originalPlaceholder;
                        // Trigger calculation update
                        gdpInput.dispatchEvent(new Event('change'));
                        return gdpValue;
                    }
                }
                console.log('No GDP data found for:', countryName, 'year:', selectedYear);
                gdpInput.placeholder = originalPlaceholder;
                return null;
            } catch (error) {
                console.error('Error fetching GDP per capita:', error);
                gdpInput.placeholder = originalPlaceholder;
                return null;
            }
        }

