<script>
    document.addEventListener('DOMContentLoaded', function() {
        // ========================================
        // PEER SNG DATA ISOLATION
        // Custom peer data stored per-report, not in global database
        // ========================================

        // Custom peer data - stores user-entered data in memory (saved with report)
        // Schema: { dataSource: 'custom'|'reference', countryCode: string, customPeers: [{sng, osr, gcp, include}], timestamp: string }
        let customPeerData = null;

        // Function to get custom peer data (for use in report save)
        window.getCustomPeerData = function() {
            return customPeerData;
        };

        // Function to set custom peer data (for loading saved reports)
        window.setCustomPeerData = function(data) {
            customPeerData = data;
            console.log('Custom peer data set:', data ? `${data.customPeers?.length || 0} peers` : 'null');
        };

        // Function to clear custom peer data (reset to reference data)
        window.clearCustomPeerData = function() {
            customPeerData = null;
            console.log('Custom peer data cleared, using reference data');
        };

        // Get the country and region elements
        const countrySelect = document.getElementById('country');
        const regionSelect = document.getElementById('region');
        const savedCountry = '@Model.Country' || '';
        const savedRegion = '@Model.Region' || '';
        const savedCity = '@Model.City' || '';
        const savedGovUnitLevel3 = '@Model.GovUnitLevel3' || '';
        const savedFinalUnitLevel = parseInt('@Model.FinalUnitLevel') || 0;

        // Government Unit Hierarchy elements
        const govUnitLevel1Row = document.getElementById('govUnitLevel1Row');
        const govUnitLevel2Row = document.getElementById('govUnitLevel2Row');
        const govUnitLevel3Row = document.getElementById('govUnitLevel3Row');
        const level1IsFinal = document.getElementById('level1IsFinal');
        const level2IsFinal = document.getElementById('level2IsFinal');
        const govUnitLevel3Input = document.getElementById('govUnitLevel3');
        const cityInput = document.getElementById('city');
        const finalUnitLevelInput = document.getElementById('finalUnitLevel');
        const hierarchyNote = document.getElementById('hierarchyNote');

        // Progressive disclosure for government unit hierarchy
        function updateGovernmentUnitVisibility() {
            const countrySelected = countrySelect.value !== '';
            const level1Selected = regionSelect.value !== '';
            const level1Checked = level1IsFinal.checked;
            const level2Filled = cityInput.value.trim() !== '';
            const level2Checked = level2IsFinal.checked;

            // Show/hide Level 1 row
            govUnitLevel1Row.style.display = countrySelected ? '' : 'none';

            // Show/hide Level 2 row
            govUnitLevel2Row.style.display = (countrySelected && level1Selected && !level1Checked) ? '' : 'none';

            // Show/hide Level 3 row
            govUnitLevel3Row.style.display = (countrySelected && level1Selected && !level1Checked && level2Filled && !level2Checked) ? '' : 'none';

            // Show hierarchy note when country is selected
            hierarchyNote.style.display = countrySelected ? '' : 'none';

            // Update the hidden FinalUnitLevel field
            if (level1Checked) {
                finalUnitLevelInput.value = '1';
            } else if (level2Checked) {
                finalUnitLevelInput.value = '2';
            } else if (govUnitLevel3Input.value.trim() !== '') {
                finalUnitLevelInput.value = '3';
            } else if (level2Filled) {
                finalUnitLevelInput.value = '2';
            } else if (level1Selected) {
                finalUnitLevelInput.value = '1';
            } else {
                finalUnitLevelInput.value = '';
            }
        }

        // Level 1 checkbox change
        level1IsFinal.addEventListener('change', function() {
            if (this.checked) {
                cityInput.value = '';
                govUnitLevel3Input.value = '';
                level2IsFinal.checked = false;
            }
            updateGovernmentUnitVisibility();
        });

        // Level 2 checkbox change
        level2IsFinal.addEventListener('change', function() {
            if (this.checked) {
                govUnitLevel3Input.value = '';
            }
            updateGovernmentUnitVisibility();
        });

        // Level 2 text input change (triggers Level 3 visibility)
        cityInput.addEventListener('input', function() {
            updateGovernmentUnitVisibility();
        });

        // Level 3 text input change (updates final unit level)
        govUnitLevel3Input.addEventListener('input', function() {
            updateGovernmentUnitVisibility();
        });

        // Data Input Block collapse toggle event listeners
        const dataInputBody = document.getElementById('dataInputBody');
        const collapsibleHeader = document.querySelector('.collapsible-header[data-bs-target="#dataInputBody"]');

        if (dataInputBody && collapsibleHeader) {
            // When collapse starts hiding
            dataInputBody.addEventListener('hide.bs.collapse', function() {
                collapsibleHeader.classList.add('collapsed');
            });

            // When collapse starts showing
            dataInputBody.addEventListener('show.bs.collapse', function() {
                collapsibleHeader.classList.remove('collapsed');
            });
        }

        // Fiscal Decentralisation Chart
        let fiscalChart = null;

        // Custom plugin to draw quadrant labels
        const quadrantLabelsPlugin = {
            id: 'quadrantLabels',
            afterDraw: function(chart) {
                const ctx = chart.ctx;
                const chartArea = chart.chartArea;
                const xScale = chart.scales.x;
                const yScale = chart.scales.y;

                // Get pixel positions for the threshold lines (80%)
                const xThreshold = xScale.getPixelForValue(80);
                const yThreshold = yScale.getPixelForValue(80);

                // Calculate quadrant centers
                const leftCenterX = (chartArea.left + xThreshold) / 2;
                const rightCenterX = (xThreshold + chartArea.right) / 2;
                const topCenterY = (chartArea.top + yThreshold) / 2;
                const bottomCenterY = (yThreshold + chartArea.bottom) / 2;

                // Set text style
                ctx.save();
                ctx.font = 'bold 12px Arial, sans-serif';
                ctx.fillStyle = '#495057';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';

                // Top-left quadrant: "Small and self-reliant"
                ctx.fillText('Small and', leftCenterX, topCenterY - 8);
                ctx.fillText('self-reliant', leftCenterX, topCenterY + 8);

                // Top-right quadrant: "Large & autonomous"
                ctx.fillText('Large &', rightCenterX, topCenterY - 8);
                ctx.fillText('autonomous', rightCenterX, topCenterY + 8);

                // Bottom-left quadrant: "Small & dependent"
                ctx.fillText('Small &', leftCenterX, bottomCenterY - 8);
                ctx.fillText('dependent', leftCenterX, bottomCenterY + 8);

                // Bottom-right quadrant: "Large but transfer"
                ctx.fillText('Large but', rightCenterX, bottomCenterY - 8);
                ctx.fillText('transfer', rightCenterX, bottomCenterY + 8);

                ctx.restore();
            }
        };

