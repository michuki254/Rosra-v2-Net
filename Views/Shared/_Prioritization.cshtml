@model RosraApp.Models.ViewModels.RosraFormViewModel

<div class="tab-content-container prioritization-module">
    <!-- Header Section -->
    <div class="prioritization-header mb-4">
        <h5 class="mb-2"><i class="fas fa-sort-amount-down me-2"></i>@Localizer["Step1_Title"]</h5>
        <p class="text-muted mb-0">
            @Html.Raw(Localizer["Step1_Description"].Value)
        </p>
    </div>

    <!-- Instructions Card -->
    <div class="alert alert-info mb-4" role="alert">
        <h6 class="alert-heading"><i class="fas fa-info-circle me-2"></i>@Localizer["Instructions_Title"]</h6>
        <ol class="mb-0 ps-3">
            <li>@Html.Raw(Localizer["Instructions_Step1"].Value)</li>
            <li>@Html.Raw(Localizer["Instructions_Step2"].Value)</li>
            <li>@Html.Raw(Localizer["Instructions_Step3"].Value)</li>
            <li>@Html.Raw(Localizer["Instructions_Step4"].Value)</li>
        </ol>
    </div>

    <div class="row g-2">
        <!-- Table 1: Adjustable Stream Prioritization -->
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white py-3">
                    <h6 class="mb-0"><i class="fas fa-sliders-h me-2"></i>@Localizer["AdjustableStream_Title"]</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" id="adjustableStreamTable">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center" style="width: 100px;" data-bs-toggle="tooltip" title="@Localizer["AdjustableStream_Tooltip_DefaultRank"]">@Localizer["AdjustableStream_Col_DefaultRank"]</th>
                                    <th data-bs-toggle="tooltip" title="@Localizer["AdjustableStream_Tooltip_StreamName"]">@Localizer["AdjustableStream_Col_StreamName"]</th>
                                    <th class="text-end" data-bs-toggle="tooltip" title="@Localizer["AdjustableStream_Tooltip_TotalFunctionalGap"]">@Localizer["AdjustableStream_Col_TotalFunctionalGap"]</th>
                                    <th class="text-center" style="width: 150px;" data-bs-toggle="tooltip" title="@Localizer["AdjustableStream_Tooltip_IncludeExclude"]">@Localizer["AdjustableStream_Col_IncludeExclude"]</th>
                                    <th class="text-center" style="width: 150px;" data-bs-toggle="tooltip" title="@Localizer["AdjustableStream_Tooltip_AdjustRank"]">@Localizer["AdjustableStream_Col_AdjustRank"]</th>
                                </tr>
                            </thead>
                            <tbody id="adjustableStreamBody">
                                <!-- Populated by JavaScript -->
                                <tr class="placeholder-row">
                                    <td colspan="5" class="text-center text-muted py-4">
                                        <i class="fas fa-spinner fa-spin me-2"></i>@Localizer["AdjustableStream_Placeholder"]
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Table 2: Final Stream Prioritization -->
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-success text-white py-3">
                    <h6 class="mb-0"><i class="fas fa-check-circle me-2"></i>@Localizer["FinalStream_Title"]</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" id="finalStreamTable">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center" style="width: 100px;" data-bs-toggle="tooltip" title="@Localizer["FinalStream_Tooltip_FinalRank"]">@Localizer["FinalStream_Col_FinalRank"]</th>
                                    <th data-bs-toggle="tooltip" title="@Localizer["FinalStream_Tooltip_StreamName"]">@Localizer["FinalStream_Col_StreamName"]</th>
                                    <th class="text-end" data-bs-toggle="tooltip" title="@Localizer["FinalStream_Tooltip_TotalFunctionalGap"]">@Localizer["FinalStream_Col_TotalFunctionalGap"]</th>
                                    <th class="text-center" data-bs-toggle="tooltip" title="@Localizer["FinalStream_Tooltip_ShareOfTotalGap"]">@Localizer["FinalStream_Col_ShareOfTotalGap"]</th>
                                    <th class="text-center" style="width: 120px;" data-bs-toggle="tooltip" title="@Localizer["FinalStream_Tooltip_Status"]">@Localizer["FinalStream_Col_Status"]</th>
                                </tr>
                            </thead>
                            <tbody id="finalStreamBody">
                                <!-- Populated by JavaScript -->
                                <tr class="placeholder-row">
                                    <td colspan="5" class="text-center text-muted py-4">
                                        <i class="fas fa-info-circle me-2"></i>@Localizer["FinalStream_Placeholder"]
                                    </td>
                                </tr>
                            </tbody>
                            <tfoot class="table-light fw-bold" id="finalStreamFooter" style="display: none;">
                                <tr>
                                    <td class="text-center">-</td>
                                    <td>@Localizer["FinalStream_Footer_Total"]</td>
                                    <td class="text-end" id="totalIncludedGap">-</td>
                                    <td class="text-center">100%</td>
                                    <td class="text-center">-</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Charts Section -->
        <div class="col-md-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-light py-3">
                    <h6 class="mb-0"><i class="fas fa-chart-bar me-2"></i>@Localizer["Chart_BarTitle"]</h6>
                </div>
                <div class="card-body">
                    <div id="barChartPlaceholder" class="chart-placeholder text-center text-muted py-5">
                        <i class="fas fa-chart-bar fa-3x mb-3 opacity-50"></i>
                        <p class="mb-0">@Localizer["Chart_Placeholder"]</p>
                    </div>
                    <canvas id="gapBarChart" height="180" style="display: none;"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-light py-3">
                    <h6 class="mb-0"><i class="fas fa-chart-pie me-2"></i>@Localizer["Chart_PieTitle"]</h6>
                </div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <div id="pieChartPlaceholder" class="chart-placeholder text-center text-muted py-5">
                        <i class="fas fa-chart-pie fa-3x mb-3 opacity-50"></i>
                        <p class="mb-0">@Localizer["Chart_Placeholder"]</p>
                    </div>
                    <canvas id="gapPieChart" height="280" style="display: none;"></canvas>
                </div>
            </div>
        </div>

        <!-- Summary Statistics -->
        <div class="col-12">
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm text-center prioritization-stat-card">
                        <div class="card-body py-2">
                            <h6 class="text-muted mb-1">@Localizer["Stats_TotalStreamsAnalyzed"]</h6>
                            <h3 class="mb-0 text-primary" id="statTotalStreams">0</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm text-center prioritization-stat-card">
                        <div class="card-body py-2">
                            <h6 class="text-muted mb-1">@Localizer["Stats_StreamsIncluded"]</h6>
                            <h3 class="mb-0 text-success" id="statIncludedStreams">0</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm text-center prioritization-stat-card">
                        <div class="card-body py-2">
                            <h6 class="text-muted mb-1">@Localizer["Stats_TotalGapAll"]</h6>
                            <h3 class="mb-0 text-info" id="statTotalGap">-</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm text-center prioritization-stat-card">
                        <div class="card-body py-2">
                            <h6 class="text-muted mb-1">@Localizer["Stats_TotalGapIncluded"]</h6>
                            <h3 class="mb-0 text-warning" id="statIncludedGap">-</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ======================= STEP 2: GAP PRIORITIZATION ======================= -->
    <hr class="my-5 border-2">

    <!-- Step 2 Header -->
    <div class="prioritization-header mb-4">
        <h5 class="mb-2"><i class="fas fa-layer-group me-2"></i>@Localizer["Step2_Title"]</h5>
        <p class="text-muted mb-0">
            @Html.Raw(Localizer["Step2_Description"].Value)
        </p>
    </div>

    <!-- Mode Explanation Accordion -->
    <div class="accordion mb-4" id="modeExplanationAccordion">
        <div class="accordion-item border-0 shadow-sm mb-2">
            <h2 class="accordion-header" id="headingRevenuePotential">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseRevenuePotential" aria-expanded="false" aria-controls="collapseRevenuePotential">
                    <span class="mode-badge mode-revenue-potential me-2">@Localizer["Mode_RevenuePotential"]</span>
                    <span class="text-muted small">@Localizer["Mode_RevenuePotential_Condition"]</span>
                </button>
            </h2>
            <div id="collapseRevenuePotential" class="accordion-collapse collapse" aria-labelledby="headingRevenuePotential" data-bs-parent="#modeExplanationAccordion">
                <div class="accordion-body">
                    <p class="mb-0">
                        <strong>@Localizer["Mode_RevenuePotential_WhenApplied"]</strong> @Localizer["Mode_RevenuePotential_Condition"]<br><br>
                        @Html.Raw(Localizer["Mode_RevenuePotential_Description"].Value)
                    </p>
                </div>
            </div>
        </div>
        <div class="accordion-item border-0 shadow-sm mb-2">
            <h2 class="accordion-header" id="headingComplianceFirst">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseComplianceFirst" aria-expanded="false" aria-controls="collapseComplianceFirst">
                    <span class="mode-badge mode-compliance-first me-2">@Localizer["Mode_ComplianceFirst"]</span>
                    <span class="text-muted small">@Localizer["Mode_ComplianceFirst_Condition"]</span>
                </button>
            </h2>
            <div id="collapseComplianceFirst" class="accordion-collapse collapse" aria-labelledby="headingComplianceFirst" data-bs-parent="#modeExplanationAccordion">
                <div class="accordion-body">
                    <p class="mb-0">
                        <strong>@Localizer["Mode_ComplianceFirst_WhenApplied"]</strong> @Localizer["Mode_ComplianceFirst_Condition"]<br><br>
                        @Html.Raw(Localizer["Mode_ComplianceFirst_Description"].Value)
                    </p>
                </div>
            </div>
        </div>
        <div class="accordion-item border-0 shadow-sm">
            <h2 class="accordion-header" id="headingOverhaul">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOverhaul" aria-expanded="false" aria-controls="collapseOverhaul">
                    <span class="mode-badge mode-overhaul me-2">@Localizer["Mode_Overhaul"]</span>
                    <span class="text-muted small">@Localizer["Mode_Overhaul_Condition"]</span>
                </button>
            </h2>
            <div id="collapseOverhaul" class="accordion-collapse collapse" aria-labelledby="headingOverhaul" data-bs-parent="#modeExplanationAccordion">
                <div class="accordion-body">
                    <p class="mb-0">
                        <strong>@Localizer["Mode_Overhaul_WhenApplied"]</strong> @Localizer["Mode_Overhaul_Condition"]<br><br>
                        @Html.Raw(Localizer["Mode_Overhaul_Description"].Value)
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Gap Sequencing Table -->
    <div class="row g-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-secondary text-white py-3">
                    <h6 class="mb-0"><i class="fas fa-sort-numeric-down me-2"></i>@Localizer["GapSequencing_Title"]</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" id="gapSequencingTable">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center" style="width: 70px;" data-bs-toggle="tooltip" title="@Localizer["GapSequencing_Tooltip_Rank"]">@Localizer["GapSequencing_Col_Rank"]</th>
                                    <th data-bs-toggle="tooltip" title="@Localizer["GapSequencing_Tooltip_Stream"]">@Localizer["GapSequencing_Col_Stream"]</th>
                                    <th class="text-center" style="width: 160px;" data-bs-toggle="tooltip" title="@Localizer["GapSequencing_Tooltip_Mode"]">@Localizer["GapSequencing_Col_Mode"]</th>
                                    <th class="text-center" data-bs-toggle="tooltip" title="@Localizer["GapSequencing_Tooltip_Priority1"]">@Localizer["GapSequencing_Col_Priority1"]</th>
                                    <th class="text-center" data-bs-toggle="tooltip" title="@Localizer["GapSequencing_Tooltip_Priority2"]">@Localizer["GapSequencing_Col_Priority2"]</th>
                                    <th class="text-center" data-bs-toggle="tooltip" title="@Localizer["GapSequencing_Tooltip_Priority3"]">@Localizer["GapSequencing_Col_Priority3"]</th>
                                </tr>
                            </thead>
                            <tbody id="gapSequencingBody">
                                <tr class="placeholder-row">
                                    <td colspan="6" class="text-center text-muted py-4">
                                        <i class="fas fa-info-circle me-2"></i>@Localizer["GapSequencing_Placeholder"]
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Gap Amounts Detail Table -->
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-info text-white py-3">
                    <h6 class="mb-0"><i class="fas fa-coins me-2"></i>@Localizer["GapAmounts_Title"]</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" id="gapAmountsTable">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center" style="width: 70px;">@Localizer["GapAmounts_Col_Rank"]</th>
                                    <th>@Localizer["GapAmounts_Col_Stream"]</th>
                                    <th class="text-center">@Localizer["GapAmounts_Col_Priority1"]</th>
                                    <th class="text-end">@Localizer["GapAmounts_Col_Amount1"]</th>
                                    <th class="text-center">@Localizer["GapAmounts_Col_Priority2"]</th>
                                    <th class="text-end">@Localizer["GapAmounts_Col_Amount2"]</th>
                                    <th class="text-center">@Localizer["GapAmounts_Col_Priority3"]</th>
                                    <th class="text-end">@Localizer["GapAmounts_Col_Amount3"]</th>
                                </tr>
                            </thead>
                            <tbody id="gapAmountsBody">
                                <tr class="placeholder-row">
                                    <td colspan="8" class="text-center text-muted py-4">
                                        <i class="fas fa-info-circle me-2"></i>@Localizer["GapAmounts_Placeholder"]
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Summary Panel -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-light py-3">
                    <h6 class="mb-0"><i class="fas fa-list-ol me-2"></i>@Localizer["ReformSummary_Title"]</h6>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-6">
                            <div class="text-muted small">@Localizer["ReformSummary_TotalStreams"]</div>
                            <div class="h4 mb-0" id="gapStatTotalStreams">0</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small">@Localizer["ReformSummary_TotalGapCombinations"]</div>
                            <div class="h4 mb-0" id="gapStatTotalCombinations">0</div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <div class="text-muted small">@Localizer["ReformSummary_RemovedGaps"]</div>
                            <div class="h4 mb-0 text-danger" id="gapStatRemovedGaps">0</div>
                        </div>
                        <div class="col-6">
                            <div class="text-muted small">@Localizer["ReformSummary_ActiveGapActions"]</div>
                            <div class="h4 mb-0 text-success" id="gapStatActiveGaps">0</div>
                        </div>
                    </div>
                    <hr>
                    <h6 class="text-muted mb-3">@Localizer["ReformSummary_FirstPriorityActions"]</h6>
                    <div id="firstPriorityActions" class="small">
                        <div class="text-muted">@Localizer["ReformSummary_NoActionsDefined"]</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Master Priority List -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-warning text-dark py-3">
                    <h6 class="mb-0"><i class="fas fa-trophy me-2"></i>@Localizer["MasterPriority_Title"]</h6>
                </div>
                <div class="card-body p-0" style="max-height: 350px; overflow-y: auto;">
                    <table class="table table-sm table-hover mb-0" id="masterPriorityTable">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th class="text-center" style="width: 50px;">@Localizer["MasterPriority_Col_Number"]</th>
                                <th>@Localizer["MasterPriority_Col_Stream"]</th>
                                <th>@Localizer["MasterPriority_Col_Gap"]</th>
                                <th class="text-end">@Localizer["MasterPriority_Col_Amount"]</th>
                            </tr>
                        </thead>
                        <tbody id="masterPriorityBody">
                            <tr class="placeholder-row">
                                <td colspan="4" class="text-center text-muted py-3">
                                    <small>@Localizer["MasterPriority_Placeholder"]</small>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- ======================= STEP 3: REVENUE IMPACT & IMPROVEMENT SCORING ======================= -->
    <hr class="my-5 border-2">

    <div class="prioritization-header mb-4">
        <h5 class="mb-2"><i class="fas fa-chart-line me-2"></i>Revenue Impact &amp; Improvement Opportunities</h5>
        <p class="text-muted mb-0">
            Gaps ranked by absolute revenue impact and scored by improvement potential to help focus reform effort where it matters most.
        </p>
    </div>

    <div class="row g-4">
        <!-- Revenue Impact Ranking -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-danger text-white py-3">
                    <h6 class="mb-0"><i class="fas fa-sort-amount-down me-2"></i>Gaps Ranked by Revenue Impact</h6>
                </div>
                <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-sm table-hover mb-0" id="revenueImpactTable">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th class="text-center" style="width: 50px;">#</th>
                                <th>Stream</th>
                                <th>Gap Type</th>
                                <th class="text-end">Amount</th>
                                <th class="text-center" style="width: 120px;">Share</th>
                            </tr>
                        </thead>
                        <tbody id="revenueImpactBody">
                            <tr class="placeholder-row">
                                <td colspan="5" class="text-center text-muted py-3">
                                    <small>Revenue impact ranking will populate from gap data</small>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Improvement Opportunity Scoring -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header text-white py-3" style="background: #7c3aed;">
                    <h6 class="mb-0"><i class="fas fa-bullseye me-2"></i>Improvement Opportunity Score</h6>
                </div>
                <div class="card-body p-0" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-sm table-hover mb-0" id="improvementScoreTable">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th class="text-center" style="width: 50px;">#</th>
                                <th>Stream</th>
                                <th>Gap Type</th>
                                <th class="text-center" style="width: 80px;">Score</th>
                                <th class="text-center" style="width: 140px;">Potential</th>
                            </tr>
                        </thead>
                        <tbody id="improvementScoreBody">
                            <tr class="placeholder-row">
                                <td colspan="5" class="text-center text-muted py-3">
                                    <small>Improvement scores will populate from gap data</small>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Interactive Priority Matrix -->
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-dark text-white py-3">
                    <h6 class="mb-0"><i class="fas fa-th me-2"></i>Priority Matrix — Revenue Impact vs. Number of Solutions</h6>
                </div>
                <div class="card-body">
                    <div id="matrixPlaceholder" class="chart-placeholder text-center text-muted py-5">
                        <i class="fas fa-th fa-3x mb-3 opacity-50"></i>
                        <p class="mb-0">Priority matrix will appear after gap prioritization</p>
                    </div>
                    <canvas id="priorityMatrixChart" height="300" style="display: none;"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Hidden inputs to persist prioritization data -->
    <input type="hidden" id="prioritizationData" name="PrioritizationData" value="@Model.PrioritizationData" />
</div>

<style>
    /* ============================================
       UN-HABITAT PRIORITIZATION MODULE DESIGN SYSTEM
       ============================================ */

    /* CSS Variables */
    .prioritization-module {
        --un-blue: #00b2e3;
        --un-dark-blue: #00689D;
        --un-orange: #FD9D24;
        --un-orange-dark: #E8891A;
        --un-success: #10b981;
        --un-warning: #f59e0b;
        --un-danger: #ef4444;
        --card-radius: 12px;
        --input-radius: 8px;
    }

    /* Summary Stat Cards (Total Streams / Included / Total Gap etc.) */
    .prioritization-module .prioritization-stat-card .card-body {
        padding: 0.45rem 0.6rem !important;
    }

    .prioritization-module .prioritization-stat-card h6 {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        margin-bottom: 0.15rem !important;
    }

    .prioritization-module .prioritization-stat-card h3 {
        font-size: 1.15rem;
        font-weight: 700;
    }

    /* Header Styling */
    .prioritization-module .prioritization-header {
        margin-bottom: 0.75rem !important;
    }

    .prioritization-module .prioritization-header h5 {
        color: var(--un-blue);
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 0.2rem !important;
    }

    .prioritization-module .prioritization-header p {
        font-size: 0.82rem;
        line-height: 1.4;
    }

    /* Card Styling */
    .prioritization-module .card {
        border: none;
        border-radius: var(--card-radius);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: all 0.2s ease;
        overflow: hidden;
    }

    .prioritization-module .card:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    }

    /* Card Headers with UN-Habitat Colors */
    .prioritization-module .card-header.bg-primary,
    .prioritization-module .card-header.bg-success,
    .prioritization-module .card-header.bg-light {
        padding: 0.55rem 1rem !important;
    }

    .prioritization-module .card-header.bg-primary {
        background: var(--un-blue) !important;
        border: none;
    }

    .prioritization-module .card-header.bg-success {
        background: var(--un-success) !important;
        border: none;
    }

    .prioritization-module .card-header.bg-light {
        background: #f8fafc !important;
        border-bottom: 2px solid #e2e8f0;
    }

