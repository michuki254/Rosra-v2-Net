    // Update Statistics
    function updateStatistics() {
        const includedStreams = streams.filter(s => s.included);
        const totalGapAll = streams.reduce((sum, s) => sum + s.totalFunctionalGap, 0);
        const totalGapIncluded = includedStreams.reduce((sum, s) => sum + s.totalFunctionalGap, 0);

        document.getElementById('statTotalStreams').textContent = streams.length;
        document.getElementById('statIncludedStreams').textContent = includedStreams.length;
        document.getElementById('statTotalGap').textContent = formatCurrency(totalGapAll);
        document.getElementById('statIncludedGap').textContent = formatCurrency(totalGapIncluded);
    }

    // ======================= STATE PERSISTENCE =======================

    // Save prioritization state to FormStateManager (and localStorage backup)
    function savePrioritizationState() {
        try {
            // Build state object with stream customizations and gap priorities
            const state = {
                streamCustomizations: streams.map(s => ({
                    id: s.id,
                    included: s.included,
                    adjustedRank: s.adjustedRank
                })),
                gapPrioritization: gapPrioritizationData.map(g => ({
                    streamId: g.streamId,
                    currentSequence: g.currentSequence.map(seq => ({
                        type: seq.type,
                        removed: seq.removed,
                        isOverridden: seq.isOverridden
                    }))
                }))
            };

            // Use FormStateManager if available (preferred)
            if (typeof FormStateManager !== 'undefined') {
                FormStateManager.setData('prioritizationState', state);
                console.log('Prioritization: State saved via FormStateManager');
            } else {
                // Fallback to localStorage only
                localStorage.setItem('prioritizationState', JSON.stringify(state));
                console.log('Prioritization: State saved to localStorage');
            }
        } catch (e) {
            console.error('Prioritization: Error saving state', e);
        }
    }

    // Load prioritization state from FormStateManager (or localStorage fallback)
    function loadPrioritizationState() {
        try {
            let state = null;

            // Use FormStateManager if available (preferred)
            if (typeof FormStateManager !== 'undefined') {
                state = FormStateManager.getData('prioritizationState');
                if (state) {
                    console.log('Prioritization: State loaded via FormStateManager');
                }
            }

            // Fallback to localStorage
            if (!state) {
                const localData = localStorage.getItem('prioritizationState');
                if (localData) {
                    state = JSON.parse(localData);
                    console.log('Prioritization: State loaded from localStorage');
                }
            }

            return state;
        } catch (e) {
            console.error('Prioritization: Error loading state', e);
            return null;
        }
    }

    // Apply saved state to streams
    function applySavedState() {
        const state = loadPrioritizationState();
        if (!state) return false;

        let stateApplied = false;

        // Apply stream customizations (include/exclude, adjusted ranks)
        if (state.streamCustomizations && streams.length > 0) {
            state.streamCustomizations.forEach(saved => {
                const stream = streams.find(s => s.id === saved.id);
                if (stream) {
                    stream.included = saved.included;
                    stream.adjustedRank = saved.adjustedRank;
                    stateApplied = true;
                }
            });
        }

        return stateApplied;
    }

    // Apply saved gap prioritization state
    function applySavedGapPrioritization() {
        const state = loadPrioritizationState();
        if (!state || !state.gapPrioritization) return;

        state.gapPrioritization.forEach(saved => {
            const gapData = gapPrioritizationData.find(g => g.streamId === saved.streamId);
            if (gapData && saved.currentSequence) {
                saved.currentSequence.forEach((seq, idx) => {
                    if (gapData.currentSequence[idx]) {
                        // Only apply if it has been overridden
                        if (seq.isOverridden) {
                            gapData.currentSequence[idx].type = seq.type;
                            gapData.currentSequence[idx].removed = seq.removed;
                            gapData.currentSequence[idx].isOverridden = seq.isOverridden;
                            // Update the amount based on the type
                            if (!seq.removed && seq.type !== 'Remove') {
                                gapData.currentSequence[idx].amount = gapData.gaps[seq.type] || 0;
                            }
                        }
                    }
                });
            }
        });

        console.log('Prioritization: Gap prioritization state applied');
    }

    // Initialize module
    function initializePrioritization() {
        loadStreamData();
        // Apply saved stream customizations (include/exclude, ranks) after loading streams
        applySavedState();
        renderAdjustableTable();
        renderFinalTable();
        updateCharts();
        updateStatistics();
    }

    // Initialize on load
    initializePrioritization();

    // Subscribe to RosraStateManager for reactive updates (preferred method)
    if (typeof RosraStateManager !== 'undefined') {
        RosraStateManager.subscribe('streams', function(updatedStreams) {
            console.log('Prioritization: Received stream update from RosraStateManager');
            loadStreamData();
            renderAdjustableTable();
            renderFinalTable();
            updateCharts();
            updateStatistics();
            initializeGapPrioritization();
        });
        console.log('Prioritization: Subscribed to RosraStateManager');
    }

    // Listen for storage changes (fallback for backward compatibility)
    window.addEventListener('storage', function(e) {
        if (e.key && (e.key.includes('Gap') || e.key.includes('Value') || e.key.includes('generic'))) {
            loadStreamData();
            renderAdjustableTable();
            renderFinalTable();
            updateCharts();
            updateStatistics();
        }
    });

    // Listen for gapDataReady event (fired by print pages after gap calculations complete)
    window.addEventListener('gapDataReady', function() {
        console.log('Prioritization: gapDataReady event received, re-initializing');
        initializePrioritization();
        initializeGapPrioritization();
    });

    // Also listen for custom events from gap analysis tabs
    window.addEventListener('gapAnalysisUpdated', function() {
        loadStreamData();
        renderAdjustableTable();
        renderFinalTable();
        updateCharts();
        updateStatistics();
        initializeGapPrioritization();
    });

    // ======================= GAP PRIORITIZATION (STEP 2) =======================

    // Gap prioritization data structure
    let gapPrioritizationData = [];

    // Determine mode based on compliance and coverage ratios
    function determineMode(stream) {
        // Calculate compliance ratio: Revenue / Billed
        const billedAmount = stream.complianceGap + stream.currentRevenue;
        const complianceRatio = billedAmount > 0 ? (stream.currentRevenue / billedAmount) : 0;

        // Calculate coverage ratio: Registered / Estimated Total
        // For simplicity, use 1 - (coverageGap / totalPotential) as proxy
        const totalPotential = stream.potentialRevenue || (stream.totalFunctionalGap + stream.currentRevenue);
        const coverageRatio = totalPotential > 0 ? 1 - (stream.coverageGap / totalPotential) : 0;

        // Store ratios for display
        stream.complianceRatio = complianceRatio;
        stream.coverageRatio = coverageRatio;

        // Get the third gap label based on stream type
        const isPropertyBased = stream.type === 'property-tax';
        const thirdGapLabel = isPropertyBased ? 'Valuation' : 'Liability';
        const thirdGapValue = isPropertyBased ? (stream.valuationGap || 0) : (stream.liabilityGap || 0);

        // Build gaps array
        const gaps = [
            { type: 'Compliance', amount: stream.complianceGap || 0 },
            { type: 'Coverage', amount: stream.coverageGap || 0 },
            { type: thirdGapLabel, amount: thirdGapValue }
        ];

        let mode, sequence;

        if (complianceRatio >= 0.75) {
            // Revenue potential mode - sort by amount descending
            mode = 'Revenue Potential';
            sequence = [...gaps].sort((a, b) => b.amount - a.amount);
        } else if (coverageRatio >= 0.60) {
            // Compliance first mode
            mode = 'Compliance First';
            sequence = [
                gaps.find(g => g.type === 'Compliance'),
                gaps.find(g => g.type === 'Coverage'),
                gaps.find(g => g.type === thirdGapLabel)
            ];
        } else {
            // Overhaul mode - coverage first
            mode = 'Overhaul';
            sequence = [
                gaps.find(g => g.type === 'Coverage'),
                gaps.find(g => g.type === 'Compliance'),
                gaps.find(g => g.type === thirdGapLabel)
            ];
        }

        return {
            mode,
            sequence,
            thirdGapLabel,
            complianceRatio,
            coverageRatio
        };
    }

    // Get mode badge class
    function getModeBadgeClass(mode) {
        switch (mode) {
            case 'Revenue Potential': return 'mode-revenue-potential';
            case 'Compliance First': return 'mode-compliance-first';
            case 'Overhaul': return 'mode-overhaul';
            default: return '';
        }
    }

    // Get gap badge class
    function getGapBadgeClass(gapType) {
        if (!gapType || gapType === 'Remove') return 'gap-removed';
        switch (gapType) {
            case 'Compliance': return 'gap-compliance';
            case 'Coverage': return 'gap-coverage';
            case 'Valuation': return 'gap-valuation';
            case 'Liability': return 'gap-liability';
            default: return '';
        }
    }

    // Initialize gap prioritization data from included streams
    function initializeGapPrioritization() {
        const { finalRanking } = calculateFinalRankings();
        gapPrioritizationData = [];

        finalRanking.forEach((stream, index) => {
            const modeInfo = determineMode(stream);

            gapPrioritizationData.push({
                streamId: stream.id,
                streamName: stream.name,
                streamType: stream.type,
                finalRank: stream.finalRank,
                mode: modeInfo.mode,
                thirdGapLabel: modeInfo.thirdGapLabel,
                complianceRatio: modeInfo.complianceRatio,
                coverageRatio: modeInfo.coverageRatio,
                defaultSequence: modeInfo.sequence.map(g => g.type),
                currentSequence: modeInfo.sequence.map(g => ({ ...g, isOverridden: false, removed: false })),
                gaps: {
                    Compliance: stream.complianceGap || 0,
                    Coverage: stream.coverageGap || 0,
                    [modeInfo.thirdGapLabel]: modeInfo.thirdGapLabel === 'Valuation' ? (stream.valuationGap || 0) : (stream.liabilityGap || 0)
                }
            });
        });

        // Apply saved gap prioritization state (overrides)
        applySavedGapPrioritization();

        renderGapSequencingTable();
        renderGapAmountsTable();
        renderGapSummary();
        renderMasterPriorityList();
    }

    // Generate gap dropdown options
    function generateGapOptions(streamData, currentGap, priorityIndex) {
        const options = ['Compliance', 'Coverage', streamData.thirdGapLabel];
        let html = '';

        // Get already used gaps (excluding current position)
        const usedGaps = streamData.currentSequence
            .filter((g, i) => i !== priorityIndex && !g.removed && g.type !== 'Remove')
            .map(g => g.type);

        options.forEach(opt => {
            const disabled = usedGaps.includes(opt) ? 'disabled' : '';
            const selected = currentGap === opt ? 'selected' : '';
            html += `<option value="${opt}" ${selected} ${disabled}>${opt}</option>`;
        });

        // Add Remove option
        const removeSelected = currentGap === 'Remove' || !currentGap ? 'selected' : '';
        html += `<option value="Remove" ${removeSelected}>(Remove)</option>`;

        return html;
    }

    // Render Gap Sequencing Table
    function renderGapSequencingTable() {
        const tbody = document.getElementById('gapSequencingBody');

        if (gapPrioritizationData.length === 0) {
            tbody.innerHTML = `
                <tr class="placeholder-row">
                    <td colspan="6" class="text-center text-muted py-4">
                        <i class="fas fa-info-circle me-2"></i>Include streams in Step 1 to see gap prioritization options
                    </td>
                </tr>
            `;
            return;
        }

        let html = '';
        gapPrioritizationData.forEach((stream) => {
            html += `
                <tr data-stream-id="${stream.streamId}">
                    <td class="text-center">
                        <span class="rank-badge ${getRankBadgeClass(stream.finalRank)}">${stream.finalRank}</span>
                    </td>
                    <td>
                        <span class="stream-badge ${stream.streamType}"></span>
                        ${stream.streamName}
                    </td>
                    <td class="text-center">
                        <span class="mode-badge ${getModeBadgeClass(stream.mode)}">${stream.mode}</span>
                    </td>
                    ${renderPriorityCell(stream, 0)}
                    ${renderPriorityCell(stream, 1)}
                    ${renderPriorityCell(stream, 2)}
                </tr>
            `;
        });

        tbody.innerHTML = html;
    }

    // Render individual priority cell
    function renderPriorityCell(stream, priorityIndex) {
        const gapData = stream.currentSequence[priorityIndex];
        const gapType = gapData ? gapData.type : null;
        const isRemoved = gapData ? gapData.removed : true;
        const isOverridden = gapData ? gapData.isOverridden : false;

        const displayGap = isRemoved ? 'Remove' : gapType;
        const badgeClass = getGapBadgeClass(displayGap);
        const overriddenDot = isOverridden ? '<span class="overridden-indicator" title="Overridden from default"></span>' : '';

        return `
            <td class="text-center priority-cell">
                <div class="gap-display">
                    <span class="priority-number priority-${priorityIndex + 1}">${priorityIndex + 1}</span>
                    <select class="form-select form-select-sm"
                            data-stream-id="${stream.streamId}"
                            data-priority-index="${priorityIndex}"
                            onchange="window.handleGapPriorityChange(this)">
                        ${generateGapOptions(stream, displayGap, priorityIndex)}
                    </select>
                    ${overriddenDot}
                </div>
            </td>
        `;
    }

    // Handle gap priority change
    window.handleGapPriorityChange = function(selectElement) {
        const streamId = selectElement.dataset.streamId;
        const priorityIndex = parseInt(selectElement.dataset.priorityIndex);
        const newGapType = selectElement.value;

        const streamData = gapPrioritizationData.find(s => s.streamId === streamId);
        if (!streamData) return;

        if (newGapType === 'Remove') {
            streamData.currentSequence[priorityIndex] = { type: 'Remove', amount: 0, removed: true, isOverridden: true };
        } else {
            const gapAmount = streamData.gaps[newGapType] || 0;
            const wasDefault = streamData.defaultSequence[priorityIndex] === newGapType;
            streamData.currentSequence[priorityIndex] = {
                type: newGapType,
                amount: gapAmount,
                removed: false,
                isOverridden: !wasDefault
            };
        }

        // Re-render all tables
        renderGapSequencingTable();
        renderGapAmountsTable();
        renderGapSummary();
        renderMasterPriorityList();

        // Save state
        savePrioritizationState();
    };

    // Render Gap Amounts Table
    function renderGapAmountsTable() {
        const tbody = document.getElementById('gapAmountsBody');

        if (gapPrioritizationData.length === 0) {
            tbody.innerHTML = `
                <tr class="placeholder-row">
                    <td colspan="8" class="text-center text-muted py-4">
                        <i class="fas fa-info-circle me-2"></i>Gap amounts will appear after gap prioritization
                    </td>
                </tr>
            `;
            return;
        }

        let html = '';
        gapPrioritizationData.forEach((stream) => {
            const seq = stream.currentSequence;
            html += `
                <tr>
                    <td class="text-center">
                        <span class="rank-badge ${getRankBadgeClass(stream.finalRank)}">${stream.finalRank}</span>
                    </td>
                    <td>${stream.streamName}</td>
                    <td class="text-center">
                        <span class="gap-badge ${getGapBadgeClass(seq[0]?.type)}">${seq[0]?.removed ? '-' : seq[0]?.type}</span>
                    </td>
                    <td class="text-end fw-semibold">${seq[0]?.removed ? '-' : formatCurrency(stream.gaps[seq[0]?.type])}</td>
                    <td class="text-center">
                        <span class="gap-badge ${getGapBadgeClass(seq[1]?.type)}">${seq[1]?.removed ? '-' : seq[1]?.type}</span>
                    </td>
                    <td class="text-end fw-semibold">${seq[1]?.removed ? '-' : formatCurrency(stream.gaps[seq[1]?.type])}</td>
                    <td class="text-center">
                        <span class="gap-badge ${getGapBadgeClass(seq[2]?.type)}">${seq[2]?.removed ? '-' : seq[2]?.type}</span>
                    </td>
                    <td class="text-end fw-semibold">${seq[2]?.removed ? '-' : formatCurrency(stream.gaps[seq[2]?.type])}</td>
                </tr>
            `;
        });

        tbody.innerHTML = html;
    }

    // Render Gap Summary
    function renderGapSummary() {
        const totalStreams = gapPrioritizationData.length;
        const totalCombinations = totalStreams * 3;
        let removedGaps = 0;
        let activeGaps = 0;

        gapPrioritizationData.forEach(stream => {
            stream.currentSequence.forEach(gap => {
                if (gap.removed) removedGaps++;
                else activeGaps++;
            });
        });

        document.getElementById('gapStatTotalStreams').textContent = totalStreams;
        document.getElementById('gapStatTotalCombinations').textContent = totalCombinations;
        document.getElementById('gapStatRemovedGaps').textContent = removedGaps;
        document.getElementById('gapStatActiveGaps').textContent = activeGaps;

        // Render first priority actions
        const firstPriorityDiv = document.getElementById('firstPriorityActions');
        if (gapPrioritizationData.length === 0) {
            firstPriorityDiv.innerHTML = '<div class="text-muted">No actions defined yet</div>';
            return;
        }

        let fpHtml = '';
        gapPrioritizationData.forEach(stream => {
            const firstGap = stream.currentSequence.find(g => !g.removed);
            if (firstGap) {
                fpHtml += `
                    <div class="first-priority-item">
                        <span class="fp-rank">${stream.finalRank}</span>
                        <span class="fp-stream">${stream.streamName}</span>
                        <span class="gap-badge ${getGapBadgeClass(firstGap.type)} fp-gap">${firstGap.type}</span>
                        <span class="fp-amount">${formatCurrency(stream.gaps[firstGap.type])}</span>
                    </div>
                `;
            }
        });

        firstPriorityDiv.innerHTML = fpHtml || '<div class="text-muted">No active gap actions</div>';
    }

    // Render Master Priority List
    function renderMasterPriorityList() {
        const tbody = document.getElementById('masterPriorityBody');

        if (gapPrioritizationData.length === 0) {
            tbody.innerHTML = `
                <tr class="placeholder-row">
                    <td colspan="4" class="text-center text-muted py-3">
                        <small>Master list will populate from gap priorities</small>
                    </td>
                </tr>
            `;
            return;
        }

        // Build master list: iterate through priorities, then streams
        const masterList = [];
        let masterPriority = 1;

        // For each stream, add their gaps in sequence order
        gapPrioritizationData.forEach(stream => {
            stream.currentSequence.forEach((gap, gapIndex) => {
                if (!gap.removed) {
                    masterList.push({
                        masterPriority: null, // Will be assigned after sorting
                        streamRank: stream.finalRank,
                        streamName: stream.streamName,
                        gapType: gap.type,
                        gapAmount: stream.gaps[gap.type] || 0,
                        gapPriority: gapIndex + 1,
                        isFirstInStream: gapIndex === stream.currentSequence.findIndex(g => !g.removed)
                    });
                }
            });
        });

        // Sort: by stream rank first, then by gap priority within stream
        masterList.sort((a, b) => {
            if (a.streamRank !== b.streamRank) return a.streamRank - b.streamRank;
            return a.gapPriority - b.gapPriority;
        });

        // Assign master priorities
        masterList.forEach((item, index) => {
            item.masterPriority = index + 1;
        });

        let html = '';
        masterList.forEach((item, index) => {
            const streamBreakClass = item.isFirstInStream && index > 0 ? 'stream-break' : '';
            html += `
                <tr class="master-priority-row ${streamBreakClass}">
                    <td class="text-center">
                        <span class="priority-number priority-${item.gapPriority}">${item.masterPriority}</span>
                    </td>
                    <td>${item.streamName}</td>
                    <td><span class="gap-badge ${getGapBadgeClass(item.gapType)}">${item.gapType}</span></td>
                    <td class="text-end fw-semibold">${formatCurrency(item.gapAmount)}</td>
                </tr>
            `;
        });

        tbody.innerHTML = html;
    }

    // ======================= REVENUE IMPACT & IMPROVEMENT SCORING =======================

    let matrixChart = null;

    // Build a flat list of all individual gaps across included streams, sorted by amount
    function buildRevenueImpactList() {
        const { finalRanking } = calculateFinalRankings();
        const allGaps = [];

        finalRanking.forEach(stream => {
            const isPropertyBased = stream.type === 'property-tax';
            const gapTypes = [
                { type: 'Compliance', amount: stream.complianceGap || 0 },
                { type: 'Coverage', amount: stream.coverageGap || 0 },
                { type: isPropertyBased ? 'Valuation' : 'Liability', amount: isPropertyBased ? (stream.valuationGap || 0) : (stream.liabilityGap || 0) }
            ];

            gapTypes.forEach(g => {
                if (g.amount > 0) {
                    allGaps.push({
                        streamName: stream.name,
                        streamType: stream.type,
                        streamRank: stream.finalRank,
                        gapType: g.type,
                        amount: g.amount,
                        currentRevenue: stream.currentRevenue || 0,
                        potentialRevenue: stream.potentialRevenue || (stream.totalFunctionalGap + (stream.currentRevenue || 0)),
                        totalFunctionalGap: stream.totalFunctionalGap
                    });
                }
            });
        });

        // Sort by amount descending
        allGaps.sort((a, b) => b.amount - a.amount);

        const totalGapSum = allGaps.reduce((sum, g) => sum + g.amount, 0);
        allGaps.forEach(g => {
            g.share = totalGapSum > 0 ? (g.amount / totalGapSum) * 100 : 0;
        });

        return allGaps;
    }

    // Render Revenue Impact Ranking table
    function renderRevenueImpactTable() {
        const tbody = document.getElementById('revenueImpactBody');
        const gaps = buildRevenueImpactList();

        if (gaps.length === 0) {
            tbody.innerHTML = '<tr class="placeholder-row"><td colspan="5" class="text-center text-muted py-3"><small>No gap data available</small></td></tr>';
            return;
        }

        const maxAmount = gaps[0].amount;
        let html = '';
        gaps.forEach((g, idx) => {
            const barWidth = maxAmount > 0 ? (g.amount / maxAmount) * 100 : 0;
            const barColor = g.gapType === 'Compliance' ? '#ef4444' :
                             g.gapType === 'Coverage' ? '#f59e0b' :
                             g.gapType === 'Valuation' ? '#3b82f6' : '#8b5cf6';

            html += `
                <tr>
                    <td class="text-center"><span class="priority-number priority-${idx < 3 ? idx + 1 : 3}">${idx + 1}</span></td>
                    <td>${g.streamName}</td>
                    <td><span class="gap-badge ${getGapBadgeClass(g.gapType)}">${g.gapType}</span></td>
                    <td class="text-end fw-semibold">${formatCurrency(g.amount)}</td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="impact-bar flex-grow-1">
                                <div class="impact-bar-fill" style="width: ${barWidth}%; background: ${barColor};"></div>
                            </div>
                            <span class="small fw-semibold" style="min-width: 36px;">${g.share.toFixed(0)}%</span>
                        </div>
                    </td>
                </tr>
            `;
        });

        tbody.innerHTML = html;
    }

    // Calculate improvement opportunity score for each gap
    // Score = weighted combination of: absolute gap size, gap-to-potential ratio, number of available solution cards
    function buildImprovementScores() {
        const gaps = buildRevenueImpactList();
        if (gaps.length === 0) return [];

        const maxAmount = Math.max(...gaps.map(g => g.amount));

        gaps.forEach(g => {
            // Factor 1: Size relative to largest gap (0-40 points)
            const sizeFactor = maxAmount > 0 ? (g.amount / maxAmount) * 40 : 0;

            // Factor 2: Gap as % of potential revenue (0-35 points)
            // Higher gap/potential ratio = more room to improve
            const gapRatio = g.potentialRevenue > 0 ? g.amount / g.potentialRevenue : 0;
            const ratioFactor = Math.min(gapRatio, 1) * 35;

            // Factor 3: Available solution cards for this gap type (0-25 points)
            let cardCount = 0;
            if (typeof SolutionsDatabase !== 'undefined') {
                if (g.streamType === 'property-tax') {
                    cardCount = SolutionsDatabase.getSolutionsByStreamAndGap('Property Tax', g.gapType).length;
                } else {
                    // For NP streams, count across all subgroups as a proxy
                    ['A', 'B', 'C'].forEach(sg => {
                        cardCount += SolutionsDatabase.getSolutionsBySubgroupAndGap(sg, g.gapType).length;
                    });
                    cardCount = Math.round(cardCount / 3); // Average per subgroup
                }
            }
            const cardFactor = Math.min(cardCount / 10, 1) * 25;

            g.score = Math.round(sizeFactor + ratioFactor + cardFactor);
            g.cardCount = cardCount;
            g.gapRatio = gapRatio;
        });

        // Sort by score descending
        gaps.sort((a, b) => b.score - a.score);
        return gaps;
    }

    // Render Improvement Opportunity Scoring table
    function renderImprovementScoreTable() {
        const tbody = document.getElementById('improvementScoreBody');
        const gaps = buildImprovementScores();

        if (gaps.length === 0) {
            tbody.innerHTML = '<tr class="placeholder-row"><td colspan="5" class="text-center text-muted py-3"><small>No gap data available</small></td></tr>';
            return;
        }

        let html = '';
        gaps.forEach((g, idx) => {
            const scoreClass = g.score >= 60 ? 'score-high' : g.score >= 35 ? 'score-medium' : 'score-low';
            const potentialClass = g.gapRatio >= 0.4 ? 'high' : g.gapRatio >= 0.2 ? 'medium' : 'low';
            const potentialLabel = g.gapRatio >= 0.4 ? 'High potential' : g.gapRatio >= 0.2 ? 'Moderate' : 'Lower';

            html += `
                <tr>
                    <td class="text-center"><span class="priority-number priority-${idx < 3 ? idx + 1 : 3}">${idx + 1}</span></td>
                    <td>${g.streamName}</td>
                    <td><span class="gap-badge ${getGapBadgeClass(g.gapType)}">${g.gapType}</span></td>
                    <td class="text-center"><span class="score-badge ${scoreClass}">${g.score}</span></td>
                    <td class="text-center"><span class="potential-label ${potentialClass}">${potentialLabel}</span></td>
                </tr>
            `;
        });

        tbody.innerHTML = html;
    }

    // Render Interactive Priority Matrix (bubble chart)
    function renderPriorityMatrix() {
        const placeholder = document.getElementById('matrixPlaceholder');
        const canvas = document.getElementById('priorityMatrixChart');
        const gaps = buildImprovementScores();

        if (matrixChart) matrixChart.destroy();

        if (gaps.length === 0) {
            if (placeholder) placeholder.style.display = 'block';
            if (canvas) canvas.style.display = 'none';
            return;
        }

        if (placeholder) placeholder.style.display = 'none';
        if (canvas) canvas.style.display = 'block';

        // Map gap types to colors
        const gapColors = {
            'Compliance': 'rgba(239, 68, 68, 0.7)',
            'Coverage': 'rgba(245, 158, 11, 0.7)',
            'Valuation': 'rgba(59, 130, 246, 0.7)',
            'Liability': 'rgba(139, 92, 246, 0.7)'
        };

        const gapBorderColors = {
            'Compliance': '#ef4444',
            'Coverage': '#f59e0b',
            'Valuation': '#3b82f6',
            'Liability': '#8b5cf6'
        };

        // Build datasets: one per gap type for legend
        const byGapType = {};
        gaps.forEach(g => {
            if (!byGapType[g.gapType]) byGapType[g.gapType] = [];
            byGapType[g.gapType].push({
                x: g.amount,
                y: g.cardCount,
                r: Math.max(8, Math.min(30, g.score / 2)),
                label: g.streamName + ' — ' + g.gapType,
                score: g.score
            });
        });

        const datasets = Object.keys(byGapType).map(gapType => ({
            label: gapType,
            data: byGapType[gapType],
            backgroundColor: gapColors[gapType] || 'rgba(107, 114, 128, 0.7)',
            borderColor: gapBorderColors[gapType] || '#6b7280',
            borderWidth: 2
        }));

        const ctx = canvas.getContext('2d');
        matrixChart = new Chart(ctx, {
            type: 'bubble',
            data: { datasets: datasets },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top',
                        labels: { usePointStyle: true, padding: 15 }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                const d = context.raw;
                                return [
                                    d.label,
                                    'Revenue impact: ' + formatCurrency(d.x),
                                    'Solution cards: ' + d.y,
                                    'Opportunity score: ' + d.score
                                ];
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        title: { display: true, text: 'Revenue Impact (Gap Amount)', font: { weight: 'bold' } },
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                var abs = Math.abs(value);
                                if (abs >= 1e9) return currencySymbol + (value / 1e9).toFixed(1) + 'B';
                                if (abs >= 1e6) return currencySymbol + (value / 1e6).toFixed(1) + 'M';
                                if (abs >= 1e3) return currencySymbol + (value / 1e3).toFixed(0) + 'K';
                                return currencySymbol + value;
                            }
                        }
                    },
                    y: {
                        title: { display: true, text: 'Available Solution Cards', font: { weight: 'bold' } },
                        beginAtZero: true,
                        ticks: { stepSize: 1 }
                    }
                }
            }
        });
        if (window.registerChart) registerChart('priorityMatrixChart', matrixChart);
    }

    // Render all Step 3 components
    function renderRevenueAndScoring() {
        renderRevenueImpactTable();
        renderImprovementScoreTable();
        renderPriorityMatrix();
    }

    // Hook into gap prioritization init so Step 3 updates whenever Step 2 does
    const _origInitGapPrioritization = initializeGapPrioritization;
    initializeGapPrioritization = function() {
        _origInitGapPrioritization();
        renderRevenueAndScoring();
    };

    // Initialize Gap Prioritization on load
    initializeGapPrioritization();
});
</script>
