</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Stream color scheme
    const streamColors = {
        'Property Tax': '#4e79a7',
        'Business License': '#f28e2b',
        'default': '#76b7b2'
    };

    // Generic stream colors (rotating palette)
    const genericStreamPalette = ['#76b7b2', '#59a14f', '#edc948', '#b07aa1', '#ff9da7', '#9c755f', '#bab0ac'];

    // Currency symbol from AppContext (single source of truth)
    let currencySymbol = '$';

    // Get initial currency from AppContext
    function getCurrencyFromContext() {
        if (typeof AppContext !== 'undefined') {
            return AppContext.get('currencySymbol') || '$';
        }
        // Fallback to localStorage if AppContext not available
        return localStorage.getItem('selectedCurrencySymbol') || '$';
    }

    currencySymbol = getCurrencyFromContext();

    // Subscribe to currency changes from AppContext for reactive updates
    if (typeof AppContext !== 'undefined') {
        AppContext.subscribe('currencySymbol', function(newSymbol) {
            console.log('Prioritization: Currency changed to', newSymbol);
            currencySymbol = newSymbol || '$';
            // Re-render tables and charts with new currency
            renderAdjustableTable();
            renderFinalTable();
            updateCharts();
            updateStatistics();
            renderGapAmountsTable();
            renderGapSummary();
            renderMasterPriorityList();
        });
        console.log('Prioritization: Subscribed to AppContext currencySymbol changes');
    }

    // Stream data array
    let streams = [];
    let barChart = null;
    let pieChart = null;

    // Initialize tooltips
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });

    // Load stream data from RosraStateManager (preferred) or localStorage (fallback)
    function loadStreamData() {
        streams = [];
        let genericColorIndex = 0;

        // Try to use RosraStateManager first
        if (typeof RosraStateManager !== 'undefined') {
            const stateStreams = RosraStateManager.getStreams();
            if (stateStreams.length > 0) {
                stateStreams.forEach((s, idx) => {
                    // Assign colors based on type
                    let color = streamColors[s.name] || streamColors['default'];
                    if (s.type === 'generic-stream') {
                        color = genericStreamPalette[genericColorIndex % genericStreamPalette.length];
                        genericColorIndex++;
                    }

                    streams.push({
                        ...s,
                        color: color
                    });
                });

                console.log('Prioritization: Loaded', streams.length, 'streams from RosraStateManager');

                // Sort and assign default ranks
                streams.sort((a, b) => b.totalFunctionalGap - a.totalFunctionalGap);
                streams.forEach((stream, index) => {
                    stream.defaultRank = index + 1;
                });
                return;
            }
        }

        // Fallback to localStorage if RosraStateManager is empty
        console.log('Prioritization: Falling back to localStorage');

        // Load Property Tax data
        const propertyTaxGap = parseFloat(localStorage.getItem('propertyTaxGapValue')) || 0;
        if (propertyTaxGap > 0) {
            streams.push({
                id: 'property-tax',
                name: 'Property Tax',
                type: 'property-tax',
                totalFunctionalGap: propertyTaxGap,
                currentRevenue: parseFloat(localStorage.getItem('propertyTaxCurrentValue')) || 0,
                potentialRevenue: parseFloat(localStorage.getItem('propertyTaxPotentialValue')) || 0,
                complianceGap: parseFloat(localStorage.getItem('propertyTaxComplianceGap')) || 0,
                coverageGap: parseFloat(localStorage.getItem('propertyTaxCoverageGap')) || 0,
                valuationGap: parseFloat(localStorage.getItem('propertyTaxValuationGap')) || 0,
                complianceRatio: parseFloat(localStorage.getItem('propertyTaxComplianceRatio')) || 0,
                coverageRatio: parseFloat(localStorage.getItem('propertyTaxCoverageRatio')) || 0,
                included: true,
                adjustedRank: null,
                color: streamColors['Property Tax']
            });
        }

        // Load Business License data
        const licenseGap = parseFloat(localStorage.getItem('licenseGapValue')) || 0;
        if (licenseGap > 0) {
            streams.push({
                id: 'business-license',
                name: 'Business License',
                type: 'business-license',
                totalFunctionalGap: licenseGap,
                currentRevenue: parseFloat(localStorage.getItem('licenseCurrentValue')) || 0,
                potentialRevenue: parseFloat(localStorage.getItem('licensePotentialValue')) || 0,
                complianceGap: parseFloat(localStorage.getItem('licenseComplianceGap')) || 0,
                coverageGap: parseFloat(localStorage.getItem('licenseCoverageGap')) || 0,
                liabilityGap: parseFloat(localStorage.getItem('licenseLiabilityGap')) || 0,
                complianceRatio: parseFloat(localStorage.getItem('licenseComplianceRatio')) || 0,
                coverageRatio: parseFloat(localStorage.getItem('licenseCoverageRatio')) || 0,
                included: true,
                adjustedRank: null,
                color: streamColors['Business License']
            });
        }

        // Load Generic Streams data
        const genericStreamsJson = localStorage.getItem('genericStreamsData');
        if (genericStreamsJson) {
            try {
                const genericStreams = JSON.parse(genericStreamsJson);
                if (Array.isArray(genericStreams)) {
                    genericStreams.forEach((gs, index) => {
                        const streamId = gs.streamId || `generic-stream-${index}`;
                        const gap = parseFloat(localStorage.getItem(streamId + 'GapValue')) || 0;
                        if (gap > 0) {
                            streams.push({
                                id: streamId,
                                name: gs.streamName || `Stream ${index + 1}`,
                                type: 'generic-stream',
                                totalFunctionalGap: gap,
                                currentRevenue: parseFloat(localStorage.getItem(streamId + 'CurrentValue')) || 0,
                                potentialRevenue: parseFloat(localStorage.getItem(streamId + 'PotentialValue')) || 0,
                                complianceGap: parseFloat(localStorage.getItem(streamId + 'ComplianceGap')) || 0,
                                coverageGap: parseFloat(localStorage.getItem(streamId + 'CoverageGap')) || 0,
                                liabilityGap: parseFloat(localStorage.getItem(streamId + 'LiabilityGap')) || 0,
                                included: true,
                                adjustedRank: null,
                                color: genericStreamPalette[genericColorIndex % genericStreamPalette.length]
                            });
                            genericColorIndex++;
                        }
                    });
                }
            } catch (e) {
                console.error('Error parsing generic streams data:', e);
            }
        }

        // Also check for individual generic stream keys
        for (let i = 0; i < 10; i++) {
            const streamId = `generic-stream-${i}`;
            const gap = parseFloat(localStorage.getItem(streamId + 'GapValue')) || 0;
            const streamName = localStorage.getItem(streamId + 'Name');

            // Check if we already added this stream
            const alreadyExists = streams.some(s => s.id === streamId);

            if (gap > 0 && !alreadyExists) {
                streams.push({
                    id: streamId,
                    name: streamName || `Generic Stream ${i + 1}`,
                    type: 'generic-stream',
                    totalFunctionalGap: gap,
                    currentRevenue: parseFloat(localStorage.getItem(streamId + 'CurrentValue')) || 0,
                    potentialRevenue: parseFloat(localStorage.getItem(streamId + 'PotentialValue')) || 0,
                    complianceGap: parseFloat(localStorage.getItem(streamId + 'ComplianceGap')) || 0,
                    coverageGap: parseFloat(localStorage.getItem(streamId + 'CoverageGap')) || 0,
                    liabilityGap: parseFloat(localStorage.getItem(streamId + 'LiabilityGap')) || 0,
                    included: true,
                    adjustedRank: null,
                    color: genericStreamPalette[genericColorIndex % genericStreamPalette.length]
                });
                genericColorIndex++;
            }
        }

        // Sort by Total Functional Gap (descending) for default ranking
        streams.sort((a, b) => b.totalFunctionalGap - a.totalFunctionalGap);

        // Assign default ranks
        streams.forEach((stream, index) => {
            stream.defaultRank = index + 1;
        });

        return streams;
    }

    // Format currency
    function formatCurrency(value) {
        if (value === null || value === undefined || isNaN(value)) return '-';
        return currencySymbol + value.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    }

    // Format percentage
    function formatPercent(value) {
        if (value === null || value === undefined || isNaN(value)) return '-';
        return value.toFixed(1) + '%';
    }

    // Get rank badge class
    function getRankBadgeClass(rank) {
        if (rank === 1) return 'rank-1';
        if (rank === 2) return 'rank-2';
        if (rank === 3) return 'rank-3';
        return 'rank-default';
    }

    // Render Adjustable Stream Table
    function renderAdjustableTable() {
        const tbody = document.getElementById('adjustableStreamBody');

        if (streams.length === 0) {
            tbody.innerHTML = `
                <tr class="placeholder-row">
                    <td colspan="5" class="text-center text-muted py-4">
                        <i class="fas fa-exclamation-circle me-2"></i>No stream data found. Please complete the Gap Analysis tabs first.
                    </td>
                </tr>
            `;
            return;
        }

        let html = '';
        streams.forEach((stream, index) => {
            const rowClass = stream.included ? '' : 'excluded-row';
            html += `
                <tr class="${rowClass}" data-stream-id="${stream.id}">
                    <td class="text-center">
                        <span class="rank-badge ${getRankBadgeClass(stream.defaultRank)}">${stream.defaultRank}</span>
                    </td>
                    <td>
                        <span class="stream-badge ${stream.type}"></span>
                        ${stream.name}
                    </td>
                    <td class="text-end fw-semibold">${formatCurrency(stream.totalFunctionalGap)}</td>
                    <td class="text-center">
                        <select class="form-select form-select-sm dropdown-include-exclude"
                                data-stream-id="${stream.id}"
                                onchange="window.handleIncludeExcludeChange(this)">
                            <option value="include" ${stream.included ? 'selected' : ''}>Include</option>
                            <option value="exclude" ${!stream.included ? 'selected' : ''}>Exclude</option>
                        </select>
                    </td>
                    <td class="text-center">
                        <select class="form-select form-select-sm dropdown-adjust-rank"
                                data-stream-id="${stream.id}"
                                onchange="window.handleAdjustRankChange(this)"
                                ${!stream.included ? 'disabled' : ''}>
                            <option value="">Auto</option>
                            ${generateRankOptions(streams.length, stream.adjustedRank)}
                        </select>
                    </td>
                </tr>
            `;
        });

        tbody.innerHTML = html;
    }

    // Generate rank options
    function generateRankOptions(totalStreams, selectedRank) {
        let options = '';
        for (let i = 1; i <= totalStreams; i++) {
            const selected = selectedRank === i ? 'selected' : '';
            options += `<option value="${i}" ${selected}>${i}</option>`;
        }
        return options;
    }

    // Handle Include/Exclude change
    window.handleIncludeExcludeChange = function(selectElement) {
        const streamId = selectElement.dataset.streamId;
        const included = selectElement.value === 'include';

        // Update stream data
        const stream = streams.find(s => s.id === streamId);
        if (stream) {
            stream.included = included;
            if (!included) {
                stream.adjustedRank = null;
            }
        }

        // Update row styling
        const row = selectElement.closest('tr');
        if (included) {
            row.classList.remove('excluded-row');
            row.querySelector('.dropdown-adjust-rank').disabled = false;
        } else {
            row.classList.add('excluded-row');
            row.querySelector('.dropdown-adjust-rank').disabled = true;
            row.querySelector('.dropdown-adjust-rank').value = '';
        }

        // Recalculate and render
        renderFinalTable();
        updateCharts();
        updateStatistics();

        // Save state
        savePrioritizationState();
    };

    // Handle Adjust Rank change
    window.handleAdjustRankChange = function(selectElement) {
        const streamId = selectElement.dataset.streamId;
        const newRank = selectElement.value ? parseInt(selectElement.value) : null;

        // Update stream data
        const stream = streams.find(s => s.id === streamId);
        if (stream) {
            stream.adjustedRank = newRank;
        }

        // Recalculate and render
        renderFinalTable();
        updateCharts();

        // Save state
        savePrioritizationState();
    };

    // Calculate final rankings
    function calculateFinalRankings() {
        const includedStreams = streams.filter(s => s.included);

        // Separate streams with and without adjusted ranks
        const adjustedStreams = includedStreams.filter(s => s.adjustedRank !== null);
        const autoStreams = includedStreams.filter(s => s.adjustedRank === null);

        // Sort auto streams by gap (descending)
        autoStreams.sort((a, b) => b.totalFunctionalGap - a.totalFunctionalGap);

        // Create final ranking array
        const finalRanking = [];
        const usedRanks = new Set(adjustedStreams.map(s => s.adjustedRank));

        // Place adjusted streams first
        adjustedStreams.forEach(stream => {
            finalRanking.push({
                ...stream,
                finalRank: stream.adjustedRank
            });
        });

        // Fill in auto streams with remaining ranks
        let autoRank = 1;
        autoStreams.forEach(stream => {
            while (usedRanks.has(autoRank)) {
                autoRank++;
            }
            finalRanking.push({
                ...stream,
                finalRank: autoRank
            });
            usedRanks.add(autoRank);
            autoRank++;
        });

        // Sort by final rank
        finalRanking.sort((a, b) => a.finalRank - b.finalRank);

        // Calculate share of total gap
        const totalGap = finalRanking.reduce((sum, s) => sum + s.totalFunctionalGap, 0);
        finalRanking.forEach(stream => {
            stream.shareOfTotalGap = totalGap > 0 ? (stream.totalFunctionalGap / totalGap) * 100 : 0;
        });

        return { finalRanking, totalGap };
    }

    // Render Final Stream Table
    function renderFinalTable() {
        const tbody = document.getElementById('finalStreamBody');
        const footer = document.getElementById('finalStreamFooter');
        const { finalRanking, totalGap } = calculateFinalRankings();

        if (finalRanking.length === 0) {
            tbody.innerHTML = `
                <tr class="placeholder-row">
                    <td colspan="5" class="text-center text-muted py-4">
                        <i class="fas fa-info-circle me-2"></i>No streams included. Please include at least one stream in the table above.
                    </td>
                </tr>
            `;
            footer.style.display = 'none';
            return;
        }

        let html = '';
        finalRanking.forEach((stream) => {
            html += `
                <tr data-stream-id="${stream.id}">
                    <td class="text-center">
                        <span class="rank-badge ${getRankBadgeClass(stream.finalRank)}">${stream.finalRank}</span>
                    </td>
                    <td>
                        <span class="stream-badge ${stream.type}"></span>
                        ${stream.name}
                    </td>
                    <td class="text-end fw-semibold">${formatCurrency(stream.totalFunctionalGap)}</td>
                    <td class="text-center">
                        <div>
                            <span class="fw-semibold">${formatPercent(stream.shareOfTotalGap)}</span>
                            <div class="share-bar">
                                <div class="share-bar-fill" style="width: ${stream.shareOfTotalGap}%; background-color: ${stream.color};"></div>
                            </div>
                        </div>
                    </td>
                    <td class="text-center">
                        <span class="status-badge included">Included</span>
                    </td>
                </tr>
            `;
        });

        tbody.innerHTML = html;

        // Show footer with total
        footer.style.display = '';
        document.getElementById('totalIncludedGap').textContent = formatCurrency(totalGap);
    }

    // Update Charts
    function updateCharts() {
        const { finalRanking, totalGap } = calculateFinalRankings();

        // Get placeholder and canvas elements
        const barPlaceholder = document.getElementById('barChartPlaceholder');
        const piePlaceholder = document.getElementById('pieChartPlaceholder');
        const barCanvas = document.getElementById('gapBarChart');
        const pieCanvas = document.getElementById('gapPieChart');

        // Destroy existing charts
        if (barChart) barChart.destroy();
        if (pieChart) pieChart.destroy();

        if (finalRanking.length === 0) {
            // Show placeholders, hide canvases
            if (barPlaceholder) barPlaceholder.style.display = 'block';
            if (piePlaceholder) piePlaceholder.style.display = 'block';
            if (barCanvas) barCanvas.style.display = 'none';
            if (pieCanvas) pieCanvas.style.display = 'none';
            return;
        }

        // Hide placeholders, show canvases
        if (barPlaceholder) barPlaceholder.style.display = 'none';
        if (piePlaceholder) piePlaceholder.style.display = 'none';
        if (barCanvas) barCanvas.style.display = 'block';
        if (pieCanvas) pieCanvas.style.display = 'block';

        const labels = finalRanking.map(s => s.name);
        const gapData = finalRanking.map(s => s.totalFunctionalGap);
        const shareData = finalRanking.map(s => s.shareOfTotalGap);
        const colors = finalRanking.map(s => s.color);

        // Bar Chart (horizontal)
        const barCtx = document.getElementById('gapBarChart').getContext('2d');
        barChart = new Chart(barCtx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Total Functional Gap',
                    data: gapData,
                    backgroundColor: colors,
                    borderColor: colors.map(c => c),
                    borderWidth: 1
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return formatCurrency(context.raw);
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return currencySymbol + value.toLocaleString();
                            }
                        }
                    }
                }
            }
        });

        // Pie Chart
        const pieCtx = document.getElementById('gapPieChart').getContext('2d');
        pieChart = new Chart(pieCtx, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: shareData,
                    backgroundColor: colors,
                    borderColor: '#fff',
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 15,
                            usePointStyle: true
                        }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.label + ': ' + formatPercent(context.raw);
                            }
                        }
                    }
                }
            }
        });
    }

    // Update Statistics
    function updateStatistics() {
        const includedStreams = streams.filter(s => s.included);
        const totalGapAll = streams.reduce((sum, s) => sum + s.totalFunctionalGap, 0);
        const totalGapIncluded = includedStreams.reduce((sum, s) => sum + s.totalFunctionalGap, 0);

        document.getElementById('statTotalStreams').textContent = streams.length;
        document.getElementById('statIncludedStreams').textContent = includedStreams.length;
        document.getElementById('statTotalGap').textContent = formatCurrency(totalGapAll);
        document.getElementById('statIncludedGap').textContent = formatCurrency(totalGapIncluded);
    }

    // ======================= STATE PERSISTENCE =======================

    // Save prioritization state to FormStateManager (and localStorage backup)
    function savePrioritizationState() {
        try {
            // Build state object with stream customizations and gap priorities
            const state = {
                streamCustomizations: streams.map(s => ({
                    id: s.id,
                    included: s.included,
                    adjustedRank: s.adjustedRank
                })),
                gapPrioritization: gapPrioritizationData.map(g => ({
                    streamId: g.streamId,
                    currentSequence: g.currentSequence.map(seq => ({
                        type: seq.type,
                        removed: seq.removed,
                        isOverridden: seq.isOverridden
                    }))
                }))
            };

            // Use FormStateManager if available (preferred)
            if (typeof FormStateManager !== 'undefined') {
                FormStateManager.setData('prioritizationState', state);
                console.log('Prioritization: State saved via FormStateManager');
            } else {
                // Fallback to localStorage only
                localStorage.setItem('prioritizationState', JSON.stringify(state));
                console.log('Prioritization: State saved to localStorage');
            }
        } catch (e) {
            console.error('Prioritization: Error saving state', e);
        }
    }

    // Load prioritization state from FormStateManager (or localStorage fallback)
    function loadPrioritizationState() {
        try {
            let state = null;

            // Use FormStateManager if available (preferred)
            if (typeof FormStateManager !== 'undefined') {
                state = FormStateManager.getData('prioritizationState');
                if (state) {
                    console.log('Prioritization: State loaded via FormStateManager');
                }
            }

            // Fallback to localStorage
            if (!state) {
                const localData = localStorage.getItem('prioritizationState');
                if (localData) {
                    state = JSON.parse(localData);
                    console.log('Prioritization: State loaded from localStorage');
                }
            }

            return state;
        } catch (e) {
            console.error('Prioritization: Error loading state', e);
            return null;
        }
    }

    // Apply saved state to streams
    function applySavedState() {
        const state = loadPrioritizationState();
        if (!state) return false;

        let stateApplied = false;

        // Apply stream customizations (include/exclude, adjusted ranks)
        if (state.streamCustomizations && streams.length > 0) {
            state.streamCustomizations.forEach(saved => {
                const stream = streams.find(s => s.id === saved.id);
                if (stream) {
                    stream.included = saved.included;
                    stream.adjustedRank = saved.adjustedRank;
                    stateApplied = true;
                }
            });
        }

        return stateApplied;
    }

    // Apply saved gap prioritization state
    function applySavedGapPrioritization() {
        const state = loadPrioritizationState();
        if (!state || !state.gapPrioritization) return;

        state.gapPrioritization.forEach(saved => {
            const gapData = gapPrioritizationData.find(g => g.streamId === saved.streamId);
            if (gapData && saved.currentSequence) {
                saved.currentSequence.forEach((seq, idx) => {
                    if (gapData.currentSequence[idx]) {
                        // Only apply if it has been overridden
                        if (seq.isOverridden) {
                            gapData.currentSequence[idx].type = seq.type;
                            gapData.currentSequence[idx].removed = seq.removed;
                            gapData.currentSequence[idx].isOverridden = seq.isOverridden;
                            // Update the amount based on the type
                            if (!seq.removed && seq.type !== 'Remove') {
                                gapData.currentSequence[idx].amount = gapData.gaps[seq.type] || 0;
                            }
                        }
                    }
                });
            }
        });

        console.log('Prioritization: Gap prioritization state applied');
    }

    // Initialize module
    function initializePrioritization() {
        loadStreamData();
        // Apply saved stream customizations (include/exclude, ranks) after loading streams
        applySavedState();
        renderAdjustableTable();
        renderFinalTable();
        updateCharts();
        updateStatistics();
    }

    // Initialize on load
    initializePrioritization();

    // Subscribe to RosraStateManager for reactive updates (preferred method)
    if (typeof RosraStateManager !== 'undefined') {
        RosraStateManager.subscribe('streams', function(updatedStreams) {
            console.log('Prioritization: Received stream update from RosraStateManager');
            loadStreamData();
            renderAdjustableTable();
            renderFinalTable();
            updateCharts();
            updateStatistics();
            initializeGapPrioritization();
        });
        console.log('Prioritization: Subscribed to RosraStateManager');
    }

    // Listen for storage changes (fallback for backward compatibility)
    window.addEventListener('storage', function(e) {
        if (e.key && (e.key.includes('Gap') || e.key.includes('Value') || e.key.includes('generic'))) {
            loadStreamData();
            renderAdjustableTable();
            renderFinalTable();
            updateCharts();
            updateStatistics();
        }
    });

    // Also listen for custom events from gap analysis tabs
    window.addEventListener('gapAnalysisUpdated', function() {
        loadStreamData();
        renderAdjustableTable();
        renderFinalTable();
        updateCharts();
        updateStatistics();
        initializeGapPrioritization();
    });

    // ======================= GAP PRIORITIZATION (STEP 2) =======================

    // Gap prioritization data structure
    let gapPrioritizationData = [];

    // Determine mode based on compliance and coverage ratios
    function determineMode(stream) {
        // Calculate compliance ratio: Revenue / Billed
        const billedAmount = stream.complianceGap + stream.currentRevenue;
        const complianceRatio = billedAmount > 0 ? (stream.currentRevenue / billedAmount) : 0;

        // Calculate coverage ratio: Registered / Estimated Total
        // For simplicity, use 1 - (coverageGap / totalPotential) as proxy
        const totalPotential = stream.potentialRevenue || (stream.totalFunctionalGap + stream.currentRevenue);
        const coverageRatio = totalPotential > 0 ? 1 - (stream.coverageGap / totalPotential) : 0;

        // Store ratios for display
        stream.complianceRatio = complianceRatio;
        stream.coverageRatio = coverageRatio;

        // Get the third gap label based on stream type
        const isPropertyBased = stream.type === 'property-tax';
        const thirdGapLabel = isPropertyBased ? 'Valuation' : 'Liability';
        const thirdGapValue = isPropertyBased ? (stream.valuationGap || 0) : (stream.liabilityGap || 0);

        // Build gaps array
        const gaps = [
            { type: 'Compliance', amount: stream.complianceGap || 0 },
            { type: 'Coverage', amount: stream.coverageGap || 0 },
            { type: thirdGapLabel, amount: thirdGapValue }
        ];

        let mode, sequence;

        if (complianceRatio >= 0.75) {
            // Revenue potential mode - sort by amount descending
            mode = 'Revenue Potential';
            sequence = [...gaps].sort((a, b) => b.amount - a.amount);
        } else if (coverageRatio >= 0.60) {
            // Compliance first mode
            mode = 'Compliance First';
            sequence = [
                gaps.find(g => g.type === 'Compliance'),
                gaps.find(g => g.type === 'Coverage'),
                gaps.find(g => g.type === thirdGapLabel)
            ];
        } else {
            // Overhaul mode - coverage first
            mode = 'Overhaul';
            sequence = [
                gaps.find(g => g.type === 'Coverage'),
                gaps.find(g => g.type === 'Compliance'),
                gaps.find(g => g.type === thirdGapLabel)
            ];
        }

        return {
            mode,
            sequence,
            thirdGapLabel,
            complianceRatio,
            coverageRatio
        };
    }

    // Get mode badge class
    function getModeBadgeClass(mode) {
        switch (mode) {
            case 'Revenue Potential': return 'mode-revenue-potential';
            case 'Compliance First': return 'mode-compliance-first';
            case 'Overhaul': return 'mode-overhaul';
            default: return '';
        }
    }

    // Get gap badge class
    function getGapBadgeClass(gapType) {
        if (!gapType || gapType === 'Remove') return 'gap-removed';
        switch (gapType) {
            case 'Compliance': return 'gap-compliance';
            case 'Coverage': return 'gap-coverage';
            case 'Valuation': return 'gap-valuation';
            case 'Liability': return 'gap-liability';
            default: return '';
        }
    }

    // Initialize gap prioritization data from included streams
    function initializeGapPrioritization() {
        const { finalRanking } = calculateFinalRankings();
        gapPrioritizationData = [];

        finalRanking.forEach((stream, index) => {
            const modeInfo = determineMode(stream);

            gapPrioritizationData.push({
                streamId: stream.id,
                streamName: stream.name,
                streamType: stream.type,
                finalRank: stream.finalRank,
                mode: modeInfo.mode,
                thirdGapLabel: modeInfo.thirdGapLabel,
                complianceRatio: modeInfo.complianceRatio,
                coverageRatio: modeInfo.coverageRatio,
                defaultSequence: modeInfo.sequence.map(g => g.type),
                currentSequence: modeInfo.sequence.map(g => ({ ...g, isOverridden: false, removed: false })),
                gaps: {
                    Compliance: stream.complianceGap || 0,
                    Coverage: stream.coverageGap || 0,
                    [modeInfo.thirdGapLabel]: modeInfo.thirdGapLabel === 'Valuation' ? (stream.valuationGap || 0) : (stream.liabilityGap || 0)
                }
            });
        });

        // Apply saved gap prioritization state (overrides)
        applySavedGapPrioritization();

        renderGapSequencingTable();
        renderGapAmountsTable();
        renderGapSummary();
        renderMasterPriorityList();
    }

    // Generate gap dropdown options
    function generateGapOptions(streamData, currentGap, priorityIndex) {
        const options = ['Compliance', 'Coverage', streamData.thirdGapLabel];
        let html = '';

        // Get already used gaps (excluding current position)
        const usedGaps = streamData.currentSequence
            .filter((g, i) => i !== priorityIndex && !g.removed && g.type !== 'Remove')
            .map(g => g.type);

        options.forEach(opt => {
            const disabled = usedGaps.includes(opt) ? 'disabled' : '';
            const selected = currentGap === opt ? 'selected' : '';
            html += `<option value="${opt}" ${selected} ${disabled}>${opt}</option>`;
        });

        // Add Remove option
        const removeSelected = currentGap === 'Remove' || !currentGap ? 'selected' : '';
        html += `<option value="Remove" ${removeSelected}>(Remove)</option>`;

        return html;
    }

    // Render Gap Sequencing Table
    function renderGapSequencingTable() {
        const tbody = document.getElementById('gapSequencingBody');

        if (gapPrioritizationData.length === 0) {
            tbody.innerHTML = `
                <tr class="placeholder-row">
                    <td colspan="6" class="text-center text-muted py-4">
                        <i class="fas fa-info-circle me-2"></i>Include streams in Step 1 to see gap prioritization options
                    </td>
                </tr>
            `;
            return;
        }

        let html = '';
        gapPrioritizationData.forEach((stream) => {
            html += `
                <tr data-stream-id="${stream.streamId}">
                    <td class="text-center">
                        <span class="rank-badge ${getRankBadgeClass(stream.finalRank)}">${stream.finalRank}</span>
                    </td>
                    <td>
                        <span class="stream-badge ${stream.streamType}"></span>
                        ${stream.streamName}
                    </td>
                    <td class="text-center">
                        <span class="mode-badge ${getModeBadgeClass(stream.mode)}">${stream.mode}</span>
                    </td>
                    ${renderPriorityCell(stream, 0)}
                    ${renderPriorityCell(stream, 1)}
                    ${renderPriorityCell(stream, 2)}
                </tr>
            `;
        });

        tbody.innerHTML = html;
    }

    // Render individual priority cell
    function renderPriorityCell(stream, priorityIndex) {
        const gapData = stream.currentSequence[priorityIndex];
        const gapType = gapData ? gapData.type : null;
        const isRemoved = gapData ? gapData.removed : true;
        const isOverridden = gapData ? gapData.isOverridden : false;

        const displayGap = isRemoved ? 'Remove' : gapType;
        const badgeClass = getGapBadgeClass(displayGap);
        const overriddenDot = isOverridden ? '<span class="overridden-indicator" title="Overridden from default"></span>' : '';

        return `
            <td class="text-center priority-cell">
                <div class="gap-display">
                    <span class="priority-number priority-${priorityIndex + 1}">${priorityIndex + 1}</span>
                    <select class="form-select form-select-sm"
                            data-stream-id="${stream.streamId}"
                            data-priority-index="${priorityIndex}"
                            onchange="window.handleGapPriorityChange(this)">
                        ${generateGapOptions(stream, displayGap, priorityIndex)}
                    </select>
                    ${overriddenDot}
                </div>
            </td>
        `;
    }

    // Handle gap priority change
    window.handleGapPriorityChange = function(selectElement) {
        const streamId = selectElement.dataset.streamId;
        const priorityIndex = parseInt(selectElement.dataset.priorityIndex);
        const newGapType = selectElement.value;

        const streamData = gapPrioritizationData.find(s => s.streamId === streamId);
        if (!streamData) return;

        if (newGapType === 'Remove') {
            streamData.currentSequence[priorityIndex] = { type: 'Remove', amount: 0, removed: true, isOverridden: true };
        } else {
            const gapAmount = streamData.gaps[newGapType] || 0;
            const wasDefault = streamData.defaultSequence[priorityIndex] === newGapType;
            streamData.currentSequence[priorityIndex] = {
                type: newGapType,
                amount: gapAmount,
                removed: false,
                isOverridden: !wasDefault
            };
        }

        // Re-render all tables
        renderGapSequencingTable();
        renderGapAmountsTable();
        renderGapSummary();
        renderMasterPriorityList();

        // Save state
        savePrioritizationState();
    };

    // Render Gap Amounts Table
    function renderGapAmountsTable() {
        const tbody = document.getElementById('gapAmountsBody');

        if (gapPrioritizationData.length === 0) {
            tbody.innerHTML = `
                <tr class="placeholder-row">
                    <td colspan="8" class="text-center text-muted py-4">
                        <i class="fas fa-info-circle me-2"></i>Gap amounts will appear after gap prioritization
                    </td>
                </tr>
            `;
            return;
        }

        let html = '';
        gapPrioritizationData.forEach((stream) => {
            const seq = stream.currentSequence;
            html += `
                <tr>
                    <td class="text-center">
                        <span class="rank-badge ${getRankBadgeClass(stream.finalRank)}">${stream.finalRank}</span>
                    </td>
                    <td>${stream.streamName}</td>
                    <td class="text-center">
                        <span class="gap-badge ${getGapBadgeClass(seq[0]?.type)}">${seq[0]?.removed ? '-' : seq[0]?.type}</span>
                    </td>
                    <td class="text-end fw-semibold">${seq[0]?.removed ? '-' : formatCurrency(stream.gaps[seq[0]?.type])}</td>
                    <td class="text-center">
                        <span class="gap-badge ${getGapBadgeClass(seq[1]?.type)}">${seq[1]?.removed ? '-' : seq[1]?.type}</span>
                    </td>
                    <td class="text-end fw-semibold">${seq[1]?.removed ? '-' : formatCurrency(stream.gaps[seq[1]?.type])}</td>
                    <td class="text-center">
                        <span class="gap-badge ${getGapBadgeClass(seq[2]?.type)}">${seq[2]?.removed ? '-' : seq[2]?.type}</span>
                    </td>
                    <td class="text-end fw-semibold">${seq[2]?.removed ? '-' : formatCurrency(stream.gaps[seq[2]?.type])}</td>
                </tr>
            `;
        });

        tbody.innerHTML = html;
    }

    // Render Gap Summary
    function renderGapSummary() {
        const totalStreams = gapPrioritizationData.length;
        const totalCombinations = totalStreams * 3;
        let removedGaps = 0;
        let activeGaps = 0;

        gapPrioritizationData.forEach(stream => {
            stream.currentSequence.forEach(gap => {
                if (gap.removed) removedGaps++;
                else activeGaps++;
            });
        });

        document.getElementById('gapStatTotalStreams').textContent = totalStreams;
        document.getElementById('gapStatTotalCombinations').textContent = totalCombinations;
        document.getElementById('gapStatRemovedGaps').textContent = removedGaps;
        document.getElementById('gapStatActiveGaps').textContent = activeGaps;

        // Render first priority actions
        const firstPriorityDiv = document.getElementById('firstPriorityActions');
        if (gapPrioritizationData.length === 0) {
            firstPriorityDiv.innerHTML = '<div class="text-muted">No actions defined yet</div>';
            return;
        }

        let fpHtml = '';
        gapPrioritizationData.forEach(stream => {
            const firstGap = stream.currentSequence.find(g => !g.removed);
            if (firstGap) {
                fpHtml += `
                    <div class="first-priority-item">
                        <span class="fp-rank">${stream.finalRank}</span>
                        <span class="fp-stream">${stream.streamName}</span>
                        <span class="gap-badge ${getGapBadgeClass(firstGap.type)} fp-gap">${firstGap.type}</span>
                        <span class="fp-amount">${formatCurrency(stream.gaps[firstGap.type])}</span>
                    </div>
                `;
            }
        });

        firstPriorityDiv.innerHTML = fpHtml || '<div class="text-muted">No active gap actions</div>';
    }

    // Render Master Priority List
    function renderMasterPriorityList() {
        const tbody = document.getElementById('masterPriorityBody');

        if (gapPrioritizationData.length === 0) {
            tbody.innerHTML = `
                <tr class="placeholder-row">
                    <td colspan="4" class="text-center text-muted py-3">
                        <small>Master list will populate from gap priorities</small>
                    </td>
                </tr>
            `;
            return;
        }

        // Build master list: iterate through priorities, then streams
        const masterList = [];
        let masterPriority = 1;

        // For each stream, add their gaps in sequence order
        gapPrioritizationData.forEach(stream => {
            stream.currentSequence.forEach((gap, gapIndex) => {
                if (!gap.removed) {
                    masterList.push({
                        masterPriority: null, // Will be assigned after sorting
                        streamRank: stream.finalRank,
                        streamName: stream.streamName,
                        gapType: gap.type,
                        gapAmount: stream.gaps[gap.type] || 0,
                        gapPriority: gapIndex + 1,
                        isFirstInStream: gapIndex === stream.currentSequence.findIndex(g => !g.removed)
                    });
                }
            });
        });

        // Sort: by stream rank first, then by gap priority within stream
        masterList.sort((a, b) => {
            if (a.streamRank !== b.streamRank) return a.streamRank - b.streamRank;
            return a.gapPriority - b.gapPriority;
        });

        // Assign master priorities
        masterList.forEach((item, index) => {
            item.masterPriority = index + 1;
        });

        let html = '';
        masterList.forEach((item, index) => {
            const streamBreakClass = item.isFirstInStream && index > 0 ? 'stream-break' : '';
            html += `
                <tr class="master-priority-row ${streamBreakClass}">
                    <td class="text-center">
                        <span class="priority-number priority-${item.gapPriority}">${item.masterPriority}</span>
                    </td>
                    <td>${item.streamName}</td>
                    <td><span class="gap-badge ${getGapBadgeClass(item.gapType)}">${item.gapType}</span></td>
                    <td class="text-end fw-semibold">${formatCurrency(item.gapAmount)}</td>
                </tr>
            `;
        });

        tbody.innerHTML = html;
    }

    // Initialize Gap Prioritization on load
    initializeGapPrioritization();
});
</script>
