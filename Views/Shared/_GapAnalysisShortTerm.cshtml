@model RosraApp.Models.ViewModels.RosraFormViewModel
@{
    bool isViewMode = ViewData["ViewMode"] != null && (bool)ViewData["ViewMode"];
}

<!-- Add jQuery if not already included -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<div class="gap-analysis-tab-content">
    <div class="row">
        <!-- Left Side (1/3 width) -->
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Short Term Information</h6>
                </div>
                <div class="card-body">
                    <!-- Original fields -->
                    <div class="mb-3">
                        <div class="form-group">
                            <label for="estimatedDailyFees">Estimated Number of Daily Fees</label>
                            <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" id="estimatedDailyFees" name="ShortTermUserCharge.EstimatedDailyFees" value="@(Model.ShortTermUserCharge.EstimatedDailyFees)" placeholder="Enter estimated number of daily fees" @(isViewMode ? "readonly" : "")>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-group">
                            <label for="actualDailyFees">Actual Number of Daily Fees</label>
                            <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" id="actualDailyFees" name="ShortTermUserCharge.ActualDailyFees" value="@(Model.ShortTermUserCharge.ActualDailyFees)" placeholder="Enter actual number of daily fees" @(isViewMode ? "readonly" : "")>
                        </div>
                    </div>
                    
                    <hr class="my-4">
                    <h6 class="mb-3">Categories</h6>
                    
                    <!-- Add Category Button -->
                    <div class="mt-3 mb-3">
                        <button type="button" class="btn btn-primary" id="openCreateCategoryModalBtn" @(isViewMode ? "disabled" : "")>
                            <i class="fas fa-plus"></i> Add New Category
                        </button>
                    </div>
                    
                    <!-- Category A Fields (Collapsible) -->
                    <div class="card mb-3 category-card" id="category-A">
                        <div class="card-header bg-light" data-bs-toggle="collapse" data-bs-target="#categoryACollapse" aria-expanded="false" aria-controls="categoryACollapse" style="cursor: pointer;">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <h6 class="mb-0 category-title">Category A</h6>
                                    <button type="button" class="btn btn-sm btn-link edit-category-btn ms-2" @(isViewMode ? "disabled" : "")>
                                        <i class="fas fa-edit"></i>
                                    </button>
                                </div>
                                <div>
                                    <button type="button" class="btn btn-sm btn-purple remove-category-btn" style="background-color: #6f42c1; color: white;" @(isViewMode ? "disabled" : "")>
                                        <i class="fas fa-trash"></i>
                                    </button>
                                    <i class="fas fa-chevron-down ms-2"></i>
                                </div>
                            </div>
                        </div>
                        <div id="categoryACollapse" class="collapse">
                            <div class="card-body">
                                <div class="mb-3">
                                    <div class="form-group">
                                        <label>Estimated Number of Daily Fees</label>
                                        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" name="ShortTermUserCharge.EstimatedDailyFeesCategoryA" value="@Model.ShortTermUserCharge.EstimatedDailyFeesCategoryA" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <div class="form-group">
                                        <label>Actual Number of Daily Fees</label>
                                        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" name="ShortTermUserCharge.ActualDailyFeesCategoryA" value="@Model.ShortTermUserCharge.ActualDailyFeesCategoryA" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <div class="form-group">
                                        <label>Potential Rate payable by Leasees</label>
                                        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" name="ShortTermUserCharge.PotentialRatePayableByCategoryA" value="@Model.ShortTermUserCharge.PotentialRatePayableByCategoryA" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <div class="form-group">
                                        <label>Actual Rate paid by Leasees</label>
                                        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" name="ShortTermUserCharge.ActualRatePaidByCategoryA" value="@Model.ShortTermUserCharge.ActualRatePaidByCategoryA" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Category B Fields (Collapsible) -->
                    <div class="card mb-3 category-card" id="category-B">
                        <div class="card-header bg-light" data-bs-toggle="collapse" data-bs-target="#categoryBCollapse" aria-expanded="false" aria-controls="categoryBCollapse" style="cursor: pointer;">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <h6 class="mb-0 category-title">Category B</h6>
                                    <button type="button" class="btn btn-sm btn-link edit-category-btn ms-2" @(isViewMode ? "disabled" : "")>
                                        <i class="fas fa-edit"></i>
                                    </button>
                                </div>
                                <div>
                                    <button type="button" class="btn btn-sm btn-purple remove-category-btn" style="background-color: #6f42c1; color: white;" @(isViewMode ? "disabled" : "")>
                                        <i class="fas fa-trash"></i>
                                    </button>
                                    <i class="fas fa-chevron-down ms-2"></i>
                                </div>
                            </div>
                        </div>
                        <div id="categoryBCollapse" class="collapse">
                            <div class="card-body">
                                <div class="mb-3">
                                    <div class="form-group">
                                        <label>Estimated Number of Daily Fees</label>
                                        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" name="ShortTermUserCharge.EstimatedDailyFeesCategoryB" value="@Model.ShortTermUserCharge.EstimatedDailyFeesCategoryB" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <div class="form-group">
                                        <label>Actual Number of Daily Fees</label>
                                        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" name="ShortTermUserCharge.ActualDailyFeesCategoryB" value="@Model.ShortTermUserCharge.ActualDailyFeesCategoryB" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <div class="form-group">
                                        <label>Potential Rate payable by Leasees</label>
                                        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" name="ShortTermUserCharge.PotentialRatePayableByCategoryB" value="@Model.ShortTermUserCharge.PotentialRatePayableByCategoryB" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <div class="form-group">
                                        <label>Actual Rate paid by Leasees</label>
                                        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" name="ShortTermUserCharge.ActualRatePaidByCategoryB" value="@Model.ShortTermUserCharge.ActualRatePaidByCategoryB" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Category C Fields (Collapsible) -->
                    <div class="card mb-3 category-card" id="category-C">
                        <div class="card-header bg-light" data-bs-toggle="collapse" data-bs-target="#categoryCCollapse" aria-expanded="false" aria-controls="categoryCCollapse" style="cursor: pointer;">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center">
                                    <h6 class="mb-0 category-title">Category C</h6>
                                    <button type="button" class="btn btn-sm btn-link edit-category-btn ms-2" @(isViewMode ? "disabled" : "")>
                                        <i class="fas fa-edit"></i>
                                    </button>
                                </div>
                                <div>
                                    <button type="button" class="btn btn-sm btn-purple remove-category-btn" style="background-color: #6f42c1; color: white;" @(isViewMode ? "disabled" : "")>
                                        <i class="fas fa-trash"></i>
                                    </button>
                                    <i class="fas fa-chevron-down ms-2"></i>
                                </div>
                            </div>
                        </div>
                        <div id="categoryCCollapse" class="collapse">
                            <div class="card-body">
                                <div class="mb-3">
                                    <div class="form-group">
                                        <label>Estimated Number of Daily Fees</label>
                                        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" name="ShortTermUserCharge.EstimatedDailyFeesCategoryC" value="@Model.ShortTermUserCharge.EstimatedDailyFeesCategoryC" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <div class="form-group">
                                        <label>Actual Number of Daily Fees</label>
                                        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" name="ShortTermUserCharge.ActualDailyFeesCategoryC" value="@Model.ShortTermUserCharge.ActualDailyFeesCategoryC" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <div class="form-group">
                                        <label>Potential Rate payable by Leasees</label>
                                        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" name="ShortTermUserCharge.PotentialRatePayableByCategoryC" value="@Model.ShortTermUserCharge.PotentialRatePayableByCategoryC" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <div class="form-group">
                                        <label>Actual Rate paid by Leasees</label>
                                        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" name="ShortTermUserCharge.ActualRatePaidByCategoryC" value="@Model.ShortTermUserCharge.ActualRatePaidByCategoryC" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Container for dynamically added categories -->
                    <div id="dynamicCategoriesContainer">
                        <!-- Dynamic categories will be added here -->
                        @if (Model.ShortTermUserCharge.DynamicCategories != null && Model.ShortTermUserCharge.DynamicCategories.Count > 0)
                        {
                            @foreach (var category in Model.ShortTermUserCharge.DynamicCategories)
                            {
                                <div class="card mb-3 category-card" id="category-@category.Name.Replace(" ", "-")">
                                    <div class="card-header bg-light" data-bs-toggle="collapse" data-bs-target="#category@(category.Name.Replace(" ", ""))Collapse" aria-expanded="false" aria-controls="category@(category.Name.Replace(" ", ""))Collapse" style="cursor: pointer;">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="d-flex align-items-center">
                                                <h6 class="mb-0 category-title">@category.Name</h6>
                                                <button type="button" class="btn btn-sm btn-link edit-category-btn ms-2" data-bs-toggle="modal" data-bs-target="#renameCategoryModal" @(isViewMode ? "disabled" : "")>
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                            </div>
                                            <div>
                                                <button type="button" class="btn btn-sm btn-purple remove-category-btn" style="background-color: #6f42c1; color: white;" data-bs-toggle="modal" data-bs-target="#deleteCategoryModal" @(isViewMode ? "disabled" : "")>
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                                <i class="fas fa-chevron-down ms-2"></i>
                                            </div>
                                        </div>
                                    </div>
                                    <div id="category@(category.Name.Replace(" ", ""))Collapse" class="collapse category-content">
                                        <div class="card-body">
                                            <div class="mb-3">
                                                <div class="form-group">
                                                    <label>Estimated Number of Daily Fees</label>
                                                    <input type="text" class="form-control number-format" name="ShortTermUserCharge.DynamicCategories[@(Model.ShortTermUserCharge.DynamicCategories.IndexOf(category))].EstimatedDailyFees" value="@category.EstimatedDailyFees" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                                </div>
                                            </div>
                                            <div class="mb-3">
                                                <div class="form-group">
                                                    <label>Actual Number of Daily Fees</label>
                                                    <input type="text" class="form-control number-format" name="ShortTermUserCharge.DynamicCategories[@(Model.ShortTermUserCharge.DynamicCategories.IndexOf(category))].ActualDailyFees" value="@category.ActualDailyFees" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                                </div>
                                            </div>
                                            <div class="mb-3">
                                                <div class="form-group">
                                                    <label>Potential Rate payable by Leasees</label>
                                                    <input type="text" class="form-control number-format" name="ShortTermUserCharge.DynamicCategories[@(Model.ShortTermUserCharge.DynamicCategories.IndexOf(category))].PotentialRatePayable" value="@category.PotentialRatePayable" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                                </div>
                                            </div>
                                            <div class="mb-3">
                                                <div class="form-group">
                                                    <label>Actual Rate paid by Leasees</label>
                                                    <input type="text" class="form-control number-format" name="ShortTermUserCharge.DynamicCategories[@(Model.ShortTermUserCharge.DynamicCategories.IndexOf(category))].ActualRatePaid" value="@category.ActualRatePaid" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                                </div>
                                            </div>
                                            <input type="hidden" name="ShortTermUserCharge.DynamicCategories[@(Model.ShortTermUserCharge.DynamicCategories.IndexOf(category))].Name" value="@category.Name">
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    
                    <!-- Template for new category (hidden) -->
                    <div id="categoryTemplate" style="display: none;">
                        <div class="card mb-3 category-card">
                            <div class="card-header bg-light" data-bs-toggle="collapse" data-bs-target="#newCategoryCollapse" aria-expanded="false" style="cursor: pointer;">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center">
                                        <h6 class="mb-0 category-title">New Category</h6>
                                        <button type="button" class="btn btn-sm btn-link edit-category-btn ms-2" @(isViewMode ? "disabled" : "")>
                                            <i class="fas fa-edit"></i>
                                        </button>
                                    </div>
                                    <div>
                                        <button type="button" class="btn btn-sm btn-purple remove-category-btn" style="background-color: #6f42c1; color: white;" @(isViewMode ? "disabled" : "")>
                                            <i class="fas fa-trash"></i>
                                        </button>
                                        <i class="fas fa-chevron-down ms-2"></i>
                                    </div>
                                </div>
                            </div>
                            <div class="collapse category-content">
                                <div class="card-body">
                                    <div class="mb-3">
                                        <div class="form-group">
                                            <label>Estimated Number of Daily Fees</label>
                                            <input type="text" class="form-control number-format" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <div class="form-group">
                                            <label>Actual Number of Daily Fees</label>
                                            <input type="text" class="form-control number-format" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <div class="form-group">
                                            <label>Potential Rate payable by Leasees</label>
                                            <input type="text" class="form-control number-format" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                        </div>
                                    </div>
                                    <div class="mb-3">
                                        <div class="form-group">
                                            <label>Actual Rate paid by Leasees</label>
                                            <input type="text" class="form-control number-format" placeholder="Enter value" @(isViewMode ? "readonly" : "")>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Right Side (2/3 width) -->
        <div class="col-md-8">
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Short Term Details</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="form-floating">
                            <input type="text" class="form-control @(isViewMode ? "bg-light" : "")" id="shortTermDescription" name="ShortTermUserCharge.Description" value="@Model.ShortTermUserCharge.Description" placeholder="Enter description" @(isViewMode ? "readonly" : "")>
                            <label for="shortTermDescription">Description</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-floating">
                            <textarea class="form-control @(isViewMode ? "bg-light" : "")" id="shortTermNotes" name="ShortTermUserCharge.Notes" style="height: 200px" placeholder="Enter notes" @(isViewMode ? "readonly" : "")>@Model.ShortTermUserCharge.Notes</textarea>
                            <label for="shortTermNotes">Notes</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Rename Category Modal -->
<div class="modal fade" id="renameCategoryModal" tabindex="-1" aria-labelledby="renameCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="renameCategoryModalLabel">Rename Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label for="newCategoryName">New Category Name</label>
                    <input type="text" class="form-control" id="newCategoryName" placeholder="Enter new category name">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveCategoryNameBtn">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Category Modal -->
<div class="modal fade" id="deleteCategoryModal" tabindex="-1" aria-labelledby="deleteCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteCategoryModalLabel">Delete Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete the category <span id="categoryToDeleteName"></span>?</p>
                <p class="text-danger">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteCategoryBtn">Delete</button>
            </div>
        </div>
    </div>
</div>

<!-- Create Category Modal -->
<div class="modal fade" id="createCategoryModal" tabindex="-1" aria-labelledby="createCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createCategoryModalLabel">Create New Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label for="newCategoryNameCreate">Category Name</label>
                    <input type="text" class="form-control" id="newCategoryNameCreate" placeholder="Enter category name">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="createCategoryBtn">Create</button>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function() {
        // Initialize counter for unique IDs - start with count of existing dynamic categories
        let categoryCounter = @(Model.ShortTermUserCharge.DynamicCategories != null ? Model.ShortTermUserCharge.DynamicCategories.Count : 0) + 1;
        
        // Variables to store current category being edited/deleted
        let currentCategory = null;
        
        // Function to safely show a modal with fallback methods
        function showModal(modalId) {
            const $modal = $('#' + modalId);
            
            // Try jQuery modal method first (works with both Bootstrap 4 and 5)
            try {
                $modal.modal('show');
            } catch (e) {
                console.warn('Error showing modal with jQuery:', e);
                
                // Try native Bootstrap 5 API
                try {
                    if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                        const modalEl = document.getElementById(modalId);
                        const bsModal = new bootstrap.Modal(modalEl);
                        bsModal.show();
                    } else {
                        throw new Error('Bootstrap Modal API not available');
                    }
                } catch (e2) {
                    console.warn('Error showing modal with Bootstrap API:', e2);
                    
                    // Last resort: show modal manually via DOM
                    $modal.addClass('show').css('display', 'block');
                    $('body').addClass('modal-open').append('<div class="modal-backdrop fade show"></div>');
                }
            }
        }
        
        // Function to safely hide a modal with fallback methods
        function hideModal(modalId) {
            const $modal = $('#' + modalId);
            
            // Try jQuery modal method first
            try {
                $modal.modal('hide');
            } catch (e) {
                console.warn('Error hiding modal with jQuery:', e);
                
                // Try native Bootstrap 5 API
                try {
                    if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                        const modalEl = document.getElementById(modalId);
                        const bsModal = bootstrap.Modal.getInstance(modalEl);
                        if (bsModal) {
                            bsModal.hide();
                        } else {
                            throw new Error('Bootstrap Modal instance not found');
                        }
                    } else {
                        throw new Error('Bootstrap Modal API not available');
                    }
                } catch (e2) {
                    console.warn('Error hiding modal with Bootstrap API:', e2);
                    
                    // Last resort: hide modal manually via DOM
                    $modal.removeClass('show').css('display', 'none');
                    $('.modal-backdrop').remove();
                    $('body').removeClass('modal-open').css('overflow', '');
                }
            }
        }
        
        // Handle Add Category button click
        $('#openCreateCategoryModalBtn').click(function() {
            // Clear input field
            $('#newCategoryNameCreate').val('');
            
            // Show the modal using our safe method
            showModal('createCategoryModal');
        });
        
        // Handle Create Category button click
        $('#createCategoryBtn').click(function() {
            const categoryName = $('#newCategoryNameCreate').val().trim();
            
            if (!categoryName) {
                alert('Please enter a category name');
                return;
            }
            
            // Check for duplicate category names
            let isDuplicate = false;
            $('.category-title').each(function() {
                if ($(this).text().trim() === categoryName) {
                    isDuplicate = true;
                    return false; // break the loop
                }
            });
            
            if (isDuplicate) {
                alert('A category with this name already exists. Please use a different name.');
                return;
            }
            
            // Create the new category
            createNewCategory(categoryName);
            
            // Close the modal
            hideModal('createCategoryModal');
        });
        
        // Handle edit button clicks (including dynamically added ones)
        $(document).on('click', '.edit-category-btn', function(e) {
                e.stopPropagation(); // Prevent collapse toggle
            currentCategory = $(this).closest('.category-card');
            const currentName = currentCategory.find('.category-title').text().trim();
                
                // Set the current name in the modal input
            $('#newCategoryName').val(currentName);
            
            // Show the rename modal
            showModal('renameCategoryModal');
        });
        
        // Handle remove button clicks (including dynamically added ones)
        $(document).on('click', '.remove-category-btn', function(e) {
            e.stopPropagation(); // Prevent collapse toggle
            currentCategory = $(this).closest('.category-card');
            const categoryName = currentCategory.find('.category-title').text().trim();
            
            // Set the category name in the modal
            $('#categoryToDeleteName').text(categoryName);
            
            // Show the delete modal
            showModal('deleteCategoryModal');
        });
        
        // Handle Save Category Name button click
        $('#saveCategoryNameBtn').click(function() {
            if (currentCategory) {
                const newName = $('#newCategoryName').val().trim();
                if (newName) {
                    // Update the category title
                    currentCategory.find('.category-title').text(newName);
                    
                    // Update the hidden input value
                    currentCategory.find('input[type="hidden"]').val(newName);
                    
                    // Close the modal
                    hideModal('renameCategoryModal');
                }
            }
        });
        
        // Handle Confirm Delete button click
        $('#confirmDeleteCategoryBtn').click(function() {
            if (currentCategory) {
                // Remove the category card
                currentCategory.remove();
                
                // Close the modal
                hideModal('deleteCategoryModal');
                
                // Update indices for remaining dynamic categories
                updateDynamicCategoryIndices();
            }
        });
        
        // Function to create a new category
        function createNewCategory(categoryName) {
            // Clone the template
            const template = $('#categoryTemplate');
            const newCategory = template.find('.category-card').clone();
            
            // Generate unique IDs
            const categoryId = 'category-' + categoryCounter;
            const collapseId = 'collapse-' + categoryCounter;
            
            // Update IDs and attributes
            newCategory.attr('id', categoryId);
            newCategory.find('.card-header').attr('data-bs-target', '#' + collapseId);
            newCategory.find('.card-header').attr('aria-controls', collapseId);
            newCategory.find('.collapse').attr('id', collapseId);
            
            // Set the user-provided category name
            newCategory.find('.category-title').text(categoryName);
            
            // Update input names for form submission
            newCategory.find('input').each(function(index) {
                const fieldName = index === 0 ? 'EstimatedDailyFees' : 
                                index === 1 ? 'ActualDailyFees' : 
                                index === 2 ? 'PotentialRatePayable' : 'ActualRatePaid';
                $(this).attr('name', `ShortTermUserCharge.DynamicCategories[${categoryCounter - 1}].${fieldName}`);
            });
            
            // Add hidden input for category name
            const hiddenInput = $('<input>').attr({
                type: 'hidden',
                name: `ShortTermUserCharge.DynamicCategories[${categoryCounter - 1}].Name`,
                value: categoryName
            });
            newCategory.find('.card-body').append(hiddenInput);
            
            // Add to container
            $('#dynamicCategoriesContainer').append(newCategory);
            
            // Increment counter for next category
            categoryCounter++;
            
            // Show the collapse
            new bootstrap.Collapse(document.getElementById(collapseId)).show();
        }
        
        // Function to update indices for dynamic categories after deletion
        function updateDynamicCategoryIndices() {
            $('#dynamicCategoriesContainer .category-card').each(function(index) {
                $(this).find('input').each(function() {
                    const name = $(this).attr('name');
                    if (name && name.includes('DynamicCategories[')) {
                        $(this).attr('name', name.replace(/DynamicCategories\[\d+\]/, `DynamicCategories[${index}]`));
                    }
                });
            });
        }
        
        // Initialize number formatting for the input fields
        $('.number-format').blur(function() {
            const value = parseFloat($(this).val().replace(/,/g, '')) || 0;
            $(this).val(value.toLocaleString('en-US'));
        });
        
        // Ensure Bootstrap is properly loaded
        // If Bootstrap Modal is not working, try initializing it manually
        if (typeof bootstrap === 'undefined' || typeof bootstrap.Modal === 'undefined') {
            console.warn('Bootstrap or bootstrap.Modal is not defined. Loading Bootstrap JS...');
            
            // Create and append the Bootstrap script
            const bootstrapScript = document.createElement('script');
            bootstrapScript.src = 'https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js';
            bootstrapScript.integrity = 'sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p';
            bootstrapScript.crossOrigin = 'anonymous';
            document.body.appendChild(bootstrapScript);
            
            // Reinitialize modals after script loads
            bootstrapScript.onload = function() {
                console.log('Bootstrap loaded. Attempting to reinitialize modals...');
                
                // Try showing the create modal with timeout to ensure Bootstrap is ready
                $('#openCreateCategoryModalBtn').off('click').on('click', function() {
                    $('#newCategoryNameCreate').val('');
                    setTimeout(function() {
                        const modal = new bootstrap.Modal(document.getElementById('createCategoryModal'));
                        modal.show();
                    }, 100);
                });
            };
        } else {
            console.log('Bootstrap is properly loaded.');
        }
    });
</script>
