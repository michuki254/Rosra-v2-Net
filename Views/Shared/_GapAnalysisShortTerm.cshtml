    // Function to update the breakdown analysis text based on the largest gap
    function updateBreakdownAnalysis(complianceGap, rateGap, combinedGaps) {
        const alertElement = $('#breakdownAnalysisAlert');
        const textElement = $('#breakdownAnalysisText');
        
        // Format the gap values as currency
        const formattedComplianceGap = formatCurrency(complianceGap);
        const formattedRateGap = formatCurrency(rateGap);
        const formattedCombinedGaps = formatCurrency(combinedGaps);
        
        // Determine which gap is the largest
        let largestGap = "";
        if (complianceGap > rateGap && complianceGap > combinedGaps) {
            largestGap = "Compliance Gap";
        } else if (rateGap > complianceGap && rateGap > combinedGaps) {
            largestGap = "Rate Gap";
        } else {
            largestGap = "Combined gaps";
        }
        
        // Remove existing alert classes
        alertElement.removeClass('alert-info alert-warning alert-danger');
        
        // Set text and class based on the largest gap
        if (largestGap === "Compliance Gap") {
            alertElement.addClass('alert-info');
            textElement.html(`
                <strong>Compliance Gap Analysis:</strong> The Compliance gap has been identified as the largest contributing factor to the 
                Short-term user charge revenue gap with the value at <strong>${formattedComplianceGap}</strong>. This suggests that there is a 
                significant discrepancy between the potential revenue that should be collected based on Compliance with established rates 
                and the actual revenue collected. Some revenues which should be collected in Compliance are not actually collected by the government.
            `);
        } else if (largestGap === "Rate Gap") {
            alertElement.addClass('alert-warning');
            textElement.html(`
                <strong>Rate Gap Analysis:</strong> The Rate Gap stands out as the largest contributor to the Short-term User Charge Revenue Gap, 
                with the value of <strong>${formattedRateGap}</strong>. This indicates that there may be a misalignment between the established 
                rates and the current market conditions or user expectations.
            `);
        } else {
            alertElement.addClass('alert-danger');
            textElement.html(`
                <strong>Combined Gaps Analysis:</strong> The combined gaps from various sources have been identified as the largest contributing 
                factor to the Short-term User Charge Revenue Gap with the value at <strong>${formattedCombinedGaps}</strong>. This highlights that 
                there are multiple factors contributing to the revenue shortfall, including other factors like assessment and registration gaps. 
                A comprehensive approach is required to address this problem.
            `);
        }
    }

    // Function to update the Category Gaps Analysis
    function updateCategoryGapsAnalysis(categories, gaps) {
        const tableBody = $('#categoryGapsAnalysisBody');
        tableBody.empty();
        
        // Filter out categories with no gaps
        const categoriesWithGaps = [];
        const gapsFiltered = [];
        
        for (let i = 0; i < categories.length; i++) {
            if (gaps[i] > 0) {
                categoriesWithGaps.push(categories[i]);
                gapsFiltered.push(gaps[i]);
            }
        }
        
        // Update the categories count
        $('#totalCategoriesCount').text(`${categoriesWithGaps.length} categories`);
        
        if (categoriesWithGaps.length === 0) {
            tableBody.append(`
                <tr>
                    <td colspan="2" class="text-center py-4 text-muted">No significant gaps found</td>
                </tr>
            `);
            return;
        }
        
        // Get the top categories with highest gaps
        const indexedGaps = gapsFiltered.map((gap, index) => ({ gap, index }));
        indexedGaps.sort((a, b) => b.gap - a.gap);
        
        // Add the category rows with appropriate icons
        const iconClasses = [
            'text-primary', // Primary category (blue)
            'text-success', // Secondary category (green)
            'text-warning', // Tertiary category (amber/yellow)
            'text-danger',  // Fourth category (red)
            'text-info'     // Fifth category (cyan/light blue)
        ];
        
        const categoryLabels = [
            'Primary category gap',
            'Secondary category gap',
            'Tertiary category gap',
            'Additional category gap',
            'Supplementary category gap'
        ];
        
        // Add regular category gaps
        for (let i = 0; i < Math.min(categoriesWithGaps.length, 3); i++) {
            const originalIndex = indexedGaps[i].index;
            const categoryName = categoriesWithGaps[originalIndex];
            const gapValue = gapsFiltered[originalIndex];
            
            const iconClass = iconClasses[i];
            const iconElement = i === 0 ? '<i class="fas fa-chart-line"></i>' :
                               i === 1 ? '<i class="fas fa-chart-bar"></i>' :
                               '<i class="fas fa-chart-pie"></i>';
            
            tableBody.append(`
                <tr>
                    <td class="ps-4">
                        <div class="d-flex align-items-center">
                            <div class="me-3 ${iconClass}" style="width: 24px; text-align: center;">
                                ${iconElement}
                            </div>
                            <div>
                                <div class="fw-semibold">Gap Category ${categoryName}</div>
                                <div class="text-muted small">${categoryLabels[i]}</div>
                            </div>
                        </div>
                    </td>
                    <td class="text-end pe-4 fw-bold ${iconClass}">KSh ${formatNumber(gapValue)}</td>
                </tr>
            `);
        }
        
        // Add separator
        tableBody.append(`<tr><td colspan="2" class="border-bottom"></td></tr>`);
        
        // Find the largest gap
        const largestGapIndex = indexedGaps[0].index;
        const largestGapValue = gapsFiltered[largestGapIndex];
        const largestGapCategory = categoriesWithGaps[largestGapIndex];
        
        // Determine the type of largest gap
        let gapType = "Undefined gap";
        if (largestGapCategory.includes("A")) {
            gapType = "Compliance Gap";
        } else if (largestGapCategory.includes("B")) {
            gapType = "Rate Gap";
        } else if (largestGapCategory.includes("C")) {
            gapType = "Assessment/Valuation gap";
        } else {
            gapType = "Registration/Documentation gap";
        }
        
        // Add the largest gap row
        tableBody.append(`
            <tr>
                <td class="ps-4">
                    <div class="d-flex align-items-center">
                        <div class="me-3 text-danger" style="width: 24px; text-align: center;">
