<!-- Add Category Modal -->
<div class="modal" id="addShortTermCategoryModal" tabindex="-1" aria-labelledby="addShortTermCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light border-0">
                <h5 class="modal-title" id="addShortTermCategoryModalLabel">Add Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 py-4">
                <div class="mb-3">
                    <label for="newShortTermCategoryNameModalInput" class="form-label text-muted small">CATEGORY NAME</label>
                    <input type="text" class="form-control form-control-lg border-0 bg-light" id="newShortTermCategoryNameModalInput" placeholder="Enter category name" required>
                    <div class="invalid-feedback">
                        Please enter a category name.
                </div>
            </div>
            </div>
            <div class="modal-footer border-0 px-4 pb-4">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary rounded-pill px-4" id="confirmAddShortTermCategoryBtn">Create</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize counter for unique IDs - start with count of existing dynamic categories
        let shortTermCategoryCounter = @(Model.ShortTermUserCharge.DynamicCategories != null ? Model.ShortTermUserCharge.DynamicCategories.Count : 0) + 1;
        
        // Initialize Add Category Modal with no animations (like License)
        const addCategoryModal = document.getElementById('addShortTermCategoryModal');
        let addModalInstance = null;
        
        if (addCategoryModal) {
            // Remove fade class to eliminate animations
            addCategoryModal.classList.remove('fade');
            
            // Initialize modal instance with no animations
            addModalInstance = new bootstrap.Modal(addCategoryModal, {
                backdrop: true,
                keyboard: true,
                focus: false
            });
            
            addCategoryModal.addEventListener('shown.bs.modal', function() {
                // Disable all transitions temporarily
                document.body.classList.add('no-transitions');
                
                // Clear the input field when modal is shown
                document.getElementById('newShortTermCategoryNameModalInput').value = '';
                document.getElementById('newShortTermCategoryNameModalInput').classList.remove('is-invalid');
        
                // Focus on the input field without delay
                document.getElementById('newShortTermCategoryNameModalInput').focus();
            });
            
            addCategoryModal.addEventListener('hidden.bs.modal', function() {
                // Re-enable transitions
                document.body.classList.remove('no-transitions');
                    
                // Clean up when modal is hidden
                document.getElementById('newShortTermCategoryNameModalInput').classList.remove('is-invalid');
                
                // Force cleanup of any remaining backdrops
                setTimeout(() => {
                    const backdrops = document.querySelectorAll('.modal-backdrop');
                    backdrops.forEach(backdrop => backdrop.remove());
                    document.body.classList.remove('modal-open');
                    document.body.style.overflow = '';
                    document.body.style.paddingRight = '';
                }, 50);
            });
        }
        
        // Add event listener for the confirm add category button
        const confirmAddCategoryBtn = document.getElementById('confirmAddShortTermCategoryBtn');
        if (confirmAddCategoryBtn) {
            confirmAddCategoryBtn.addEventListener('click', function() {
                const categoryNameInput = document.getElementById('newShortTermCategoryNameModalInput');
                const categoryName = categoryNameInput.value.trim();
                
                if (!categoryName) {
                    categoryNameInput.classList.add('is-invalid');
                    return;
                }
                
                // Check for duplicates
                const existingCategories = [];
                
                // Check default categories
                existingCategories.push('Category A', 'Category B', 'Category C');
                
                // Check dynamic categories
                const dynamicCategoryElements = document.querySelectorAll('#dynamicShortTermCategoriesContainer .category-card .category-title');
                dynamicCategoryElements.forEach(element => {
                    const name = element.textContent.trim();
                    if (name && name !== 'New Category') {
                        existingCategories.push(name);
                    }
                });
                
                // Check for duplicates
                const isDuplicate = existingCategories.some(name => name.toLowerCase() === categoryName.toLowerCase());
                
                if (isDuplicate) {
                    categoryNameInput.classList.add('is-invalid');
                    return;
                }
                
                // Create the new category
                createNewShortTermCategory(categoryName);
                
                // Hide the modal
                addModalInstance.hide();
            });
        }
        
        // Function to create a new category
        function createNewShortTermCategory(categoryName) {
            // Clone the template
                const template = document.getElementById('shortTermCategoryTemplate');
                const newCategory = template.querySelector('.category-card').cloneNode(true);
            
