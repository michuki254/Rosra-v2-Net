                        </div>
                        <div>
                            <div class="fw-semibold">Largest Gap</div>
                            <div class="text-muted small">Highest value difference</div>
                        </div>
                    </div>
                </td>
                <td class="text-end pe-4 fw-bold text-primary">${gapType}</td>
            </tr>
        `);
        
        // Add the category with largest gap row
        tableBody.append(`
            <tr>
                <td class="ps-4">
                    <div class="d-flex align-items-center">
                        <div class="me-3 text-info" style="width: 24px; text-align: center;">
