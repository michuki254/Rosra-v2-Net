@model RosraApp.Models.ViewModels.RosraFormViewModel
@{
    bool isViewMode = ViewData["ViewMode"] != null && (bool)ViewData["ViewMode"];
}

<div class="card mb-3">
    <div class="card-header">
        <h6 class="mb-0"><i class="fas fa-chart-line"></i>Property Tax Revenue Gap Analysis</h6>
    </div>
    <div class="card-body">
        <!-- Revenue Comparison Chart -->
        <div class="row mb-3">
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-header bg-gradient-light p-3 rounded-top-3 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-chart-bar text-primary me-2"></i>
                            <h6 class="mb-0 fw-bold">Revenue Comparison</h6>
                        </div>
                        <div class="btn-group" role="group" aria-label="Chart type">
                            <button type="button" class="btn btn-sm btn-outline-primary active" id="viewBarChartBtn">
                                <i class="fas fa-chart-bar"></i> Bar
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-primary" id="viewPieChartBtn">
                                <i class="fas fa-chart-pie"></i> Pie
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-3">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="chart-container" style="position: relative; height: 250px;">
                                    <canvas id="revenueComparisonChart"></canvas>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="d-flex flex-column justify-content-center h-100">
                                    <div class="revenue-stat">
                                        <div class="stat-label">Actual Revenue</div>
                                        <div class="stat-value text-primary" id="actualRevenue">-</div>
                                    </div>
                                    <div class="revenue-stat">
                                        <div class="stat-label">Potential Revenue</div>
                                        <div class="stat-value text-success" id="potentialRevenue">-</div>
                                    </div>
                                    <div class="revenue-stat">
                                        <div class="stat-label">Revenue Gap</div>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="stat-value text-danger" id="revenueGap">-</div>
                                            <div class="stat-percentage badge bg-danger" id="revenueGapPercentage">-%</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Gap Distribution Chart -->
        <div class="row mb-3">
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-header bg-gradient-light p-3 rounded-top-3 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-chart-pie text-primary me-2"></i>
                            <h6 class="mb-0 fw-bold">Gap Distribution</h6>
                        </div>
                        <div class="btn-group" role="group" aria-label="Chart type">
                            <button type="button" class="btn btn-sm btn-outline-primary active" id="viewStackedBarBtn">
                                <i class="fas fa-layer-group"></i> Stacked
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-primary" id="viewPieGapBtn">
                                <i class="fas fa-chart-pie"></i> Pie
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-3">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="chart-container" style="position: relative; height: 250px;">
                                    <canvas id="gapDistributionChart"></canvas>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="table-responsive">
                                    <table class="table table-sm">
                                        <thead>
                                            <tr>
                                                <th>Gap Type</th>
                                                <th class="text-end">Amount</th>
                                                <th class="text-end">%</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td><span class="badge bg-danger me-1">&nbsp;</span> Registration</td>
                                                <td class="text-end" id="registrationGap">-</td>
                                                <td class="text-end" id="registrationGapPercentage">-%</td>
                                            </tr>
                                            <tr>
                                                <td><span class="badge bg-primary me-1">&nbsp;</span> Compliance</td>
                                                <td class="text-end" id="complianceGap">-</td>
                                                <td class="text-end" id="complianceGapPercentage">-%</td>
                                            </tr>
                                            <tr>
                                                <td><span class="badge bg-warning me-1">&nbsp;</span> Assessment</td>
                                                <td class="text-end" id="assessmentValuationGap">-</td>
                                                <td class="text-end" id="assessmentGapPercentage">-%</td>
                                            </tr>
                                            <tr>
                                                <td><span class="badge bg-info me-1">&nbsp;</span> Other</td>
                                                <td class="text-end" id="combinedGaps">-</td>
                                                <td class="text-end" id="combinedGapsPercentage">-%</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Gap Analysis Breakdown -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-header bg-gradient-light p-3 rounded-top-3 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-lightbulb text-primary me-2"></i>
                            <h6 class="mb-0 fw-bold">Analysis & Recommendations</h6>
                        </div>
                        <span class="badge bg-secondary" id="breakdownStatusBadge">Pending</span>
                    </div>
                    <div class="card-body p-3">
                        <div id="breakdownContent">
                            <p class="text-muted">Complete the property tax information to see analysis and recommendations.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Detailed Gap Analysis Section -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-header bg-gradient-light p-3 rounded-top-3">
                        <h6 class="mb-0 fw-bold"><i class="fas fa-search-dollar me-2 text-primary"></i>Gap Analysis Details</h6>
                    </div>
                    <div class="card-body p-3">
                        <div class="row">
                            <!-- Registration Gap Card -->
                            <div class="col-md-3">
                                <div class="gap-card">
                                    <div class="gap-indicator registration">
                                        <i class="fas fa-user-plus fa-lg"></i>
                                    </div>
                                    <div class="gap-content">
                                        <div class="gap-title">Registration Gap</div>
                                        <div class="gap-amount" id="registrationGapAmount">-</div>
                                        <div class="gap-subtitle registration-text">
                                            Unregistered<br>property value
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Compliance Gap Card -->
                            <div class="col-md-3">
                                <div class="gap-card">
                                    <div class="gap-indicator compliance">
                                        <i class="fas fa-clipboard-check fa-lg"></i>
                                    </div>
                                    <div class="gap-content">
                                        <div class="gap-title">Compliance Gap</div>
                                        <div class="gap-amount" id="complianceGapAmount">-</div>
                                        <div class="gap-subtitle compliance-text">
                                            Non-compliant<br>revenue loss
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Assessment Gap Card -->
                            <div class="col-md-3">
                                <div class="gap-card">
                                    <div class="gap-indicator assessment">
                                        <i class="fas fa-calculator fa-lg"></i>
                                    </div>
                                    <div class="gap-content">
                                        <div class="gap-title">Assessment Gap</div>
                                        <div class="gap-amount" id="assessmentGapAmount">-</div>
                                        <div class="gap-subtitle assessment-text">
                                            Valuation<br>difference
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Combined Gaps Card -->
                            <div class="col-md-3">
                                <div class="gap-card">
                                    <div class="gap-indicator combined">
                                        <i class="fas fa-chart-pie fa-lg"></i>
                                    </div>
                                    <div class="gap-content">
                                        <div class="gap-title">Total Gap</div>
                                        <div class="gap-amount" id="totalGapAmount">-</div>
                                        <div class="gap-subtitle combined-text">
                                            All revenue<br>gaps combined
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
