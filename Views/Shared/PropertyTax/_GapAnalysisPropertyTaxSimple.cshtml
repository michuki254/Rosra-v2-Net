@model RosraApp.Models.ViewModels.RosraFormViewModel
@{
    bool isViewMode = ViewData["ViewMode"] != null && (bool)ViewData["ViewMode"];
}

<!-- This is a simplified version that includes the Add Category modal -->
<div class="gap-analysis-tab-content">
    <div class="row">
        <!-- Left Side (1/3 width) -->
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Property Tax Information</h6>
                </div>
                <div class="card-body">
                    <!-- Include the property tax information partial view -->
                    @await Html.PartialAsync("PropertyTax/_PropertyTaxInformation", Model)
                    
                    <hr class="my-4">
                    <h6 class="mb-3">Property Tax Categories</h6>
                    
                    <!-- Add Category Button -->
                    <div class="mb-3">
                        <button type="button" class="btn btn-sm btn-primary" id="addCategoryBtn">
                            <i class="fas fa-plus"></i> Add Category
                        </button>
                    </div>
                    
                    <!-- Add Category Inline Form -->
                    <div class="card mb-3" id="addCategoryForm" style="display: none;">
                        <div class="card-header bg-light">
                            <h6 class="mb-0">Add New Category</h6>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label for="newPropertyTaxCategoryNameCreate" class="form-label">Category Name</label>
                                <input type="text" class="form-control" id="newPropertyTaxCategoryNameCreate" placeholder="Enter category name">
                            </div>
                            <div class="d-flex justify-content-end">
                                <button type="button" class="btn btn-outline-secondary me-2" id="cancelAddCategoryBtn">Cancel</button>
                                <button type="button" class="btn btn-primary" id="createPropertyTaxCategoryBtn">Create</button>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Include the static categories partial view -->
                    @await Html.PartialAsync("PropertyTax/_StaticCategories", Model)
                    
                    <!-- Dynamic Categories Container -->
                    <div id="dynamicPropertyTaxCategoriesContainer">
                        <!-- Dynamic categories will be added here -->
                        @if (Model.PropertyTax.DynamicCategories != null && Model.PropertyTax.DynamicCategories.Count > 0)
                        {
                            @for (int i = 0; i < Model.PropertyTax.DynamicCategories.Count; i++)
                            {
                                var category = Model.PropertyTax.DynamicCategories[i];
                                ViewData["Category"] = category;
                                ViewData["CategoryIndex"] = i;
                                @await Html.PartialAsync("PropertyTax/_DynamicCategory", Model)
                            }
                        }
                    </div>
                    
                    <!-- Include the category template partial view -->
                    @await Html.PartialAsync("PropertyTax/_CategoryTemplate", Model)
                </div>
            </div>
        </div>
        
        <!-- Right Side (2/3 width) -->
        <div class="col-md-8">
            <!-- Include the property tax analysis partial view -->
            @await Html.PartialAsync("PropertyTax/_PropertyTaxAnalysis", Model)
        </div>
    </div>
</div>

<!-- Include the Add Category Modal -->
@await Html.PartialAsync("PropertyTax/_AddCategoryModal", Model)

<!-- Add New Category Modal -->
<div class="modal fade" id="addPropertyTaxCategoryModal" tabindex="-1" aria-labelledby="addPropertyTaxCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addPropertyTaxCategoryModalLabel">Add New Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="newPropertyTaxCategoryFormModal">
                    <div class="mb-3">
                        <label for="newPropertyTaxCategoryNameModalInput" class="form-label">Category Name</label>
                        <input type="text" class="form-control" id="newPropertyTaxCategoryNameModalInput" placeholder="Enter category name" required>
                        <div class="invalid-feedback">
                            Please enter a category name.
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmAddPropertyTaxCategoryBtn">Create Category</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Button to open the add category modal
        const addCategoryButton = document.getElementById('addPropertyTaxCategoryBtn');
        if (addCategoryButton) {
            addCategoryButton.addEventListener('click', function() {
                const modalInputElement = document.getElementById('newPropertyTaxCategoryNameModalInput');
                if (modalInputElement) {
                    modalInputElement.value = ''; // Clear previous input
                    modalInputElement.classList.remove('is-invalid'); // Clear validation state
                }
                
                const addCategoryModalElement = document.getElementById('addPropertyTaxCategoryModal');
                if (addCategoryModalElement) {
                    // Ensure Bootstrap 5 Modal instance is correctly handled
                    let modalInstance = bootstrap.Modal.getInstance(addCategoryModalElement);
                    if (!modalInstance) {
                        modalInstance = new bootstrap.Modal(addCategoryModalElement);
                    }
                    modalInstance.show();
                }
            });
        }

        // Functionality for the Create Category button inside the modal
        const confirmButton = document.getElementById('confirmAddPropertyTaxCategoryBtn');
        if (confirmButton) {
            confirmButton.addEventListener('click', function() {
                const categoryNameInput = document.getElementById('newPropertyTaxCategoryNameModalInput');
                const categoryName = categoryNameInput.value.trim();

                if (!categoryName) {
                    categoryNameInput.classList.add('is-invalid');
                    return;
                } else {
                    categoryNameInput.classList.remove('is-invalid');
                }

                // Prevent adding duplicate category names
                const existingCategories = document.querySelectorAll('.category-title');
                let isDuplicate = false;
                existingCategories.forEach(titleEl => {
                    if (titleEl.textContent.trim().toLowerCase() === categoryName.toLowerCase()) {
                        isDuplicate = true;
                    }
                });

                if (isDuplicate) {
                    categoryNameInput.classList.add('is-invalid');
                    const feedbackElement = categoryNameInput.nextElementSibling;
                    if (feedbackElement && feedbackElement.classList.contains('invalid-feedback')) {
                        feedbackElement.textContent = 'This category name already exists.';
                    }
                    return;
                }

                // Clone the template
                const template = document.getElementById('propertyTaxCategoryTemplate');
                if (!template) {
                    console.error('Category template not found!');
                    alert('Error: Category template is missing. Cannot add category.');
                    return;
                }
                const newCategory = template.querySelector('.category-card').cloneNode(true);

                // Generate a unique ID for the new category
                const uniqueIdPart = categoryName.replace(/\s+/g, '-').replace(/[^a-zA-Z0-9-]/g, '').toLowerCase() || `new-${propertyTaxCategoryCounter++}`;
                const newCategoryId = `category-${uniqueIdPart}`;
                newCategory.id = newCategoryId;

                // Update title and IDs within the new category card
                newCategory.querySelector('.category-title').textContent = categoryName;
                const collapseTargetId = `collapse-${uniqueIdPart}`;
                const header = newCategory.querySelector('.card-header');
                if (header) {
                    header.setAttribute('data-bs-target', `#${collapseTargetId}`);
                    header.setAttribute('aria-controls', collapseTargetId);
                }
                const collapseDiv = newCategory.querySelector('.collapse');
                if (collapseDiv) {
                    collapseDiv.id = collapseTargetId;
                }
                
                // Update input names and IDs
                const inputs = newCategory.querySelectorAll('input, select, textarea');
                const dynamicCategoryIndex = document.querySelectorAll('#dynamicPropertyTaxCategoriesContainer .category-card').length;

                inputs.forEach(input => {
                    const originalId = input.id;
                    const originalName = input.name;

                    if (originalId) {
                        input.id = originalId.replace(/Category[A-Z0-9]+$/, '') + `-${uniqueIdPart}`;
                    }
                    if (originalName) {
                        input.name = originalName.replace(/Categories\[[^\]]+\]/g, `DynamicCategories[${dynamicCategoryIndex}]`);
                    }
                    input.value = ''; // Clear values in the new category form
                });
                
                // Update label 'for' attributes
                const labels = newCategory.querySelectorAll('label');
                labels.forEach(label => {
                    const originalFor = label.getAttribute('for');
                    if (originalFor) {
                        label.setAttribute('for', originalFor.replace(/Category[A-Z0-9]+$/, '') + `-${uniqueIdPart}`);
                    }
                });

                // Add event listeners for rename button
                const newRenameBtn = newCategory.querySelector('.rename-category-btn');
                if (newRenameBtn) {
                    newRenameBtn.addEventListener('click', function (e) {
                        e.stopPropagation();
                        currentPropertyTaxCategory = this.closest('.category-card');
                        document.getElementById('currentPropertyTaxCategoryName').value = currentPropertyTaxCategory.querySelector('.category-title').textContent;
                        document.getElementById('newPropertyTaxCategoryName').value = ''; // Clear input
                        var renameModal = new bootstrap.Modal(document.getElementById('renamePropertyTaxCategoryModal'));
                        renameModal.show();
                    });
                }

                // Add event listeners for delete button
                const newRemoveBtn = newCategory.querySelector('.remove-category-btn');
                if (newRemoveBtn) {
                    newRemoveBtn.addEventListener('click', function (e) {
                        e.stopPropagation();
                        var card = this.closest('.category-card');
                        if (card) {
                            var catName = card.querySelector('.category-title').textContent;
                            document.getElementById('deleteCategoryName').textContent = catName;
                            document.getElementById('categoryToDeleteId').value = card.id;
                            var deleteModal = new bootstrap.Modal(document.getElementById('deletePropertyTaxCategoryModal'));
                            deleteModal.show();
                        }
                    });
                }

                // Append to the container
                const container = document.getElementById('dynamicPropertyTaxCategoriesContainer');
                if (container) {
                    container.appendChild(newCategory);
                } else {
                    console.error('Dynamic categories container not found!');
                    alert('Error: Could not find where to add the new category.');
                    return;
                }

                // Re-initialize event listeners and update calculations
                if (typeof calculatePropertyTaxRevenue === 'function') {
                    calculatePropertyTaxRevenue();
                }

                // Close the modal
                const addCategoryModalElement = document.getElementById('addPropertyTaxCategoryModal');
                if (addCategoryModalElement) {
                    const modalInstance = bootstrap.Modal.getInstance(addCategoryModalElement);
                    if (modalInstance) {
                        modalInstance.hide();
                    }
                }
            });
        }
    });
</script>
