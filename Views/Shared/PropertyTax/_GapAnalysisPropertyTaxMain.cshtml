@model RosraApp.Models.ViewModels.RosraFormViewModel
@{
    bool isViewMode = ViewData["ViewMode"] != null && (bool)ViewData["ViewMode"];
}

<link rel="stylesheet" href="~/css/property-tax.css" asp-append-version="true" />

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<div class="gap-analysis-tab-content">
    <div class="row">
        <!-- Left Side (1/3 width) -->
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header">
                    <h6 class="mb-0"><i class="fas fa-home"></i>Property Tax Information</h6>
                </div>
                <div class="card-body">
                    <!-- Include the property tax information form -->
                    @await Html.PartialAsync("~/Views/Shared/PropertyTax/_PropertyTaxInformation.cshtml", Model)
                    
                    <!-- Static Categories (A, B, C) -->
                    @await Html.PartialAsync("~/Views/Shared/PropertyTax/_StaticCategoriesModern.cshtml", Model)
                    
                    <!-- Dynamic Categories Container -->
                    <div id="dynamicPropertyTaxCategoriesContainer">
                        <!-- Dynamic categories will be added here -->
                        @if (Model.PropertyTax.DynamicCategories != null && Model.PropertyTax.DynamicCategories.Count > 0)
                        {
                            @foreach (var category in Model.PropertyTax.DynamicCategories)
                            {
                                <!-- Include the dynamic category partial for each existing dynamic category -->
                                @await Html.PartialAsync("~/Views/Shared/PropertyTax/_DynamicCategory.cshtml", category)
                            }
                        }
                    </div>
                    
                    <!-- Include the category template -->
                    @await Html.PartialAsync("~/Views/Shared/PropertyTax/_CategoryTemplate.cshtml")
                    
                    <!-- Add Category Button -->
                    <div class="text-center mt-4">
                        <button type="button" class="btn btn-primary btn-lg" id="addPropertyTaxCategoryBtn">
                            <i class="fas fa-plus-circle me-2"></i> Add Category
                        </button>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Right Side (2/3 width) -->
        <div class="col-md-8">
            <!-- Include the property tax analysis section -->
            @await Html.PartialAsync("~/Views/Shared/PropertyTax/_PropertyTaxAnalysis.cshtml", Model)
        </div>
    </div>
</div>

<!-- Include all modals -->
@await Html.PartialAsync("~/Views/Shared/PropertyTax/_AddCategoryModal.cshtml")
@await Html.PartialAsync("~/Views/Shared/PropertyTax/_RenamePropertyTaxCategoryModal.cshtml")
@await Html.PartialAsync("~/Views/Shared/PropertyTax/_DeletePropertyTaxCategoryModal.cshtml")

<!-- Include all scripts -->
@await Html.PartialAsync("~/Views/Shared/PropertyTax/_PropertyTaxScripts.cshtml")
@await Html.PartialAsync("~/Views/Shared/PropertyTax/_ModernChartFunctions.cshtml")
@await Html.PartialAsync("~/Views/Shared/PropertyTax/_AddCategoryModalScript.cshtml")
