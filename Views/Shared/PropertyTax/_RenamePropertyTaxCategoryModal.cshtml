<!-- Rename Category Modal -->
<div class="modal fade" id="renamePropertyTaxCategoryModal" tabindex="-1" aria-labelledby="renamePropertyTaxCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="renamePropertyTaxCategoryModalLabel">Rename Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="renamePropertyTaxCategoryForm">
                    <input type="hidden" id="currentPropertyTaxCategoryName" value="">
                    <div class="mb-3">
                        <label for="newPropertyTaxCategoryName" class="form-label">New Category Name</label>
                        <input type="text" class="form-control" id="newPropertyTaxCategoryName" placeholder="Enter new category name" required>
                        <div class="invalid-feedback">
                            Please enter a category name.
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="savePropertyTaxCategoryNameBtn">Save Changes</button>
            </div>
        </div>
    </div>
</div>
