@model RosraApp.Models.ViewModels.RosraFormViewModel
@{
    bool isViewMode = ViewData["ViewMode"] != null && (bool)ViewData["ViewMode"];
}

<div class="mb-4">
    <div class="form-group">
        <label for="totalPropertyTaxPayers">Total estimated property tax payers</label>
        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" 
               id="totalPropertyTaxPayers" 
               name="PropertyTax.TotalPropertyTaxPayers" 
               value="@Model.PropertyTax.TotalPropertyTaxPayers" 
               placeholder="Enter total estimated property tax payers" 
               @(isViewMode ? "readonly" : "")>
    </div>
</div>
<div class="mb-4">
    <div class="form-group">
        <label for="registeredPropertyTaxPayers">Total registered property tax payers</label>
        <input type="text" class="form-control number-format @(isViewMode ? "bg-light" : "")" 
               id="registeredPropertyTaxPayers" 
               name="PropertyTax.RegisteredPropertyTaxPayers" 
               value="@Model.PropertyTax.RegisteredPropertyTaxPayers" 
               placeholder="Enter total registered property tax payers" 
               @(isViewMode ? "readonly" : "")>
    </div>
</div>
<div class="mb-4">
    <div class="form-group">
        <label for="totalPropertyTaxCollected">Total property tax collected</label>
        <input type="text" class="form-control currency-format @(isViewMode ? "bg-light" : "")" 
               id="totalPropertyTaxCollected" 
               name="PropertyTax.CurrentValue" 
               value="@Model.PropertyTax.CurrentValue" 
               placeholder="Enter total property tax collected" 
               @(isViewMode ? "readonly" : "")>
    </div>
</div>
<hr class="my-4">
<h6 class="mb-3"><i class="fas fa-layer-group me-2 text-primary"></i>Property Categories</h6>
