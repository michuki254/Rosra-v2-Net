@model RosraApp.Models.ViewModels.RosraFormViewModel
@{
    bool isViewMode = ViewData["ViewMode"] != null && (bool)ViewData["ViewMode"];
    string currencySymbol = string.IsNullOrEmpty(Model.CurrencySymbol) ? "$" : Model.CurrencySymbol;
}

<!-- Include Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@3.7.1/dist/chart.min.js"></script>

<div class="property-tax-gap-analysis">
    <div class="row">
        <!-- Left Column - Data Input Section -->
        <div class="col-lg-4">
            <!-- Required Data + Derived Metrics -->
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0"><i class="bi bi-input-cursor-text me-2"></i>Entry of required information + Processed Metrics</h6>
                </div>
                <div class="card-body">
                    <p class="small text-muted mb-3">For proper execution of the analysis, you are required to complete only the cells shaded in gray and in bold.</p>

                    <!-- User Input Fields -->
                    <div class="mb-3">
                        <label for="registeredProperties" class="form-label fw-bold">
                            Registered Properties
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Total number of properties currently listed in the official property tax register/cadastre."></i>
                        </label>
                        <input type="text" class="form-control number-format bg-light fw-bold" id="registeredProperties"
                               name="PropertyTax.RegisteredProperties" value="@(Model.PropertyTax.RegisteredProperties?.ToString("N0") ?? "20,344")"
                               placeholder="Enter value" @(isViewMode ? "readonly" : "") data-input="true">
                    </div>

                    <div class="mb-3">
                        <label for="nonRegisteredProperties" class="form-label fw-bold">
                            Non-registered Properties
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Estimated properties not in the tax register. If unknown, check 'I don't have a specific number' to enter a percentage of registered properties."></i>
                        </label>
                        <input type="text" class="form-control number-format bg-light fw-bold" id="nonRegisteredProperties"
                               name="PropertyTax.NonRegisteredProperties" value="@(Model.PropertyTax.NonRegisteredProperties?.ToString("N0") ?? "1,000")"
                               placeholder="Enter value" @(isViewMode ? "readonly" : "") data-input="true">

                        <!-- Estimation Option -->
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" id="estimateNonRegistered" @(isViewMode ? "disabled" : "")>
                            <label class="form-check-label small text-muted" for="estimateNonRegistered">
                                I don't have a specific number (use estimate)
                            </label>
                        </div>
                        <div id="estimatePercentageContainer" class="mt-2" style="display: none;">
                            <label class="form-label small text-primary">Estimate as % of Registered Properties</label>
                            <div class="input-group input-group-sm">
                                <input type="number" class="form-control" id="nonRegisteredPercentage"
                                       value="5" min="0" max="100" step="0.1" @(isViewMode ? "readonly" : "")>
                                <span class="input-group-text">%</span>
                            </div>
                            <small class="text-muted">e.g., 5% means Non-registered = Registered × 0.05</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="estimatedProperties" class="form-label text-primary">
                            Estimated Properties
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Total estimated taxable properties in the jurisdiction = Registered + Non-registered."></i>
                        </label>
                        <input type="text" class="form-control number-format" id="estimatedProperties"
                               readonly value="0" style="background-color: #e8f4fc;">
                    </div>

                    <div class="mb-3">
                        <label for="compliantProperties" class="form-label text-primary">
                            Compliant Properties
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Estimated using proxy formula to account for partial payments across fiscal year. Assumes proportion of compliant properties equals proportion of revenue collected."></i>
                        </label>
                        <input type="text" class="form-control number-format" id="compliantProperties"
                               name="PropertyTax.CompliantProperties" value="@Model.PropertyTax.CompliantProperties"
                               readonly style="background-color: #e8f4fc;">
                        <small class="text-muted">= Registered × (Revenue to Date / Billed Amount)</small>
                    </div>

                    <div class="mb-3">
                        <label for="totalFiscalBase" class="form-label fw-bold">
                            Total Fiscal Base (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Total value of all registered and taxable properties based on their fiscal (assessed) valuation. This is the officially recorded fiscal base used for property tax calculations."></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format bg-light fw-bold" id="totalFiscalBase"
                                   name="PropertyTax.TotalFiscalBase" value="@(Model.PropertyTax.TotalFiscalBase?.ToString("N0") ?? "236,465,062,053")"
                                   placeholder="Enter value" @(isViewMode ? "readonly" : "") data-input="true">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="totalMarketValue" class="form-label fw-bold">
                            Total Market Value (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Estimated total market value of all taxable properties at real market prices. If unknown, check 'I don't have market value data' to enter estimated percentage above fiscal values."></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format bg-light fw-bold" id="totalMarketValue"
                                   name="PropertyTax.TotalMarketValue" value="@(Model.PropertyTax.TotalMarketValue?.ToString("N0") ?? "300,000,000,000")"
                                   placeholder="Enter value" @(isViewMode ? "readonly" : "") data-input="true">
                        </div>

                        <!-- Market Value Estimation Option -->
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" id="estimateMarketValue" @(isViewMode ? "disabled" : "")>
                            <label class="form-check-label small text-muted" for="estimateMarketValue">
                                I don't have market value data (use estimate)
                            </label>
                        </div>
                        <div id="marketValueEstimateContainer" class="mt-2" style="display: none;">
                            <label class="form-label small text-primary">Market value is higher than Fiscal Base by:</label>
                            <div class="input-group input-group-sm">
                                <input type="number" class="form-control" id="marketValuePercentage"
                                       value="30" min="0" max="500" step="1" @(isViewMode ? "readonly" : "")>
                                <span class="input-group-text">%</span>
                            </div>
                            <small class="text-muted">e.g., 30% means Market Value = Fiscal Base × 1.30</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="billedAmount" class="form-label fw-bold">
                            Billed Amount (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Amount officially charged for collection (billed) for the year under analysis."></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format bg-light fw-bold" id="billedAmount"
                                   name="PropertyTax.BilledAmount" value="@(Model.PropertyTax.BilledAmount?.ToString("N0") ?? "407,911,073")"
                                   placeholder="Enter value" @(isViewMode ? "readonly" : "") data-input="true">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="outstandingAmount" class="form-label fw-bold">
                            Outstanding Amount (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Portion of current year charges that remain unpaid. Should NOT include arrears from previous years. If exact data unavailable, provide reasonable estimate."></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format bg-light fw-bold" id="outstandingAmount"
                                   name="PropertyTax.OutstandingAmount" value="@(Model.PropertyTax.OutstandingAmount?.ToString("N0") ?? "123,880,968")"
                                   placeholder="Enter value" @(isViewMode ? "readonly" : "") data-input="true">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="revenueToDate" class="form-label text-primary">
                            Revenue to Date (<span class="currency-label">@currencySymbol</span>)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Auto-calculated. Total revenue collected = Billed Amount minus Outstanding. Updates dynamically."></i>
                        </label>
                        <div class="input-group">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control number-format" id="revenueToDate"
                                   name="PropertyTax.RevenueToDate" value="@Model.PropertyTax.RevenueToDate"
                                   readonly style="background-color: #e8f4fc;">
                        </div>
                        <small class="text-muted">= Billed Amount - Outstanding Amount</small>
                    </div>
                </div>
            </div>

            <!-- Useful Average Values -->
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0"><i class="bi bi-calculator me-2"></i>Useful Average Values required for the Analysis</h6>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <label class="form-label small text-primary">
                            Average taxable value (registered)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Average official valuation per property, determined by cadastre. Base for applying tax rates."></i>
                        </label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control" id="avgTaxableValue" readonly style="background-color: #e8f4fc;">
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small text-primary">
                            Average Market Value (registered)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Estimate of average property value if assessed at market levels. Reflects theoretical tax base under ideal valuation."></i>
                        </label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control" id="avgMarketValue" readonly style="background-color: #e8f4fc;">
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small text-primary">
                            Effective tax rate
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Actual effective rate from real revenue collected. Reflects under-assessment, exemptions, and compliance limitations."></i>
                        </label>
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control" id="effectiveTaxRate" readonly style="background-color: #e8f4fc;">
                            <span class="input-group-text">%</span>
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small text-primary">
                            Average billed amount
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Estimated billing per property based on current assessed values and effective tax rate."></i>
                        </label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control" id="avgBilledAmount" readonly style="background-color: #e8f4fc;">
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label small text-primary">
                            Potential billing (market basis)
                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                               title="Theoretical maximum billing per property assuming full market value assessment."></i>
                        </label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text currency-prefix-display">@currencySymbol</span>
                            <input type="text" class="form-control" id="potentialBilling" readonly style="background-color: #e8f4fc;">
                        </div>
                    </div>
                </div>
            </div>

            <!-- KPI Ratios -->
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-warning">
                    <h6 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>Key Performance Indicators (KPI) Ratios</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label small mb-0">
                                Compliance Ratio
                                <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                   title="Proxy indicator of compliance system performance. Measures proportion of billed amounts actually collected. >80% Green, 60-80% Yellow, <60% Red."></i>
                            </label>
                            <span id="complianceRatioValue" class="badge bg-success">0%</span>
                        </div>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar" role="progressbar" id="complianceRatioBar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <small class="text-muted">Revenue to Date / Billed Amount</small>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label small mb-0">
                                Coverage Ratio
                                <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                   title="Proxy indicator of coverage system performance. Measures proportion of total properties registered. >80% Green, 60-80% Yellow, <60% Red."></i>
                            </label>
                            <span id="coverageRatioValue" class="badge bg-info">0%</span>
                        </div>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar" role="progressbar" id="coverageRatioBar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <small class="text-muted">Registered Properties / Estimated Properties</small>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label small mb-0">
                                Valuation Ratio
                                <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                   title="Proxy indicator of valuation system performance. Measures how closely fiscal assessments match market values. >80% Green, 60-80% Yellow, <60% Red."></i>
                            </label>
                            <span id="valuationRatioValue" class="badge bg-primary">0%</span>
                        </div>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar" role="progressbar" id="valuationRatioBar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <small class="text-muted">Total Fiscal Base / Total Market Value</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column - Results Section -->
        <div class="col-lg-8">
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-success text-white">
                    <h6 class="mb-0"><i class="bi bi-graph-up me-2"></i>Graphical Representation of Analyzed Data</h6>
                </div>
                <div class="card-body">
                    <!-- Potential Revenue Breakdown Table (MOVED TO TOP) -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">Potential Revenue Breakdown (Actual Revenue + Adm. Gap breakdown)</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Revenue & Administrative Gaps</th>
                                        <th class="text-end">Amount (<span class="currency-label">@currencySymbol</span>)</th>
                                        <th class="text-end">Share (%)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="table-success">
                                        <td>Revenue to date</td>
                                        <td class="text-end" id="tableRevenueToDate">0</td>
                                        <td class="text-end" id="tableRevenueToDatePct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Compliance Gap
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="The proportion of registered properties that do not pay the tax or fulfill their liability. It reflects weaknesses in enforcement, billing, and payment collection systems. The compliance gap equals Outstanding."></i>
                                        </td>
                                        <td class="text-end" id="tableComplianceGap">0</td>
                                        <td class="text-end" id="tableComplianceGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Coverage Gap
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="The proportion of total estimated properties that are not registered in the property tax system. This gap indicates lack of property identification and inclusion in the fiscal database. The gap is quantified by multiplying the number of unregistered properties by the average billed amount per registered property."></i>
                                        </td>
                                        <td class="text-end" id="tableCoverageGap">0</td>
                                        <td class="text-end" id="tableCoverageGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Valuation Gap
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="The valuation gap estimates how much more revenue could be billed to compliant properties if they were assessed at market value instead of undervalued fiscal assessments. It reflects weaknesses in the valuation framework and outdated property records."></i>
                                        </td>
                                        <td class="text-end" id="tableValuationGap">0</td>
                                        <td class="text-end" id="tableValuationGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Mixed Gap (val./cov. reg.)
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="This mixed gap captures the revenue loss from non-compliant properties that are registered but do not pay - and whose values are also below market. It shows the compounded effect of enforcement failure and undervaluation."></i>
                                        </td>
                                        <td class="text-end" id="tableMixedGapReg">0</td>
                                        <td class="text-end" id="tableMixedGapRegPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Mixed Gap (val./uncov. unreg.)
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="This mixed gap estimates the revenue missed from unregistered properties valued at market levels. It captures the full revenue loss due to both lack of registry and undervaluation."></i>
                                        </td>
                                        <td class="text-end" id="tableMixedGapUnreg">0</td>
                                        <td class="text-end" id="tableMixedGapUnregPct">0%</td>
                                    </tr>
                                    <tr class="table-secondary fw-bold">
                                        <td>TOTAL (Potential Revenue)</td>
                                        <td class="text-end" id="tableTotalPotential">0</td>
                                        <td class="text-end">100%</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <hr>

                    <!-- Matrix Gap Analysis Dashboard (Primary Visualization) -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">Property Tax Gap Analysis - Dashboard</h6>
                        <div class="row g-3 align-items-stretch">
                            <!-- Matrix Visualization -->
                            <div class="col-12">
                                <div class="matrix-container position-relative" style="height: 320px; min-height: 320px; border-radius: 8px; overflow: hidden; background: #fff;">
                                    <!-- Y-axis Title (rotated) -->
                                    <div class="position-absolute d-flex align-items-center justify-content-center" style="left: 0; top: 0; bottom: 30px; width: 20px; background: #f8f9fa;">
                                        <span style="transform: rotate(-90deg); white-space: nowrap; font-size: 0.6rem; color: #666;"># of Properties</span>
                                    </div>

                                    <!-- Y-axis Labels Container - labels positioned at row BOUNDARIES -->
                                    <div class="matrix-y-labels position-absolute" id="matrixYLabelsContainer" style="left: 20px; top: 0; bottom: 30px; width: 55px; font-size: 0.6rem; background: #f8f9fa; position: relative;">
                                        <!-- Estimated label at TOP boundary (top of matrix) -->
                                        <div class="y-label-item" id="yLabelEstimated" style="position: absolute; right: 3px; top: 0; text-align: right; transform: translateY(-50%);">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">Estimated</small>
                                            <span id="matrixEstimatedLabel" class="fw-bold" style="font-size: 0.65rem;">0</span>
                                        </div>
                                        <!-- Registered label at boundary between Row1 and Row2 -->
                                        <div class="y-label-item" id="yLabelRegistered" style="position: absolute; right: 3px; text-align: right; transform: translateY(-50%);">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">Registered</small>
                                            <span id="matrixRegisteredLabel" class="fw-bold" style="font-size: 0.65rem;">0</span>
                                        </div>
                                        <!-- Compliant label at boundary between Row2 and Row3 -->
                                        <div class="y-label-item" id="yLabelCompliant" style="position: absolute; right: 3px; text-align: right; transform: translateY(-50%);">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">Compliant</small>
                                            <span id="matrixCompliantLabel" class="fw-bold" style="font-size: 0.65rem;">0</span>
                                        </div>
                                    </div>

                                    <!-- Matrix Grid Area -->
                                    <div class="matrix-grid position-absolute" id="matrixGridArea" style="left: 75px; top: 0; right: 0; bottom: 30px; display: flex; flex-direction: column;">
                                        <!-- Row 1: Unregistered (Estimated - Registered) -->
                                        <div class="matrix-row d-flex" id="matrixRowUnreg" style="flex: 1; min-height: 30px;">
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="matrixCoverageGap"
                                                 style="background-color: #5B9BD5; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">Coverage Gap</small><br>
                                                    <span id="matrixCoverageGapVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="matrixMixedUnreg"
                                                 style="background-color: #FF6B6B; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">Mixed Gap (Unreg.)</small><br>
                                                    <span id="matrixMixedUnregVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- Row 2: Non-Compliant Registered (Registered - Compliant) -->
                                        <div class="matrix-row d-flex" id="matrixRowNonCompliant" style="flex: 1; min-height: 30px;">
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="matrixComplianceGap"
                                                 style="background-color: #FFD966; color: #333; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">Compliance Gap</small><br>
                                                    <span id="matrixComplianceGapVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="matrixMixedReg"
                                                 style="background-color: #F4A6A6; color: #333; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">Mixed Gap (Reg.)</small><br>
                                                    <span id="matrixMixedRegVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- Row 3: Compliant -->
                                        <div class="matrix-row d-flex" id="matrixRowCompliant" style="flex: 1; min-height: 30px;">
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="matrixActualRevenue"
                                                 style="background-color: #70AD47; color: white; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">Actual Revenue</small><br>
                                                    <span id="matrixActualRevenueVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                            <div class="matrix-cell d-flex align-items-center justify-content-center" id="matrixValuationGap"
                                                 style="background-color: #FFF2CC; color: #333; flex: 1; min-width: 60px;">
                                                <div class="text-center p-1">
                                                    <small style="font-size: 0.7rem;">Valuation Gap</small><br>
                                                    <span id="matrixValuationGapVal" class="fw-bold" style="font-size: 0.8rem;">@currencySymbol 0</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- X-axis Labels - positioned at column BOUNDARIES -->
                                    <div class="matrix-x-axis position-absolute" id="matrixXAxisContainer" style="left: 75px; right: 0; bottom: 0; height: 30px; background: #f8f9fa;">
                                        <!-- X-axis label at left edge (origin = 0) -->
                                        <div class="x-label-item" id="xLabelOrigin" style="position: absolute; left: 0; bottom: 2px; transform: translateX(0%); text-align: left; font-size: 0.6rem;">
                                            <span id="matrixOriginLabel" class="fw-bold" style="font-size: 0.65rem;">@currencySymbol 0</span>
                                        </div>
                                        <!-- X-axis label at column boundary (between left and right columns) -->
                                        <div class="x-label-item" id="xLabelAvgBilled" style="position: absolute; bottom: 2px; transform: translateX(-50%); text-align: center; font-size: 0.6rem;">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">Avg. Billed</small>
                                            <span id="matrixAvgBilledLabel" class="fw-bold" style="font-size: 0.65rem;">@currencySymbol 0</span>
                                        </div>
                                        <!-- X-axis label at right edge -->
                                        <div class="x-label-item" id="xLabelAchievable" style="position: absolute; right: 0; bottom: 2px; transform: translateX(0%); text-align: right; font-size: 0.6rem;">
                                            <small class="text-muted d-block" style="font-size: 0.55rem;">Achievable Avg.</small>
                                            <span id="matrixAvgMarketLabel" class="fw-bold" style="font-size: 0.65rem;">@currencySymbol 0</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div><!-- end row -->
                        <p class="small text-muted mt-3 text-center">
                            <strong>DESCRIPTION:</strong> This matrix visualization shows the property tax gap analysis across two dimensions: the number of properties (vertical axis from Compliant to Estimated) and the billing level (horizontal axis from average billed to achievable market-based billing). Each colored cell represents a different type of gap or revenue component. The same breakdown is also shown in the pie chart below.
                        </p>
                    </div>

                    <hr>

                    <!-- Revenue and Administrative Gaps Pie Chart -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">Revenue and Administrative Gaps</h6>
                        <div class="d-flex justify-content-center">
                            <div style="height: 300px; width: 450px; position: relative;">
                                <canvas id="potentialRevenueChart"></canvas>
                            </div>
                        </div>
                        <p class="small text-muted mt-2 text-center">
                            <strong>DESCRIPTION:</strong> This pie chart illustrates the same information as the matrix above in percentage form. It shows the share of total potential revenue corresponding to the revenue actually collected, as well as the contribution of each type of administrative gap (uncollected or lost revenue) to that total.
                        </p>
                    </div>

                    <hr>

                    <!-- Administrative Gap Breakdown Table -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">Administrative Gap Breakdown (<span class="currency-label">@currencySymbol</span>)</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Administrative Gaps</th>
                                        <th class="text-end">Amount (<span class="currency-label">@currencySymbol</span>)</th>
                                        <th class="text-end">Share (%)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            Compliance Gap
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="The proportion of registered properties that do not pay the tax or fulfill their liability. It reflects weaknesses in enforcement, billing, and payment collection systems. The compliance gap equals Outstanding."></i>
                                        </td>
                                        <td class="text-end" id="admComplianceGap">0</td>
                                        <td class="text-end" id="admComplianceGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Coverage Gap
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="The proportion of total estimated properties that are not registered in the property tax system. This gap indicates lack of property identification and inclusion in the fiscal database. The gap is quantified by multiplying the number of unregistered properties by the average billed amount per registered property."></i>
                                        </td>
                                        <td class="text-end" id="admCoverageGap">0</td>
                                        <td class="text-end" id="admCoverageGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Valuation/assessment Gap
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="The valuation gap estimates how much more revenue could be billed to compliant properties if they were assessed at market value instead of undervalued fiscal assessments. It reflects weaknesses in the valuation framework and outdated property records."></i>
                                        </td>
                                        <td class="text-end" id="admValuationGap">0</td>
                                        <td class="text-end" id="admValuationGapPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Mixed Gap (val./reg.)
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="This mixed gap captures the revenue loss from non-compliant properties that are registered but do not pay - and whose values are also below market. It shows the compounded effect of enforcement failure and undervaluation."></i>
                                        </td>
                                        <td class="text-end" id="admMixedGapReg">0</td>
                                        <td class="text-end" id="admMixedGapRegPct">0%</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Mixed Gap (val./unreg.)
                                            <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip" data-bs-placement="right"
                                               title="This mixed gap estimates the revenue missed from unregistered properties valued at market levels. It captures the full revenue loss due to both lack of registry and undervaluation."></i>
                                        </td>
                                        <td class="text-end" id="admMixedGapUnreg">0</td>
                                        <td class="text-end" id="admMixedGapUnregPct">0%</td>
