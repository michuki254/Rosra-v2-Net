        border-radius: 8px;
    }

    .property-tax-gap-analysis .card-header {
        border-radius: 8px 8px 0 0;
    }

    .property-tax-gap-analysis .form-control[readonly] {
        cursor: default;
    }

    .property-tax-gap-analysis .progress {
        border-radius: 10px;
    }

    .property-tax-gap-analysis .progress-bar {
        border-radius: 10px;
        transition: width 0.3s ease-in-out;
    }

    .property-tax-gap-analysis .table th,
    .property-tax-gap-analysis .table td {
        vertical-align: middle;
        font-size: 0.875rem;
    }

    /* Ensure table header text is visible with white color on dark background */
    .property-tax-gap-analysis .table thead.table-dark th {
        color: #ffffff !important;
        background-color: #212529 !important;
    }

    /* KPI Ratio badges should display as normal Bootstrap badges */
    .property-tax-gap-analysis .card-body > .mb-3 .badge {
        width: auto;
        height: auto;
        border-radius: 0.25rem;
        padding: 0.35em 0.65em;
        font-size: 0.75em;
    }

    .property-tax-gap-analysis .input-group-sm .form-control,
    .property-tax-gap-analysis .input-group-sm .input-group-text {
        font-size: 0.8rem;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Chart instances
        let potentialRevenueChart = null;
        let adminGapChart = null;

        // Get currency symbol from AppContext (single source of truth)
        function getCurrencySymbol() {
            if (window.AppContext) {
                return window.AppContext.get('currencySymbol') || '$';
            }
            return '$';
        }

        // Update all currency displays in Property Tax section
        function updatePropertyTaxCurrencySymbols() {
            const symbol = getCurrencySymbol();
            console.log('Updating Property Tax currency symbols to:', symbol);

            // Update input group prefixes
            document.querySelectorAll('.property-tax-gap-analysis .currency-prefix-display').forEach(el => {
                el.textContent = symbol;
            });

            // Update labels with currency
            document.querySelectorAll('.property-tax-gap-analysis .currency-label').forEach(el => {
                el.textContent = symbol;
            });
        }

        // Subscribe to AppContext currency changes (similar to useContext in React)
        if (window.AppContext) {
            window.AppContext.subscribe('currencySymbol', function(newSymbol) {
                console.log('Property Tax received currency change via AppContext:', newSymbol);
                updatePropertyTaxCurrencySymbols();
                // Also recalculate to update matrix dashboard with new currency
                calculatePropertyTaxGaps();
            });
        }

        // Initial currency update
        updatePropertyTaxCurrencySymbols();

        // Delayed update to catch currency loaded from API (after country data loads)
        setTimeout(function() {
            updatePropertyTaxCurrencySymbols();
        }, 1000);

        // Another update after 2 seconds for slower connections
        setTimeout(function() {
            updatePropertyTaxCurrencySymbols();
        }, 2000);

        // Initialize Bootstrap tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });

        // Initialize charts
        initializeCharts();

        // Add event listeners to all input fields
        const inputFields = document.querySelectorAll('.property-tax-gap-analysis input[data-input="true"]');
        inputFields.forEach(field => {
            field.addEventListener('input', function() {
                calculatePropertyTaxGaps();
            });
            field.addEventListener('change', function() {
                calculatePropertyTaxGaps();
            });
        });

        // Non-registered Properties Estimation Logic
        const estimateCheckbox = document.getElementById('estimateNonRegistered');
        const estimateContainer = document.getElementById('estimatePercentageContainer');
        const nonRegisteredInput = document.getElementById('nonRegisteredProperties');
        const percentageInput = document.getElementById('nonRegisteredPercentage');
        const registeredInput = document.getElementById('registeredProperties');

        if (estimateCheckbox) {
            estimateCheckbox.addEventListener('change', function() {
                if (this.checked) {
                    // Show percentage input, make non-registered field readonly
                    estimateContainer.style.display = 'block';
                    nonRegisteredInput.readOnly = true;
                    nonRegisteredInput.style.backgroundColor = '#e8f4fc';
                    nonRegisteredInput.classList.remove('bg-light');
                    // Calculate based on percentage
                    updateNonRegisteredFromPercentage();
                } else {
                    // Hide percentage input, make non-registered field editable
                    estimateContainer.style.display = 'none';
                    nonRegisteredInput.readOnly = false;
                    nonRegisteredInput.style.backgroundColor = '';
                    nonRegisteredInput.classList.add('bg-light');
                }
            });
        }

        if (percentageInput) {
            percentageInput.addEventListener('input', updateNonRegisteredFromPercentage);
            percentageInput.addEventListener('change', updateNonRegisteredFromPercentage);
        }

        // Also recalculate when registered properties change (if estimate mode is on)
        if (registeredInput) {
            registeredInput.addEventListener('input', function() {
                if (estimateCheckbox && estimateCheckbox.checked) {
                    updateNonRegisteredFromPercentage();
                }
            });
        }

        function updateNonRegisteredFromPercentage() {
            if (!estimateCheckbox || !estimateCheckbox.checked) return;

            const registered = parseNumber(registeredInput?.value);
            const percentage = parseFloat(percentageInput?.value) || 0;

            const nonRegistered = Math.round(registered * (percentage / 100));
            nonRegisteredInput.value = formatCurrency(nonRegistered).replace('.00', '');

            // Trigger recalculation
            calculatePropertyTaxGaps();
        }

        // Total Market Value Estimation Logic
        const marketValueCheckbox = document.getElementById('estimateMarketValue');
        const marketValueContainer = document.getElementById('marketValueEstimateContainer');
        const marketValueInput = document.getElementById('totalMarketValue');
        const marketValuePercentageInput = document.getElementById('marketValuePercentage');
        const fiscalBaseInput = document.getElementById('totalFiscalBase');

        if (marketValueCheckbox) {
            marketValueCheckbox.addEventListener('change', function() {
                if (this.checked) {
                    // Show percentage input, make market value field readonly
                    marketValueContainer.style.display = 'block';
                    marketValueInput.readOnly = true;
                    marketValueInput.style.backgroundColor = '#e8f4fc';
                    marketValueInput.classList.remove('bg-light');
                    // Calculate based on percentage
                    updateMarketValueFromPercentage();
                } else {
                    // Hide percentage input, make market value field editable
                    marketValueContainer.style.display = 'none';
                    marketValueInput.readOnly = false;
                    marketValueInput.style.backgroundColor = '';
                    marketValueInput.classList.add('bg-light');
                }
            });
        }

        if (marketValuePercentageInput) {
            marketValuePercentageInput.addEventListener('input', updateMarketValueFromPercentage);
            marketValuePercentageInput.addEventListener('change', updateMarketValueFromPercentage);
        }

        // Also recalculate market value when fiscal base changes (if estimate mode is on)
        if (fiscalBaseInput) {
            fiscalBaseInput.addEventListener('input', function() {
                if (marketValueCheckbox && marketValueCheckbox.checked) {
                    updateMarketValueFromPercentage();
                }
            });
        }

        function updateMarketValueFromPercentage() {
            if (!marketValueCheckbox || !marketValueCheckbox.checked) return;

            const fiscalBase = parseNumber(fiscalBaseInput?.value);
            const percentage = parseFloat(marketValuePercentageInput?.value) || 0;

            // Market Value = Fiscal Base × (1 + percentage/100)
            const marketValue = fiscalBase * (1 + percentage / 100);
            marketValueInput.value = formatCurrency(marketValue);

            // Trigger recalculation
            calculatePropertyTaxGaps();
        }

        // Initial calculation
        calculatePropertyTaxGaps();

        function initializeCharts() {
            // Potential Revenue Pie Chart
            const ctx1 = document.getElementById('potentialRevenueChart');
            if (ctx1) {
                potentialRevenueChart = new Chart(ctx1.getContext('2d'), {
                    type: 'pie',
                    data: {
                        labels: ['Revenue to date', 'Compliance Gap', 'Coverage Gap', 'Valuation Gap', 'Mixed Gap (reg.)', 'Mixed Gap (unreg.)'],
                        datasets: [{
                            data: [0, 0, 0, 0, 0, 0],
                            backgroundColor: ['#4CAF50', '#F44336', '#FF9800', '#2196F3', '#9C27B0', '#E91E63'],
                            borderWidth: 2,
                            borderColor: '#ffffff'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'right',
                                labels: {
                                    boxWidth: 12,
                                    font: { size: 10 },
                                    generateLabels: function(chart) {
                                        const data = chart.data;
                                        if (data.labels.length && data.datasets.length) {
                                            const total = data.datasets[0].data.reduce((a, b) => a + b, 0);
                                            return data.labels.map((label, i) => {
                                                const value = data.datasets[0].data[i];
                                                const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                                return {
                                                    text: label + ' (' + percentage + '%)',
                                                    fillStyle: data.datasets[0].backgroundColor[i],
                                                    hidden: false,
                                                    index: i
                                                };
                                            });
                                        }
                                        return [];
                                    }
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const value = context.raw || 0;
                                        const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                        const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                        return context.label + ': ' + formatCurrency(value) + ' (' + percentage + '%)';
                                    }
                                }
                            }
                        }
                    }
                });
                if (window.registerChart) registerChart('potentialRevenueChart', potentialRevenueChart);
            }

            // Administrative Gap Pie Chart
            const ctx2 = document.getElementById('adminGapChart');
            if (ctx2) {
                adminGapChart = new Chart(ctx2.getContext('2d'), {
                    type: 'pie',
                    data: {
                        labels: ['Compliance Gap', 'Coverage Gap', 'Valuation/assessment gap', 'Mixed Gap (reg.)', 'Mixed Gap (unreg.)'],
                        datasets: [{
                            data: [0, 0, 0, 0, 0],
                            backgroundColor: ['#F44336', '#FF9800', '#2196F3', '#9C27B0', '#E91E63'],
                            borderWidth: 2,
                            borderColor: '#ffffff'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'right',
                                labels: {
                                    boxWidth: 12,
                                    font: { size: 10 },
                                    generateLabels: function(chart) {
                                        const data = chart.data;
                                        if (data.labels.length && data.datasets.length) {
                                            const total = data.datasets[0].data.reduce((a, b) => a + b, 0);
                                            return data.labels.map((label, i) => {
                                                const value = data.datasets[0].data[i];
                                                const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                                return {
                                                    text: label + ' (' + percentage + '%)',
                                                    fillStyle: data.datasets[0].backgroundColor[i],
                                                    hidden: false,
                                                    index: i
                                                };
                                            });
                                        }
                                        return [];
                                    }
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const value = context.raw || 0;
                                        const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                        const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                        return context.label + ': ' + formatCurrency(value) + ' (' + percentage + '%)';
                                    }
                                }
                            }
                        }
                    }
                });
                if (window.registerChart) registerChart('adminGapChart', adminGapChart);
            }
        }

        function parseNumber(value) {
            if (!value) return 0;
            // Remove currency symbols, commas, spaces
            const cleaned = String(value).replace(/[^0-9.-]/g, '');
            return parseFloat(cleaned) || 0;
        }

        function formatCurrency(value) {
            if (isNaN(value) || value === null) return '0';
            return new Intl.NumberFormat('en-US', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            }).format(value);
        }

        function formatPercentage(value) {
            if (isNaN(value) || value === null) return '0.00%';
            return value.toFixed(2) + '%';
        }

        function calculatePropertyTaxGaps() {
            // Get input values (user inputs)
            const registeredProperties = parseNumber(document.getElementById('registeredProperties')?.value);
            const nonRegisteredProperties = parseNumber(document.getElementById('nonRegisteredProperties')?.value);
            const totalFiscalBase = parseNumber(document.getElementById('totalFiscalBase')?.value);
            const totalMarketValue = parseNumber(document.getElementById('totalMarketValue')?.value);
            const billedAmount = parseNumber(document.getElementById('billedAmount')?.value);
            const outstandingAmount = parseNumber(document.getElementById('outstandingAmount')?.value);

            // AUTO-CALCULATE Revenue to Date = Billed - Outstanding
            const revenueToDate = billedAmount - outstandingAmount;
            document.getElementById('revenueToDate').value = formatCurrency(revenueToDate);

            // Calculate Derived Metrics
            const estimatedProperties = registeredProperties + nonRegisteredProperties;

            // Calculate Compliant Properties = Registered Properties × (Revenue to Date / Billed Amount)
            const compliantProperties = billedAmount > 0 ? registeredProperties * (revenueToDate / billedAmount) : 0;

            // Average values
            const avgTaxableValue = registeredProperties > 0 ? totalFiscalBase / registeredProperties : 0;
            const avgMarketValue = registeredProperties > 0 ? totalMarketValue / registeredProperties : 0;

            // Effective Tax Rate = Revenue to Date / (Avg Taxable Value × Compliant Properties)
            const effectiveTaxRate = (avgTaxableValue * compliantProperties) > 0
                ? (revenueToDate / (avgTaxableValue * compliantProperties)) * 100
                : 0;
            const effectiveTaxRateDecimal = effectiveTaxRate / 100;

            // Average Billed Amount = Effective Tax Rate × Average Taxable Value
            const avgBilledAmount = effectiveTaxRateDecimal * avgTaxableValue;

            // Potential Billing (market basis) = Effective Tax Rate × Average Market Value
            const potentialBilling = effectiveTaxRateDecimal * avgMarketValue;

            // Calculate KPI Ratios
            const complianceRatio = billedAmount > 0 ? (revenueToDate / billedAmount) * 100 : 0;
            const coverageRatio = estimatedProperties > 0 ? (registeredProperties / estimatedProperties) * 100 : 0;
            const valuationRatio = totalMarketValue > 0 ? (totalFiscalBase / totalMarketValue) * 100 : 0;

            // Calculate Gaps (using CORRECT formulas from spec)
            // Compliance Gap = Outstanding Amount
            const complianceGap = outstandingAmount;

            // Coverage Gap = (Estimated - Registered) × Avg Billed Amount
            const coverageGap = (estimatedProperties - registeredProperties) * avgBilledAmount;

            // Valuation Gap = Compliant Properties × (Potential Billing Market - Avg Billed)
            const valuationGap = compliantProperties * (potentialBilling - avgBilledAmount);

            // Mixed Gap (val./reg.) = (Registered - Compliant) × (Potential Billing Market - Avg Billed)
            const mixedGapReg = (registeredProperties - compliantProperties) * (potentialBilling - avgBilledAmount);

            // Mixed Gap (val./unreg.) = (Estimated - Registered) × (Potential Billing Market - Avg Billed)
            const mixedGapUnreg = (estimatedProperties - registeredProperties) * (potentialBilling - avgBilledAmount);

            // Calculate Totals
            const totalPotentialRevenue = revenueToDate + complianceGap + coverageGap + valuationGap + mixedGapReg + mixedGapUnreg;
            const totalAdminGap = complianceGap + coverageGap + valuationGap + mixedGapReg + mixedGapUnreg;

            // Calculate percentages for potential revenue
            const revenueToDatePct = totalPotentialRevenue > 0 ? (revenueToDate / totalPotentialRevenue) * 100 : 0;
            const complianceGapPct = totalPotentialRevenue > 0 ? (complianceGap / totalPotentialRevenue) * 100 : 0;
            const coverageGapPct = totalPotentialRevenue > 0 ? (coverageGap / totalPotentialRevenue) * 100 : 0;
            const valuationGapPct = totalPotentialRevenue > 0 ? (valuationGap / totalPotentialRevenue) * 100 : 0;
            const mixedGapRegPct = totalPotentialRevenue > 0 ? (mixedGapReg / totalPotentialRevenue) * 100 : 0;
            const mixedGapUnregPct = totalPotentialRevenue > 0 ? (mixedGapUnreg / totalPotentialRevenue) * 100 : 0;

            // Calculate percentages for admin gaps
            const admComplianceGapPct = totalAdminGap > 0 ? (complianceGap / totalAdminGap) * 100 : 0;
            const admCoverageGapPct = totalAdminGap > 0 ? (coverageGap / totalAdminGap) * 100 : 0;
            const admValuationGapPct = totalAdminGap > 0 ? (valuationGap / totalAdminGap) * 100 : 0;
            const admMixedGapRegPct = totalAdminGap > 0 ? (mixedGapReg / totalAdminGap) * 100 : 0;
            const admMixedGapUnregPct = totalAdminGap > 0 ? (mixedGapUnreg / totalAdminGap) * 100 : 0;

            // Update derived metrics display
            document.getElementById('estimatedProperties').value = formatCurrency(estimatedProperties).replace('.00', '');
            document.getElementById('compliantProperties').value = formatCurrency(compliantProperties).replace('.00', '');
            document.getElementById('avgTaxableValue').value = formatCurrency(avgTaxableValue);
            document.getElementById('avgMarketValue').value = formatCurrency(avgMarketValue);
            document.getElementById('effectiveTaxRate').value = effectiveTaxRate.toFixed(2);
            document.getElementById('avgBilledAmount').value = formatCurrency(avgBilledAmount);
            document.getElementById('potentialBilling').value = formatCurrency(potentialBilling);

            // Update KPI progress bars (colors are dynamic based on thresholds)
            updateKPIBar('complianceRatio', complianceRatio);
            updateKPIBar('coverageRatio', coverageRatio);
            updateKPIBar('valuationRatio', valuationRatio);

            // Update Potential Revenue Breakdown Table
            document.getElementById('tableRevenueToDate').textContent = formatCurrency(revenueToDate);
            document.getElementById('tableRevenueToDatePct').textContent = formatPercentage(revenueToDatePct);
            document.getElementById('tableComplianceGap').textContent = formatCurrency(complianceGap);
            document.getElementById('tableComplianceGapPct').textContent = formatPercentage(complianceGapPct);
            document.getElementById('tableCoverageGap').textContent = formatCurrency(coverageGap);
            document.getElementById('tableCoverageGapPct').textContent = formatPercentage(coverageGapPct);
            document.getElementById('tableValuationGap').textContent = formatCurrency(valuationGap);
            document.getElementById('tableValuationGapPct').textContent = formatPercentage(valuationGapPct);
            document.getElementById('tableMixedGapReg').textContent = formatCurrency(mixedGapReg);
            document.getElementById('tableMixedGapRegPct').textContent = formatPercentage(mixedGapRegPct);
            document.getElementById('tableMixedGapUnreg').textContent = formatCurrency(mixedGapUnreg);
            document.getElementById('tableMixedGapUnregPct').textContent = formatPercentage(mixedGapUnregPct);
            document.getElementById('tableTotalPotential').textContent = formatCurrency(totalPotentialRevenue);

            // Update Administrative Gap Breakdown Table
            document.getElementById('admComplianceGap').textContent = formatCurrency(complianceGap);
            document.getElementById('admComplianceGapPct').textContent = formatPercentage(admComplianceGapPct);
            document.getElementById('admCoverageGap').textContent = formatCurrency(coverageGap);
            document.getElementById('admCoverageGapPct').textContent = formatPercentage(admCoverageGapPct);
            document.getElementById('admValuationGap').textContent = formatCurrency(valuationGap);
            document.getElementById('admValuationGapPct').textContent = formatPercentage(admValuationGapPct);
            document.getElementById('admMixedGapReg').textContent = formatCurrency(mixedGapReg);
            document.getElementById('admMixedGapRegPct').textContent = formatPercentage(admMixedGapRegPct);
            document.getElementById('admMixedGapUnreg').textContent = formatCurrency(mixedGapUnreg);
            document.getElementById('admMixedGapUnregPct').textContent = formatPercentage(admMixedGapUnregPct);
            document.getElementById('tableTotalAdmGap').textContent = formatCurrency(totalAdminGap);

            // Update Charts
            updateCharts(revenueToDate, complianceGap, coverageGap, valuationGap, mixedGapReg, mixedGapUnreg);

            // Update Matrix Dashboard
            updateMatrixDashboard({
                estimatedProperties,
                registeredProperties,
                compliantProperties,
                avgBilledAmount,
                potentialBilling,
                revenueToDate,
                complianceGap,
                coverageGap,
                valuationGap,
                mixedGapReg,
                mixedGapUnreg,
                totalPotentialRevenue,
                revenueToDatePct,
                complianceGapPct,
                coverageGapPct,
                valuationGapPct,
                mixedGapRegPct,
                mixedGapUnregPct
            });

            // Store values in localStorage for Prioritization tab
            storePropertyTaxValues(revenueToDate, totalPotentialRevenue, totalAdminGap, complianceGap, coverageGap, valuationGap, mixedGapReg, mixedGapUnreg, complianceRatio, coverageRatio);
        }

        function storePropertyTaxValues(revenueToDate, totalPotentialRevenue, totalFunctionalGap, complianceGap, coverageGap, valuationGap, mixedGapReg, mixedGapUnreg, complianceRatio, coverageRatio) {
            try {
                // Use RosraStateManager if available (preferred method)
                if (typeof RosraStateManager !== 'undefined') {
                    RosraStateManager.updatePropertyTax({
                        currentRevenue: revenueToDate,
                        potentialRevenue: totalPotentialRevenue,
                        totalFunctionalGap: totalFunctionalGap,
                        complianceGap: complianceGap,
                        coverageGap: coverageGap,
                        valuationGap: valuationGap,
                        mixedGapReg: mixedGapReg,
                        mixedGapUnreg: mixedGapUnreg,
                        complianceRatio: complianceRatio,
                        coverageRatio: coverageRatio
                    });
                    console.log('Property Tax: Updated via RosraStateManager');
                }

                // Also keep localStorage for backward compatibility
                localStorage.setItem('propertyTaxCurrentValue', revenueToDate);
                localStorage.setItem('propertyTaxPotentialValue', totalPotentialRevenue);
                localStorage.setItem('propertyTaxGapValue', totalFunctionalGap);
                localStorage.setItem('propertyTaxGap', totalFunctionalGap);
                localStorage.setItem('propertyTaxComplianceGap', complianceGap);
                localStorage.setItem('propertyTaxCoverageGap', coverageGap);
                localStorage.setItem('propertyTaxValuationGap', valuationGap);
                localStorage.setItem('propertyTaxMixedGapReg', mixedGapReg);
                localStorage.setItem('propertyTaxMixedGapUnreg', mixedGapUnreg);
                localStorage.setItem('propertyTaxComplianceRatio', complianceRatio);
                localStorage.setItem('propertyTaxCoverageRatio', coverageRatio);

                const propertyTaxValuesUpdated = new CustomEvent('propertyTaxValuesUpdated', {
                    detail: {
                        current: revenueToDate,
                        potential: totalPotentialRevenue,
                        gap: totalFunctionalGap
                    }
                });
                document.dispatchEvent(propertyTaxValuesUpdated);
            } catch (e) {
                console.error('Error storing Property Tax values:', e);
            }
        }

        function updateKPIBar(name, value) {
            const bar = document.getElementById(name + 'Bar');
            const valueSpan = document.getElementById(name + 'Value');
            const cappedValue = Math.min(Math.max(value, 0), 100);

            // Determine color based on value: >80% Green, 60-80% Yellow, <60% Red
            let colorClass, badgeClass;
            if (value >= 80) {
                colorClass = 'bg-success';
                badgeClass = 'bg-success';
            } else if (value >= 60) {
                colorClass = 'bg-warning';
                badgeClass = 'bg-warning text-dark';
            } else {
                colorClass = 'bg-danger';
                badgeClass = 'bg-danger';
            }

            if (bar) {
                bar.style.width = cappedValue + '%';
                bar.setAttribute('aria-valuenow', cappedValue);
                // Remove old color classes and add new one
                bar.classList.remove('bg-success', 'bg-warning', 'bg-danger', 'bg-info', 'bg-primary');
                bar.classList.add(colorClass);
            }
            if (valueSpan) {
                valueSpan.textContent = value.toFixed(0) + '%';
                // Update badge color
                valueSpan.classList.remove('bg-success', 'bg-warning', 'bg-danger', 'bg-info', 'bg-primary', 'text-dark');
                badgeClass.split(' ').forEach(cls => valueSpan.classList.add(cls));
            }
        }

        function updateCharts(revenueToDate, complianceGap, coverageGap, valuationGap, mixedGapReg, mixedGapUnreg) {
            // Update Potential Revenue Chart
            if (potentialRevenueChart) {
                potentialRevenueChart.data.datasets[0].data = [
                    Math.max(0, revenueToDate),
                    Math.max(0, complianceGap),
                    Math.max(0, coverageGap),
                    Math.max(0, valuationGap),
                    Math.max(0, mixedGapReg),
                    Math.max(0, mixedGapUnreg)
                ];
                potentialRevenueChart.update();
            }

            // Update Admin Gap Chart
            if (adminGapChart) {
                adminGapChart.data.datasets[0].data = [
                    Math.max(0, complianceGap),
                    Math.max(0, coverageGap),
                    Math.max(0, valuationGap),
                    Math.max(0, mixedGapReg),
                    Math.max(0, mixedGapUnreg)
                ];
                adminGapChart.update();
            }
        }

        function updateMatrixDashboard(data) {
            const currencySymbol = getCurrencySymbol();

            // Format number for display (compact for large numbers)
            function formatCompact(value) {
                if (value >= 1000000000) {
                    return currencySymbol + ' ' + (value / 1000000000).toFixed(1) + 'B';
                } else if (value >= 1000000) {
                    return currencySymbol + ' ' + (value / 1000000).toFixed(1) + 'M';
                } else if (value >= 1000) {
                    return currencySymbol + ' ' + (value / 1000).toFixed(1) + 'K';
                }
                return currencySymbol + ' ' + formatCurrency(value);
            }

            function formatPropertyCount(value) {
                if (value >= 1000000) {
                    return (value / 1000000).toFixed(1) + 'M';
                } else if (value >= 1000) {
                    return (value / 1000).toFixed(1) + 'K';
                }
                return Math.round(value).toLocaleString();
            }

            // Update Y-axis labels (property counts)
            const estLabel = document.getElementById('matrixEstimatedLabel');
            const regLabel = document.getElementById('matrixRegisteredLabel');
            const compLabel = document.getElementById('matrixCompliantLabel');

            if (estLabel) estLabel.textContent = formatPropertyCount(data.estimatedProperties);
            if (regLabel) regLabel.textContent = formatPropertyCount(data.registeredProperties);
            if (compLabel) compLabel.textContent = formatPropertyCount(data.compliantProperties);

            // Update X-axis labels (average billing amounts)
            const avgBilledLabel = document.getElementById('matrixAvgBilledLabel');
            const avgMarketLabel = document.getElementById('matrixAvgMarketLabel');
            const originLabel = document.getElementById('matrixOriginLabel');

            if (avgBilledLabel) avgBilledLabel.textContent = formatCompact(data.avgBilledAmount);
            if (avgMarketLabel) avgMarketLabel.textContent = formatCompact(data.potentialBilling);
            if (originLabel) originLabel.textContent = currencySymbol + ' 0';

            // Update matrix cell values
            const matrixActualRevenue = document.getElementById('matrixActualRevenueVal');
            const matrixValuationGap = document.getElementById('matrixValuationGapVal');
            const matrixComplianceGap = document.getElementById('matrixComplianceGapVal');
            const matrixMixedReg = document.getElementById('matrixMixedRegVal');
            const matrixCoverageGap = document.getElementById('matrixCoverageGapVal');
            const matrixMixedUnreg = document.getElementById('matrixMixedUnregVal');

            if (matrixActualRevenue) matrixActualRevenue.textContent = formatCompact(data.revenueToDate);
            if (matrixValuationGap) matrixValuationGap.textContent = formatCompact(data.valuationGap);
            if (matrixComplianceGap) matrixComplianceGap.textContent = formatCompact(data.complianceGap);
            if (matrixMixedReg) matrixMixedReg.textContent = formatCompact(data.mixedGapReg);
            if (matrixCoverageGap) matrixCoverageGap.textContent = formatCompact(data.coverageGap);
            if (matrixMixedUnreg) matrixMixedUnreg.textContent = formatCompact(data.mixedGapUnreg);

            // === DYNAMIC ROW HEIGHTS (proportional to property counts) ===
            const totalProps = data.estimatedProperties || 1;
            const unregProps = Math.max(0, data.estimatedProperties - data.registeredProperties);
            const nonCompliantProps = Math.max(0, data.registeredProperties - data.compliantProperties);
            const compliantProps = Math.max(0, data.compliantProperties);

            // Calculate flex ratios with minimum 15% to ensure text visibility
            const minFlex = 0.15;
            const unregRatio = unregProps / totalProps;
            const nonCompliantRatio = nonCompliantProps / totalProps;
            const compliantRatio = compliantProps / totalProps;

            // Apply minimum and scale
            const unregFlex = Math.max(minFlex, unregRatio);
            const nonCompliantFlex = Math.max(minFlex, nonCompliantRatio);
            const compliantFlex = Math.max(minFlex, compliantRatio);

            const rowUnreg = document.getElementById('matrixRowUnreg');
            const rowNonCompliant = document.getElementById('matrixRowNonCompliant');
            const rowCompliant = document.getElementById('matrixRowCompliant');

            if (rowUnreg) rowUnreg.style.flex = unregFlex.toString();
            if (rowNonCompliant) rowNonCompliant.style.flex = nonCompliantFlex.toString();
            if (rowCompliant) rowCompliant.style.flex = compliantFlex.toString();

            // === DYNAMIC COLUMN WIDTHS (proportional to billing amounts) ===
            const totalBilling = data.potentialBilling || 1;
            const avgBilled = data.avgBilledAmount || 0;
            const valuationDiff = Math.max(0, data.potentialBilling - data.avgBilledAmount);

            // Calculate column width ratios (min 20% to ensure text visibility)
            const minColWidth = 0.2;
            const leftColRatio = avgBilled / totalBilling;
            const rightColRatio = valuationDiff / totalBilling;

            const leftColFlex = Math.max(minColWidth, leftColRatio);
            const rightColFlex = Math.max(minColWidth, rightColRatio);

            // Apply to all row cells
            const allRows = document.querySelectorAll('.matrix-row');
            allRows.forEach(row => {
                const cells = row.querySelectorAll('.matrix-cell');
                if (cells.length >= 2) {
                    cells[0].style.flex = leftColFlex.toString();
                    cells[1].style.flex = rightColFlex.toString();
                }
            });

            // === POSITION Y-AXIS LABELS AT ROW BOUNDARIES ===
            // Get the grid area and y-axis container heights
            const gridArea = document.getElementById('matrixGridArea');
            const yAxisContainer = document.getElementById('matrixYLabelsContainer');

            if (gridArea && yAxisContainer) {
                const gridHeight = gridArea.offsetHeight;
                const totalFlex = unregFlex + nonCompliantFlex + compliantFlex;

                // Calculate row heights in pixels
                const row1Height = (unregFlex / totalFlex) * gridHeight;
                const row2Height = (nonCompliantFlex / totalFlex) * gridHeight;
                const row3Height = (compliantFlex / totalFlex) * gridHeight;

                // Position labels at boundaries
                const yLabelEstimated = document.getElementById('yLabelEstimated');
                const yLabelRegistered = document.getElementById('yLabelRegistered');
                const yLabelCompliant = document.getElementById('yLabelCompliant');

                // Estimated at top (0px from top)
                if (yLabelEstimated) {
                    yLabelEstimated.style.top = '0px';
                }
                // Registered at boundary between row1 and row2
                if (yLabelRegistered) {
                    yLabelRegistered.style.top = row1Height + 'px';
                }
                // Compliant at boundary between row2 and row3
                if (yLabelCompliant) {
                    yLabelCompliant.style.top = (row1Height + row2Height) + 'px';
                }
            }

            // === POSITION X-AXIS LABEL AT COLUMN BOUNDARY ===
            const xAxisContainer = document.getElementById('matrixXAxisContainer');
            const xLabelAvgBilled = document.getElementById('xLabelAvgBilled');

            if (xAxisContainer && xLabelAvgBilled) {
                const totalColFlex = leftColFlex + rightColFlex;
                const leftColPercent = (leftColFlex / totalColFlex) * 100;

                // Position the "Avg. Billed" label at the column boundary
                xLabelAvgBilled.style.left = leftColPercent + '%';
            }
        }

        // Expose calculatePropertyTaxGaps globally
        window.calculatePropertyTaxGaps = calculatePropertyTaxGaps;
    });
</script>
