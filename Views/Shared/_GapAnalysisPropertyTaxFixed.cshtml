                    <!-- Administrative Gap Breakdown Table -->
                    <div class="mb-4">
                        <h6 class="text-center mb-3">@Localizer["AdmGapBreakdown_Title"] (<span class="currency-label">@currencySymbol</span>)</h6>
                        <div class="table-responsive">
