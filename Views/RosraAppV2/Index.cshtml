@{
    ViewData["Title"] = "RosraApp V2";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow border-0 rounded-lg">
                <div class="card-header bg-primary text-white">
                    <h3 class="m-0">Welcome to RosraApp V2</h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8">
                            <h4>Next Generation User Management System</h4>
                            <p class="lead">RosraApp V2 provides enhanced user management capabilities with a modern interface and improved security features.</p>
                            <p>Our application helps organizations manage their users efficiently with role-based access control, detailed user profiles, and comprehensive administrative tools.</p>
                            
                            <div class="mt-4">
                                <h5>Key Features:</h5>
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item bg-transparent">
                                        <i class="bi bi-shield-check text-primary me-2"></i>
                                        Enhanced security with ASP.NET Core Identity
                                    </li>
                                    <li class="list-group-item bg-transparent">
                                        <i class="bi bi-people text-primary me-2"></i>
                                        Comprehensive user management
                                    </li>
                                    <li class="list-group-item bg-transparent">
                                        <i class="bi bi-person-badge text-primary me-2"></i>
                                        Role-based access control
                                    </li>
                                    <li class="list-group-item bg-transparent">
                                        <i class="bi bi-database-check text-primary me-2"></i>
                                        SQL Server integration for reliable data storage
                                    </li>
                                    <li class="list-group-item bg-transparent">
                                        <i class="bi bi-layout-text-window text-primary me-2"></i>
                                        Modern, responsive user interface
                                    </li>
                                </ul>
                            </div>
                            
                            <div class="mt-4">
                                <a asp-controller="Account" asp-action="Register" class="btn btn-primary me-2">Register Now</a>
                                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">Login</a>
                            </div>
                        </div>
                        <div class="col-md-4 d-flex align-items-center justify-content-center">
                            <div class="text-center">
                                <i class="bi bi-people-fill text-primary" style="font-size: 8rem;"></i>
                                <h5 class="mt-3">User Management Simplified</h5>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow border-0 rounded-lg">
                <div class="card-header bg-light">
                    <h5 class="m-0">User Management</h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-3">
                        <i class="bi bi-person-plus text-primary" style="font-size: 3rem;"></i>
                    </div>
                    <p>Create and manage user accounts with detailed profiles including organization information and contact details.</p>
                    <p>Assign roles to control access to different parts of the application.</p>
                </div>
                <div class="card-footer text-center">
                    <a href="#" class="btn btn-sm btn-outline-primary">Learn More</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow border-0 rounded-lg">
                <div class="card-header bg-light">
                    <h5 class="m-0">Admin Dashboard</h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-3">
                        <i class="bi bi-speedometer2 text-primary" style="font-size: 3rem;"></i>
                    </div>
                    <p>Powerful admin dashboard for managing users, roles, and permissions.</p>
                    <p>Monitor user activity and generate reports on system usage.</p>
                </div>
                <div class="card-footer text-center">
                    <a href="#" class="btn btn-sm btn-outline-primary">Learn More</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow border-0 rounded-lg">
                <div class="card-header bg-light">
                    <h5 class="m-0">Security Features</h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-3">
                        <i class="bi bi-shield-lock text-primary" style="font-size: 3rem;"></i>
                    </div>
                    <p>Built on ASP.NET Core Identity for secure authentication and authorization.</p>
                    <p>Password hashing, account lockout, and two-factor authentication support.</p>
                </div>
                <div class="card-footer text-center">
                    <a href="#" class="btn btn-sm btn-outline-primary">Learn More</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            console.log("RosraApp V2 page loaded");
        });
    </script>
}
