@model RosraApp.Models.ApplicationUser

@{
    ViewData["Title"] = "User Details";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow border-0 rounded-lg">
                <div class="card-header bg-primary text-white">
                    <h3 class="m-0">User Details</h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 text-center mb-4 mb-md-0">
                            <div class="bg-light rounded-circle mx-auto d-flex align-items-center justify-content-center" style="width: 150px; height: 150px;">
                                <i class="bi bi-person-circle text-primary" style="font-size: 5rem;"></i>
                            </div>
                            <h4 class="mt-3">@Model.FirstName @Model.LastName</h4>
                            <p class="text-muted">@(await Component.InvokeAsync("UserRole", new { userId = Model.Id }))</p>
                        </div>
                        <div class="col-md-9">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <div class="card h-100">
                                        <div class="card-header bg-light">
                                            <h5 class="m-0">Personal Information</h5>
                                        </div>
                                        <div class="card-body">
                                            <div class="mb-3">
                                                <label class="fw-bold">First Name:</label>
                                                <p>@Model.FirstName</p>
                                            </div>
                                            <div class="mb-3">
                                                <label class="fw-bold">Last Name:</label>
                                                <p>@Model.LastName</p>
                                            </div>
                                            <div class="mb-3">
                                                <label class="fw-bold">Email:</label>
                                                <p>@Model.Email</p>
                                            </div>
                                            <div class="mb-3">
                                                <label class="fw-bold">Phone Number:</label>
                                                <p>@(Model.PhoneNumber ?? "Not specified")</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="card h-100">
                                        <div class="card-header bg-light">
                                            <h5 class="m-0">Organization Details</h5>
                                        </div>
                                        <div class="card-body">
                                            <div class="mb-3">
                                                <label class="fw-bold">Organization:</label>
                                                <p>@(Model.Organization ?? "Not specified")</p>
                                            </div>
                                            <div class="mb-3">
                                                <label class="fw-bold">Account Created:</label>
                                                <p>@(Model.CreatedAt.HasValue ? Model.CreatedAt.Value.ToString("MMMM dd, yyyy") : "Not available")</p>
                                            </div>
                                            <div class="mb-3">
                                                <label class="fw-bold">Email Confirmed:</label>
                                                <p>@(Model.EmailConfirmed ? "Yes" : "No")</p>
                                            </div>
                                            <div class="mb-3">
                                                <label class="fw-bold">Phone Confirmed:</label>
                                                <p>@(Model.PhoneNumberConfirmed ? "Yes" : "No")</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <div class="d-flex justify-content-between">
                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-primary">Back to Dashboard</a>
                        <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-primary">Edit Profile</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            console.log("User Details page loaded");
        });
    </script>
}
