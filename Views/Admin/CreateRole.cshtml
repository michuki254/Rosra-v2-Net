@model RosraApp.Models.ViewModels.CreateRoleViewModel

@{
    ViewData["Title"] = Localizer["PageTitle"].Value;
}

@section Styles {
    <style>
        body { background: #FFFFFF; }

        /* ── Header ── */
        .page-header {
            background: white; border-radius: 12px; padding: 1.75rem 2rem;
            margin-bottom: 1.75rem; box-shadow: 0 2px 20px -4px rgba(0,0,0,0.1);
        }
        .header-icon {
            width: 40px; height: 40px; border-radius: 10px; background: #3B82F6;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; color: white; box-shadow: 0 6px 12px -2px rgba(59,130,246,0.25); flex-shrink: 0;
        }
        .page-header h1 { color: #222222; font-weight: 700; font-size: 1.75rem; margin-bottom: 0.25rem; }
        .page-header p { color: #6A6A6A; font-size: 0.9375rem; margin: 0; }
        .btn-back {
            background: white; border: none; color: #222222; border-radius: 10px;
            font-weight: 500; padding: 0.5rem 1rem; font-size: 0.875rem;
            box-shadow: 0 1px 6px -1px rgba(0,0,0,0.08); transition: all 0.2s;
        }
        .btn-back:hover { color: #3B82F6; box-shadow: 0 4px 16px -4px rgba(0,0,0,0.15); }

        /* ── Alerts ── */
        .alert-biz {
            border: none; border-radius: 10px; padding: 0.875rem 1.25rem;
            margin-bottom: 1.25rem; font-size: 0.875rem; font-weight: 500;
        }
        .alert-biz.success { background: #D1FAE5; color: #065F46; }
        .alert-biz.error { background: #FEE2E2; color: #991B1B; }

        /* ── Section Cards ── */
        .section-card {
            background: white; border-radius: 12px; padding: 1.75rem;
            box-shadow: 0 2px 20px -4px rgba(0,0,0,0.1); margin-bottom: 1.5rem;
        }
        .section-header { display: flex; align-items: center; gap: 0.625rem; margin-bottom: 1.25rem; }
        .section-icon {
            width: 32px; height: 32px; border-radius: 8px;
            display: flex; align-items: center; justify-content: center; color: white; font-size: 0.875rem;
        }
        .section-header h5 { color: #222222; font-weight: 600; margin: 0; font-size: 1rem; }
        .section-header h5 small { color: #6A6A6A !important; }
        .section-desc { color: #6A6A6A; font-size: 0.8125rem; margin: -0.75rem 0 1rem 0; padding-left: 2.625rem; }

        /* ── Form Inputs ── */
        .form-label-biz { font-weight: 600; color: #222222; margin-bottom: 0.375rem; font-size: 0.875rem; }
        .input-biz {
            background: #F7F7F7; border: 1px solid #DDDDDD; border-radius: 8px;
            padding: 0.625rem 1rem; font-size: 0.9375rem; transition: all 0.2s;
        }
        .input-biz:focus { background: white; border-color: #3B82F6; box-shadow: 0 0 0 3px rgba(59,130,246,0.1); }

        /* ── Permissions ── */
        .permissions-container { border-radius: 10px; overflow: hidden; }

        .perm-category { margin-bottom: 0.5rem; }

        .category-header {
            background: #F7F7F7; padding: 0.75rem 1rem; border-radius: 8px;
            display: flex; align-items: center; gap: 0.625rem;
            cursor: pointer; user-select: none; transition: all 0.15s;
        }
        .category-header:hover { background: #EFEFEF; }
        .category-header .chevron { color: #6A6A6A; font-size: 0.75rem; transition: transform 0.2s; }
        .category-header.collapsed .chevron { transform: rotate(-90deg); }
        .category-name { font-weight: 600; color: #222222; font-size: 0.875rem; flex: 1; }
        .category-count {
            font-size: 0.75rem; font-weight: 600; background: white; color: #6A6A6A;
            padding: 0.15rem 0.5rem; border-radius: 10px;
        }

        .category-body {
            padding: 0.75rem 0 0.75rem 1rem;
            display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 0.5rem;
        }
        .category-body.collapsed { display: none; }

        .perm-item {
            display: flex; align-items: start; gap: 0.625rem;
            padding: 0.625rem 0.75rem; border-radius: 8px; transition: all 0.15s; background: #FAFAFA;
        }
        .perm-item:hover { background: #F0F7FF; }

        .perm-check {
            width: 18px; height: 18px; border: 2px solid #DDDDDD; border-radius: 5px;
            cursor: pointer; margin-top: 1px; flex-shrink: 0; accent-color: #3B82F6;
        }
        .perm-check:checked { border-color: #3B82F6; }

        .perm-label { cursor: pointer; margin: 0; flex: 1; }
        .perm-name { font-weight: 600; color: #222222; font-size: 0.8125rem; display: block; }
        .perm-desc { color: #6A6A6A; font-size: 0.75rem; line-height: 1.4; display: block; }

        .perm-toolbar { display: flex; gap: 0.5rem; justify-content: flex-end; margin-bottom: 0.75rem; }
        .perm-toolbar-btn {
            background: white; border: none; border-radius: 8px; padding: 0.3rem 0.75rem;
            font-size: 0.8125rem; font-weight: 500; color: #6A6A6A;
            box-shadow: 0 1px 4px -1px rgba(0,0,0,0.08); transition: all 0.2s;
        }
        .perm-toolbar-btn:hover { color: #3B82F6; box-shadow: 0 2px 8px -2px rgba(0,0,0,0.12); }

        /* ── Create Button ── */
        .btn-create {
            background: #3B82F6; color: white; border: none; border-radius: 10px;
            padding: 0.625rem 1.75rem; font-weight: 600; font-size: 0.9375rem;
            box-shadow: 0 4px 12px -2px rgba(59,130,246,0.25); transition: all 0.2s;
        }
        .btn-create:hover { background: #2563EB; color: white; transform: translateY(-1px); box-shadow: 0 6px 16px -2px rgba(59,130,246,0.35); }
        .btn-cancel {
            background: white; color: #6A6A6A; border: none; border-radius: 10px;
            padding: 0.625rem 1.25rem; font-weight: 500;
            box-shadow: 0 1px 4px -1px rgba(0,0,0,0.08); transition: all 0.2s;
        }
        .btn-cancel:hover { color: #222222; box-shadow: 0 2px 8px -2px rgba(0,0,0,0.12); }

        /* ── Roles Table ── */
        .roles-table { margin: 0; }
        .roles-table thead th {
            background: #F7F7F7; border-bottom: none; color: #6A6A6A; font-weight: 600;
            font-size: 0.8125rem; padding: 0.875rem 1rem; text-transform: uppercase; letter-spacing: 0.5px;
        }
        .roles-table thead th:first-child { border-radius: 8px 0 0 8px; }
        .roles-table thead th:last-child { border-radius: 0 8px 8px 0; }
        .roles-table tbody td { padding: 0.875rem 1rem; vertical-align: middle; border-bottom: 1px solid #F7F7F7; }
        .roles-table tbody tr { transition: background 0.15s; }
        .roles-table tbody tr:hover { background: #FAFAFA; }

        .role-name { font-weight: 600; color: #222222; font-size: 0.9375rem; }
        .type-badge {
            display: inline-flex; align-items: center; gap: 0.25rem;
            padding: 0.25rem 0.625rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600;
        }
        .type-system { background: #F7F7F7; color: #6A6A6A; }
        .type-custom { background: #EDE9FE; color: #7C3AED; }
        .user-count { font-weight: 600; color: #222222; font-size: 0.875rem; }

        .btn-perms {
            background: white; border: none; color: #3B82F6; border-radius: 8px;
            padding: 0.375rem 0.75rem; font-size: 0.8125rem; font-weight: 500;
            box-shadow: 0 1px 4px -1px rgba(0,0,0,0.08); transition: all 0.2s;
        }
        .btn-perms:hover { color: #2563EB; box-shadow: 0 2px 8px -2px rgba(59,130,246,0.2); }

        .btn-delete-role {
            background: white; border: none; color: #6A6A6A; border-radius: 8px;
            padding: 0.375rem 0.75rem; font-size: 0.8125rem; font-weight: 500;
            box-shadow: 0 1px 4px -1px rgba(0,0,0,0.08); transition: all 0.2s;
        }
        .btn-delete-role:hover { color: #EF4444; background: #FEE2E2; box-shadow: none; }
        .btn-delete-role:disabled { opacity: 0.4; cursor: not-allowed; }
        .btn-delete-role:disabled:hover { color: #6A6A6A; background: white; }

        /* ── Empty & Modal ── */
        .empty-state { text-align: center; padding: 2.5rem 1rem; }
        .empty-icon {
            width: 56px; height: 56px; border-radius: 14px; background: #F7F7F7;
            display: inline-flex; align-items: center; justify-content: center;
            font-size: 1.5rem; color: #6A6A6A; margin-bottom: 0.75rem;
        }
        .empty-state p { color: #6A6A6A; font-size: 0.875rem; margin: 0; }

        .modal-content { border: none !important; border-radius: 12px !important; box-shadow: 0 20px 60px -12px rgba(0,0,0,0.25) !important; overflow: hidden; }
    </style>
}

<div class="container py-4">
    <!-- Header -->
    <div class="page-header d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-3">
            <div class="header-icon"><i class="bi bi-shield-lock-fill"></i></div>
            <div>
                <h1>@Localizer["PageTitle"]</h1>
                <p>@Localizer["PageSubtitle"]</p>
            </div>
        </div>
        <a asp-action="Index" class="btn btn-back">
            <i class="bi bi-arrow-left me-1"></i> @Localizer["BackToDashboard"]
        </a>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert-biz success"><i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]</div>
    }
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert-biz error"><i class="bi bi-exclamation-triangle-fill me-2"></i><div asp-validation-summary="All" class="mb-0 d-inline"></div></div>
    }

    <!-- Create Role Form -->
    <div class="section-card">
        <div class="section-header">
            <div class="section-icon" style="background:#10B981;"><i class="bi bi-plus-lg"></i></div>
            <h5>@Localizer["CreateNewRole"]</h5>
        </div>
        <p class="section-desc">@Localizer["CreateNewRoleDescription"]</p>

        <form asp-action="CreateRole" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="RoleName" class="form-label-biz">@Localizer["RoleName"]</label>
                <input asp-for="RoleName" class="form-control input-biz" placeholder="@Localizer["RoleNamePlaceholder"].Value" required />
                <span asp-validation-for="RoleName" class="text-danger" style="font-size:0.8125rem;"></span>
            </div>

            <!-- Permissions -->
            <div class="mb-4">
                <label class="form-label-biz mb-2">@Localizer["Permissions"]</label>
                <div class="perm-toolbar">
                    <button type="button" class="perm-toolbar-btn" onclick="selectAllPermissions()">
                        <i class="bi bi-check-all me-1"></i> @Localizer["SelectAll"]
                    </button>
                    <button type="button" class="perm-toolbar-btn" onclick="deselectAllPermissions()">
                        <i class="bi bi-x-lg me-1"></i> @Localizer["ClearAll"]
                    </button>
                </div>

                @if (Model.PermissionCategories != null && Model.PermissionCategories.Any())
                {
                    <div class="permissions-container">
                        @foreach (var category in Model.PermissionCategories)
                        {
                            <div class="perm-category">
                                <div class="category-header" onclick="toggleCategory(this)">
                                    <i class="bi bi-chevron-down chevron"></i>
                                    <span class="category-name">@category.Category</span>
                                    <span class="category-count">@category.Permissions.Count</span>
                                </div>
                                <div class="category-body">
                                    @foreach (var perm in category.Permissions)
                                    {
                                        <div class="perm-item">
                                            <input type="checkbox" class="perm-check" name="SelectedPermissionIds"
                                                   value="@perm.Id" id="perm_@perm.Id" @(perm.IsSelected ? "checked" : "") />
                                            <label for="perm_@perm.Id" class="perm-label">
                                                <span class="perm-name">@perm.Name</span>
                                                @if (!string.IsNullOrEmpty(perm.Description))
                                                {
                                                    <span class="perm-desc">@perm.Description</span>
                                                }
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="background:#FEF3C7; color:#92400E; border-radius:8px; padding:0.75rem 1rem; font-size:0.875rem;">
                        <i class="bi bi-exclamation-triangle me-1"></i> @Localizer["NoPermissionsFound"]
                    </div>
                }
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn-create"><i class="bi bi-plus-lg me-2"></i> @Localizer["CreateRole"]</button>
                <a asp-action="Index" class="btn-cancel text-decoration-none d-flex align-items-center">@Localizer["Cancel"]</a>
            </div>
        </form>
    </div>

    <!-- Existing Roles Table -->
    <div class="section-card">
        <div class="section-header">
            <div class="section-icon" style="background:#8B5CF6;"><i class="bi bi-shield-check"></i></div>
            <h5>@Localizer["ExistingRoles"] <small class="fw-normal ms-2">(@Model.ExistingRoles.Count)</small></h5>
        </div>

        @if (Model.ExistingRoles.Any())
        {
            <div class="table-responsive">
                <table class="table roles-table">
                    <thead>
                        <tr>
                            <th>@Localizer["RoleNameHeader"]</th>
                            <th>@Localizer["Type"]</th>
                            <th>@Localizer["Users"]</th>
                            <th>@Localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var role in Model.ExistingRoles)
                        {
                            var isSystem = role.RoleName == "Admin" || role.RoleName == "User";
                            <tr data-role-id="@role.RoleId">
                                <td><span class="role-name">@role.RoleName</span></td>
                                <td>
                                    <span class="type-badge @(isSystem ? "type-system" : "type-custom")">
                                        <i class="bi bi-@(isSystem ? "lock-fill" : "gear-fill")"></i>
                                        @(isSystem ? Localizer["SystemRole"].Value : Localizer["CustomRole"].Value)
                                    </span>
                                </td>
                                <td>
                                    <span class="user-count">@role.UserCount</span>
                                    <span style="color:#6A6A6A; font-size:0.8125rem;"> @(role.UserCount != 1 ? Localizer["UserPlural"].Value : Localizer["UserSingular"].Value)</span>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="EditRolePermissions" asp-route-roleId="@role.RoleId" class="btn btn-sm btn-perms">
                                            <i class="bi bi-shield-check me-1"></i> @Localizer["PermissionsButton"]
                                        </a>
                                        @if (isSystem)
                                        {
                                            <button class="btn btn-sm btn-delete-role" disabled title="@Localizer["SystemRolesCannotBeDeleted"].Value">
                                                <i class="bi bi-lock-fill"></i>
                                            </button>
                                        }
                                        else if (role.UserCount > 0)
                                        {
                                            <button class="btn btn-sm btn-delete-role" disabled title="@Localizer["CannotDeleteRoleWithUsers"].Value">
                                                <i class="bi bi-info-circle"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-delete-role" onclick="showDeleteModal('@role.RoleId', '@role.RoleName')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="bi bi-shield-x"></i></div>
                <p>@Localizer["NoRolesFound"]</p>
            </div>
        }
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background:#222222; color:white; padding:1.25rem 1.5rem;">
                <h5 class="modal-title fw-bold"><i class="bi bi-trash me-2"></i>Delete Role</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:1.5rem;">
                <p style="color:#6A6A6A; margin:0;">Are you sure you want to delete the role "<strong id="deleteRoleName"></strong>"? This cannot be undone.</p>
                <input type="hidden" id="deleteRoleId" />
            </div>
            <div class="modal-footer" style="border:none; background:#F7F7F7; padding:1rem 1.5rem;">
                <button class="btn" style="background:white; color:#222222; border:none; border-radius:8px; box-shadow:0 1px 4px -1px rgba(0,0,0,0.1); font-weight:500;" data-bs-dismiss="modal">Cancel</button>
                <button class="btn" style="background:#EF4444; color:white; border:none; border-radius:8px; box-shadow:0 4px 12px -2px rgba(239,68,68,0.25); font-weight:600;" id="confirmDeleteBtn">
                    <i class="bi bi-trash me-1"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Toast -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:1050">
    <div id="toast" class="toast hide" role="alert">
        <div class="toast-header">
            <strong class="me-auto" id="toast-title">@Localizer["Notification"]</strong>
            <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
        </div>
        <div class="toast-body" id="toast-message"></div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    @Html.AntiForgeryToken()

    <script>
        function toggleCategory(header) {
            header.nextElementSibling.classList.toggle('collapsed');
            header.classList.toggle('collapsed');
        }

        function selectAllPermissions() {
            document.querySelectorAll('.perm-check').forEach(cb => cb.checked = true);
        }

        function deselectAllPermissions() {
            document.querySelectorAll('.perm-check').forEach(cb => cb.checked = false);
        }

        function showDeleteModal(roleId, roleName) {
            $('#deleteRoleId').val(roleId);
            $('#deleteRoleName').text(roleName);
            new bootstrap.Modal(document.getElementById('deleteModal')).show();
        }

        $(document).ready(function() {
            var token = $('input[name="__RequestVerificationToken"]').val();

            function showToast(title, message, type) {
                $('#toast-title').text(title);
                $('#toast-message').text(message);
                $('#toast').removeClass('bg-danger bg-success').addClass(type === 'success' ? 'bg-success text-white' : 'bg-danger text-white');
                new bootstrap.Toast(document.getElementById('toast')).show();
            }

            $('#confirmDeleteBtn').click(function() {
                var roleId = $('#deleteRoleId').val();
                $.ajax({
                    url: '@Url.Action("DeleteRole", "Admin")',
                    type: 'POST',
                    data: { roleId: roleId, __RequestVerificationToken: token },
                    success: function(r) {
                        bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
                        if (r.success) {
                            showToast('Success', r.message, 'success');
                            $('tr[data-role-id="' + roleId + '"]').fadeOut(300, function() { $(this).remove(); });
                        } else {
                            showToast('Error', r.message, 'error');
                        }
                    },
                    error: function() {
                        bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
                        showToast('Error', 'An error occurred', 'error');
                    }
                });
            });
        });
    </script>
}
