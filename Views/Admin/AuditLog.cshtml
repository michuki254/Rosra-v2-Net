@model List<RosraApp.Models.AuditLog>

@{
    ViewData["Title"] = "Audit Log";
    var pageNumber = (int)(ViewData["PageNumber"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
    var totalCount = (int)(ViewData["TotalCount"] ?? 0);
    var actionFilter = ViewData["ActionFilter"] as string;
    var entityTypeFilter = ViewData["EntityTypeFilter"] as string;
    var allActions = ViewData["AllActions"] as List<string> ?? new();
    var allEntityTypes = ViewData["AllEntityTypes"] as List<string> ?? new();
}

@section Styles {
    <style>
        body { background: #FFFFFF; }

        .page-header {
            background: white; border-radius: 12px; padding: 1.75rem 2rem;
            margin-bottom: 1.75rem; box-shadow: 0 2px 20px -4px rgba(0,0,0,0.1);
        }
        .header-icon {
            width: 40px; height: 40px; border-radius: 10px; background: #F59E0B;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; color: white; box-shadow: 0 6px 12px -2px rgba(245,158,11,0.25); flex-shrink: 0;
        }
        .page-header h1 { color: #222222; font-weight: 700; font-size: 1.75rem; margin-bottom: 0.25rem; }
        .page-header p { color: #6A6A6A; font-size: 0.9375rem; margin: 0; }
        .btn-back {
            background: white; border: none; color: #222222; border-radius: 10px;
            font-weight: 500; padding: 0.5rem 1rem; font-size: 0.875rem;
            box-shadow: 0 1px 6px -1px rgba(0,0,0,0.08); transition: all 0.2s;
        }
        .btn-back:hover { color: #3B82F6; box-shadow: 0 4px 16px -4px rgba(0,0,0,0.15); }

        /* ── Filters ── */
        .filter-bar { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.5rem; align-items: center; }
        .filter-select {
            background: #F7F7F7; border: 1px solid #DDDDDD; border-radius: 8px;
            font-size: 0.875rem; padding: 0.375rem 0.75rem; transition: all 0.2s;
        }
        .filter-select:focus { background: white; border-color: #3B82F6; box-shadow: 0 0 0 3px rgba(59,130,246,0.1); }
        .btn-filter {
            background: #3B82F6; color: white; border: none; border-radius: 8px;
            box-shadow: 0 2px 6px -1px rgba(59,130,246,0.25); transition: all 0.2s; font-size: 0.875rem; padding: 0.375rem 0.75rem;
        }
        .btn-filter:hover { background: #2563EB; color: white; }
        .btn-clear {
            background: white; color: #EF4444; border: none; border-radius: 8px;
            box-shadow: 0 1px 4px -1px rgba(0,0,0,0.08); transition: all 0.2s; font-size: 0.875rem; padding: 0.375rem 0.75rem;
        }
        .btn-clear:hover { background: #FEE2E2; }

        /* ── Table ── */
        .table-card {
            background: white; border-radius: 12px; padding: 1.75rem;
            box-shadow: 0 2px 20px -4px rgba(0,0,0,0.1);
        }
        .table-card-header { display: flex; align-items: center; gap: 0.625rem; margin-bottom: 1.25rem; }
        .section-icon {
            width: 32px; height: 32px; border-radius: 8px;
            display: flex; align-items: center; justify-content: center; color: white; font-size: 0.875rem;
        }
        .table-card-header h5 { color: #222222; font-weight: 600; margin: 0; font-size: 1rem; }
        .table-card-header h5 small { color: #6A6A6A !important; }

        .audit-table { margin: 0; }
        .audit-table thead th {
            background: #F7F7F7; border-bottom: none; color: #6A6A6A; font-weight: 600;
            font-size: 0.75rem; padding: 0.75rem 0.875rem; text-transform: uppercase; letter-spacing: 0.5px;
        }
        .audit-table thead th:first-child { border-radius: 8px 0 0 8px; }
        .audit-table thead th:last-child { border-radius: 0 8px 8px 0; }
        .audit-table tbody td { padding: 0.75rem 0.875rem; vertical-align: middle; border-bottom: 1px solid #F7F7F7; font-size: 0.8125rem; }
        .audit-table tbody tr { transition: background 0.15s; }
        .audit-table tbody tr:hover { background: #FAFAFA; }

        /* ── Action Badges ── */
        .action-badge {
            display: inline-flex; align-items: center; gap: 0.25rem;
            padding: 0.2rem 0.5rem; border-radius: 6px; font-size: 0.75rem; font-weight: 600;
        }
        .action-Created { background: #D1FAE5; color: #065F46; }
        .action-Updated { background: #DBEAFE; color: #1E40AF; }
        .action-Deleted { background: #FEE2E2; color: #991B1B; }
        .action-Restored { background: #E0E7FF; color: #4338CA; }
        .action-PermanentlyDeleted { background: #222222; color: white; }
        .action-StatusChanged { background: #FEF3C7; color: #92400E; }
        .action-UserActivated { background: #D1FAE5; color: #065F46; }
        .action-UserDeactivated { background: #F7F7F7; color: #6A6A6A; }
        .action-RoleAssigned { background: #EDE9FE; color: #7C3AED; }
        .action-RoleRemoved { background: #FEE2E2; color: #991B1B; }
        .action-RoleCreated { background: #D1FAE5; color: #065F46; }
        .action-RoleDeleted { background: #FEE2E2; color: #991B1B; }

        .entity-badge {
            display: inline-flex; align-items: center; gap: 0.25rem;
            padding: 0.2rem 0.5rem; border-radius: 6px; font-size: 0.75rem; font-weight: 600;
        }
        .entity-RosraReport { background: #DBEAFE; color: #1E40AF; }
        .entity-User { background: #EDE9FE; color: #7C3AED; }
        .entity-Role { background: #FEF3C7; color: #92400E; }

        .status-transition {
            display: inline-flex; align-items: center; gap: 0.25rem; font-size: 0.75rem; font-weight: 500;
        }
        .status-transition .arrow { color: #6A6A6A; }

        .details-text {
            max-width: 350px; color: #6A6A6A; font-size: 0.8125rem;
            overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
            cursor: pointer; transition: all 0.2s;
        }
        .details-text:hover, .details-text.expanded { white-space: normal; word-break: break-word; color: #222222; }

        .timestamp { font-weight: 500; color: #222222; }
        .timestamp-time { color: #6A6A6A; font-size: 0.75rem; }
        .user-cell { font-size: 0.8125rem; color: #222222; font-weight: 500; }
        .ip-cell { font-size: 0.6875rem; color: #6A6A6A; font-family: monospace; }

        /* ── Pagination ── */
        .pagination .page-link {
            border: none; border-radius: 8px; color: #6A6A6A; font-weight: 500;
            padding: 0.5rem 0.875rem; margin: 0 0.125rem; transition: all 0.2s;
        }
        .pagination .page-link:hover { background: #F7F7F7; color: #222222; }
        .pagination .page-item.active .page-link {
            background: #3B82F6; color: white; box-shadow: 0 2px 8px -2px rgba(59,130,246,0.3);
        }

        .empty-state { text-align: center; padding: 3rem 1rem; }
        .empty-icon {
            width: 56px; height: 56px; border-radius: 14px; background: #F7F7F7;
            display: inline-flex; align-items: center; justify-content: center;
            font-size: 1.5rem; color: #6A6A6A; margin-bottom: 0.75rem;
        }
    </style>
}

<div class="container py-4">
    <!-- Header -->
    <div class="page-header d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-3">
            <div class="header-icon"><i class="bi bi-clock-history"></i></div>
            <div>
                <h1>Audit Log</h1>
                <p>@totalCount total entries</p>
            </div>
        </div>
        <a asp-action="Index" class="btn btn-back">
            <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
        </a>
    </div>

    <!-- Filters -->
    <form asp-action="AuditLog" method="get" class="filter-bar">
        <select name="action" class="form-select form-select-sm filter-select" style="width:auto;">
            <option value="">All Actions</option>
            @foreach (var a in allActions)
            {
                <option value="@a" selected="@(actionFilter == a)">@a</option>
            }
        </select>
        <select name="entityType" class="form-select form-select-sm filter-select" style="width:auto;">
            <option value="">All Entities</option>
            @foreach (var et in allEntityTypes)
            {
                <option value="@et" selected="@(entityTypeFilter == et)">@et</option>
            }
        </select>
        <button type="submit" class="btn btn-sm btn-filter"><i class="bi bi-funnel me-1"></i> Filter</button>
        @if (!string.IsNullOrEmpty(actionFilter) || !string.IsNullOrEmpty(entityTypeFilter))
        {
            <a asp-action="AuditLog" class="btn btn-sm btn-clear"><i class="bi bi-x-lg"></i></a>
        }
    </form>

    <!-- Table -->
    <div class="table-card">
        <div class="table-card-header">
            <div class="section-icon" style="background:#F59E0B;"><i class="bi bi-journal-text"></i></div>
            <h5>Activity Log <small class="fw-normal ms-2">(@totalCount entries)</small></h5>
        </div>

        <div class="table-responsive">
            <table class="table audit-table">
                <thead>
                    <tr>
                        <th>Timestamp</th>
                        <th>Action</th>
                        <th>Entity</th>
                        <th>User</th>
                        <th>Details</th>
                        <th>Status Transition</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td>
                                    <div class="timestamp">@log.Timestamp.ToLocalTime().ToString("dd MMM yyyy")</div>
                                    <div class="timestamp-time">@log.Timestamp.ToLocalTime().ToString("HH:mm:ss")</div>
                                </td>
                                <td>
                                    <span class="action-badge action-@log.Action">
                                        @log.Action
                                    </span>
                                </td>
                                <td>
                                    <span class="entity-badge entity-@log.EntityType">
                                        @log.EntityType
                                    </span>
                                    @if (!string.IsNullOrEmpty(log.EntityId))
                                    {
                                        <span style="color:#6A6A6A; font-size:0.75rem;"> #@log.EntityId</span>
                                    }
                                </td>
                                <td>
                                    <div class="user-cell">@(log.UserEmail ?? "System")</div>
                                    @if (!string.IsNullOrEmpty(log.IpAddress))
                                    {
                                        <div class="ip-cell">@log.IpAddress</div>
                                    }
                                </td>
                                <td>
                                    <div class="details-text" onclick="this.classList.toggle('expanded')" title="Click to expand">
                                        @(log.Details ?? "-")
                                    </div>
                                    @if (!string.IsNullOrEmpty(log.Reason))
                                    {
                                        <div style="font-size:0.75rem; color:#92400E; margin-top:0.25rem;">
                                            <i class="bi bi-chat-left-text me-1"></i>@log.Reason
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(log.StatusFrom) && !string.IsNullOrEmpty(log.StatusTo))
                                    {
                                        <div class="status-transition">
                                            <span style="background:#F7F7F7; padding:0.15rem 0.4rem; border-radius:4px;">@log.StatusFrom</span>
                                            <span class="arrow"><i class="bi bi-arrow-right"></i></span>
                                            <span style="background:#D1FAE5; color:#065F46; padding:0.15rem 0.4rem; border-radius:4px;">@log.StatusTo</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span style="color:#DDDDDD;">-</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="py-0">
                                <div class="empty-state">
                                    <div class="empty-icon"><i class="bi bi-journal-x"></i></div>
                                    <p style="color:#6A6A6A; font-size:0.875rem; margin:0;">No audit entries found</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(pageNumber <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="AuditLog" asp-route-page="@(pageNumber - 1)" asp-route-action="@actionFilter" asp-route-entityType="@entityTypeFilter">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                @for (int i = Math.Max(1, pageNumber - 2); i <= Math.Min(totalPages, pageNumber + 2); i++)
                {
                    <li class="page-item @(i == pageNumber ? "active" : "")">
                        <a class="page-link" asp-action="AuditLog" asp-route-page="@i" asp-route-action="@actionFilter" asp-route-entityType="@entityTypeFilter">@i</a>
                    </li>
                }
                <li class="page-item @(pageNumber >= totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="AuditLog" asp-route-page="@(pageNumber + 1)" asp-route-action="@actionFilter" asp-route-entityType="@entityTypeFilter">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
            <p class="text-center small mb-0" style="color:#6A6A6A;">Page @pageNumber of @totalPages</p>
        </nav>
    }
</div>
