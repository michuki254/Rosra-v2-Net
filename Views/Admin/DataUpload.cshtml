                               "Angola,AOA,Kz,,,,106713626126.56,35588987,,Unitary,No,Lower-middle,Lower-middle income,,,";

            downloadCSV(csvContent, 'CountryData_Template.csv');
        }

        function downloadCSV(content, filename) {
            const blob = new Blob([content], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');

            if (navigator.msSaveBlob) {
                navigator.msSaveBlob(blob, filename);
            } else {
                link.href = URL.createObjectURL(blob);
                link.download = filename;
                link.style.display = 'none';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            }
        }

        // PeerSNG File Handling
        let peerFile = null;
        const peerFileInput = document.getElementById('peerFileInput');
        const peerUploadArea = document.getElementById('peerUploadArea');

        peerFileInput.addEventListener('change', function(e) {
            handlePeerFile(e.target.files[0]);
        });

        peerUploadArea.addEventListener('dragover', function(e) {
            e.preventDefault();
            this.classList.add('dragging');
        });

        peerUploadArea.addEventListener('dragleave', function(e) {
            this.classList.remove('dragging');
        });

        peerUploadArea.addEventListener('drop', function(e) {
            e.preventDefault();
            this.classList.remove('dragging');
            handlePeerFile(e.dataTransfer.files[0]);
        });

        function handlePeerFile(file) {
            if (!file || !file.name.endsWith('.csv')) {
                showToast('Error', 'Please select a CSV file', 'error');
                return;
            }

            peerFile = file;
            document.getElementById('peerFileName').textContent = file.name;
            document.getElementById('peerFileSize').textContent = formatFileSize(file.size);
            document.getElementById('peerSelectedFile').classList.add('show');
            document.getElementById('peerUploadBtn').disabled = false;
        }

        function removePeerFile() {
            peerFile = null;
            peerFileInput.value = '';
            document.getElementById('peerSelectedFile').classList.remove('show');
