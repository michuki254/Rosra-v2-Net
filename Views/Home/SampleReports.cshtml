@{
    ViewData["Title"] = "Sample Reports";
    // Fixed PublicIds matching SampleReportSeeder
    var nairobiId = "a0000001-0001-0001-0001-000000000001";
    var kampalaId = "a0000001-0001-0001-0001-000000000002";
    var darId = "a0000001-0001-0001-0001-000000000003";
    var accraId = "a0000001-0001-0001-0001-000000000004";
    var addisId = "a0000001-0001-0001-0001-000000000005";
}

<style>
    .sample-reports-page {
        font-family: 'Roboto', sans-serif;
        background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf1 100%);
        min-height: 100vh;
        padding: 3rem 0;
    }
    .sample-reports-header {
        text-align: center;
        margin-bottom: 3rem;
    }
    .sample-reports-header h1 {
        font-size: 2.2rem;
        font-weight: 700;
        color: #1a2332;
        margin-bottom: 0.5rem;
    }
    .sample-reports-header .subtitle {
        font-size: 1.05rem;
        color: #6c757d;
        max-width: 700px;
        margin: 0 auto;
    }
    .sample-reports-header .badge-row {
        margin-top: 1rem;
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .sample-reports-header .info-badge {
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 500;
        background: #fff;
        border: 1px solid #dee2e6;
        color: #495057;
    }

    /* Report Cards Grid */
    .reports-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    .report-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.06);
        transition: transform 0.3s, box-shadow 0.3s;
        border: 1px solid rgba(0,0,0,0.04);
        display: flex;
        flex-direction: column;
    }
    .report-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 36px rgba(0,0,0,0.1);
    }
    .report-card .card-body-custom {
        padding: 1.75rem;
    }
    .report-card .city-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
    }
    .report-card .city-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .report-card .country-flag {
        font-size: 2.2rem;
        line-height: 1;
    }
    .report-card .city-name {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1a2332;
    }
    .report-card .country-name {
        font-size: 0.85rem;
        color: #6c757d;
        margin-top: 2px;
    }
    .report-card .status-badge {
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .report-card .status-validated { background: #d1fae5; color: #065f46; }
    .report-card .status-demo { background: #e0f2fe; color: #0369a1; }

    /* Financial Summary */
    .financial-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem;
        margin-bottom: 1.25rem;
    }
    .fin-item {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 0.75rem;
        text-align: center;
    }
    .fin-item .fin-label {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #6c757d;
        font-weight: 600;
        margin-bottom: 0.25rem;
    }
    .fin-item .fin-value {
        font-size: 1rem;
        font-weight: 700;
        color: #1a2332;
    }

    /* Streams */
    .streams-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1.25rem;
    }
    .stream-tag {
        padding: 0.3rem 0.75rem;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 500;
    }
    .stream-tag.pt { background: #fef3c7; color: #92400e; }
    .stream-tag.bl { background: #ede9fe; color: #5b21b6; }
    .stream-tag.np-a { background: #dbeafe; color: #1e40af; }
    .stream-tag.np-b { background: #ffedd5; color: #9a3412; }
    .stream-tag.np-c { background: #d1fae5; color: #065f46; }

    /* Gap Bars */
    .gap-bars {
        margin-bottom: 1.25rem;
    }
    .gap-bar-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }
    .gap-bar-label {
        font-size: 0.7rem;
        font-weight: 600;
        color: #6c757d;
        width: 80px;
        text-align: right;
    }
    .gap-bar-track {
        flex: 1;
        height: 8px;
        background: #e9ecef;
        border-radius: 4px;
        overflow: hidden;
    }
    .gap-bar-fill {
        height: 100%;
        border-radius: 4px;
        transition: width 0.8s ease;
    }
    .gap-bar-fill.compliance { background: #F44336; }
    .gap-bar-fill.coverage { background: #FF9800; }
    .gap-bar-fill.valuation { background: #2196F3; }
    .gap-bar-fill.liability { background: #9C27B0; }
    .gap-bar-value {
        font-size: 0.7rem;
        font-weight: 600;
        color: #333;
        width: 60px;
    }

    /* Solutions selected */
    .solutions-summary {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 1rem;
        background: #f0f9ff;
        border-radius: 10px;
        margin-bottom: 1rem;
    }
    .solutions-summary .sol-label {
        font-size: 0.8rem;
        color: #0369a1;
        font-weight: 500;
    }
    .solutions-summary .sol-count {
        font-size: 1.1rem;
        font-weight: 700;
        color: #0369a1;
    }

    /* Card footer */
    .card-footer-custom {
        padding: 1rem 1.75rem;
        border-top: 1px solid #f0f0f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .card-footer-custom .meta-info {
        font-size: 0.75rem;
        color: #adb5bd;
    }
    .btn-view-report {
        background: #00689D;
        color: #fff;
        border: none;
        padding: 0.5rem 1.25rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s;
        text-decoration: none;
    }
    .btn-view-report:hover {
        background: #004d73;
        color: #fff;
        text-decoration: none;
    }

    .report-card .card-body-custom {
        flex: 1;
    }

    @@media (max-width: 992px) {
        .reports-grid { grid-template-columns: 1fr; }
    }
    @@media (max-width: 768px) {
        .financial-grid { grid-template-columns: 1fr; }
        .sample-reports-header h1 { font-size: 1.6rem; }
    }
</style>

