@{
    ViewData["Title"] = "Developer Administration Guide";
}

@section Styles {
    <style>
        body {
            background: #f8f9fa;
        }

        /* ── Hero ── */
        .dev-hero {
            background: #1e293b;
            color: white;
            padding: 3rem 0;
            margin-bottom: 2rem;
        }

        .dev-hero h1 {
            font-size: 2.25rem;
            font-weight: 800;
            margin-bottom: 0.5rem;
        }

        .dev-hero .lead {
            font-size: 1.05rem;
            opacity: 0.85;
            margin-bottom: 0;
        }

        .dev-hero .badge-dev {
            background: rgba(99,102,241,0.35);
            color: #c7d2fe;
            padding: 0.35rem 0.85rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        /* ── TOC Sidebar ── */
        .toc-sidebar {
            position: sticky;
            top: 100px;
            max-height: calc(100vh - 120px);
            overflow-y: auto;
            padding-right: 1rem;
        }

        .toc-sidebar::-webkit-scrollbar { width: 3px; }
        .toc-sidebar::-webkit-scrollbar-thumb { background: #dee2e6; border-radius: 3px; }

        .toc-card {
            background: white;
            border-radius: 10px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.08);
            border: 1px solid #e9ecef;
            padding: 1.25rem;
        }

        .toc-card h6 {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #868e96;
            font-weight: 700;
            margin-bottom: 0.75rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #f1f3f5;
        }

        .toc-link {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.45rem 0.65rem;
            border-radius: 6px;
            color: #495057;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            transition: all 0.15s ease;
            margin-bottom: 2px;
        }

        .toc-link:hover, .toc-link.active {
            background: #eef2ff;
            color: #4338ca;
        }

        .toc-link i { font-size: 0.75rem; width: 18px; text-align: center; color: #adb5bd; }
        .toc-link:hover i, .toc-link.active i { color: #4338ca; }

        /* ── Sections ── */
        .guide-section {
            background: white;
            border-radius: 10px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.08);
            border: 1px solid #e9ecef;
            padding: 2rem;
            margin-bottom: 1.5rem;
        }

        .guide-section h2 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 1.25rem;
            padding-bottom: 0.75rem;
            border-bottom: 2px solid #e9ecef;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .guide-section h2 .section-icon {
            width: 38px;
            height: 38px;
            background: #4338ca;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .guide-section h3 {
            font-size: 1.15rem;
            font-weight: 700;
            color: #334155;
            margin-top: 1.75rem;
            margin-bottom: 0.75rem;
        }

        .guide-section h4 {
            font-size: 1rem;
            font-weight: 600;
            color: #475569;
            margin-top: 1.25rem;
            margin-bottom: 0.5rem;
        }

        .guide-section p, .guide-section li {
            color: #475569;
            font-size: 0.925rem;
            line-height: 1.7;
        }

        .guide-section ol, .guide-section ul { padding-left: 1.25rem; }
        .guide-section ol li, .guide-section ul li { margin-bottom: 0.4rem; }

        /* ── Tables ── */
        .guide-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid #e9ecef;
            margin: 1rem 0;
            font-size: 0.875rem;
        }

        .guide-table thead th {
            background: #f1f5f9;
            color: #475569;
            font-weight: 600;
            padding: 0.7rem 1rem;
            border-bottom: 2px solid #e2e8f0;
            text-align: left;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .guide-table tbody td {
            padding: 0.6rem 1rem;
            border-bottom: 1px solid #f1f3f5;
            color: #475569;
            vertical-align: top;
        }

        .guide-table tbody tr:last-child td { border-bottom: none; }
        .guide-table tbody tr:hover { background: #f8fafc; }

        /* ── Code Blocks ── */
        .code-block {
            background: #1e293b;
            color: #e2e8f0;
            border-radius: 8px;
            padding: 1rem 1.25rem;
            margin: 0.75rem 0;
            font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace;
            font-size: 0.825rem;
            line-height: 1.6;
            overflow-x: auto;
            border: 1px solid #334155;
        }

        .code-block .kw { color: #c084fc; }
        .code-block .str { color: #86efac; }
        .code-block .num { color: #fbbf24; }
        .code-block .cm { color: #64748b; font-style: italic; }
        .code-block .fn { color: #67e8f9; }
        .code-block .type { color: #93c5fd; }

        .code-inline {
            background: #f1f5f9;
            color: #6366f1;
            padding: 0.15rem 0.45rem;
            border-radius: 4px;
            font-family: 'Cascadia Code', 'Consolas', monospace;
            font-size: 0.85em;
            font-weight: 500;
        }

        /* ── Callout Boxes ── */
        .dev-note {
            background: #eef2ff;
            border-left: 4px solid #6366f1;
            border-radius: 0 8px 8px 0;
            padding: 1rem 1.25rem;
            margin: 1rem 0;
            font-size: 0.9rem;
            color: #4338ca;
        }

        .dev-note i { margin-right: 0.5rem; }

        .dev-warning {
            background: #fef3c7;
            border-left: 4px solid #f59e0b;
            border-radius: 0 8px 8px 0;
            padding: 1rem 1.25rem;
            margin: 1rem 0;
            font-size: 0.9rem;
            color: #92400e;
        }

        .dev-warning i { margin-right: 0.5rem; }

        .dev-danger {
            background: #fee2e2;
            border-left: 4px solid #ef4444;
            border-radius: 0 8px 8px 0;
            padding: 1rem 1.25rem;
            margin: 1rem 0;
            font-size: 0.9rem;
            color: #991b1b;
        }

        .dev-danger i { margin-right: 0.5rem; }

        /* ── File Path Tags ── */
        .file-path {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            background: #f1f5f9;
            color: #64748b;
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            font-family: 'Consolas', monospace;
            font-size: 0.8rem;
            font-weight: 500;
            margin: 0.15rem 0;
        }

        .file-path i { font-size: 0.7rem; color: #94a3b8; }

        /* ── Permission Grid ── */
        .perm-category {
            background: #f8fafc;
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 0.75rem;
            border: 1px solid #e2e8f0;
        }

        .perm-category h5 {
            font-size: 0.85rem;
            font-weight: 700;
            color: #334155;
            margin-bottom: 0.5rem;
        }

        .perm-list {
            display: flex;
            flex-wrap: wrap;
            gap: 0.35rem;
        }

        .perm-tag {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 4px;
            padding: 0.2rem 0.55rem;
            font-size: 0.775rem;
            color: #475569;
            font-family: 'Consolas', monospace;
        }

        /* ── Workflow Diagram ── */
        .workflow-flow {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin: 1.25rem 0;
        }

        .wf-step {
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            padding: 0.5rem 0.85rem;
            font-size: 0.825rem;
            font-weight: 600;
            color: #475569;
            text-align: center;
            background: white;
        }

        .wf-step.draft { border-color: #94a3b8; color: #64748b; }
        .wf-step.submitted { border-color: #22c55e; color: #16a34a; background: #f0fdf4; }
        .wf-step.review { border-color: #3b82f6; color: #2563eb; background: #eff6ff; }
        .wf-step.revision { border-color: #f59e0b; color: #d97706; background: #fffbeb; }
        .wf-step.validated { border-color: #10b981; color: #059669; background: #ecfdf5; }

        .wf-arrow { color: #cbd5e1; font-size: 1.1rem; }

        /* ── Route Table ── */
        .route-method {
            display: inline-block;
            padding: 0.1rem 0.4rem;
            border-radius: 3px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            font-family: 'Consolas', monospace;
        }

        .route-get { background: #dbeafe; color: #1d4ed8; }
        .route-post { background: #dcfce7; color: #16a34a; }

        /* ── Print ── */
        .btn-print-guide {
            background: white;
            border: 1px solid rgba(255,255,255,0.3);
            color: rgba(255,255,255,0.9);
            border-radius: 6px;
            font-weight: 500;
            padding: 0.45rem 1rem;
            font-size: 0.875rem;
            transition: all 0.2s ease;
        }

        .btn-print-guide:hover { background: rgba(255,255,255,0.15); color: white; }

        @@media (max-width: 991.98px) {
            .toc-sidebar { position: static; max-height: none; margin-bottom: 1.5rem; }
        }

        @@media print {
            .dev-hero { padding: 1.5rem 0; }
            .toc-sidebar { display: none; }
            .guide-section { box-shadow: none; border: 1px solid #ccc; page-break-inside: avoid; }
            .btn-print-guide { display: none; }
            .code-block { background: #f8f9fa; color: #1e293b; border: 1px solid #ccc; }
        }
    </style>
}

<!-- Hero -->
