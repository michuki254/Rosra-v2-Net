                <h3>RolePermission (Junction Table)</h3>
                <div class="code-block">
<span class="kw">public class</span> <span class="type">RolePermission</span>
{
    <span class="kw">int</span> Id
    <span class="kw">string</span> RoleId         <span class="cm">// FK &rarr; IdentityRole</span>
