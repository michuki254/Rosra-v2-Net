                <h4>Expected CSV Format (16 Columns)</h4>
                <table class="guide-table">
                    <thead><tr><th>#</th><th>Column</th><th>Type</th><th>Required</th></tr></thead>
                    <tbody>
                        <tr><td>1</td><td>Country</td><td>string</td><td>Yes</td></tr>
                        <tr><td>2</td><td>CurrencyCode</td><td>string</td><td>Yes</td></tr>
                        <tr><td>3</td><td>CurrencySymbol</td><td>string</td><td>Yes</td></tr>
                        <tr><td>4</td><td>SNG_total_revenue_pct_gdp</td><td>decimal</td><td>No</td></tr>
                        <tr><td>5</td><td>OSR_pct_gdp</td><td>decimal</td><td>No</td></tr>
                        <tr><td>6</td><td>GDP_nominal_usd</td><td>decimal</td><td>No</td></tr>
                        <tr><td>7</td><td>Population_total</td><td>long</td><td>No</td></tr>
                        <tr><td>8</td><td>Government_Type</td><td>string</td><td>No</td></tr>
                        <tr><td>9</td><td>Income_Level</td><td>string</td><td>No</td></tr>
                        <tr><td>10-16</td><td>Additional indicators</td><td>decimal</td><td>No</td></tr>
                    </tbody>
                </table>

                <div class="dev-note">
                    <i class="bi bi-info-circle"></i>
                    <strong>Import behavior:</strong> Existing records matching by country name are updated; new records are inserted. The header row is skipped automatically.
                </div>
