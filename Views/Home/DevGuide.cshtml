                <h3>AuditLog</h3>
                <div class="code-block">
<span class="kw">public class</span> <span class="type">AuditLog</span>
{
    <span class="kw">int</span> Id
    <span class="kw">string?</span> UserId, UserEmail
    <span class="kw">string</span> Action          <span class="cm">// "RoleAssigned", "UserDeactivated", etc.</span>
    <span class="kw">string</span> EntityType       <span class="cm">// "User", "RosraReport", "Role"</span>
    <span class="kw">string?</span> EntityId
    <span class="type">DateTime</span> Timestamp
    <span class="kw">string?</span> Details         <span class="cm">// Free text or JSON</span>
    <span class="kw">string?</span> IpAddress
    <span class="kw">string?</span> StatusFrom, StatusTo
    <span class="kw">string?</span> Reason          <span class="cm">// Max 500 chars</span>
}
