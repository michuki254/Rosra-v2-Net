                <h3>ReviewNote</h3>
                <div class="code-block">
<span class="kw">public class</span> <span class="type">ReviewNote</span>
{
    <span class="kw">int</span> Id, ReportId
    <span class="kw">string</span> AuthorUserId
    <span class="kw">string</span> Content          <span class="cm">// Max 2000 chars</span>
    <span class="kw">int</span> NoteType             <span class="cm">// 0=General, 1=CorrectionRequest, 2=ValidationComment, 3=RevisionReason</span>
    <span class="kw">string?</span> StreamReference  <span class="cm">// e.g., "PropertyTax"</span>
