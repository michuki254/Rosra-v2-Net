    <div class="container">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h1><i class="bi bi-terminal me-2"></i> Developer Administration Guide</h1>
                <p class="lead">Technical reference for admin features, authorization, services, and the review workflow</p>
            </div>
            <div class="d-flex gap-2 align-items-center">
                <span class="badge-dev">ROSRA V2</span>
                <button class="btn-print-guide" onclick="window.print()">
                    <i class="bi bi-printer me-1"></i> Print
                </button>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="row">

