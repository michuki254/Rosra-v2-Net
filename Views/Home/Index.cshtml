            </div>
            <div class="hero-slide">
                <img src="~/images/cities/addis-ababa.jpg" asp-append-version="true" alt="Addis Ababa, Ethiopia" />
            </div>
            <div class="hero-slide">
                <img src="~/images/cities/lagos.jpg" asp-append-version="true" alt="Lagos, Nigeria" />
            </div>
            <div class="hero-slide">
                <img src="~/images/cities/dar-es-salaam.jpg" asp-append-version="true" alt="Dar es Salaam, Tanzania" />
            </div>
