                    <img src="~/images/cities/addis-ababa.jpg" asp-append-version="true" alt="Reform Prioritization" />
                </div>
                <div class="uh-info-card__body">
                    <h4>Reform Prioritization</h4>
                    <p>Prioritize interventions and allocate resources effectively.</p>
                </div>
            </div>
            <div class="uh-info-card">
                <div class="uh-info-card__img">
                    <img src="~/images/cities/dar-es-salaam.jpg" asp-append-version="true" alt="Enhanced Creditworthiness" />
                </div>
                <div class="uh-info-card__body">
                    <h4>Enhanced Creditworthiness</h4>
