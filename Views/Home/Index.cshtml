                <span class="city-country">Tanzania</span>
            </div>
        </div>
    </div>
</section>

<!-- SDG Banner -->
<section class="sdg-banner">
    <div class="container">
        <div class="sdg-banner-content">
            <div class="sdg-banner-text">
                <h3>Aligned with UN Sustainable Development Goals</h3>
                <p>ROSRA contributes to building sustainable, inclusive, and resilient cities through improved local governance and municipal finance.</p>
            </div>
            <div class="sdg-banner-icons">
                <a href="https://sdgs.un.org/goals/goal11" target="_blank" title="SDG 11: Sustainable Cities">
                    <img src="~/images/sdg/sdg-11.svg" alt="SDG 11" />
                </a>
                <a href="https://sdgs.un.org/goals/goal16" target="_blank" title="SDG 16: Peace, Justice and Strong Institutions">
                    <img src="~/images/sdg/sdg-16.svg" alt="SDG 16" />
                </a>
                <a href="https://sdgs.un.org/goals/goal17" target="_blank" title="SDG 17: Partnerships for the Goals">
                    <img src="~/images/sdg/sdg-17.svg" alt="SDG 17" />
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Who is ROSRA For Section - Full Width Light -->
<section id="who-is-rosra-for" class="full-width-section section-light">
    <div class="container">
        <div class="section-header text-center">
            <span class="section-badge">Target Users</span>
            <h2 class="section-title">Who is the ROSRA for?</h2>
            <div class="section-divider"></div>
        </div>

        <div class="target-intro text-center mt-4">
            <p class="lead-text">The ROSRA was designed primarily for government officials in local governments in <span class="text-highlight">low-income</span> and <span class="text-highlight">fragile state</span> contexts.</p>
            <p class="sub-text">It can also be used by non-governmental partners with access to revenue related data of local governments.</p>
        </div>

        <div class="target-cards-row mt-5">
            <div class="target-card">
                <div class="target-card-icon">
                    <i class="fas fa-city"></i>
                </div>
                <h4>Secondary Cities</h4>
                <p>Better suited for secondary cities rather than very large urban metropoles</p>
            </div>
            <div class="target-card">
                <div class="target-card-icon">
                    <i class="fas fa-users-cog"></i>
                </div>
                <h4>Senior Management</h4>
                <p>Functions best when supported by senior management with technical staff input</p>
            </div>
            <div class="target-card">
                <div class="target-card-icon">
                    <i class="fas fa-landmark"></i>
                </div>
                <h4>Land-Based Finance</h4>
                <p>Particularly helpful where land-based finance systems are present at the local level</p>
            </div>
        </div>
    </div>
</section>

<!-- How It Works Section - Full Width Accent Background -->
<section id="how-it-works" class="full-width-section section-accent">
    <div class="container">
        <div class="section-header text-center">
            <span class="section-badge badge-dark">Process</span>
            <h2 class="section-title">How does the ROSRA work?</h2>
            <div class="section-divider"></div>
        </div>

        <div class="row mt-5 align-items-stretch">
            <div class="col-lg-8">
                <div class="process-card">
                    <h3 class="process-card-title">
                        <i class="fas fa-cogs me-2"></i>Analysis Process
                    </h3>
                    <p class="process-intro">The ROSRA analyses user data by comparing it with accepted benchmarks and the specific characteristics of well-functioning OSR systems observed in peer local governments.</p>

                    <div class="process-steps">
                        <div class="process-step">
                            <div class="step-number">1</div>
                            <div class="step-content">
                                <h4>Authority & Incentives</h4>
                                <p>The authority and incentives of local government to raise OSR</p>
                            </div>
                        </div>
                        <div class="process-step">
                            <div class="step-number">2</div>
                            <div class="step-content">
                                <h4>Capacity Assessment</h4>
                                <p>The capacity and incentives of the revenue administration</p>
                            </div>
                        </div>
                        <div class="process-step">
                            <div class="step-number">3</div>
                            <div class="step-content">
                                <h4>Strategy & Management</h4>
                                <p>The strategy, management and collection processes</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="stats-sidebar">
                    <div class="stat-box">
                        <div class="stat-icon">
                            <i class="far fa-clock"></i>
                        </div>
                        <div class="stat-info">
                            <span class="stat-label">Completion Time</span>
                            <span class="stat-value">~1 Hour</span>
                        </div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-icon">
                            <i class="fas fa-robot"></i>
                        </div>
                        <div class="stat-info">
                            <span class="stat-label">Analysis Type</span>
                            <span class="stat-value">Automated</span>
                        </div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-icon">
                            <i class="fas fa-file-pdf"></i>
                        </div>
                        <div class="stat-info">
                            <span class="stat-label">Output</span>
                            <span class="stat-value">Detailed Report</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Data Requirements Section - Full Width Split Design -->
<section id="data-requirements" class="full-width-section section-split">
    <div class="split-left">
        <div class="split-content">
            <div class="split-header">
                <i class="fas fa-database"></i>
                <h3>Required Input Data</h3>
            </div>
            <div class="data-list">
                <div class="data-item">
                    <div class="data-icon"><i class="fas fa-chart-bar"></i></div>
                    <div class="data-content">
                        <h4>Socio-economic data</h4>
                        <p>GDP, population statistics</p>
                    </div>
                </div>
                <div class="data-item">
                    <div class="data-icon"><i class="fas fa-coins"></i></div>
                    <div class="data-content">
                        <h4>Budget data</h4>
                        <p>Revenue and OSR data from past financial year</p>
                    </div>
                </div>
                <div class="data-item">
                    <div class="data-icon"><i class="fas fa-tasks"></i></div>
                    <div class="data-content">
                        <h4>Management data</h4>
                        <p>OSR environment, management and administration details</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="split-right">
        <div class="split-content">
            <div class="split-header">
                <i class="fas fa-shield-alt"></i>
                <h3>Data Privacy</h3>
            </div>
            <div class="privacy-highlight">
                <i class="fas fa-lock"></i>
                <p>Only visible to the local government itself</p>
            </div>
            <div class="privacy-features">
                <div class="privacy-item">
                    <i class="fas fa-check-circle"></i>
                    <p>UN-Habitat will only use data after gaining explicit formal permission</p>
                </div>
                <div class="privacy-item">
                    <i class="fas fa-check-circle"></i>
                    <p>All data input into the ROSRA is <strong>completely confidential</strong></p>
                </div>
            </div>
        </div>
    </div>
</section>

