@{
    ViewData["Title"] = "Home";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<!-- Hero Section - UN-Habitat Style Slider -->
<div class="hero-container">
    <section id="hero" class="hero-section">
        <div class="hero-slides">
            <div class="hero-slide active">
                <img src="~/images/cities/nairobi.jpg" asp-append-version="true" alt="Nairobi, Kenya" />
            </div>
            <div class="hero-slide">
                <img src="~/images/cities/addis-ababa.jpg" asp-append-version="true" alt="Addis Ababa, Ethiopia" />
            </div>
            <div class="hero-slide">
                <img src="~/images/cities/lagos.jpg" asp-append-version="true" alt="Lagos, Nigeria" />
            </div>
            <div class="hero-slide">
                <img src="~/images/cities/dar-es-salaam.jpg" asp-append-version="true" alt="Dar es Salaam, Tanzania" />
            </div>
        </div>
        <div class="hero-gradient"></div>
        <div class="hero-content">
            <h1 class="hero-title">
                @Localizer["Hero_Title"]
            </h1>
            <a href="#what-is-rosra" class="btn-hero-learn-more">@Localizer["Hero_LearnMore"]</a>
        </div>
        <div class="hero-indicators">
            <span class="indicator active" data-slide="0"></span>
            <span class="indicator" data-slide="1"></span>
            <span class="indicator" data-slide="2"></span>
            <span class="indicator" data-slide="3"></span>
        </div>
    </section>
</div>

<!-- Featured Highlights Row (UN-Habitat style) -->
<section class="uh-featured-row">
    <div class="container">
        <div class="featured-cards">
            <div class="featured-card featured-card--primary">
