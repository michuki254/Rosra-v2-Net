<!-- CTA Section - Full Width Bold -->
<section id="get-started" class="full-width-section section-cta">
    <div class="cta-pattern"></div>
    <div class="container position-relative">
        <div class="cta-content text-center">
            <h2>Ready to Optimize Your Revenue Systems?</h2>
            <p>Start analyzing your revenue gaps and unlock your municipality's financial potential for sustainable urban development.</p>
            <div class="cta-buttons">
                <a asp-controller="Account" asp-action="Register" class="btn-cta-primary">
                    <i class="fas fa-user-plus me-2"></i>Get Started Today
                </a>
                <a asp-controller="Rosra" asp-action="NewReport" class="btn-cta-secondary">
                    <i class="fas fa-rocket me-2"></i>Create Report
                </a>
            </div>
            <div class="cta-sdg">
                <a href="https://sdgs.un.org/goals/goal11" target="_blank">
                    <img src="~/images/sdg/sdg-11.svg" alt="SDG 11 - Sustainable Cities" />
                </a>
                <a href="https://sdgs.un.org/goals/goal16" target="_blank">
                    <img src="~/images/sdg/sdg-16.svg" alt="SDG 16 - Peace and Justice" />
                </a>
                <a href="https://sdgs.un.org/goals/goal17" target="_blank">
                    <img src="~/images/sdg/sdg-17.svg" alt="SDG 17 - Partnerships" />
                </a>
            </div>
        </div>
    </div>
</section>

