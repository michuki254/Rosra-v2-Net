                <p>@Localizer["Featured_RosraTool_Desc"]</p>
                <a asp-controller="Rosra" asp-action="NewReport" class="uh-btn uh-btn--dark">@Localizer["Featured_StartAnalysis"]</a>
            </div>
            <div class="featured-card featured-card--accent">
                <h4>@Localizer["Featured_WhatIsRosra"]</h4>
                <p>@Localizer["Featured_WhatIsRosra_Desc"]</p>
                <a href="#what-is-rosra" class="uh-btn uh-btn--outline-light">@Localizer["Featured_LearnMore"]</a>
            </div>
            <div class="featured-card featured-card--white">
