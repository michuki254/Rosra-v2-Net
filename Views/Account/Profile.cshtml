@model RosraApp.Models.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = SharedLocalizer["Profile_Title"].Value;
    var initials = "";
    if (!string.IsNullOrEmpty(Model.FirstName)) initials += Model.FirstName[0];
    if (!string.IsNullOrEmpty(Model.LastName)) initials += Model.LastName[0];
    if (string.IsNullOrEmpty(initials) && !string.IsNullOrEmpty(Model.Email)) initials = Model.Email[0].ToString().ToUpper();
}

@section Styles {
    <style>
        body { background: #FFFFFF; }

        /* ── Header ── */
        .profile-header {
            background: white; border-radius: 12px; padding: 1.75rem 2rem;
            margin-bottom: 1.75rem; box-shadow: 0 2px 20px -4px rgba(0,0,0,0.1);
        }
        .header-icon {
            width: 40px; height: 40px; border-radius: 10px; background: #8B5CF6;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; color: white; box-shadow: 0 6px 12px -2px rgba(139,92,246,0.25); flex-shrink: 0;
        }
        .profile-header h1 { color: #222222; font-weight: 700; font-size: 1.75rem; margin-bottom: 0.25rem; }
        .profile-header p { color: #6A6A6A; font-size: 0.9375rem; margin: 0; }
        .btn-back {
            background: white; border: none; color: #222222; border-radius: 10px;
            font-weight: 500; padding: 0.5rem 1rem; font-size: 0.875rem;
            box-shadow: 0 1px 6px -1px rgba(0,0,0,0.08); transition: all 0.2s;
        }
        .btn-back:hover { color: #3B82F6; box-shadow: 0 4px 16px -4px rgba(0,0,0,0.15); }

        .alert-biz {
            border: none; border-radius: 10px; padding: 0.875rem 1.25rem;
            margin-bottom: 1.25rem; font-size: 0.875rem; font-weight: 500;
            background: #D1FAE5; color: #065F46;
        }

        .profile-card {
            background: white; border-radius: 12px; padding: 2rem;
            box-shadow: 0 2px 20px -4px rgba(0,0,0,0.1); text-align: center; margin-bottom: 1.25rem;
        }
        .avatar-lg {
            width: 88px; height: 88px; border-radius: 22px; background: #8B5CF6;
            display: inline-flex; align-items: center; justify-content: center;
            font-size: 2rem; font-weight: 700; color: white; margin-bottom: 1rem;
            box-shadow: 0 8px 16px -4px rgba(139,92,246,0.25);
        }
        .profile-name { font-size: 1.375rem; font-weight: 700; color: #222222; margin-bottom: 0.125rem; }
        .profile-email { font-size: 0.875rem; color: #6A6A6A; margin-bottom: 0.75rem; }

        .badge-row { display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap; }
        .status-pill {
            display: inline-flex; align-items: center; gap: 0.375rem;
            padding: 0.3rem 0.75rem; border-radius: 20px; font-size: 0.8125rem; font-weight: 600;
        }
        .status-pill i { font-size: 0.5rem; }
        .pill-verified { background: #D1FAE5; color: #065F46; }
        .pill-unverified { background: #FEE2E2; color: #991B1B; }
        .pill-role { background: #EDE9FE; color: #7C3AED; }

        .stat-chips { display: flex; gap: 0.75rem; justify-content: center; margin-top: 1.25rem; }
        .stat-chip {
            background: #FAFAFA; border-radius: 10px; padding: 0.75rem 1rem;
            display: flex; align-items: center; gap: 0.5rem; flex: 1;
        }
        .stat-chip-icon {
            width: 32px; height: 32px; border-radius: 8px;
            display: flex; align-items: center; justify-content: center; font-size: 0.875rem; color: white; flex-shrink: 0;
        }
        .stat-chip-value { font-size: 1rem; font-weight: 700; color: #222222; line-height: 1; }
        .stat-chip-label { font-size: 0.6875rem; color: #6A6A6A; font-weight: 500; }

        .section-card {
            background: white; border-radius: 12px; padding: 1.5rem;
            box-shadow: 0 2px 20px -4px rgba(0,0,0,0.1); margin-bottom: 1.25rem;
        }
        .section-header { display: flex; align-items: center; gap: 0.625rem; margin-bottom: 1.25rem; }
        .section-icon {
            width: 32px; height: 32px; border-radius: 8px;
            display: flex; align-items: center; justify-content: center; color: white; font-size: 0.875rem;
        }
        .section-header h5 { color: #222222; font-weight: 600; margin: 0; font-size: 1rem; }

        .form-label-biz { font-weight: 600; color: #222222; margin-bottom: 0.375rem; font-size: 0.875rem; }
        .input-biz {
            background: #F7F7F7; border: 1px solid #DDDDDD; border-radius: 8px;
            padding: 0.625rem 1rem; font-size: 0.9375rem; transition: all 0.2s;
        }
        .input-biz:focus { background: white; border-color: #3B82F6; box-shadow: 0 0 0 3px rgba(59,130,246,0.1); }
        .input-biz:read-only { background: #F7F7F7; color: #6A6A6A; cursor: default; }

        .btn-save {
            background: #3B82F6; color: white; border: none; border-radius: 10px;
            padding: 0.625rem 1.75rem; font-weight: 600; font-size: 0.9375rem;
            box-shadow: 0 4px 12px -2px rgba(59,130,246,0.25); transition: all 0.2s;
        }
        .btn-save:hover { background: #2563EB; color: white; transform: translateY(-1px); }

        .btn-change-pw {
            background: #F59E0B; color: white; border: none; border-radius: 10px;
            padding: 0.625rem 1.25rem; font-weight: 600; font-size: 0.875rem;
            box-shadow: 0 4px 12px -2px rgba(245,158,11,0.25); transition: all 0.2s; width: 100%;
        }
        .btn-change-pw:hover { background: #D97706; color: white; }

        .meta-row {
            display: flex; justify-content: space-between; align-items: center;
            padding: 0.625rem 0; border-bottom: 1px solid #F7F7F7;
        }
        .meta-row:last-child { border-bottom: none; }
        .meta-label { font-size: 0.8125rem; color: #6A6A6A; font-weight: 500; }
        .meta-value { font-size: 0.875rem; color: #222222; font-weight: 600; }

        .modal-content { border: none !important; border-radius: 12px !important; box-shadow: 0 20px 60px -12px rgba(0,0,0,0.25) !important; overflow: hidden; }
    </style>
}

<div class="container pt-4 pb-5 mb-5" style="max-width: 900px;">
    <!-- Header -->
    <div class="profile-header d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-3">
            <div class="header-icon"><i class="bi bi-person-gear"></i></div>
            <div>
                <h1>@SharedLocalizer["Profile_Title"]</h1>
                <p>@SharedLocalizer["Profile_Subtitle"]</p>
            </div>
        </div>
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-back">
            <i class="bi bi-arrow-left me-1"></i> @SharedLocalizer["Profile_Dashboard"]
        </a>
    </div>

    @if (TempData["ProfileSuccess"] != null)
    {
        <div class="alert-biz"><i class="bi bi-check-circle-fill me-2"></i>@TempData["ProfileSuccess"]</div>
    }

    <div class="row g-4">
        <!-- Left Column -->
        <div class="col-md-4">
            <div class="profile-card">
                <div class="avatar-lg">@initials</div>
                <div class="profile-name">@Model.FirstName @Model.LastName</div>
                <div class="profile-email">@Model.Email</div>

                <div class="badge-row">
                    @if (Model.EmailConfirmed)
                    {
                        <span class="status-pill pill-verified"><i class="bi bi-patch-check-fill"></i> @SharedLocalizer["Profile_Verified"]</span>
                    }
                    else
                    {
                        <span class="status-pill pill-unverified"><i class="bi bi-exclamation-circle-fill"></i> @SharedLocalizer["Profile_Unverified"]</span>
                    }
                    @foreach (var role in Model.Roles)
                    {
                        <span class="status-pill pill-role"><i class="bi bi-shield-fill"></i> @role</span>
                    }
                </div>

                <div class="stat-chips">
                    <div class="stat-chip">
                        <div class="stat-chip-icon" style="background:#F59E0B; box-shadow:0 4px 8px -2px rgba(245,158,11,0.25);"><i class="bi bi-file-text-fill"></i></div>
                        <div><div class="stat-chip-value">@Model.ReportCount</div><div class="stat-chip-label">@SharedLocalizer["Profile_Reports"]</div></div>
                    </div>
                    <div class="stat-chip">
                        <div class="stat-chip-icon" style="background:#10B981; box-shadow:0 4px 8px -2px rgba(16,185,129,0.25);"><i class="bi bi-calendar-check"></i></div>
                        <div>
                            <div class="stat-chip-value" style="font-size:0.8125rem;">@(Model.CreatedAt?.ToString("MMM yyyy") ?? "-")</div>
                            <div class="stat-chip-label">@SharedLocalizer["Profile_Joined"]</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Account Details -->
            <div class="section-card">
                <div class="section-header">
                    <div class="section-icon" style="background:#06B6D4;"><i class="bi bi-info-circle-fill"></i></div>
                    <h5>@SharedLocalizer["Profile_Account"]</h5>
                </div>
                <div class="meta-row">
                    <span class="meta-label">@SharedLocalizer["Profile_Email"]</span>
                    <span class="meta-value" style="font-size:0.8125rem;">@Model.Email</span>
                </div>
                <div class="meta-row">
                    <span class="meta-label">@SharedLocalizer["Profile_Phone"]</span>
                    <span class="meta-value">@(Model.PhoneNumber ?? "-")</span>
                </div>
                <div class="meta-row">
                    <span class="meta-label">@SharedLocalizer["Profile_Organization"]</span>
                    <span class="meta-value">@(Model.Organization ?? "-")</span>
                </div>
                <div class="meta-row">
                    <span class="meta-label">@SharedLocalizer["Profile_Joined"]</span>
                    <span class="meta-value">@(Model.CreatedAt?.ToString("dd MMM yyyy") ?? "-")</span>
                </div>
            </div>

            <!-- Security -->
            <div class="section-card">
                <div class="section-header">
                    <div class="section-icon" style="background:#EF4444;"><i class="bi bi-lock-fill"></i></div>
                    <h5>@SharedLocalizer["Profile_Security"]</h5>
                </div>
                <button class="btn-change-pw" data-bs-toggle="modal" data-bs-target="#changePasswordModal">
                    <i class="bi bi-key me-1"></i> @SharedLocalizer["Profile_ChangePassword"]
                </button>
            </div>
        </div>

        <!-- Right Column: Edit Form -->
        <div class="col-md-8">
            <div class="section-card">
                <div class="section-header">
                    <div class="section-icon" style="background:#3B82F6;"><i class="bi bi-pencil-square"></i></div>
                    <h5>@SharedLocalizer["Profile_EditProfile"]</h5>
                </div>

                <form asp-action="Profile" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label-biz">@SharedLocalizer["Profile_FirstName"]</label>
                            <input asp-for="FirstName" class="form-control input-biz" />
                            <span asp-validation-for="FirstName" class="text-danger" style="font-size:0.8125rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label-biz">@SharedLocalizer["Profile_LastName"]</label>
                            <input asp-for="LastName" class="form-control input-biz" />
                            <span asp-validation-for="LastName" class="text-danger" style="font-size:0.8125rem;"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label-biz">@SharedLocalizer["Profile_Email"]</label>
                        <input asp-for="Email" class="form-control input-biz" readonly />
                        <small style="color:#6A6A6A; font-size:0.75rem;">@SharedLocalizer["Profile_EmailReadonly"]</small>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Organization" class="form-label-biz">@SharedLocalizer["Profile_Organization"]</label>
                        <input asp-for="Organization" class="form-control input-biz" placeholder="@SharedLocalizer["Profile_OrgPlaceholder"].Value" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="PhoneNumber" class="form-label-biz">@SharedLocalizer["Profile_Phone"]</label>
                        <input asp-for="PhoneNumber" class="form-control input-biz" placeholder="+254 700 000 000" />
                        <span asp-validation-for="PhoneNumber" class="text-danger" style="font-size:0.8125rem;"></span>
                    </div>

                    <button type="submit" class="btn-save">
                        <i class="bi bi-check-lg me-1"></i> @SharedLocalizer["Profile_SaveChanges"]
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Change Password Modal -->
<div class="modal fade" id="changePasswordModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background:#222222; color:white; padding:1.25rem 1.5rem;">
                <h5 class="modal-title fw-bold"><i class="bi bi-key me-2"></i>@SharedLocalizer["Profile_ChangePassword"]</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:1.5rem;">
                <div class="mb-3">
                    <label class="form-label-biz">@SharedLocalizer["Profile_CurrentPassword"]</label>
                    <input type="password" id="currentPassword" class="form-control input-biz" />
                </div>
                <div class="mb-3">
                    <label class="form-label-biz">@SharedLocalizer["Profile_NewPassword"]</label>
                    <input type="password" id="newPassword" class="form-control input-biz" />
                </div>
                <div>
                    <label class="form-label-biz">@SharedLocalizer["Profile_ConfirmNewPassword"]</label>
                    <input type="password" id="confirmNewPassword" class="form-control input-biz" />
                </div>
                <div id="pwError" class="mt-2" style="color:#EF4444; font-size:0.8125rem; display:none;"></div>
                <div id="pwSuccess" class="mt-2" style="color:#10B981; font-size:0.8125rem; display:none;"></div>
            </div>
            <div class="modal-footer" style="border:none; background:#F7F7F7; padding:1rem 1.5rem;">
                <button class="btn" style="background:white; color:#222222; border:none; border-radius:8px; box-shadow:0 1px 4px -1px rgba(0,0,0,0.1); font-weight:500;" data-bs-dismiss="modal">@SharedLocalizer["Common_Cancel"]</button>
                <button class="btn" style="background:#F59E0B; color:white; border:none; border-radius:8px; box-shadow:0 4px 12px -2px rgba(245,158,11,0.25); font-weight:600;" id="confirmChangePwBtn">
                    <i class="bi bi-key me-1"></i> @SharedLocalizer["Profile_ChangePassword"]
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    @Html.AntiForgeryToken()

    <script>
        $(document).ready(function() {
            var token = $('input[name="__RequestVerificationToken"]').val();

            $('#confirmChangePwBtn').click(function() {
                var current = $('#currentPassword').val();
                var newPw = $('#newPassword').val();
                var confirm = $('#confirmNewPassword').val();
                $('#pwError').hide();
                $('#pwSuccess').hide();

                if (!current || !newPw || !confirm) {
                    $('#pwError').text('Please fill in all fields.').show();
                    return;
                }
                if (newPw !== confirm) {
                    $('#pwError').text('Passwords do not match.').show();
                    return;
                }
                if (newPw.length < 6) {
                    $('#pwError').text('Password must be at least 6 characters.').show();
                    return;
                }

                var btn = $(this);
                btn.prop('disabled', true).html('<i class="bi bi-hourglass-split me-1"></i> ...');

                $.ajax({
                    url: '@Url.Action("ChangePassword", "Account")',
                    type: 'POST',
                    data: {
                        CurrentPassword: current,
                        NewPassword: newPw,
                        ConfirmNewPassword: confirm,
                        __RequestVerificationToken: token
                    },
                    success: function(r) {
                        btn.prop('disabled', false).html('<i class="bi bi-key me-1"></i> @SharedLocalizer["Profile_ChangePassword"].Value');
                        if (r.success) {
                            $('#pwSuccess').text(r.message).show();
                            $('#currentPassword, #newPassword, #confirmNewPassword').val('');
                            setTimeout(function() {
                                bootstrap.Modal.getInstance(document.getElementById('changePasswordModal')).hide();
                                $('#pwSuccess').hide();
                            }, 1500);
                        } else {
                            $('#pwError').text(r.message).show();
                        }
                    },
                    error: function() {
                        btn.prop('disabled', false).html('<i class="bi bi-key me-1"></i> @SharedLocalizer["Profile_ChangePassword"].Value');
                        $('#pwError').text('An error occurred.').show();
                    }
                });
            });
        });
    </script>
}
