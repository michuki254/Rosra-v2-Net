@model RosraApp.Models.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = Localizer["PageTitle"].Value;
}

@section Styles {
    <style>
        /* UN Habitat & SDG11 Color Palette */
        :root {
            --un-cyan: #00A9E0;
            --un-navy: #1B3A5C;
            --un-green: #7CB342;
            --sdg-yellow: #00b2e3;
            --un-light-gray: #F5F5F5;
            --un-medium-gray: #757575;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow-x: hidden;
            margin-bottom: 0 !important;
        }

        .footer {
            position: relative !important;
        }

        /* Navigation adjustments */
        .top-navbar {
            position: relative;
            z-index: 1000;
        }

        .main-navbar {
            position: relative;
            z-index: 1000;
        }

        .split-container {
            display: flex;
            min-height: calc(100vh - 300px);
            height: auto;
            margin: -1.5rem -12px 0 -12px;
            width: calc(100% + 24px);
        }

        /* Left Side - Register Form */
        .register-side {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            padding: 1rem 1.5rem;
            overflow-y: auto;
        }

        .register-content {
            width: 100%;
            max-width: 520px;
        }

        .logo-section {
            text-align: left;
            margin-bottom: 0.75rem;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            background: var(--sdg-yellow);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 0.5rem;
            box-shadow: 0 4px 12px rgba(0, 178, 227, 0.3);
        }

        .logo-icon svg {
            width: 24px;
            height: 24px;
            fill: white;
        }

        .register-content h1 {
            color: var(--un-navy);
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 0.15rem;
        }

        .register-content p {
            color: var(--un-medium-gray);
            font-size: 0.85rem;
            margin-bottom: 0.75rem;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
            margin-bottom: 0.75rem;
        }

        .form-group {
            margin-bottom: 0.75rem;
        }

        .form-label {
            display: block;
            color: var(--un-navy);
            font-size: 0.75rem;
            font-weight: 600;
            margin-bottom: 0.3rem;
            letter-spacing: 0.2px;
        }

        .form-control {
            width: 100%;
            border: 1.5px solid #E0E0E0;
            border-radius: 8px;
            padding: 0.5rem 0.75rem;
            font-size: 0.85rem;
            transition: all 0.2s ease;
            background: #FAFAFA;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--sdg-yellow);
            background: white;
            box-shadow: 0 0 0 3px rgba(0, 178, 227, 0.15);
        }

        .form-control::placeholder {
            color: #B0B0B0;
        }

        .btn-register {
            width: 100%;
            background: var(--sdg-yellow);
            border: none;
            color: white;
            padding: 0.6rem 1.5rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.2s ease;
            cursor: pointer;
            margin-top: 0.25rem;
            margin-bottom: 0.5rem;
            box-shadow: 0 4px 12px rgba(0, 178, 227, 0.2);
        }

        .btn-register:hover {
            background: #0095c0;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(0, 178, 227, 0.4);
        }

        .login-row {
            text-align: center;
            color: var(--un-medium-gray);
            font-size: 0.875rem;
        }

        .login-link {
            color: var(--sdg-yellow);
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s ease;
        }

        .login-link:hover {
            color: var(--un-navy);
        }

        /* Right Side - Visual Content */
        .visual-side {
            flex: 1;
            background: #FAFAFA;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem;
            position: relative;
            overflow: hidden;
            border-left: 1px solid #E0E0E0;
        }

        .visual-content {
            position: relative;
            z-index: 2;
            text-align: center;
            max-width: 600px;
        }

        .visual-content h2 {
            color: var(--un-navy);
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 1rem;
            line-height: 1.2;
        }

        .visual-content h2 span {
            color: var(--sdg-yellow);
        }

        .visual-content p {
            color: var(--un-medium-gray);
            font-size: 1.125rem;
            margin-bottom: 2rem;
        }

        .image-showcase {
            position: relative;
            margin-bottom: 2rem;
            perspective: 1000px;
        }

        .showcase-image {
            width: 100%;
            max-width: 550px;
            border-radius: 20px;
            box-shadow:
                0 10px 40px rgba(0, 0, 0, 0.15),
                0 5px 15px rgba(0, 0, 0, 0.1);
            margin: 0 auto;
            display: block;
            animation: floatIn 1s ease-out;
            border: 1px solid #E0E0E0;
            transition: transform 0.6s ease;
        }

        .showcase-image:hover {
            transform: scale(1.02);
            box-shadow:
                0 15px 50px rgba(0, 0, 0, 0.2),
                0 7px 20px rgba(0, 0, 0, 0.15);
        }

        .carousel-indicators {
            display: flex;
            justify-content: center;
            gap: 0.5rem;
            margin-top: 2.5rem;
        }

        .indicator {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #D0D0D0;
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid transparent;
        }

        .indicator:hover {
            background: #A0A0A0;
        }

        .indicator.active {
            background: var(--sdg-yellow);
            width: 36px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0, 178, 227, 0.4);
        }

        /* Floating cards */
        .floating-card {
            position: absolute;
            background: white;
            border: 1px solid #E0E0E0;
            border-radius: 12px;
            padding: 1rem 1.25rem;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
            animation: floatCard 4s ease-in-out infinite;
            z-index: 3;
        }

        .card-1 {
            top: 15%;
            right: 5%;
            animation-delay: 0s;
        }

        .card-2 {
            bottom: 20%;
            left: 5%;
            animation-delay: 2s;
        }

        .floating-card .icon {
            width: 40px;
            height: 40px;
            background: var(--sdg-yellow);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 0.5rem;
            box-shadow: 0 2px 8px rgba(0, 178, 227, 0.3);
        }

        .floating-card .icon svg {
            width: 20px;
            height: 20px;
            fill: white;
        }

        .floating-card .label {
            color: var(--un-medium-gray);
            font-size: 0.75rem;
            margin-bottom: 0.25rem;
        }

        .floating-card .value {
            color: var(--un-navy);
            font-size: 1.25rem;
            font-weight: 700;
        }

        .text-danger {
            color: #D32F2F;
            font-size: 0.75rem;
            margin-top: 0.25rem;
            display: block;
        }

        .validation-summary-errors {
            background: #FFEBEE;
            border-left: 3px solid #D32F2F;
            border-radius: 8px;
            padding: 0.625rem 0.875rem;
            margin-bottom: 1rem;
        }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 1.25rem;
        }

        .validation-summary-errors li {
            color: #C62828;
            font-size: 0.8125rem;
        }

        @@keyframes floatIn {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes floatCard {
            0%, 100% {
                transform: translateY(0);
            }
            50% {
                transform: translateY(-15px);
            }
        }

        @@media (max-width: 992px) {
            .split-container {
                flex-direction: column;
                min-height: auto;
                height: auto;
            }

            .visual-side {
                display: none;
            }

            .register-side {
                flex: 1;
                min-height: calc(100vh - 120px);
            }

            .form-row {
                grid-template-columns: 1fr;
            }

            .floating-card {
                display: none;
            }
        }
    </style>
}

<div class="split-container">
        <!-- Left Side - Register Form -->
        <div class="register-side">
            <div class="register-content">
                <div class="logo-section">
                    <h1>@Localizer["Heading"]</h1>
                    <p>@Localizer["Subheading"]</p>
                </div>

                <form asp-action="Register" method="post">
                    @if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div asp-validation-summary="All" class="text-danger validation-summary-errors"></div>
                    }

                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="FirstName" class="form-label">@Localizer["FirstNameLabel"]</label>
                            <input asp-for="FirstName" class="form-control" type="text" placeholder="@Localizer["FirstNamePlaceholder"].Value" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="LastName" class="form-label">@Localizer["LastNameLabel"]</label>
                            <input asp-for="LastName" class="form-control" type="text" placeholder="@Localizer["LastNamePlaceholder"].Value" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Email" class="form-label">@Localizer["EmailLabel"]</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="@Localizer["EmailPlaceholder"].Value" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Organization" class="form-label">@Localizer["OrganizationLabel"]</label>
                        <input asp-for="Organization" class="form-control" type="text" placeholder="@Localizer["OrganizationPlaceholder"].Value" />
                        <span asp-validation-for="Organization" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="PhoneNumber" class="form-label">@Localizer["PhoneLabel"]</label>
                        <input asp-for="PhoneNumber" class="form-control" type="tel" placeholder="@Localizer["PhonePlaceholder"].Value" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="Password" class="form-label">@Localizer["PasswordLabel"]</label>
                            <input asp-for="Password" class="form-control" type="password" placeholder="@Localizer["PasswordPlaceholder"].Value" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="ConfirmPassword" class="form-label">@Localizer["ConfirmPasswordLabel"]</label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="@Localizer["ConfirmPasswordPlaceholder"].Value" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <button type="submit" class="btn-register">@Localizer["CreateAccountButton"]</button>

                    <div class="login-row">
                        @Localizer["AlreadyHaveAccount"] <a class="login-link" asp-controller="Account" asp-action="Login">@Localizer["SignIn"]</a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Right Side - Visual Content -->
        <div class="visual-side">
            <!-- Floating Cards -->
            <div class="floating-card card-1">
                <div class="icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                    </svg>
                </div>
                <div class="label">@Localizer["FloatingCard_RevenueGap"]</div>
                <div class="value">KSh 7.2B</div>
            </div>

            <div class="floating-card card-2">
                <div class="icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                    </svg>
                </div>
                <div class="label">@Localizer["FloatingCard_Counties"]</div>
                <div class="value">47</div>
            </div>

            <div class="visual-content">
                <h2>@Localizer["VisualHeading_JoinThe"] <span>@Localizer["VisualHeading_RevenueRevolution"]</span></h2>
                <p>@Localizer["VisualText"]</p>

                <div class="image-showcase">
                    <img src="~/images/Login 1.png" alt="ROSRA Dashboard" class="showcase-image" id="showcaseImage" />
                </div>

                <div class="carousel-indicators">
                    <div class="indicator active" onclick="changeImage(0)"></div>
                    <div class="indicator" onclick="changeImage(1)"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script>
        const images = [
            '/images/Login 1.png',
            '/images/Login 2.png'
        ];
        let currentIndex = 0;

        function changeImage(index) {
            currentIndex = index;
            document.getElementById('showcaseImage').src = images[index];

            const indicators = document.querySelectorAll('.indicator');
            indicators.forEach((ind, i) => {
                if (i === index) {
                    ind.classList.add('active');
                } else {
                    ind.classList.remove('active');
                }
            });
        }

        // Auto-rotate images
        setInterval(() => {
            currentIndex = (currentIndex + 1) % images.length;
            changeImage(currentIndex);
        }, 5000);
    </script>
}
