@model RosraApp.Models.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow border-0 rounded-lg">
                <div class="card-header bg-primary text-white">
                    <h3 class="m-0">Welcome to Your Dashboard</h3>
                </div>
                <div class="card-body">
                    <h4>Hello, @ViewData["UserName"]!</h4>
                    <p class="lead">Welcome to the Rosra Application Dashboard. Here you can manage your account and access all your saved Rosra reports.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow border-0 rounded-lg">
                <div class="card-header bg-light">
                    <h5 class="m-0">User Information</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="fw-bold">Name:</label>
                        <p>@ViewData["UserName"]</p>
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold">Email:</label>
                        <p>@ViewData["Email"]</p>
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold">Organization:</label>
                        <p>@ViewData["Organization"]</p>
                    </div>
                    <div class="mb-3">
                        <label class="fw-bold">Phone Number:</label>
                        <p>@ViewData["PhoneNumber"]</p>
                    </div>
                </div>
                <div class="card-footer">
                    <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-outline-primary">Manage Account</a>
                </div>
            </div>
        </div>

        <div class="col-md-8 mb-4">
            <div class="card h-100 shadow border-0 rounded-lg">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="m-0">Your Rosra Reports</h5>
                    <a asp-controller="Rosra" asp-action="Index" class="btn btn-sm btn-primary">
                        <i class="bi bi-plus-circle"></i> New Report
                    </a>
                </div>
                <div class="card-body">
                    @if (Model.Reports.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th>Project</th>
                                        <th>Budget</th>
                                        <th>Created</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var report in Model.Reports)
                                    {
                                        <tr>
                                            <td>@report.Title</td>
                                            <td>@(report.ProjectName ?? "N/A")</td>
                                            <td>@(report.EstimatedBudget.HasValue ? $"${report.EstimatedBudget:N2}" : "N/A")</td>
                                            <td>@report.CreatedAt.ToString("MMM dd, yyyy")</td>
                                            <td>
                                                <div class="btn-group">
                                                    <a asp-controller="Dashboard" asp-action="ViewReport" asp-route-id="@report.Id" class="btn btn-sm btn-outline-primary">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                    <a asp-controller="Rosra" asp-action="Edit" asp-route-id="@report.Id" class="btn btn-sm btn-outline-warning">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <a href="#" class="btn btn-sm btn-outline-success export-report" data-id="@report.Id">
                                                        <i class="bi bi-download"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-file-earmark-text fs-1 text-muted mb-3"></i>
                            <h5>No Reports Found</h5>
                            <p>You haven't created any Rosra reports yet.</p>
                            <a asp-controller="Rosra" asp-action="Index" class="btn btn-primary mt-2">
                                Create Your First Report
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Export report functionality
            $('.export-report').click(function(e) {
                e.preventDefault();
                var reportId = $(this).data('id');
                
                // In a real application, this would trigger a download
                // For now, we'll just show an alert
                alert('Export functionality will be implemented in a future update.');
            });
        });
    </script>
}
