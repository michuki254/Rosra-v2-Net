@model RosraApp.Models.ViewModels.RosraFormViewModel
@{
    Layout = null;
    ViewData["ViewMode"] = true;
    var cs = Model.CurrencySymbol ?? "$";
}
@functions {
    public string GetCountryCode(string country)
    {
        if (string.IsNullOrEmpty(country)) return "";
        var codes = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            {"Kenya","ke"},{"Nigeria","ng"},{"South Africa","za"},{"Egypt","eg"},{"Ethiopia","et"},
            {"Ghana","gh"},{"Tanzania","tz"},{"Uganda","ug"},{"Rwanda","rw"},{"Morocco","ma"},
            {"Algeria","dz"},{"Senegal","sn"},{"Cameroon","cm"},{"Zambia","zm"},{"Zimbabwe","zw"},
            {"Botswana","bw"},{"Namibia","na"},{"Mozambique","mz"},{"Mali","ml"},{"Burkina Faso","bf"},
            {"Ivory Coast","ci"},{"Cote d'Ivoire","ci"},{"Malawi","mw"},{"Benin","bj"},{"Togo","tg"},
            {"Niger","ne"},{"Sierra Leone","sl"},{"Liberia","lr"},
            {"United Kingdom","gb"},{"UK","gb"},{"Britain","gb"},{"France","fr"},{"Germany","de"},
            {"Italy","it"},{"Spain","es"},{"Netherlands","nl"},{"Belgium","be"},{"Switzerland","ch"},
            {"Sweden","se"},{"Norway","no"},{"Portugal","pt"},{"Poland","pl"},{"Denmark","dk"},
            {"Finland","fi"},{"Austria","at"},{"Ireland","ie"},{"Greece","gr"},{"Czech Republic","cz"},
            {"Romania","ro"},{"Hungary","hu"},
            {"United States","us"},{"United States of America","us"},{"USA","us"},{"Canada","ca"},
            {"Mexico","mx"},{"Brazil","br"},{"Argentina","ar"},{"Chile","cl"},{"Colombia","co"},
            {"Peru","pe"},{"Venezuela","ve"},{"Ecuador","ec"},{"Bolivia","bo"},{"Paraguay","py"},
            {"Uruguay","uy"},{"Costa Rica","cr"},{"Panama","pa"},{"Guatemala","gt"},{"Honduras","hn"},
            {"El Salvador","sv"},{"Nicaragua","ni"},{"Jamaica","jm"},{"Trinidad and Tobago","tt"},
            {"China","cn"},{"India","in"},{"Japan","jp"},{"Singapore","sg"},{"South Korea","kr"},
            {"Korea","kr"},{"Thailand","th"},{"Indonesia","id"},{"Malaysia","my"},{"Philippines","ph"},
            {"Vietnam","vn"},{"Pakistan","pk"},{"Bangladesh","bd"},{"Sri Lanka","lk"},{"Nepal","np"},
            {"Myanmar","mm"},{"Cambodia","kh"},{"Taiwan","tw"},{"Hong Kong","hk"},
            {"UAE","ae"},{"United Arab Emirates","ae"},{"Saudi Arabia","sa"},{"Israel","il"},
            {"Turkey","tr"},{"Iran","ir"},{"Iraq","iq"},{"Jordan","jo"},{"Lebanon","lb"},
            {"Kuwait","kw"},{"Qatar","qa"},{"Oman","om"},{"Bahrain","bh"},
            {"Australia","au"},{"New Zealand","nz"},{"Fiji","fj"},{"Papua New Guinea","pg"},
            {"Russia","ru"},{"Ukraine","ua"},{"Kazakhstan","kz"},{"Uzbekistan","uz"}
        };
        return codes.TryGetValue(country, out var code) ? code : "";
    }
}
@{
    var countryCode = GetCountryCode(Model.Country);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="~/images/LogoFavicon.png" />
    <title>Bottom-Up Gap Analysis — @(Model.Country ?? "ROSRA")</title>
    <link rel="stylesheet" href="~/lib/roboto/roboto.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RosraApp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/flag-icons/css/flag-icons.min.css" asp-append-version="true" />
    <style>
        * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; color-adjust: exact !important; }
        body { font-family: 'Roboto', sans-serif; margin: 0; padding: 0; background: #fff; }

        /* ============================
           COVER PAGE
           ============================ */
        .cover-page {
            width: 100%;
            min-height: 100vh;
            background: #009EDB;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            page-break-after: always;
            box-sizing: border-box;
            border: 8px solid #2c3e50;
        }
        .cover-bg-image {
            position: absolute;
            inset: 0;
            z-index: 0;
        }
        .cover-bg-image img {
            width: 100%; height: 100%;
            object-fit: cover;
            opacity: 0.12;
        }
        .cover-page::before {
            content: '';
            position: absolute;
            inset: 0;
            background: #009EDB;
            opacity: 0.88;
            z-index: 0;
        }

        .cover-top {
            position: relative;
            z-index: 1;
            flex: 1;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            min-height: 420px;
        }
        .cover-circle-main {
            width: 340px; height: 340px;
            border-radius: 50%; overflow: hidden;
            border: 3px dashed rgba(255,255,255,0.25);
            position: absolute; top: 60px; left: 50%; transform: translateX(-50%);
            box-shadow: none; z-index: 1;
        }
        .cover-circle-main img { width: 100%; height: 100%; object-fit: cover; }
        .cover-circle-sm {
            width: 75px; height: 75px;
            border-radius: 8px; overflow: hidden;
            border: 2px solid rgba(255,255,255,0.3);
            position: absolute; z-index: 2;
            box-shadow: none;
        }
        .cover-circle-sm img { width: 100%; height: 100%; object-fit: cover; }
        .cover-circle-sm-1 { top: 50px; left: calc(50% + 170px); }
        .cover-circle-sm-2 { top: 330px; left: calc(50% - 200px); }
        .cover-circle-sm-3 { top: 200px; left: calc(50% + 185px); }
        .cover-orbit {
            position: absolute;
            width: 420px; height: 420px;
            border: 2px dashed rgba(255,255,255,0.12);
            border-radius: 50%;
            top: 20px; left: 50%; transform: translateX(-50%);
            z-index: 0;
        }

        .cover-title-section {
            position: relative;
            z-index: 2;
            padding: 0 50px;
        }
        .cover-title {
            font-size: 44px;
            font-weight: 700;
            color: #ffffff;
            line-height: 1.15;
            margin: 0 0 8px;
            text-shadow: 0 2px 20px rgba(0,0,0,0.3);
        }
        .cover-subtitle {
            font-size: 22px;
            font-weight: 300;
            color: rgba(255,255,255,0.85);
            margin: 0 0 16px;
        }
        .cover-location { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
        .cover-flag {
            font-size: 32px; line-height: 1;
            border-radius: 4px; overflow: hidden;
            box-shadow: none;
        }
        .cover-country-name { font-size: 26px; font-weight: 500; color: #fff; }
        .cover-location-detail {
            font-size: 15px;
            color: rgba(255,255,255,0.75);
            margin-top: 2px;
        }
        .cover-location-detail span + span::before { content: '  |  '; opacity: 0.5; }

        .cover-bottom {
            position: relative;
            z-index: 1;
            height: 220px;
            margin-top: auto;
            overflow: hidden;
        }
        .cover-block { position: absolute; }
        .cover-block-1 { width: 120px; height: 220px; background: #00b2e3; left: 0; bottom: 0; }
        .cover-block-2 { width: 140px; height: 140px; left: 120px; bottom: 80px; overflow: hidden; border-radius: 4px; }
        .cover-block-2 img { width: 100%; height: 100%; object-fit: contain; }
        .cover-block-3 { width: 140px; height: 80px; background: #00689D; left: 120px; bottom: 0; }
        .cover-circle-deco {
            width: 320px; height: 320px;
            border-radius: 50%;
            position: absolute;
            right: -20px; bottom: -60px;
            overflow: hidden;
        }
        .cover-circle-deco-inner { width: 100%; height: 100%; position: relative; }
        .cover-circle-deco-inner::before { content: ''; position: absolute; width: 50%; height: 100%; left: 0; background: #005a87; }
        .cover-circle-deco-inner::after { content: ''; position: absolute; width: 50%; height: 100%; right: 0; background: #00b2e3; }
        .cover-circle-accent {
            width: 260px; height: 260px;
            border: 2px dashed rgba(255,255,255,0.15);
            border-radius: 50%;
            position: absolute;
            right: 80px; bottom: -30px;
        }

        .cover-logo-bottom { position: absolute; bottom: 24px; left: 30px; z-index: 3; }
        .cover-logo-bottom img { height: 60px; filter: brightness(0) invert(1); opacity: 0.9; }
        .cover-logo-norad { position: absolute; bottom: 30px; right: 30px; z-index: 3; }
        .cover-logo-norad img { height: 32px; filter: brightness(0) invert(1); opacity: 0.7; }

        /* ── SDG strip on cover ── */
        .cover-sdg-strip {
            position: absolute;
            bottom: 80px;
            right: 30px;
            z-index: 3;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .cover-sdg-strip img.sdg-goal { height: 50px; border-radius: 3px; }
        .cover-sdg-strip img.sdg-wheel { height: 44px; }

        /* ============================
           REPORT CONTENT (page 2+)
           ============================ */
        .report-box {
            max-width: 960px;
            margin: 0 auto;
            background: #fff;
            overflow: hidden;
        }
        .report-content { padding: 30px 35px; font-size: 0.8rem; }
        .report-content table { font-size: 0.8rem !important; }
        .report-content table td, .report-content table th { padding: 6px 8px !important; }
        .report-content h6 { font-size: 0.85rem !important; }
        .report-content .card-header h6 { font-size: 0.8rem !important; }
        .report-content-header {
            background: #009EDB;
            color: white;
            padding: 18px 25px;
            border-radius: 8px;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .report-content-header h2 { font-size: 18px; font-weight: 700; margin: 0; }
        .report-content-header .header-meta {
            font-size: 11px; opacity: 0.85;
            display: flex; align-items: center; gap: 6px;
        }
        .report-content-header .header-flag { font-size: 16px; border-radius: 2px; overflow: hidden; }
        .print-section { margin-bottom: 30px; }
        .print-section-title { color: #00689D; font-size: 16px; font-weight: 700; border-bottom: 2px solid #00b2e3; padding-bottom: 6px; margin-bottom: 15px; }

        /* ── Footer ── */
        .print-footer { margin-top: 30px; padding: 15px 20px 0; border-top: 2px solid #00689D; font-size: 9px; color: #868e96; }
        .print-footer-content { display: flex; align-items: center; justify-content: space-between; }
        .print-footer-left { display: flex; align-items: center; gap: 10px; }
        .print-footer-left img { height: 28px; object-fit: contain; }
        .print-footer-right { display: flex; align-items: center; gap: 6px; }
        .print-footer-right .sdg-footer-goal { height: 32px; border-radius: 2px; }
        .print-footer-right .sdg-footer-logo { height: 38px; margin-left: 4px; }
        .print-footer-center { text-align: center; font-size: 9px; color: #868e96; margin-top: 8px; }

        /* ── Hide input columns and interactive elements ── */
        /* Hide left input column visually but keep in DOM for JS calculations */
        .col-lg-4 { position: absolute !important; left: -9999px !important; width: 1px !important; height: 1px !important; overflow: hidden !important; }
        .col-lg-8 { flex: 0 0 100% !important; max-width: 100% !important; width: 100% !important; }
        .sidebar, .nav, .btn, .report-content button, textarea,
        .tooltip-trigger .info-btn, [data-bs-toggle], .no-print,
        .gap-tabs-nav, .gap-tab-btn { display: none !important; }
        /* Show selects as static text */
        select, .form-select {
            border: none !important;
            background: transparent !important;
            appearance: none !important;
            -webkit-appearance: none !important;
            pointer-events: none !important;
            font-weight: 500 !important;
            font-size: 0.75rem !important;
            padding: 0 !important;
            background-image: none !important;
            width: auto !important;
        }
        .row { margin: 0 !important; }
        .print-section .card { margin-bottom: 12px; }
        /* Fix matrix label clipping */
        .matrix-container { overflow: visible !important; margin-top: 15px !important; }

        /* ── Force col-md grid to stay side by side ── */
        .prioritization-module .col-md-3 { flex: 0 0 25% !important; max-width: 25% !important; }
        .prioritization-module .col-md-6 { flex: 0 0 50% !important; max-width: 50% !important; }

        /* ── Scale down prioritization section ── */
        .prioritization-module { font-size: 0.75rem !important; }
        .prioritization-module table { font-size: 0.75rem !important; }
        .prioritization-module table td, .prioritization-module table th { font-size: 0.75rem !important; padding: 6px 8px !important; }
        .prioritization-module .mode-badge { font-size: 0.65rem !important; padding: 3px 8px !important; }
        .prioritization-module .rank-badge { width: 24px !important; height: 24px !important; font-size: 0.7rem !important; }
        .prioritization-module .priority-number { width: 20px !important; height: 20px !important; font-size: 0.65rem !important; }
        .prioritization-module .card-header h6 { font-size: 0.85rem !important; }
        .prioritization-module h3 { font-size: 1rem !important; }
        .prioritization-module h4, .prioritization-module .h4 { font-size: 0.95rem !important; }
        .prioritization-module h5 { font-size: 0.9rem !important; }
        .prioritization-module h6 { font-size: 0.75rem !important; }
        .prioritization-module .card-body { padding: 0.75rem !important; }
        .prioritization-module .text-muted.small, .prioritization-module p { font-size: 0.75rem !important; }

        /* ── Constrain prioritization charts ── */
        .prioritization-module canvas { max-height: 200px !important; }
        .prioritization-module .col-md-7,
        .prioritization-module .col-md-5 {
            flex: 0 0 auto !important;
            max-width: none !important;
        }
        .prioritization-module .col-md-7 { width: 58% !important; }
        .prioritization-module .col-md-5 { width: 42% !important; }

        /* ── Hide interactive elements from new sections ── */
        /* Prioritization */
        .prioritization-module .drag-handle,
        .prioritization-module input[type="checkbox"],
        .prioritization-module .form-check,
        .prioritization-module .alert,
        #modeExplanationAccordion { display: none !important; }

        /* Overview Selection */
        .overview-selection-container .filter-panel,
        .overview-selection-container .solution-card-actions,
        .overview-selection-container .progress-tracker,
        .overview-selection-container .selection-toolbar { display: none !important; }

        /* Recommendations */
        .recommendations-container .header-actions { display: none !important; }
        .recommendations-container .recommendations-header h2 { font-size: 1.1rem !important; }
        .recommendations-container .section-description { font-size: 0.75rem !important; }
        .recommendations-container .recommendations-summary { gap: 8px !important; }
        .recommendations-container .summary-card { padding: 10px !important; }
        .recommendations-container .summary-value { font-size: 1.2rem !important; }
        .recommendations-container .summary-label { font-size: 0.65rem !important; }
        .recommendations-container .solution-detail-card { font-size: 0.8rem !important; }
        .recommendations-container h3, .recommendations-container h4 { font-size: 0.95rem !important; }

        /* ── Page break rules (global for Playwright PDF + browser print) ── */
        .print-section, .card, .matrix-container { break-inside: avoid; page-break-inside: avoid; }
        .print-section-title { break-after: avoid; page-break-after: avoid; }
        .report-content-header { break-inside: avoid; break-after: avoid; page-break-inside: avoid; }
        .print-footer { break-inside: avoid; page-break-inside: avoid; }
        h4, h5 { break-after: avoid; page-break-after: avoid; }
        img, svg, canvas { break-inside: avoid; page-break-inside: avoid; }
        table, .table { break-inside: avoid; page-break-inside: avoid; }
        .chart-container, .chart-wrapper { break-inside: avoid; page-break-inside: avoid; }
        .kpi-row, .kpi-grid { break-inside: avoid; page-break-inside: avoid; }
        .gap-analysis-section, .stream-section { break-inside: avoid; page-break-inside: avoid; }
        .prioritization-module .col-md-6 .card { break-inside: avoid; page-break-inside: avoid; }
        .solution-card { break-inside: avoid; page-break-inside: avoid; }
        .recommendations-summary { break-inside: avoid; page-break-inside: avoid; }

        .print-btn-wrapper { display: block; }
        @@page {
            size: portrait;
            margin: 8mm;
        }
        @@page :first {
            margin: 0;
        }
        @@media print {
            body { margin: 0; padding: 0; background: #fff; }
            .print-btn-wrapper { display: none !important; }
            .report-box {
                max-width: 100%;
                margin: 0;
                border: none;
                border-radius: 0;
                box-shadow: none;
            }
            .cover-page { min-height: 0; height: 100vh; }
            .report-content { padding: 10px; }
        }
    </style>
</head>
<body>

    <!-- Seed state data from session model for partial JS to read -->
    <script>
        var isViewMode = true;
        // Seed localStorage so partial scripts can load data via fallback path
        (function() {
            var prioritizationData = '@Html.Raw(Model.PrioritizationData?.Replace("'", "\\'")?.Replace("\n", "") ?? "")';
            if (prioritizationData) {
                try { localStorage.setItem('prioritizationData', prioritizationData); } catch(e) {}
            }
            var selectedSolutions = '@Html.Raw(Model.SelectedSolutionsData?.Replace("'", "\\'")?.Replace("\n", "") ?? "")';
            if (selectedSolutions) {
                try {
                    localStorage.setItem('selectedSolutionsData', selectedSolutions);
                    // Also seed as rosraSelectedSolutions for the overview summary
                    localStorage.setItem('rosraSelectedSolutions', selectedSolutions);
                } catch(e) {}
            }
        })();
    </script>

    <!-- ════════════════════════════════
         BOXED REPORT CONTAINER
         ════════════════════════════════ -->
    <div class="report-box">

    <!-- Cover Page -->
    <div class="cover-page">
        <div class="cover-bg-image">
            <img src="~/images/cities/nairobi.jpg" alt="" />
        </div>
        <div class="cover-orbit"></div>
        <div class="cover-top">
            <div class="cover-circle-main">
                <img src="~/images/cities/addis-ababa.jpg" alt="City skyline" />
            </div>
            <div class="cover-circle-sm cover-circle-sm-1">
                <img src="~/images/sdg/E_WEB_11.png" alt="SDG 11" />
            </div>
            <div class="cover-circle-sm cover-circle-sm-2">
                <img src="~/images/cities/nairobi.jpg" alt="City" />
            </div>
            <div class="cover-circle-sm cover-circle-sm-3">
                <img src="~/images/sdg/E_WEB_17.png" alt="SDG 17" />
            </div>
        </div>

        <div class="cover-title-section">
            <h1 class="cover-title">Rapid Own-Source<br />Revenue Analysis</h1>
            <p class="cover-subtitle">Bottom-Up Gap Analysis Report</p>
            <div class="cover-location">
                @if (!string.IsNullOrEmpty(countryCode))
                {
                    <span class="cover-flag fi fi-@countryCode"></span>
                }
                <span class="cover-country-name">@(Model.Country ?? "ROSRA")</span>
            </div>
            <div class="cover-location-detail">
                @if (Model.Region != null)
                {
                    <span>@Model.Region</span>
                }
                @if (Model.City != null)
                {
                    <span>@Model.City</span>
                }
                @if (Model.FinancialYear != null)
                {
                    <span>FY @Model.FinancialYear</span>
                }
                @if (Model.Currency != null)
                {
                    <span>@Model.Currency (@cs)</span>
                }
            </div>
        </div>

        <div class="cover-bottom">
            <div class="cover-block cover-block-1"></div>
            <div class="cover-block cover-block-2">
                <img src="~/images/sdg/E_WEB_11.png" alt="" />
            </div>
            <div class="cover-block cover-block-3"></div>
            <div class="cover-circle-deco">
                <div class="cover-circle-deco-inner"></div>
            </div>
            <div class="cover-circle-accent"></div>
        </div>

        <div class="cover-logo-bottom">
            <img src="~/images/Light-theme-logo.png" alt="UN-Habitat" />
        </div>
        <div class="cover-logo-norad">
            <img src="~/images/Light-theme-norad.png" alt="Norad" />
        </div>

        <!-- SDG Goals strip -->
        <div class="cover-sdg-strip">
            <img class="sdg-goal" src="~/images/sdg/E_WEB_INVERTED_11.png" alt="SDG 11" />
            <img class="sdg-goal" src="~/images/sdg/E_WEB_INVERTED_16.png" alt="SDG 16" />
            <img class="sdg-goal" src="~/images/sdg/E_WEB_INVERTED_17.png" alt="SDG 17" />
            <img class="sdg-wheel" src="~/images/sdg/SDG_Wheel_WEB.png" alt="SDG Wheel" />
        </div>
    </div>

    <!-- ════════════════════════════════
         REPORT CONTENT (page 2+)
         ════════════════════════════════ -->
    <div class="report-content">
        <div class="report-content-header">
            <h2>Bottom-Up Gap Analysis Report</h2>
            <div class="header-meta">
                @if (!string.IsNullOrEmpty(countryCode))
                {
                    <span class="header-flag fi fi-@countryCode"></span>
                }
                <span>@(Model.Country ?? "-")</span>
                @if (Model.Region != null)
                {
                    <span>&rsaquo; @Model.Region</span>
                }
                @if (Model.City != null)
                {
                    <span>&rsaquo; @Model.City</span>
                }
            </div>
        </div>

        <!-- Property Tax Section -->
        <div class="print-section">
            <div class="print-section-title">Property Tax Gap Analysis</div>
            @await Html.PartialAsync("_GapAnalysisPropertyTaxFixed", Model)
        </div>

        <!-- Business License Section -->
        <div class="print-section">
            <div class="print-section-title">Business License Gap Analysis</div>
            @await Html.PartialAsync("_GapAnalysisLicense", Model)
        </div>

        <!-- Generic Streams -->
        @if (Model.GenericStreams != null && Model.GenericStreams.Any())
        {
            @foreach (var stream in Model.GenericStreams)
            {
                <div class="print-section">
                    <div class="print-section-title">@(stream.StreamName ?? "Revenue Stream") Gap Analysis</div>
                    @await Html.PartialAsync("_GapAnalysisGenericStream", stream, new ViewDataDictionary(ViewData) { { "CurrencySymbol", cs } })
                </div>
            }
        }

        <!-- Prioritization Section -->
        <div class="print-section">
            <div class="print-section-title">Revenue Stream Prioritization</div>
            @await Html.PartialAsync("_Prioritization", Model)
        </div>

        <!-- Overview Selection Section (compact print summary) -->
        <div class="print-section">
            <div class="print-section-title">Solution Overview &amp; Selection</div>
            <div id="overviewSelectionSummary">
                <!-- Summary stats -->
                <div class="row mb-3" id="overviewStats">
                    <div class="col-4">
                        <div class="card border-0 bg-light text-center p-3">
                            <div class="h4 mb-0" id="ovSelectedCount">0</div>
                            <small class="text-muted">Solutions Selected</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="card border-0 bg-light text-center p-3">
                            <div class="h4 mb-0" id="ovSkippedCount">0</div>
                            <small class="text-muted">Solutions Skipped</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="card border-0 bg-light text-center p-3">
                            <div class="h4 mb-0" id="ovQuickWinsCount">0</div>
                            <small class="text-muted">Quick Wins</small>
                        </div>
                    </div>
                </div>
                <!-- Selected solutions table (populated by JS) -->
                <div id="overviewSelectedTable"></div>
                <!-- Skipped solutions (populated by JS) -->
                <div id="overviewSkippedList" class="mt-3"></div>
            </div>
        </div>

        <!-- Recommendations Section -->
        <div class="print-section">
            <div class="print-section-title">Recommendations</div>
            @await Html.PartialAsync("_Recommendations", Model)
        </div>

        <!-- Footer -->
        <div class="print-footer">
            <div class="print-footer-content">
                <div class="print-footer-left">
                    <img src="~/images/logo.d95ced55c7a543c8d241.png" alt="ROSRA UN-Habitat" />
                </div>
                <div class="print-footer-right">
                    <img class="sdg-footer-goal" src="~/images/sdg/E_WEB_11.png" alt="SDG 11" />
                    <img class="sdg-footer-goal" src="~/images/sdg/E_WEB_16.png" alt="SDG 16" />
                    <img class="sdg-footer-goal" src="~/images/sdg/E_WEB_17.png" alt="SDG 17" />
                    <img class="sdg-footer-logo" src="~/images/sdg/E_SDG_logo_horizontal_trans.png" alt="SDG" />
                </div>
            </div>
            <div class="print-footer-center">
                ROSRA &mdash; Rapid Own-Source Revenue Analysis Tool | &copy; @DateTime.Now.Year UN-Habitat. All rights reserved. | Generated @DateTime.Now.ToString("dd MMM yyyy")
            </div>
        </div>
    </div>

    </div> <!-- /.report-box -->

    <div class="print-btn-wrapper" style="position:fixed;top:15px;right:15px;z-index:9999;">
        <button onclick="window.print()" style="background:#009EDB;color:#fff;border:none;padding:10px 24px;border-radius:6px;font-size:14px;font-weight:600;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,.15);">
            &#128438; Print / Save as PDF
        </button>
    </div>

    <!-- Scripts -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/chart.js/chart.umd.min.js" asp-append-version="true"></script>
    <script src="~/lib/chart.js/chartjs-plugin-datalabels.min.js" asp-append-version="true"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <!-- Solution data for Overview Selection & Recommendations -->
    <script src="~/js/solutionsData-PT-Compliance.js"></script>
    <script src="~/js/solutionsData-PT-Coverage.js"></script>
    <script src="~/js/solutionsData-PT-Valuation.js"></script>
    <script src="~/js/solutionsData-NP-A.js"></script>
    <script src="~/js/solutionsData-NP-B.js"></script>
    <script src="~/js/solutionsData-NP-C.js"></script>
    <script src="~/js/solutionsData-BL.js"></script>
    <script src="~/js/solutionsData-Generic.js"></script>
    <script src="~/js/streamClassification.js"></script>
    <script src="~/js/solutionsDatabase.js"></script>
    <script src="~/js/solutionsFullDatabase.js"></script>
    <script src="~/js/recommendationsModule.js"></script>
    <script>
        $(document).ready(function() {
            // Step 1: Trigger gap calculations (Property Tax, Business License)
            setTimeout(function() {
                document.querySelectorAll('input[data-input="true"]').forEach(function(el) {
                    el.dispatchEvent(new Event('change', { bubbles: true }));
                });
                document.querySelectorAll('input[type="range"]').forEach(function(el) {
                    el.dispatchEvent(new Event('input', { bubbles: true }));
                });
            }, 1000);

            // Step 2: After gap data is in localStorage, re-initialize Prioritization
            setTimeout(function() {
                window.dispatchEvent(new Event('gapDataReady'));
            }, 2500);

            // Step 3: Render Overview Selection summary table
            setTimeout(function() {
                renderOverviewSummary();
            }, 3000);

            // Step 4: Auto-print if requested (opens Save as PDF dialog, then closes tab)
            if (window.location.search.indexOf('autoPrint=true') >= 0) {
                setTimeout(function() {
                    window.print();
                    window.onafterprint = function() { window.close(); };
                }, 5000);
            }
        });

        function renderOverviewSummary() {
            // Read selections from localStorage
            var selectionsRaw = localStorage.getItem('rosraOverviewSelections');
            var solutionsRaw = localStorage.getItem('rosraSelectedSolutions');
            var selections = { selected: [], skipped: [] };
            var solutions = [];

            try { if (selectionsRaw) selections = JSON.parse(selectionsRaw); } catch(e) {}
            try { if (solutionsRaw) solutions = JSON.parse(solutionsRaw); } catch(e) {}

            var selectedIds = selections.selected || [];
            var skippedIds = selections.skipped || [];

            // Update stats
            var quickWins = solutions.filter(function(s) { return s.timeline && s.timeline.indexOf('<') >= 0; }).length;
            document.getElementById('ovSelectedCount').textContent = selectedIds.length;
            document.getElementById('ovSkippedCount').textContent = skippedIds.length;
            document.getElementById('ovQuickWinsCount').textContent = quickWins;

            // Group solutions by stream
            var streams = {};
            solutions.forEach(function(s) {
                var key = s.streamName || 'Other';
                if (!streams[key]) streams[key] = [];
                streams[key].push(s);
            });

            // Build selected solutions tables
            var html = '';
            Object.keys(streams).forEach(function(streamName) {
                var items = streams[streamName];
                html += '<div class="card mb-3"><div class="card-header bg-light py-2">';
                html += '<h6 class="mb-0"><i class="fas fa-stream me-2"></i>' + streamName + ' &mdash; ' + items.length + ' solution' + (items.length !== 1 ? 's' : '') + ' selected</h6></div>';
                html += '<div class="card-body p-0"><table class="table table-sm table-striped mb-0">';
                html += '<thead class="table-light"><tr><th>Solution</th><th class="text-center">Gap Type</th><th class="text-center">Timeline</th></tr></thead><tbody>';
                items.forEach(function(s) {
                    var timelineLabel = s.timeline || '-';
                    if (timelineLabel.indexOf('<') >= 0) timelineLabel = '<span class="badge bg-success">Quick Win</span>';
                    else if (timelineLabel.indexOf('1-3') >= 0) timelineLabel = '<span class="badge bg-warning text-dark">Medium-Term</span>';
                    else if (timelineLabel.indexOf('3+') >= 0 || timelineLabel.indexOf('3-5') >= 0) timelineLabel = '<span class="badge bg-danger">Long-Term</span>';
                    html += '<tr><td>' + (s.title || s.solutionId) + '</td>';
                    html += '<td class="text-center"><span class="badge bg-info">' + (s.gapType || '-') + '</span></td>';
                    html += '<td class="text-center">' + timelineLabel + '</td></tr>';
                });
                html += '</tbody></table></div></div>';
            });

            if (selectedIds.length === 0) {
                html = '<div class="alert alert-secondary text-center"><i class="fas fa-info-circle me-2"></i>No solutions have been selected yet. Complete the Overview Selection step in the main app.</div>';
            }

            document.getElementById('overviewSelectedTable').innerHTML = html;

            // Build skipped list
            if (skippedIds.length > 0) {
                var skippedHtml = '<details><summary class="text-muted small mb-2"><i class="fas fa-ban me-1"></i>' + skippedIds.length + ' solution' + (skippedIds.length !== 1 ? 's' : '') + ' skipped</summary>';
                skippedHtml += '<div class="text-muted small">' + skippedIds.join(', ') + '</div></details>';
                document.getElementById('overviewSkippedList').innerHTML = skippedHtml;
            }
        }
    </script>
</body>
</html>
