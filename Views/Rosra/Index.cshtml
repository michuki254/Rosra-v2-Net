@section Scripts {
    <!-- Prevent browser scroll restoration and fix modal layout issues -->
    <script>
        // Disable browser's automatic scroll restoration
        if ('scrollRestoration' in history) {
            history.scrollRestoration = 'manual';
        }
        // Force scroll to top on page load
        window.scrollTo(0, 0);

        // Clean up any Bootstrap modal artifacts on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Remove any leftover modal-open class from body
            document.body.classList.remove('modal-open');
            document.body.style.overflow = '';
            document.body.style.paddingRight = '';

            // Remove any leftover modal backdrops
            document.querySelectorAll('.modal-backdrop').forEach(function(backdrop) {
                backdrop.remove();
            });

            // Listen for modal hidden events to ensure cleanup
            document.addEventListener('hidden.bs.modal', function() {
                // Small delay to ensure Bootstrap has finished
                setTimeout(function() {
                    if (!document.querySelector('.modal.show')) {
                        document.body.classList.remove('modal-open');
                        document.body.style.overflow = '';
                        document.body.style.paddingRight = '';
                    }
                }, 100);
            });
        });
    </script>

    <!-- Form State Manager - Primary data storage using form fields -->
    <script>
        // FormStateManager - Pure form field binding (Best Practice)
        // Form fields are the single source of truth, localStorage is just a backup for crash recovery
        window.FormStateManager = (function() {
            'use strict';

            // Field mappings: localStorage key -> { fieldId, subKey (optional) }
            // When subKey is specified, the data is stored under that property in the form field
            const fieldMappings = {
                // Overview Selection tab - both stored in same field under different properties
                'rosraOverviewSelections': { fieldId: 'selectedSolutionsData', subKey: 'selections' },
                'rosraSelectedSolutions': { fieldId: 'selectedSolutionsData', subKey: 'selectedSolutions' },
                // Implementation Progress tab
                'rosraImplementationProgress': { fieldId: 'implementationProgressData' },
                // Prioritization tab (read-only, populated from Gap Analysis)
                'prioritizationState': { fieldId: 'prioritizationData' }
            };

            // Get data from form field (primary source) with localStorage fallback
            function getData(key) {
                const mapping = fieldMappings[key];
                if (!mapping) {
                    console.warn('FormStateManager: No mapping for key', key);
                    return null;
                }

                // Try form field first
                const formField = document.getElementById(mapping.fieldId);
                if (formField && formField.value && formField.value.trim() !== '') {
                    try {
                        const formData = JSON.parse(formField.value);
                        // If subKey is specified, return that property
                        if (mapping.subKey) {
                            if (formData[mapping.subKey] !== undefined) {
                                console.log('FormStateManager: Loaded', key, 'from form field (subKey:', mapping.subKey + ')');
                                return formData[mapping.subKey];
                            }
                        } else {
                            console.log('FormStateManager: Loaded', key, 'from form field');
                            return formData;
                        }
                    } catch (e) {
                        console.warn('FormStateManager: Could not parse form field data for', key, e);
                    }
                }

                // Fallback to localStorage (for backward compatibility and draft recovery)
                const localData = localStorage.getItem(key);
                if (localData) {
                    try {
                        const parsed = JSON.parse(localData);
                        console.log('FormStateManager: Loaded', key, 'from localStorage (fallback)');
                        return parsed;
                    } catch (e) {
                        console.warn('FormStateManager: Could not parse localStorage data for', key, e);
                    }
                }

                return null;
            }

            // Set data to form field (primary) AND localStorage (backup)
            function setData(key, data) {
                const mapping = fieldMappings[key];
                if (!mapping) {
                    console.warn('FormStateManager: No mapping for key', key);
                    return;
                }

                // Update form field (primary storage)
                const formField = document.getElementById(mapping.fieldId);
                if (formField) {
                    if (mapping.subKey) {
                        // Merge with existing data in the field
                        let existingData = {};
                        try {
                            if (formField.value && formField.value.trim() !== '') {
                                existingData = JSON.parse(formField.value);
                            }
                        } catch (e) {
                            existingData = {};
                        }
                        existingData[mapping.subKey] = data;
                        formField.value = JSON.stringify(existingData);
                        console.log('FormStateManager: Saved', key, 'to form field (subKey:', mapping.subKey + ')');
                    } else {
                        formField.value = JSON.stringify(data);
                        console.log('FormStateManager: Saved', key, 'to form field');
                    }
                }

                // Also update localStorage as backup
                try {
                    localStorage.setItem(key, JSON.stringify(data));
                    console.log('FormStateManager: Saved', key, 'to localStorage (backup)');
                } catch (e) {
                    console.warn('FormStateManager: Could not save to localStorage', key, e);
                }
            }

            // Get form field element by localStorage key
            function getFormField(key) {
                const mapping = fieldMappings[key];
                if (mapping) {
                    return document.getElementById(mapping.fieldId);
                }
                // Try direct field lookup
                return document.getElementById(key);
            }

            // Get all form state as an object (for debugging)
            function getAllFormState() {
                const state = {};
                Object.keys(fieldMappings).forEach(key => {
                    state[key] = getData(key);
                });
                return state;
            }

            // Clear localStorage backup only (form fields remain)
            function clearLocalStorageBackup() {
                Object.keys(fieldMappings).forEach(key => {
                    localStorage.removeItem(key);
                });
                console.log('FormStateManager: Cleared localStorage backups');
            }

            // Public API
            return {
                getData: getData,
                setData: setData,
                getFormField: getFormField,
                getAllFormState: getAllFormState,
                clearLocalStorageBackup: clearLocalStorageBackup
            };
        })();

        console.log('FormStateManager initialized');

        // Clear localStorage when starting a new report
        @if (TempData["ClearLocalStorage"] != null)
        {
            <text>
            window.FormStateManager.clearLocalStorageBackup();
            // Also clear any other ROSRA-related localStorage keys
            Object.keys(localStorage).forEach(function(key) {
                if (key.indexOf('propertyTax') === 0 || key.indexOf('license') === 0 ||
                    key.indexOf('total') === 0 || key.indexOf('largest') === 0 ||
                    key.indexOf('selectedCurrency') === 0 || key.indexOf('shortTerm') === 0 ||
                    key.indexOf('longTerm') === 0 || key.indexOf('mixed') === 0 ||
                    key.indexOf('generic') === 0 || key.indexOf('peer') === 0 ||
                    key.indexOf('rosra') === 0) {
                    localStorage.removeItem(key);
                }
            });
            console.log('New Report: Cleared all localStorage data');
            </text>
        }
    </script>

    <!-- Global App Context - Similar to React Context for state management across tabs -->
    <script>
        // AppContext - Global state management (similar to React Context)
        window.AppContext = (function() {
            // Private state
            const state = {
                currencySymbol: localStorage.getItem('selectedCurrencySymbol') || '@Model.TabContentModel.CurrencySymbol' || '$',
                country: '@Model.TabContentModel.Country' || '',
                region: '@Model.TabContentModel.Region' || ''
            };

            // Subscribers for state changes
            const subscribers = {
                currencySymbol: [],
                country: [],
                region: []
            };

            // Notify all subscribers of a state change
            function notify(key, value) {
                if (subscribers[key]) {
                    subscribers[key].forEach(callback => callback(value));
                }
            }

            return {
                // Get current state value
                get: function(key) {
                    return state[key];
                },

                // Set state value and notify subscribers
                set: function(key, value) {
                    if (state[key] !== value) {
                        state[key] = value;
                        // Persist to localStorage
                        if (key === 'currencySymbol') {
                            localStorage.setItem('selectedCurrencySymbol', value);
                        }
                        console.log(`AppContext: ${key} changed to:`, value);
                        notify(key, value);
                    }
                },

                // Subscribe to state changes (similar to useContext)
                subscribe: function(key, callback) {
                    if (!subscribers[key]) {
                        subscribers[key] = [];
                    }
                    subscribers[key].push(callback);
                    // Return unsubscribe function
                    return function() {
                        subscribers[key] = subscribers[key].filter(cb => cb !== callback);
                    };
                },

                // Get all state (for debugging)
                getState: function() {
                    return { ...state };
                }
            };
        })();

        console.log('AppContext initialized:', AppContext.getState());
    </script>

    <script>
        $(document).ready(function() {
            // Restore saved tab data to localStorage if loading an existing report
            restoreTabDataToLocalStorage();

            // Function to restore tab data from the database to localStorage
            function restoreTabDataToLocalStorage() {
                var prioritizationDataJson = $("#prioritizationData").val();
                var selectedSolutionsDataJson = $("#selectedSolutionsData").val();
                var implementationProgressDataJson = $("#implementationProgressData").val();

                // Restore Prioritization data
                if (prioritizationDataJson && prioritizationDataJson.trim() !== '') {
                    try {
                        var prioritizationData = JSON.parse(prioritizationDataJson);
                        console.log('Restoring prioritization data to localStorage:', prioritizationData);

                        if (prioritizationData.propertyTax) {
                            localStorage.setItem('propertyTaxGapValue', prioritizationData.propertyTax.gap || 0);
                            localStorage.setItem('propertyTaxCurrentValue', prioritizationData.propertyTax.currentRevenue || 0);
                            localStorage.setItem('propertyTaxPotentialValue', prioritizationData.propertyTax.potentialRevenue || 0);
                            localStorage.setItem('propertyTaxComplianceGap', prioritizationData.propertyTax.complianceGap || 0);
                            localStorage.setItem('propertyTaxCoverageGap', prioritizationData.propertyTax.coverageGap || 0);
                            localStorage.setItem('propertyTaxValuationGap', prioritizationData.propertyTax.valuationGap || 0);
                        }
                        if (prioritizationData.license) {
                            localStorage.setItem('licenseGapValue', prioritizationData.license.gap || 0);
                            localStorage.setItem('licenseCurrentValue', prioritizationData.license.currentRevenue || 0);
                            localStorage.setItem('licensePotentialValue', prioritizationData.license.potentialRevenue || 0);
                            localStorage.setItem('licenseComplianceGap', prioritizationData.license.complianceGap || 0);
                            localStorage.setItem('licenseCoverageGap', prioritizationData.license.coverageGap || 0);
                            localStorage.setItem('licenseLiabilityGap', prioritizationData.license.liabilityGap || 0);
                        }
                        if (prioritizationData.totals) {
                            localStorage.setItem('totalCurrentRevenue', prioritizationData.totals.currentTotal || 0);
                            localStorage.setItem('totalPotentialRevenue', prioritizationData.totals.potentialTotal || 0);
                            localStorage.setItem('totalRevenueGap', prioritizationData.totals.gapTotal || 0);
                            localStorage.setItem('largestGapSource', prioritizationData.totals.largestGapSource || '');
                            localStorage.setItem('largestGapValue', prioritizationData.totals.largestGapValue || 0);
                        }
                    } catch (e) {
                        console.warn('Could not parse prioritization data:', e);
                    }
                }

                // Restore Overview Selection data
                if (selectedSolutionsDataJson && selectedSolutionsDataJson.trim() !== '') {
                    try {
                        var selectedSolutionsData = JSON.parse(selectedSolutionsDataJson);
                        console.log('Restoring selected solutions data to localStorage:', selectedSolutionsData);

                        if (selectedSolutionsData.selections) {
                            localStorage.setItem('rosraOverviewSelections', JSON.stringify(selectedSolutionsData.selections));
                        }
                        if (selectedSolutionsData.selectedSolutions) {
                            localStorage.setItem('rosraSelectedSolutions', JSON.stringify(selectedSolutionsData.selectedSolutions));
                        }
                    } catch (e) {
                        console.warn('Could not parse selected solutions data:', e);
                    }
                }

                // Restore Implementation Progress data
                if (implementationProgressDataJson && implementationProgressDataJson.trim() !== '') {
                    try {
                        var implementationProgressData = JSON.parse(implementationProgressDataJson);
                        console.log('Restoring implementation progress data to localStorage:', implementationProgressData);

                        if (implementationProgressData.progress) {
                            localStorage.setItem('rosraImplementationProgress', JSON.stringify(implementationProgressData.progress));
                        }
                    } catch (e) {
                        console.warn('Could not parse implementation progress data:', e);
                    }
                }

                // Load Peer SNG data for report isolation
                var savedPeerSNGData = '@Html.Raw(Model.TabContentModel.PeerSNGData?.Replace("'", "\\'") ?? "")';
                if (savedPeerSNGData && savedPeerSNGData.trim() !== '') {
                    console.log('Found saved peer SNG data, will load after page initialization');
                    // Wait for _PotentialEstimates.cshtml to initialize, then load the data
                    setTimeout(function() {
                        if (typeof window.loadReportPeerData === 'function') {
                            window.loadReportPeerData(savedPeerSNGData);
                        } else {
                            console.warn('loadReportPeerData function not available yet');
                        }
                    }, 1000); // Give time for peer module to initialize
                }
            }
            // Initialize Bootstrap tabs
            var triggerTabList = [].slice.call(document.querySelectorAll('#@Model.ContainerId button'))
            triggerTabList.forEach(function (triggerEl) {
                var tabTrigger = new bootstrap.Tab(triggerEl)
                triggerEl.addEventListener('click', function (event) {
                    event.preventDefault()
                    // Don't trigger tab show here as we're using form submission for tab navigation
                })
            })
            
            // Check if we're in view mode
            var isViewMode = @Json.Serialize(isViewMode);
            
            // Check if user is authenticated (for save functionality)
            var isAuthenticated = @Json.Serialize(User.Identity?.IsAuthenticated ?? false);

            // Keep URL in sync with the loaded report
            (function() {
                var publicId = $("#reportPublicId").val();
                var reportId = parseInt($("#reportId").val());
                if (reportId > 0 && publicId && publicId !== '00000000-0000-0000-0000-000000000000') {
                    var editUrl = '@Url.Action("Edit", "Rosra")/' + publicId;
                    if (window.location.pathname !== editUrl) {
                        history.replaceState(null, '', editUrl + window.location.search);
                    }
                }
            })();

            if (!isViewMode) {
                // Save Report button click handler
                $("#saveReportBtn").click(function() {
                    // Function to perform the actual save
                    function performSave() {
                        var btn = $("#saveReportBtn");
                        var originalHtml = btn.html();
                        btn.prop('disabled', true).html('<i class="bi bi-hourglass-split me-1"></i><span>Saving...</span>');

                        // Auto-generate title from Country and Region (no popup)
                        var country = $("#country option:selected").text().trim();
                        var region = $("#region option:selected").text().trim();

                        var title = "ROSRA Report";
                        if (country && country !== "Select Country" && country !== "") {
                            title += " - " + country;
                            if (region && region !== "Select Region/State" && region !== "") {
                                title += " - " + region;
                            }
                        }
                        $("#reportTitle").val(title);

                        // Collect tab data from localStorage before saving
                        collectTabDataFromLocalStorage();

                        // Save via AJAX
                        $.ajax({
                            url: '@Url.Action("AutoSaveReport", "Rosra")',
                            type: 'POST',
                            data: $("#rosraForm").serialize(),
                            success: function(r) {
                                if (r.success) {
                                    // Update hidden fields with new report ID and row version
                                    if (r.reportId && parseInt($("#reportId").val()) === 0) {
                                        $("#reportId").val(r.reportId);
                                    }
                                    if (r.rowVersion) {
                                        $('input[name="RowVersion"]').val(r.rowVersion);
                                    }

                                    // Update URL to point to this report
                                    // Update PublicId hidden field
                                    if (r.publicId) {
                                        $("#reportPublicId").val(r.publicId);
                                    }
                                    var editUrl = '@Url.Action("Edit", "Rosra")/' + r.publicId;
                                    history.replaceState(null, '', editUrl);

                                    // Change button text to "Update Report"
                                    btn.prop('disabled', false).html('<i class="bi bi-save me-1"></i><span>Update Report</span>');

                                    // Show brief success feedback
                                    var badge = $('<span class="badge bg-success ms-2" style="font-size: 0.75rem;">Saved</span>');
                                    btn.after(badge);
                                    setTimeout(function() { badge.fadeOut(400, function() { $(this).remove(); }); }, 2000);
                                } else {
                                    alert("Error saving report: " + r.message);
                                    btn.prop('disabled', false).html(originalHtml);
                                }
                            },
                            error: function() {
                                alert("An error occurred while saving. Please try again.");
                                btn.prop('disabled', false).html(originalHtml);
                            }
                        });
                    }

                    // Check if user is authenticated
                    if (isAuthenticated) {
                        performSave();
                    } else {
                        if (typeof AuthModal !== 'undefined') {
                            AuthModal.showForSave(performSave);
                        } else {
                            alert('Please log in to save your report.');
                            window.location.href = '/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
                        }
                    }
                });

                // Function to collect all tab data from localStorage
                function collectTabDataFromLocalStorage() {
                    console.log('Collecting tab data from localStorage...');

                    // 1. Collect Prioritization data (stream rankings, adjustments)
                    var prioritizationData = {
                        propertyTax: {
                            gap: parseFloat(localStorage.getItem('propertyTaxGapValue')) || 0,
                            currentRevenue: parseFloat(localStorage.getItem('propertyTaxCurrentValue')) || 0,
                            potentialRevenue: parseFloat(localStorage.getItem('propertyTaxPotentialValue')) || 0,
                            complianceGap: parseFloat(localStorage.getItem('propertyTaxComplianceGap')) || 0,
                            coverageGap: parseFloat(localStorage.getItem('propertyTaxCoverageGap')) || 0,
                            valuationGap: parseFloat(localStorage.getItem('propertyTaxValuationGap')) || 0
                        },
                        license: {
                            gap: parseFloat(localStorage.getItem('licenseGapValue')) || 0,
                            currentRevenue: parseFloat(localStorage.getItem('licenseCurrentValue')) || 0,
                            potentialRevenue: parseFloat(localStorage.getItem('licensePotentialValue')) || 0,
                            complianceGap: parseFloat(localStorage.getItem('licenseComplianceGap')) || 0,
                            coverageGap: parseFloat(localStorage.getItem('licenseCoverageGap')) || 0,
                            liabilityGap: parseFloat(localStorage.getItem('licenseLiabilityGap')) || 0
                        },
                        totals: {
                            currentTotal: parseFloat(localStorage.getItem('totalCurrentRevenue')) || 0,
                            potentialTotal: parseFloat(localStorage.getItem('totalPotentialRevenue')) || 0,
                            gapTotal: parseFloat(localStorage.getItem('totalRevenueGap')) || 0,
                            largestGapSource: localStorage.getItem('largestGapSource') || '',
                            largestGapValue: parseFloat(localStorage.getItem('largestGapValue')) || 0
                        },
                        timestamp: new Date().toISOString()
                    };
                    $("#prioritizationData").val(JSON.stringify(prioritizationData));
                    console.log('Prioritization data collected:', prioritizationData);

                    // 2. Collect Overview Selection data (selected solutions, skipped solutions)
                    var overviewSelections = localStorage.getItem('rosraOverviewSelections');
                    var selectedSolutionsList = localStorage.getItem('rosraSelectedSolutions');
                    var selectedSolutionsData = {
                        selections: overviewSelections ? JSON.parse(overviewSelections) : {},
                        selectedSolutions: selectedSolutionsList ? JSON.parse(selectedSolutionsList) : [],
                        timestamp: new Date().toISOString()
                    };
                    $("#selectedSolutionsData").val(JSON.stringify(selectedSolutionsData));
                    console.log('Selected solutions data collected:', selectedSolutionsData);

                    // 3. Collect Implementation Progress data (milestone completions)
                    var implementationProgress = localStorage.getItem('rosraImplementationProgress');
                    var implementationProgressData = {
                        progress: implementationProgress ? JSON.parse(implementationProgress) : {},
                        timestamp: new Date().toISOString()
                    };
                    $("#implementationProgressData").val(JSON.stringify(implementationProgressData));
                    console.log('Implementation progress data collected:', implementationProgressData);

                    // 4. Collect Peer SNG data (Within-Country OSR Frontier analysis)
                    // Uses new data isolation schema: custom data stored per-report, not globally
                    var peerSNGData = {
                        dataSource: 'reference', // Default to reference data
                        countryCode: null,
                        customPeers: null,
                        selectedSNG: null,
                        analysisResults: {},
                        timestamp: new Date().toISOString()
                    };

                    // Get country code
                    var countrySelect = document.getElementById('country');
                    if (countrySelect && countrySelect.selectedIndex > 0) {
                        var selectedOption = countrySelect.options[countrySelect.selectedIndex];
                        peerSNGData.countryCode = selectedOption.dataset?.code || null;
                    }

                    // Check for custom peer data (from _PotentialEstimates.cshtml)
                    if (typeof window.getCustomPeerData === 'function') {
                        var customData = window.getCustomPeerData();
                        if (customData && customData.customPeers && customData.customPeers.length > 0) {
                            peerSNGData.dataSource = 'custom';
                            peerSNGData.customPeers = customData.customPeers;
                            peerSNGData.countryCode = customData.countryCode || peerSNGData.countryCode;
                            console.log('Custom peer data found:', customData.customPeers.length, 'peers');
                        }
                    }

                    // Try to get peer SNG selection from the page (peerSngSelectTop is the actual ID)
                    var peerSngSelect = $('#peerSngSelectTop');
                    if (peerSngSelect.length > 0 && peerSngSelect.val()) {
                        peerSNGData.selectedSNG = peerSngSelect.val();
                    }

                    // Try to get frontier analysis results from localStorage
                    var frontierData = localStorage.getItem('rosraPeerFrontierData');
                    if (frontierData) {
                        try {
                            peerSNGData.analysisResults = JSON.parse(frontierData);
                        } catch (e) {
                            console.warn('Could not parse frontier data:', e);
                        }
                    }

                    // Collect all visible frontier metrics from the DOM
