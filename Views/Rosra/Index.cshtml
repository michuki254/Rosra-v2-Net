                        fundingIndex: getMetricText('fundingIndex'),
                        fundingHeadroom: getMetricText('fundingHeadroom'),
                        nonGrantsShare: getMetricText('nonGrantsShare'),
                        peerBenchmarkAutonomy: getMetricText('peerBenchmarkAutonomy'),
                        autonomyIndex: getMetricText('autonomyIndex'),
                        distanceFromBenchmark: getMetricText('distanceFromBenchmark'),
                        positionRelative: getMetricText('positionRelative')
                    };

                    // Collect cross-country result text
                    var ccResultEl = document.getElementById('analysisResultText');
                    if (ccResultEl) {
                        peerSNGData.crossCountryResultText = ccResultEl.textContent.trim();
                    }

                    // Store chart data if available
                    if (window.peerFrontierChartData) {
                        peerSNGData.chartData = window.peerFrontierChartData;
                    }

                    $("#peerSNGData").val(JSON.stringify(peerSNGData));
                    console.log('Peer SNG data collected:', peerSNGData);
                }
                
                // Export PDF button click handler
                $("#exportPdfBtn").click(function() {
                    // Collect all tab data before export
                    collectTabDataFromLocalStorage();
