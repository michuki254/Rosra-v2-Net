@model RosraApp.Models.ViewModels.TabsContainerViewModel

@{
    ViewData["Title"] = "Rosra";
    bool isViewMode = ViewData["ViewMode"] != null && (bool)ViewData["ViewMode"];
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-12">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="mb-0">
                    @if (isViewMode)
                    {
                        <span>View Report: @Model.TabContentModel.Title</span>
                    }
                    else if (Model.TabContentModel.Id > 0)
                    {
                        <span>Edit Report: @Model.TabContentModel.Title</span>
                    }
                    else
                    {
                        <span>Rosra Analysis</span>
                    }
                </h2>
                <div class="action-buttons">
                    @if (!isViewMode)
                    {
                        <a asp-controller="Rosra" asp-action="NewReport" class="btn btn-primary me-2">
                            <i class="bi bi-plus-circle"></i> New Report
                        </a>
                        <button type="button" id="saveReportBtn" class="btn btn-success me-2">
                            <i class="bi bi-save"></i> @(Model.TabContentModel.Id > 0 ? "Update Report" : "Save Report")
                        </button>
                        <button type="button" id="exportAnalysisBtn" class="btn btn-primary">
                            <i class="bi bi-download"></i> Export Analysis
                        </button>
                    }
                    else
                    {
                        <a asp-controller="Rosra" asp-action="Edit" asp-route-id="@Model.TabContentModel.Id" class="btn btn-warning me-2">
                            <i class="bi bi-pencil"></i> Edit Report
                        </a>
                        <a href="#" class="btn btn-primary export-report me-2" data-id="@Model.TabContentModel.Id">
                            <i class="bi bi-download"></i> Export Analysis
                        </a>
                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Back to Dashboard
                        </a>
                    }
                </div>
            </div>
            
            <form id="rosraForm" method="post">
                <!-- Hidden field for report ID -->
                <input type="hidden" id="reportId" name="Id" value="@Model.TabContentModel.Id" />
                
                <!-- Hidden field for report title -->
                <input type="hidden" id="reportTitle" name="Title" value="@Model.TabContentModel.Title" />
                
                <!-- Hidden field for view mode state - only include if in view mode -->
                @if (isViewMode)
                {
                    <input type="hidden" id="isViewMode" name="IsViewMode" value="true" />
                }
                
                <!-- Tab Navigation Component -->
                <partial name="_TabNavigation" model="Model" />
                
                <!-- Hidden submit buttons for form actions -->
                @if (!isViewMode)
                {
                    <input type="submit" id="saveReportSubmit" name="action" value="SaveReport" formaction="@Url.Action("SaveReport", "Rosra")" style="display: none;" />
                    <input type="submit" id="exportAnalysisSubmit" name="action" value="ExportAnalysis" formaction="@Url.Action("ExportAnalysis", "Rosra")" style="display: none;" />
                }
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize Bootstrap tabs
            var triggerTabList = [].slice.call(document.querySelectorAll('#@Model.ContainerId button'))
            triggerTabList.forEach(function (triggerEl) {
                var tabTrigger = new bootstrap.Tab(triggerEl)
                triggerEl.addEventListener('click', function (event) {
                    event.preventDefault()
                    // Don't trigger tab show here as we're using form submission for tab navigation
                })
            })
            
            // Check if we're in view mode
            var isViewMode = @Json.Serialize(isViewMode);
            
            if (!isViewMode) {
                // Save Report button click handler
                $("#saveReportBtn").click(function() {
                    // Set a custom title if needed
                    var title = prompt("Enter a title for this report:", "@Model.TabContentModel.Title");
                    if (title) {
                        $("#reportTitle").val(title);
                    }
                    
                    // Submit the form to save the report
                    $("#saveReportSubmit").click();
                });
                
                // Export Analysis button click handler
                $("#exportAnalysisBtn").click(function() {
                    // Submit the form to export the analysis
                    $("#exportAnalysisSubmit").click();
                });
            } else {
                // Make all form fields read-only in view mode
                $("input, textarea, select").prop("readonly", true);
                $("button.btn-outline-secondary, button.btn-outline-danger, button.remove-root-cause, button.remove-action-item").hide();
                $(".input-group-append, .input-group button").hide();
            }
            
            // Export report functionality for view mode
            $('.export-report').click(function(e) {
                e.preventDefault();
                alert('Export functionality will be implemented in a future update.');
            });
        });
    </script>
}
