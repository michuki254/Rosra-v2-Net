                        var chartImages = captureAllCharts();
                        $('#chartImagesData').val(JSON.stringify(chartImages));
                    }
                    // Submit the form to export as PDF
                    $("#exportPdfSubmit").click();
                });

                // Export Excel button click handler
                $("#exportExcelBtn").click(function() {
                    // Collect all tab data before export
                    collectTabDataFromLocalStorage();
                    // Capture chart images for Excel embedding
                    if (typeof captureAllCharts === 'function') {
                        var chartImages = captureAllCharts();
                        $('#chartImagesData').val(JSON.stringify(chartImages));
                    }
                    // Submit the form to export as Excel
                    $("#exportExcelSubmit").click();
                });
            } else {
                // Make all form fields read-only in view mode
                $("input, textarea, select").prop("readonly", true);
                $("button.btn-outline-secondary, button.btn-outline-danger, button.remove-root-cause, button.remove-action-item").hide();
                $(".input-group-append, .input-group button").hide();
            }
            
            // Export report functionality for view mode
            $("#viewExportPdfBtn").click(function() {
                if (typeof captureAllCharts === 'function') {
                    $('#chartImagesData').val(JSON.stringify(captureAllCharts()));
                }
                document.getElementById('rosraForm').action = '@Url.Action("ExportPdf", "Rosra")';
                document.getElementById('rosraForm').submit();
            });
            $("#viewExportExcelBtn").click(function() {
                if (typeof captureAllCharts === 'function') {
                    $('#chartImagesData').val(JSON.stringify(captureAllCharts()));
                }
                document.getElementById('rosraForm').action = '@Url.Action("ExportExcel", "Rosra")';
                document.getElementById('rosraForm').submit();
            });
            // Helper: save session, then open print page with auto-print
            function openPrintPage(printUrl) {
                if (typeof collectTabDataFromLocalStorage === 'function') collectTabDataFromLocalStorage();
                $.ajax({
                    url: '@Url.Action("AutoSaveReport", "Rosra")',
                    type: 'POST',
                    data: $("#rosraForm").serialize(),
                    success: function(r) {
                        if (r.success && r.reportId && parseInt($("#reportId").val()) === 0) {
                            $("#reportId").val(r.reportId);
                        }
                        window.open(printUrl + '?autoPrint=true', '_blank');
                    },
                    error: function() {
                        window.open(printUrl + '?autoPrint=true', '_blank');
                    }
                });
            }

            // Print Top-Down
            $("#printTopDownBtn").click(function() {
                openPrintPage('@Url.Action("PrintTopDown", "Rosra")');
            });

            // Print Bottom-Up
            $("#printBottomUpBtn").click(function() {
                openPrintPage('@Url.Action("PrintBottomUp", "Rosra")');
            });

            // Print Full Report
            $("#printFullReportBtn").click(function() {
                openPrintPage('@Url.Action("PrintFullReport", "Rosra")');
            });
        });

        // --- Submit for Review ---
        @if (!isViewMode && (User.Identity?.IsAuthenticated ?? false))
        {
            <text>
            $("#submitForReviewBtn").click(function() {
                var submitModal = new bootstrap.Modal(document.getElementById('submitForReviewModal'));
                submitModal.show();
            });

            $("#confirmSubmitBtn").click(function() {
                // Close the modal
                bootstrap.Modal.getInstance(document.getElementById('submitForReviewModal')).hide();

                var btn = $("#submitForReviewBtn");
                btn.prop('disabled', true).html('<i class="bi bi-hourglass-split me-1"></i><span>@RosraLocalizer["Sidebar_Submitting"].Value</span>');

                // Collect latest data from localStorage before saving
                if (typeof collectTabDataFromLocalStorage === 'function') {
                    collectTabDataFromLocalStorage();
                }

                // Auto-generate title if missing
                var title = $("#reportTitle").val();
                if (!title) {
                    var country = $("#country option:selected").text().trim();
                    var region = $("#region option:selected").text().trim();
                    title = "ROSRA Report";
                    if (country && country !== "Select Country" && country !== "") {
                        title += " - " + country;
                        if (region && region !== "Select Region/State" && region !== "") {
                            title += " - " + region;
                        }
                    }
                    $("#reportTitle").val(title);
                }

                // Step 1: Auto-save the report first to ensure all data is persisted
                $.ajax({
                    url: '@Url.Action("AutoSaveReport", "Rosra")',
                    type: 'POST',
                    data: $("#rosraForm").serialize(),
                    success: function(saveResult) {
                        if (!saveResult.success) {
                            alert("Error saving report: " + saveResult.message);
                            btn.prop('disabled', false).html('<i class="bi bi-send me-1"></i><span>@RosraLocalizer["Sidebar_SubmitForReview"].Value</span>');
                            return;
                        }

                        var reportId = saveResult.reportId;
                        // Update the hidden fields
                        if (reportId && parseInt($("#reportId").val()) === 0) {
                            $("#reportId").val(reportId);
                        }
                        if (saveResult.publicId) {
                            $("#reportPublicId").val(saveResult.publicId);
                        }
                        if (saveResult.rowVersion) {
                            $('input[name="RowVersion"]').val(saveResult.rowVersion);
                        }

                        // Step 2: Submit the saved report for review (uses int id internally)
                        $.ajax({
                            url: '@Url.Action("Submit", "Submission")/' + reportId,
                            type: 'POST',
                            data: { __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() },
                            success: function(r) {
                                if (r.success) {
                                    window.location.href = '@Url.Action("Index", "Dashboard")';
                                } else {
                                    alert("Error: " + r.message);
                                    btn.prop('disabled', false).html('<i class="bi bi-send me-1"></i><span>@RosraLocalizer["Sidebar_SubmitForReview"].Value</span>');
                                }
                            },
                            error: function() {
                                alert("An error occurred while submitting. Please try again.");
                                btn.prop('disabled', false).html('<i class="bi bi-send me-1"></i><span>@RosraLocalizer["Sidebar_SubmitForReview"].Value</span>');
                            }
                        });
                    },
                    error: function() {
                        alert("An error occurred while saving the report. Please try again.");
                        btn.prop('disabled', false).html('<i class="bi bi-send me-1"></i><span>@RosraLocalizer["Sidebar_SubmitForReview"].Value</span>');
                    }
                });
            });
            </text>
        }
    </script>

    @* Include authentication modal script for unauthenticated users *@
    @if (!(User.Identity?.IsAuthenticated ?? false))
    {
        <script src="~/js/authModal.js" asp-append-version="true"></script>
    }

    <!-- Sidebar Navigation Script -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Sidebar umbrella tab navigation
            document.querySelectorAll('.sidebar-nav-item').forEach(function(navItem) {
                navItem.addEventListener('click', function(e) {
                    e.preventDefault();

                    var umbrellaId = this.getAttribute('data-umbrella-id');
                    document.getElementById('umbrellaTabIdInput').value = umbrellaId;

                    // Get the first sub-tab of the clicked umbrella tab
                    var umbrellaContent = document.getElementById(umbrellaId + '-umbrella-content');
                    if (umbrellaContent) {
                        var firstSubTab = umbrellaContent.querySelector('[data-tab-id]');
                        if (firstSubTab) {
                            document.getElementById('tabIdInput').value = firstSubTab.getAttribute('data-tab-id');
                        }
                    }

                    // Submit form to switch tabs
                    document.getElementById('rosraForm').action = '@Url.Action("SwitchTab", "Rosra")';
                    document.getElementById('rosraForm').submit();
                });
            });
        });
    </script>
}
