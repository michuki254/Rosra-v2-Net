@model RosraApp.Models.ViewModels.TabsContainerViewModel
@inject IHtmlLocalizer<RosraApp.RosraResources> RosraLocalizer

@{
    ViewData["Title"] = "Rosra";
    bool isViewMode = ViewData["ViewMode"] != null && (bool)ViewData["ViewMode"];
}

@section Styles {
    <style>
        /* UN-Habitat Official Brand Colors */
        :root {
            --un-blue: #00b2e3;
            --un-dark-blue: #00689D;
            --un-orange: #FD9D24;
            --un-orange-dark: #E8891A;
            --un-light-bg: #E6F9FC;
            --un-light-gray: #F5F5F5;
            --font-primary: 'Roboto', Calibri, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Ensure Roboto font is used throughout the Rosra page */
        .rosra-full-page,
        .rosra-full-page * {
            font-family: var(--font-primary);
        }

        .rosra-full-page h1,
        .rosra-full-page h2,
        .rosra-full-page h3,
        .rosra-full-page h4,
        .rosra-full-page h5,
        .rosra-full-page h6 {
            font-family: var(--font-primary);
            font-weight: 700;
        }

        .alert-success {
            background: var(--un-light-bg);
            border-left: 4px solid var(--un-blue);
            border-radius: 12px;
            color: var(--un-dark-blue);
            margin: 1rem;
        }

        #rosraForm {
            background: white;
            border-radius: 0;
            padding: 0;
            box-shadow: none;
            width: 100%;
            margin: 0;
        }

        /* Full-page layout for Rosra - override leaked CSS from JS template literals */
        body {
            max-width: none !important;
            padding: 0 !important;
            margin: 0 !important;
            margin-bottom: 230px !important;
        }

        /* When modal is open, prevent double scrollbar but keep layout stable */
        body.modal-open {
            overflow: hidden !important;
            padding-right: 0 !important;
        }

        /* Footer Separator */
        .footer-separator {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1.5rem;
            background: #ffffff;
            margin-top: 0;
        }

        .footer-separator .separator-line {
            flex: 1;
            height: 1px;
            background: #e5e7eb;
            max-width: 200px;
        }

        .footer-separator .separator-content {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1.5rem;
            background: white;
            border-radius: 50px;
            border: none;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
            margin: 0 1.5rem;
        }

        .footer-separator .separator-content i {
            color: var(--un-orange);
            font-size: 1.25rem;
        }

        .footer-separator .separator-content span {
            color: var(--un-dark-blue);
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Full-page layout container */
        .rosra-full-page {
            min-height: calc(100vh - 80px);
            width: 100%;
            padding: 0 24px;
            padding-bottom: 40px;
            display: flex;
            flex-direction: column;
            background: #ffffff;
        }

        /* Main content wrapper - flexbox row layout */
        .rosra-content-wrapper {
            width: 100%;
            padding: 0;
            margin: 0;
            flex: 1;
            display: flex;
            flex-direction: row;
        }

        /* Left Sidebar Styles */
        .rosra-sidebar {
            width: 280px;
            min-width: 220px;
            flex-shrink: 0;
            background: #ffffff;
            border-right: 1px solid #e8e8e8;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            position: sticky;
            top: 80px;
            height: fit-content;
            max-height: calc(100vh - 100px);
            overflow-y: auto;
        }

        .sidebar-section {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .sidebar-section-header {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--un-dark-blue);
            padding-bottom: 0.5rem;
            border-bottom: 2px solid var(--un-light-bg);
            margin-bottom: 0.25rem;
        }

        .sidebar-section-header i {
            margin-right: 0.5rem;
        }

        /* Sidebar Action Buttons */
        .sidebar-btn {
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 0.75rem;
            width: 100%;
            padding: 0.75rem 1rem;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.85rem;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
            text-decoration: none;
        }

        .sidebar-btn i {
            font-size: 1.1rem;
            width: 20px;
            text-align: center;
        }

        .sidebar-btn-primary {
            background: var(--un-blue);
            color: white;
            box-shadow: 0 4px 12px rgba(0, 178, 227, 0.25);
        }

        .sidebar-btn-primary:hover {
            background: #0099c7;
            box-shadow: 0 6px 16px rgba(0, 178, 227, 0.3);
            color: white;
        }

        .sidebar-btn-secondary {
            background: var(--un-orange);
            color: white;
            box-shadow: 0 4px 12px rgba(253, 157, 36, 0.25);
        }

        .sidebar-btn-secondary:hover {
            background: var(--un-orange-dark);
            box-shadow: 0 6px 16px rgba(253, 157, 36, 0.3);
            color: white;
        }

        .sidebar-btn-outline {
            background: #F7F7F7;
            color: var(--un-dark-blue);
        }

        .sidebar-btn-outline:hover {
            background: #E6F9FC;
            color: var(--un-blue);
        }

        /* Export Dropdown in Sidebar */
        .sidebar-dropdown {
            position: relative;
            width: 100%;
        }

        .sidebar-dropdown .dropdown-toggle {
            width: 100%;
            justify-content: space-between;
        }

        .sidebar-dropdown .dropdown-toggle::after {
            margin-left: auto;
        }

        .sidebar-dropdown .dropdown-menu {
            width: 100%;
            border-radius: 12px;
            box-shadow: 0 4px 20px -4px rgba(0, 0, 0, 0.15);
            border: none;
            padding: 0.5rem;
        }

        .sidebar-dropdown .dropdown-item {
            border-radius: 8px;
            padding: 0.6rem 1rem;
            font-weight: 500;
            transition: all 0.2s ease;
        }

        .sidebar-dropdown .dropdown-item:hover {
            background: var(--un-light-bg);
        }

        /* Sidebar Analysis Type Navigation */
        .sidebar-nav {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .sidebar-nav-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            width: 100%;
            padding: 0.75rem 1rem;
            border-radius: 10px;
            font-weight: 600;
            font-size: 0.85rem;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
            background: #F7F7F7;
            color: var(--un-dark-blue);
            text-align: left;
        }

        .sidebar-nav-item i {
            font-size: 1.1rem;
            width: 24px;
            text-align: center;
        }

        .sidebar-nav-item:hover {
            background: #E6F9FC;
            color: var(--un-blue);
        }

        .sidebar-nav-item.active {
            background: var(--un-blue);
            color: white;
            box-shadow: 0 4px 12px rgba(0, 178, 227, 0.25);
        }

        .sidebar-nav-item.active i {
            color: white;
        }

        /* Sidebar Divider */
        .sidebar-divider {
            height: 1px;
            background: #e0e0e0;
            margin: 0.5rem 0;
        }

        /* Main Content Area */
        .rosra-main-content {
            flex: 1;
            padding: 1.5rem 2rem;
            background: #ffffff;
            min-width: 0;
        }

        /* Cards - BizFlow pop-out style */
        .rosra-main-content .input-card,
        .rosra-main-content .frontier-card,
        .rosra-main-content .compact-card {
            background: #fff;
            border: none;
            border-radius: 12px;
            margin-bottom: 1.5rem;
            overflow: hidden;
            box-shadow: 0 2px 20px -4px rgba(0, 0, 0, 0.1);
            transition: box-shadow 0.3s ease;
        }

        .rosra-main-content .input-card:hover,
        .rosra-main-content .frontier-card:hover,
        .rosra-main-content .compact-card:hover {
            box-shadow: 0 8px 30px -4px rgba(0, 0, 0, 0.15);
        }

        /* Card headers - BizFlow style */
        .rosra-main-content .input-card-header,
        .rosra-main-content .compact-header {
            background: white;
            border-bottom: 1px solid #f0f0f0;
            border-left: none;
            padding: 1.25rem 1.5rem;
        }

        .rosra-main-content .compact-header {
            background: white !important;
        }

        .rosra-main-content .compact-header .header-icon,
        .rosra-main-content .input-card-header .header-icon {
            background: var(--un-blue);
            width: 36px;
            height: 36px;
            border-radius: 10px;
            box-shadow: 0 4px 12px rgba(0, 178, 227, 0.25);
        }

        .rosra-main-content .compact-header .card-title,
        .rosra-main-content .input-card-header .card-title {
            color: var(--un-dark-blue);
            font-size: 1rem;
            font-weight: 600;
        }

        .rosra-main-content .compact-header .card-subtitle,
        .rosra-main-content .input-card-header .card-subtitle {
            color: #666;
            font-size: 0.8rem;
        }

        .rosra-main-content .compact-header .collapse-icon {
            color: var(--un-dark-blue);
        }

        /* Frontier card header */
        .rosra-main-content .frontier-header {
            background: var(--un-blue) !important;
            padding: 1.25rem 1.5rem;
        }

        .rosra-main-content .frontier-header-icon {
            background: rgba(255, 255, 255, 0.2);
            color: white;
            width: 44px;
            height: 44px;
        }

        .rosra-main-content .frontier-title {
            color: white;
        }

        .rosra-main-content .frontier-subtitle {
            color: rgba(255, 255, 255, 0.85);
        }

        /* Card body padding */
        .rosra-main-content .input-card-body,
        .rosra-main-content .compact-body {
            padding: 1.5rem 2rem;
        }

        .rosra-main-content .frontier-content {
            padding: 1.5rem 2rem;
        }

        /* Nested sections inside cards */
        .rosra-main-content .frontier-section,
        .rosra-main-content .module2-section {
            background: #F7F7F7;
            border-radius: 10px;
            padding: 1.25rem;
            margin-bottom: 1rem;
            border: none;
        }

        /* Intro boxes */
        .rosra-main-content .intro-text-box,
        .rosra-main-content .top-down-intro-section .intro-text-box,
        .rosra-main-content .bottom-up-intro-section .intro-text-box {
            background: #F7F7F7;
            border-left: 4px solid var(--un-blue);
            border-radius: 0 10px 10px 0;
        }

        /* Tab system - no side margins */
        .tab-system {
            margin: 0 !important;
            padding: 0 !important;
        }

        /* Umbrella tab content - transparent container */
        .umbrella-tab-content {
            padding: 0 !important;
            margin: 0 !important;
            border-radius: 0 !important;
            background: transparent !important;
        }

        /* Stepper container */
        .stepper-container {
            margin: 0 0 1.5rem 0 !important;
            border-radius: 12px !important;
            background: #fff !important;
            border: none !important;
            box-shadow: 0 2px 20px -4px rgba(0, 0, 0, 0.1) !important;
        }

        /* Stepper content - transparent, cards inside will pop */
        .stepper-content,
        .single-tab-content {
            padding: 0 !important;
            margin: 0 !important;
            border-radius: 0 !important;
            background: transparent !important;
            box-shadow: none !important;
        }

        /* Force all tab content to full width */
        .rosra-full-page .tab-system,
        .rosra-full-page .sub-tab-content,
        .rosra-full-page .tab-pane,
        .rosra-full-page .sub-tab-pane {
            width: 100% !important;
            max-width: 100% !important;
            margin-left: 0 !important;
            margin-right: 0 !important;
        }

        /* Tab Navigation Styles */
        .nav-tabs {
            border-bottom: 2px solid #E0E0E0;
            margin-bottom: 1.5rem;
        }

        .nav-tabs .nav-link {
            color: var(--un-dark-blue);
            border: none;
            border-bottom: 3px solid transparent;
            font-weight: 600;
            padding: 0.75rem 1.5rem;
            transition: all 0.3s ease;
        }

        .nav-tabs .nav-link:hover {
            color: var(--un-orange);
            border-bottom-color: rgba(253, 157, 36, 0.3);
        }

        .nav-tabs .nav-link.active {
            color: var(--un-orange);
            background: transparent;
            border-bottom-color: var(--un-orange);
        }

        /* Form Styling */
        .form-control {
            border-radius: 10px;
            border: 1px solid #DDDDDD;
            background: #F7F7F7;
            padding: 0.625rem 0.875rem;
            transition: all 0.2s ease;
        }

        .form-control:focus {
            border-color: var(--un-blue);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(0, 178, 227, 0.1);
        }

        .form-label {
            color: var(--un-dark-blue);
            font-weight: 600;
            font-size: 0.875rem;
            margin-bottom: 0.5rem;
        }

        /* Responsive Design */
        @@media (max-width: 992px) {
            .rosra-content-wrapper {
                flex-direction: column;
            }

            .rosra-sidebar {
                width: 100%;
                max-width: 100%;
                min-width: 100%;
                flex-direction: row;
                flex-wrap: wrap;
                gap: 1rem;
                padding: 1rem;
                position: relative;
                height: auto;
                max-height: none;
                border-right: none;
                border-bottom: 1px solid #e0e0e0;
                background: #f8f9fa;
            }

            .sidebar-section {
                flex: 1;
                min-width: 200px;
            }

            .sidebar-nav {
                flex-direction: row;
                flex-wrap: wrap;
            }

            .sidebar-nav-item {
                flex: 1;
                min-width: 150px;
                justify-content: center;
            }
        }

        @@media (max-width: 991px) {
            .rosra-full-page {
                padding: 16px;
            }
        }

        @@media (max-width: 768px) {
            .rosra-full-page {
                padding: 10px 16px;
            }

            .rosra-sidebar {
                flex-direction: column;
                gap: 1rem;
            }

            .sidebar-section {
                min-width: 100%;
            }

            .sidebar-nav {
                flex-direction: column;
            }

            .sidebar-nav-item {
                justify-content: flex-start;
            }

            .sidebar-btn {
                padding: 0.6rem 0.875rem;
                font-size: 0.8rem;
            }
        }
    </style>
}

@{
    var hasUmbrellaTabs = Model.UmbrellaTabs != null && Model.UmbrellaTabs.Any();
    var activeUmbrellaTab = hasUmbrellaTabs ? Model.UmbrellaTabs.FirstOrDefault(u => u.IsActive) : null;
}

<script>
    // Immediate scroll fix - runs before content renders
    if ('scrollRestoration' in history) { history.scrollRestoration = 'manual'; }
    // Removed window.scrollTo(0, 0) to prevent snapping issue
</script>
<div class="rosra-full-page">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="rosra-content-wrapper">
        <!-- Left Sidebar -->
        <aside class="rosra-sidebar">
            <!-- Analysis Type Section -->
            @if (hasUmbrellaTabs)
            {
                <div class="sidebar-section">
                    <div class="sidebar-section-header">
                        <i class="bi bi-diagram-3"></i>@RosraLocalizer["Sidebar_AnalysisType"]
                    </div>
                    <nav class="sidebar-nav">
                        @foreach (var umbrellaTab in Model.UmbrellaTabs)
                        {
                            <button type="button"
                                    class="sidebar-nav-item @(umbrellaTab.IsActive ? "active" : "")"
                                    data-umbrella-id="@umbrellaTab.Id"
                                    id="sidebar-@umbrellaTab.Id-btn">
                                <i class="@umbrellaTab.Icon"></i>
                                <span>@umbrellaTab.Title</span>
                            </button>
                        }
                    </nav>
                </div>

                <div class="sidebar-divider"></div>
            }

            <!-- Report Info (if editing existing report) -->
            @if (Model.TabContentModel.Id > 0)
            {
                <div class="sidebar-section">
                    <div class="sidebar-section-header">
                        <i class="bi bi-info-circle"></i>@RosraLocalizer["Sidebar_ReportInfo"]
                    </div>
                    <div style="font-size: 0.85rem; color: #666;">
                        <div><strong>@RosraLocalizer["Sidebar_Title"]</strong> @Model.TabContentModel.Title</div>
                        @if (!string.IsNullOrEmpty(Model.TabContentModel.Country))
                        {
                            <div><strong>@RosraLocalizer["Sidebar_Country"]</strong> @Model.TabContentModel.Country</div>
                        }
                        @if (!string.IsNullOrEmpty(Model.TabContentModel.Region))
                        {
                            <div><strong>@RosraLocalizer["Sidebar_Region"]</strong> @Model.TabContentModel.Region</div>
                        }
                    </div>
                </div>

                <div class="sidebar-divider"></div>
            }

            <!-- Report Actions Section -->
            <div class="sidebar-section">
                <div class="sidebar-section-header">
                    <i class="bi bi-lightning-charge"></i>@RosraLocalizer["Sidebar_ReportActions"]
                </div>
                @if (!isViewMode)
                {
                    <a asp-controller="Rosra" asp-action="NewReport" class="sidebar-btn sidebar-btn-primary">
                        <span>@RosraLocalizer["Sidebar_NewReport"]</span>
                    </a>
                    <a asp-controller="Rosra" asp-action="LoadSampleData" class="sidebar-btn" style="background: #f0f9ff; color: #0369a1; border: 1px solid #bae6fd; border-radius: 6px; padding: 0.5rem 1rem; font-weight: 500; cursor: pointer; width: 100%; text-align: center; text-decoration: none; display: block; margin-top: 0.25rem;">
                        <i class="bi bi-database me-1"></i>
                        <span>@RosraLocalizer["Sidebar_LoadSampleData"]</span>
                    </a>
                    <button type="button" id="saveReportBtn" class="sidebar-btn sidebar-btn-secondary">
                        <i class="bi bi-save me-1"></i>
                        <span>@(Model.TabContentModel.Id > 0 ? RosraLocalizer["Sidebar_UpdateReport"].Value : RosraLocalizer["Sidebar_SaveAsDraft"].Value)</span>
                    </button>
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <button type="button" id="submitForReviewBtn" class="sidebar-btn" style="background: #10b981; color: white; border: none; border-radius: 6px; padding: 0.5rem 1rem; font-weight: 500; cursor: pointer; width: 100%; text-align: center; margin-top: 0.25rem;">
                            <i class="bi bi-send me-1"></i>
                            <span>@RosraLocalizer["Sidebar_SubmitForReview"]</span>
                        </button>
                    }
                    <div class="sidebar-dropdown dropdown">
                        <button type="button" class="sidebar-btn sidebar-btn-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                            <span>@RosraLocalizer["Sidebar_Export"]</span>
                        </button>
                        <ul class="dropdown-menu">
                            <li><button type="button" class="dropdown-item" id="exportPdfBtn"><i class="bi bi-file-pdf text-danger me-2"></i>@RosraLocalizer["Sidebar_ExportPdf"]</button></li>
                            <li><button type="button" class="dropdown-item" id="exportExcelBtn"><i class="bi bi-file-earmark-excel text-success me-2"></i>@RosraLocalizer["Sidebar_ExportExcel"]</button></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><button type="button" class="dropdown-item" id="printTopDownBtn"><i class="bi bi-bar-chart text-primary me-2"></i>@RosraLocalizer["Sidebar_TopDownPrint"]</button></li>
                            <li><button type="button" class="dropdown-item" id="printBottomUpBtn"><i class="bi bi-layers text-success me-2"></i>@RosraLocalizer["Sidebar_BottomUpPrint"]</button></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><button type="button" class="dropdown-item" id="printFullReportBtn"><i class="bi bi-file-earmark-text text-info me-2"></i>@RosraLocalizer["Sidebar_FullReportPrint"]</button></li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-controller="Rosra" asp-action="Edit" asp-route-id="@Model.TabContentModel.PublicId" class="sidebar-btn sidebar-btn-primary">
                        <span>@RosraLocalizer["Sidebar_EditReport"]</span>
                    </a>
                    <div class="sidebar-dropdown dropdown">
                        <button type="button" class="sidebar-btn sidebar-btn-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                            <span>@RosraLocalizer["Sidebar_Export"]</span>
                        </button>
                        <ul class="dropdown-menu">
                            <li><button type="button" class="dropdown-item" id="viewExportPdfBtn"><i class="bi bi-file-pdf text-danger me-2"></i>@RosraLocalizer["Sidebar_ExportPdf"]</button></li>
                            <li><button type="button" class="dropdown-item" id="viewExportExcelBtn"><i class="bi bi-file-earmark-excel text-success me-2"></i>@RosraLocalizer["Sidebar_ExportExcel"]</button></li>
                        </ul>
                    </div>
                    <a asp-controller="Dashboard" asp-action="Index" class="sidebar-btn sidebar-btn-outline">
                        <span>@RosraLocalizer["Sidebar_BackToDashboard"]</span>
                    </a>
                }
            </div>
        </aside>

        <!-- Main Content Area -->
        <div class="rosra-main-content">
            <form id="rosraForm" method="post">
                @Html.AntiForgeryToken()
                <!-- Hidden field for report ID -->
                <input type="hidden" id="reportId" name="Id" value="@Model.TabContentModel.Id" />
                <input type="hidden" id="reportPublicId" name="PublicId" value="@Model.TabContentModel.PublicId" />
                <input type="hidden" name="RowVersion" value="@Model.TabContentModel.RowVersion" />

                <!-- Hidden field for report title -->
                <input type="hidden" id="reportTitle" name="Title" value="@Model.TabContentModel.Title" />

                <!-- Hidden fields for tab data (populated from localStorage before save) -->
                <input type="hidden" id="prioritizationData" name="PrioritizationData" value="@Model.TabContentModel.PrioritizationData" />
                <input type="hidden" id="selectedSolutionsData" name="SelectedSolutionsData" value="@Model.TabContentModel.SelectedSolutionsData" />
                <input type="hidden" id="implementationProgressData" name="ImplementationProgressData" value="@Model.TabContentModel.ImplementationProgressData" />
                <input type="hidden" id="peerSNGData" name="PeerSNGData" value="@Model.TabContentModel.PeerSNGData" />
                <input type="hidden" id="chartImagesData" name="ChartImagesData" />

                <!-- Hidden field for view mode state - only include if in view mode -->
                @if (isViewMode)
                {
                    <input type="hidden" id="isViewMode" name="IsViewMode" value="true" />
                }
                
                <!-- Tab Navigation Component -->
                <partial name="_TabNavigation" model="Model" />
                
                <!-- Hidden submit buttons for form actions -->
                @if (!isViewMode)
                {
                    <input type="submit" id="saveReportSubmit" name="action" value="SaveReport" formaction="@Url.Action("SaveReport", "Rosra")" style="display: none;" />
                    <input type="submit" id="exportAnalysisSubmit" name="action" value="ExportAnalysis" formaction="@Url.Action("ExportAnalysis", "Rosra")" style="display: none;" />
                    <input type="submit" id="exportPdfSubmit" name="action" value="ExportPdf" formaction="@Url.Action("ExportPdf", "Rosra")" style="display: none;" />
                    <input type="submit" id="exportExcelSubmit" name="action" value="ExportExcel" formaction="@Url.Action("ExportExcel", "Rosra")" style="display: none;" />
                }
