                        subnationalGDP: getMetricText('m2SubnationalGDPTop'),
                        frontierMultiplier: getMetricText('m2FrontierMultiplierTop'),
                        subjectMultiplier: getMetricText('m2SubjectMultiplierTop'),
                        osrPotential: getMetricText('m2OSRPotentialTop'),
                        osrGap: getMetricText('m2OSRGapTop'),
