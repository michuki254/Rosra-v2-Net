@model RosraApp.Models.ViewModels.RosraFormViewModel
@{
    Layout = null;
    ViewData["ViewMode"] = true;
    var cs = Model.CurrencySymbol ?? "$";
}
@functions {
    public string GetCountryCode(string country)
    {
        if (string.IsNullOrEmpty(country)) return "";
        var codes = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            {"Kenya","ke"},{"Nigeria","ng"},{"South Africa","za"},{"Egypt","eg"},{"Ethiopia","et"},
            {"Ghana","gh"},{"Tanzania","tz"},{"Uganda","ug"},{"Rwanda","rw"},{"Morocco","ma"},
            {"Algeria","dz"},{"Senegal","sn"},{"Cameroon","cm"},{"Zambia","zm"},{"Zimbabwe","zw"},
            {"Botswana","bw"},{"Namibia","na"},{"Mozambique","mz"},{"Mali","ml"},{"Burkina Faso","bf"},
            {"Ivory Coast","ci"},{"Cote d'Ivoire","ci"},{"Malawi","mw"},{"Benin","bj"},{"Togo","tg"},
            {"Niger","ne"},{"Sierra Leone","sl"},{"Liberia","lr"},
            {"United Kingdom","gb"},{"UK","gb"},{"Britain","gb"},{"France","fr"},{"Germany","de"},
            {"Italy","it"},{"Spain","es"},{"Netherlands","nl"},{"Belgium","be"},{"Switzerland","ch"},
            {"Sweden","se"},{"Norway","no"},{"Portugal","pt"},{"Poland","pl"},{"Denmark","dk"},
            {"Finland","fi"},{"Austria","at"},{"Ireland","ie"},{"Greece","gr"},{"Czech Republic","cz"},
            {"Romania","ro"},{"Hungary","hu"},
            {"United States","us"},{"United States of America","us"},{"USA","us"},{"Canada","ca"},
            {"Mexico","mx"},{"Brazil","br"},{"Argentina","ar"},{"Chile","cl"},{"Colombia","co"},
            {"Peru","pe"},{"Venezuela","ve"},{"Ecuador","ec"},{"Bolivia","bo"},{"Paraguay","py"},
            {"Uruguay","uy"},{"Costa Rica","cr"},{"Panama","pa"},{"Guatemala","gt"},{"Honduras","hn"},
            {"El Salvador","sv"},{"Nicaragua","ni"},{"Jamaica","jm"},{"Trinidad and Tobago","tt"},
            {"China","cn"},{"India","in"},{"Japan","jp"},{"Singapore","sg"},{"South Korea","kr"},
            {"Korea","kr"},{"Thailand","th"},{"Indonesia","id"},{"Malaysia","my"},{"Philippines","ph"},
            {"Vietnam","vn"},{"Pakistan","pk"},{"Bangladesh","bd"},{"Sri Lanka","lk"},{"Nepal","np"},
            {"Myanmar","mm"},{"Cambodia","kh"},{"Taiwan","tw"},{"Hong Kong","hk"},
            {"UAE","ae"},{"United Arab Emirates","ae"},{"Saudi Arabia","sa"},{"Israel","il"},
            {"Turkey","tr"},{"Iran","ir"},{"Iraq","iq"},{"Jordan","jo"},{"Lebanon","lb"},
            {"Kuwait","kw"},{"Qatar","qa"},{"Oman","om"},{"Bahrain","bh"},
            {"Australia","au"},{"New Zealand","nz"},{"Fiji","fj"},{"Papua New Guinea","pg"},
            {"Russia","ru"},{"Ukraine","ua"},{"Kazakhstan","kz"},{"Uzbekistan","uz"}
        };
        return codes.TryGetValue(country, out var code) ? code : "";
    }
}
@{
    var countryCode = GetCountryCode(Model.Country);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="~/images/LogoFavicon.png" />
    <title>Top-Down Analysis — @(Model.Country ?? "ROSRA")</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RosraApp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css">
    <style>
        * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; color-adjust: exact !important; }
        body { font-family: 'Roboto', sans-serif; margin: 0; padding: 0; background: #fff; }

        /* ============================
           COVER PAGE
           ============================ */
        /* ── Outer box wrapping everything ── */
        .report-box {
            max-width: 960px;
            margin: 0 auto;
            background: #fff;
            overflow: hidden;
        }

        .cover-page {
            width: 100%;
            min-height: 100vh;
            background: #009EDB;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            page-break-after: always;
            box-sizing: border-box;
        }

        /* City background image overlay */
        .cover-bg-image {
            position: absolute;
            inset: 0;
            z-index: 0;
        }
        .cover-bg-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.12;
        }
        /* Solid color overlay on top of bg image */
        .cover-page::before {
            content: '';
            position: absolute;
            inset: 0;
            background: #009EDB;
            opacity: 0.88;
            z-index: 0;
        }

        /* ── Top section with circles ── */
        .cover-top {
            position: relative;
            z-index: 1;
            flex: 1;
            min-height: 420px;
        }

        /* Main large circle with city image */
        .cover-circle-main {
            width: 340px;
            height: 340px;
            border-radius: 50%;
            overflow: hidden;
            border: 3px dashed rgba(255,255,255,0.25);
            position: absolute;
            top: 60px;
            left: 50%;
            transform: translateX(-50%);
            box-shadow: none;
            z-index: 1;
        }
        .cover-circle-main img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Small accent squares */
        .cover-circle-sm {
            width: 75px;
            height: 75px;
            border-radius: 8px;
            overflow: hidden;
            border: 2px solid rgba(255,255,255,0.3);
            position: absolute;
            z-index: 2;
            box-shadow: none;
        }
        .cover-circle-sm img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        /* Top-right */
        .cover-circle-sm-1 { top: 50px; left: calc(50% + 170px); }
        /* Bottom-left — overlapping main circle edge */
        .cover-circle-sm-2 { top: 330px; left: calc(50% - 200px); }
        /* Right — mid height */
        .cover-circle-sm-3 { top: 200px; left: calc(50% + 185px); }

        /* Decorative dashed orbit ring */
        .cover-orbit {
            position: absolute;
            width: 420px;
            height: 420px;
            border: 2px dashed rgba(255,255,255,0.12);
            border-radius: 50%;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 0;
        }

        /* ── Title section ── */
        .cover-title-section {
            position: relative;
            z-index: 2;
            padding: 0 50px 0 50px;
        }
        .cover-title {
            font-size: 44px;
            font-weight: 700;
            color: #ffffff;
            line-height: 1.15;
            margin: 0 0 8px;
            text-shadow: 0 2px 20px rgba(0,0,0,0.3);
        }
        .cover-subtitle {
            font-size: 22px;
            font-weight: 300;
            color: rgba(255,255,255,0.85);
            margin: 0 0 16px;
        }
        .cover-location {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }
        .cover-flag {
            font-size: 32px;
            line-height: 1;
            border-radius: 4px;
            overflow: hidden;
            box-shadow: none;
        }
        .cover-country-name {
            font-size: 26px;
            font-weight: 500;
            color: #fff;
        }
        .cover-location-detail {
            font-size: 15px;
            color: rgba(255,255,255,0.75);
            margin-top: 2px;
        }
        .cover-location-detail span + span::before {
            content: '  |  ';
            opacity: 0.5;
        }

        /* ── Bottom geometric blocks ── */
        .cover-bottom {
            position: relative;
            z-index: 1;
            height: 220px;
            margin-top: auto;
            overflow: hidden;
        }
        /* Color blocks — UN-Habitat blue palette */
        .cover-block {
            position: absolute;
            border-radius: 0;
        }
        .cover-block-1 {
            width: 120px; height: 220px;
            background: #00b2e3;
            left: 0; bottom: 0;
        }
        .cover-block-2 {
            width: 140px; height: 140px;
            left: 120px; bottom: 80px;
            overflow: hidden;
            border-radius: 4px;
        }
        .cover-block-2 img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }
        .cover-block-3 {
            width: 140px; height: 80px;
            background: #00689D;
            left: 120px; bottom: 0;
        }
        /* Large decorative circle */
        .cover-circle-deco {
            width: 320px;
            height: 320px;
            border-radius: 50%;
            position: absolute;
            right: -20px;
            bottom: -60px;
            overflow: hidden;
        }
        .cover-circle-deco-inner {
            width: 100%;
            height: 100%;
            position: relative;
        }
        .cover-circle-deco-inner::before {
            content: '';
            position: absolute;
            width: 50%;
            height: 100%;
            left: 0;
            background: #005a87;
        }
        .cover-circle-deco-inner::after {
            content: '';
            position: absolute;
            width: 50%;
            height: 100%;
            right: 0;
            background: #00b2e3;
        }
        /* Accent circle overlap */
        .cover-circle-accent {
            width: 260px;
            height: 260px;
            border: 2px dashed rgba(255,255,255,0.15);
            border-radius: 50%;
            position: absolute;
            right: 80px;
            bottom: -30px;
        }

        /* ── UN-Habitat logo at bottom-left ── */
        .cover-logo-bottom {
            position: absolute;
            bottom: 24px;
            left: 30px;
            z-index: 3;
        }
        .cover-logo-bottom img {
            height: 60px;
            filter: brightness(0) invert(1);
            opacity: 0.9;
        }

        /* ── Norad logo at bottom-right ── */
        .cover-logo-norad {
            position: absolute;
            bottom: 30px;
            right: 30px;
            z-index: 3;
        }
        .cover-logo-norad img {
            height: 32px;
            filter: brightness(0) invert(1);
            opacity: 0.7;
        }

        /* ── SDG strip on cover ── */
        .cover-sdg-strip {
            position: absolute;
            bottom: 80px;
            right: 30px;
            z-index: 3;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .cover-sdg-strip img.sdg-goal {
            height: 50px;
            border-radius: 3px;
        }
        .cover-sdg-strip img.sdg-wheel {
            height: 44px;
        }

        /* ============================
           REPORT CONTENT (page 2+)
           ============================ */
        .report-content {
            padding: 30px 35px;
        }
        .report-content-header {
            background: #009EDB;
            color: white;
            padding: 18px 25px;
            border-radius: 8px;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .report-content-header h2 {
            font-size: 18px;
            font-weight: 700;
            margin: 0;
        }
        .report-content-header .header-meta {
            font-size: 11px;
            opacity: 0.85;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .report-content-header .header-flag { font-size: 16px; border-radius: 2px; overflow: hidden; }

        /* ── Footer ── */
        .print-footer { margin-top: 30px; padding: 15px 20px 0; border-top: 2px solid #00689D; font-size: 9px; color: #868e96; }
        .print-footer-content { display: flex; align-items: center; justify-content: space-between; }
        .print-footer-left { display: flex; align-items: center; gap: 10px; }
        .print-footer-left img { height: 28px; object-fit: contain; }
        .print-footer-right { display: flex; align-items: center; gap: 6px; }
        .print-footer-right .sdg-footer-goal { height: 32px; border-radius: 2px; }
        .print-footer-right .sdg-footer-logo { height: 38px; margin-left: 4px; }
        .print-footer-center { text-align: center; font-size: 9px; color: #868e96; margin-top: 8px; }

        /* ── Hide interactive / irrelevant elements ── */
        .btn, button:not(.print-btn), .no-print,
        .tooltip-trigger .info-btn,
        .peer-data-section, .peer-upload-section, .custom-peer-section,
        .currency-override-toggle, .currency-override-select, #currencyOverrideRow,
        .form-check, .collapse-toggle-btn,
        #financialMetricsSection,
        .gov-unit-helper,
        .module2-selection,
        .frontier-placeholder { display: none !important; }

        /* ── Form elements as static text ── */
        .form-control, .form-select, select, input[type="text"], input[type="number"] {
            border: none !important;
            background: transparent !important;
            box-shadow: none !important;
            appearance: none !important;
            -webkit-appearance: none !important;
            -moz-appearance: none !important;
            pointer-events: none !important;
            font-weight: 500 !important;
            color: #212529 !important;
            padding-left: 2px !important;
            opacity: 1 !important;
        }
        .collapse { display: block !important; }
        [data-bs-toggle] { cursor: default !important; }

        /* ── Page break rules (global for Playwright PDF + browser print) ── */
        .card, .input-card, .compact-card { break-inside: avoid; page-break-inside: avoid; }
        .module2-section { break-inside: avoid; page-break-inside: avoid; }
        .report-content-header { break-inside: avoid; break-after: avoid; page-break-inside: avoid; }
        .print-footer { break-inside: avoid; page-break-inside: avoid; }
        .frontier-header, .module2-header { break-after: avoid; page-break-after: avoid; }
        h4, h5 { break-after: avoid; page-break-after: avoid; }
        img, svg, canvas { break-inside: avoid; page-break-inside: avoid; }
        table, .table { break-inside: avoid; page-break-inside: avoid; }
        .chart-container, .chart-wrapper { break-inside: avoid; page-break-inside: avoid; }
        .kpi-row, .kpi-grid { break-inside: avoid; page-break-inside: avoid; }

        .print-btn-wrapper { display: block; }
        @@page {
            size: portrait;
            margin: 8mm;
        }
        @@page :first {
            margin: 0;
        }
        @@media print {
            body { margin: 0; padding: 0; background: #fff; }
            .print-btn-wrapper { display: none !important; }
            .report-box {
                max-width: 100%;
                margin: 0;
                border: none;
                border-radius: 0;
                box-shadow: none;
            }
            .cover-page { min-height: 0; height: 100vh; }
            .report-content { padding: 15px; }
        }
    </style>
</head>
<body>

    <!-- ════════════════════════════════
         BOXED REPORT CONTAINER
         ════════════════════════════════ -->
    <div class="report-box">

    <!-- Cover Page -->
    <div class="cover-page">
        <!-- City background image -->
        <div class="cover-bg-image">
            <img src="~/images/cities/nairobi.jpg" alt="" />
        </div>
        <!-- Orbit ring -->
        <div class="cover-orbit"></div>

        <!-- Top: City circle -->
        <div class="cover-top">
            <div class="cover-circle-main">
                <img src="~/images/cities/addis-ababa.jpg" alt="City skyline" />
            </div>
            <div class="cover-circle-sm cover-circle-sm-1">
                <img src="~/images/sdg/E_WEB_11.png" alt="SDG 11" />
            </div>
            <div class="cover-circle-sm cover-circle-sm-2">
                <img src="~/images/cities/nairobi.jpg" alt="City" />
            </div>
            <div class="cover-circle-sm cover-circle-sm-3">
                <img src="~/images/sdg/E_WEB_17.png" alt="SDG 17" />
            </div>
        </div>

        <!-- Title -->
        <div class="cover-title-section">
            <h1 class="cover-title">Rapid Own-Source<br />Revenue Analysis</h1>
            <p class="cover-subtitle">Top-Down Analysis Report</p>
            <div class="cover-location">
                @if (!string.IsNullOrEmpty(countryCode))
                {
                    <span class="cover-flag fi fi-@countryCode"></span>
                }
                <span class="cover-country-name">@(Model.Country ?? "ROSRA")</span>
            </div>
            <div class="cover-location-detail">
                @if (Model.Region != null)
                {
                    <span>@Model.Region</span>
                }
                @if (Model.City != null)
                {
                    <span>@Model.City</span>
                }
                @if (Model.FinancialYear != null)
                {
                    <span>FY @Model.FinancialYear</span>
                }
                @if (Model.Currency != null)
                {
                    <span>@Model.Currency (@cs)</span>
                }
            </div>
        </div>

        <!-- Bottom geometric blocks -->
        <div class="cover-bottom">
            <div class="cover-block cover-block-1"></div>
            <div class="cover-block cover-block-2">
                <img src="~/images/sdg/E_WEB_11.png" alt="" />
            </div>
            <div class="cover-block cover-block-3"></div>
            <div class="cover-circle-deco">
                <div class="cover-circle-deco-inner"></div>
            </div>
            <div class="cover-circle-accent"></div>
        </div>

        <!-- Logos -->
        <div class="cover-logo-bottom">
            <img src="~/images/Light-theme-logo.png" alt="UN-Habitat" />
        </div>
        <div class="cover-logo-norad">
            <img src="~/images/Light-theme-norad.png" alt="Norad" />
        </div>

        <!-- SDG Goals strip -->
        <div class="cover-sdg-strip">
            <img class="sdg-goal" src="~/images/sdg/E_WEB_INVERTED_11.png" alt="SDG 11" />
            <img class="sdg-goal" src="~/images/sdg/E_WEB_INVERTED_16.png" alt="SDG 16" />
            <img class="sdg-goal" src="~/images/sdg/E_WEB_INVERTED_17.png" alt="SDG 17" />
            <img class="sdg-wheel" src="~/images/sdg/SDG_Wheel_WEB.png" alt="SDG Wheel" />
        </div>
    </div>

    <!-- ════════════════════════════════
         REPORT CONTENT (page 2+)
         ════════════════════════════════ -->
    <div class="report-content">
        <!-- Compact running header -->
        <div class="report-content-header">
            <h2>Top-Down Analysis Report</h2>
            <div class="header-meta">
                @if (!string.IsNullOrEmpty(countryCode))
                {
                    <span class="header-flag fi fi-@countryCode"></span>
                }
                <span>@(Model.Country ?? "-")</span>
                @if (Model.Region != null)
                {
                    <span>&rsaquo; @Model.Region</span>
                }
                @if (Model.City != null)
                {
                    <span>&rsaquo; @Model.City</span>
                }
            </div>
        </div>

        <!-- Render the same partial as the main app -->
        @await Html.PartialAsync("_PotentialEstimates", Model)

        <!-- Footer -->
        <div class="print-footer">
            <div class="print-footer-content">
                <div class="print-footer-left">
                    <img src="~/images/logo.d95ced55c7a543c8d241.png" alt="ROSRA UN-Habitat" />
                </div>
                <div class="print-footer-right">
                    <img class="sdg-footer-goal" src="~/images/sdg/E_WEB_11.png" alt="SDG 11" />
                    <img class="sdg-footer-goal" src="~/images/sdg/E_WEB_16.png" alt="SDG 16" />
                    <img class="sdg-footer-goal" src="~/images/sdg/E_WEB_17.png" alt="SDG 17" />
                    <img class="sdg-footer-logo" src="~/images/sdg/E_SDG_logo_horizontal_trans.png" alt="SDG" />
                </div>
            </div>
            <div class="print-footer-center">
                ROSRA &mdash; Rapid Own-Source Revenue Analysis Tool | &copy; @DateTime.Now.Year UN-Habitat. All rights reserved. | Generated @DateTime.Now.ToString("dd MMM yyyy")
            </div>
        </div>
    </div>

    </div> <!-- /.report-box -->

    <div class="print-btn-wrapper" style="position:fixed;top:15px;right:15px;z-index:9999;">
        <button class="print-btn" onclick="window.print()" style="background:#009EDB;color:#fff;border:none;padding:10px 24px;border-radius:6px;font-size:14px;font-weight:600;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,.15);">
            &#128438; Print / Save as PDF
        </button>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        var isViewMode = true;

        document.addEventListener('DOMContentLoaded', function () {
            function setSelectValue(id, value) {
                var el = document.getElementById(id);
                if (el && value) {
                    var opt = document.createElement('option');
                    opt.value = value;
                    opt.text = value;
                    opt.selected = true;
                    el.appendChild(opt);
                }
            }

            setSelectValue('country', '@Html.Raw(Model.Country?.Replace("'", "\\'") ?? "")');
            setSelectValue('financialYear', '@Html.Raw(Model.FinancialYear?.Replace("'", "\\'") ?? "")');
            setSelectValue('region', '@Html.Raw(Model.Region?.Replace("'", "\\'") ?? "")');

            var region = '@Html.Raw(Model.Region?.Replace("'", "\\'") ?? "")';
            var city = '@Html.Raw(Model.City?.Replace("'", "\\'") ?? "")';
            var level3 = '@Html.Raw(Model.GovUnitLevel3?.Replace("'", "\\'") ?? "")';

            if (region) {
                var l1Row = document.getElementById('govUnitLevel1Row');
                if (l1Row) l1Row.style.display = '';
            }
            if (city) {
                var l2Row = document.getElementById('govUnitLevel2Row');
                if (l2Row) l2Row.style.display = '';
            }
            if (level3) {
                var l3Row = document.getElementById('govUnitLevel3Row');
                if (l3Row) l3Row.style.display = '';
            }
            // Auto-print if requested (opens Save as PDF dialog, then closes tab)
            if (window.location.search.indexOf('autoPrint=true') >= 0) {
                setTimeout(function() {
                    window.print();
                    window.onafterprint = function() { window.close(); };
                }, 2000);
            }
        });
    </script>
</body>
</html>
