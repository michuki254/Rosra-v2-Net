  <data name="GapAmounts_Col_Stream" xml:space="preserve"><value>Stream</value></data>
  <data name="GapAmounts_Col_Priority1" xml:space="preserve"><value>Priority 1</value></data>
  <data name="GapAmounts_Col_Amount1" xml:space="preserve"><value>Amount 1</value></data>
  <data name="GapAmounts_Col_Priority2" xml:space="preserve"><value>Priority 2</value></data>
  <data name="GapAmounts_Col_Amount2" xml:space="preserve"><value>Amount 2</value></data>
  <data name="GapAmounts_Col_Priority3" xml:space="preserve"><value>Priority 3</value></data>
  <data name="GapAmounts_Col_Amount3" xml:space="preserve"><value>Amount 3</value></data>
  <data name="GapAmounts_Placeholder" xml:space="preserve"><value>Gap amounts will appear after gap prioritization</value></data>

  <!-- Reform Sequence Summary -->
  <data name="ReformSummary_Title" xml:space="preserve"><value>Reform Sequence Summary</value></data>
  <data name="ReformSummary_TotalStreams" xml:space="preserve"><value>Total Streams</value></data>
  <data name="ReformSummary_TotalGapCombinations" xml:space="preserve"><value>Total Gap Combinations</value></data>
  <data name="ReformSummary_RemovedGaps" xml:space="preserve"><value>Removed Gaps</value></data>
  <data name="ReformSummary_ActiveGapActions" xml:space="preserve"><value>Active Gap Actions</value></data>
  <data name="ReformSummary_FirstPriorityActions" xml:space="preserve"><value>First Priority Actions:</value></data>
  <data name="ReformSummary_NoActionsDefined" xml:space="preserve"><value>No actions defined yet</value></data>

  <!-- Master Priority List -->
  <data name="MasterPriority_Title" xml:space="preserve"><value>Master Priority List</value></data>
  <data name="MasterPriority_Col_Number" xml:space="preserve"><value>#</value></data>
  <data name="MasterPriority_Col_Stream" xml:space="preserve"><value>Stream</value></data>
  <data name="MasterPriority_Col_Gap" xml:space="preserve"><value>Gap</value></data>
  <data name="MasterPriority_Col_Amount" xml:space="preserve"><value>Amount</value></data>
  <data name="MasterPriority_Placeholder" xml:space="preserve"><value>Master list will populate from gap priorities</value></data>
</root>
