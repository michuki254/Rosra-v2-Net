  <resheader name="writer"><value>System.Resources.ResXResourceWriter, System.Windows.Forms, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089</value></resheader>

  <!-- Step 1: Stream Prioritization Header -->
  <data name="Step1_Title" xml:space="preserve"><value>Stream Prioritization</value></data>
  <data name="Step1_Description" xml:space="preserve"><value>&lt;strong&gt;Step 1&lt;/strong&gt; of the Prioritization Pipeline: Rank revenue streams by their Total Functional Gap to determine which streams to tackle first. Include or exclude streams based on local priorities, capacity, or political considerations.</value></data>

  <!-- Instructions -->
  <data name="Instructions_Title" xml:space="preserve"><value>How to use this module</value></data>
  <data name="Instructions_Step1" xml:space="preserve"><value>Review the &lt;strong&gt;Adjustable Stream Prioritization&lt;/strong&gt; table showing all analyzed revenue streams ranked by Total Functional Gap.</value></data>
  <data name="Instructions_Step2" xml:space="preserve"><value>Use the &lt;strong&gt;Include/Exclude&lt;/strong&gt; dropdown to select which streams to include in your reform plan.</value></data>
  <data name="Instructions_Step3" xml:space="preserve"><value>Use the &lt;strong&gt;Adjust Rank&lt;/strong&gt; dropdown to override the default ranking based on local priorities.</value></data>
  <data name="Instructions_Step4" xml:space="preserve"><value>View the &lt;strong&gt;Final Stream Prioritization&lt;/strong&gt; table to see your finalized rankings and share of total gap.</value></data>

  <!-- Adjustable Stream Table -->
  <data name="AdjustableStream_Title" xml:space="preserve"><value>Adjustable Stream Prioritization</value></data>
  <data name="AdjustableStream_Col_DefaultRank" xml:space="preserve"><value>Default Rank</value></data>
  <data name="AdjustableStream_Col_StreamName" xml:space="preserve"><value>Stream Name</value></data>
  <data name="AdjustableStream_Col_TotalFunctionalGap" xml:space="preserve"><value>Total Functional Gap</value></data>
  <data name="AdjustableStream_Col_IncludeExclude" xml:space="preserve"><value>Include/Exclude</value></data>
  <data name="AdjustableStream_Col_AdjustRank" xml:space="preserve"><value>Adjust Rank</value></data>
  <data name="AdjustableStream_Tooltip_DefaultRank" xml:space="preserve"><value>Automatically assigned based on Total Functional Gap (largest = 1)</value></data>
  <data name="AdjustableStream_Tooltip_StreamName" xml:space="preserve"><value>The name of the revenue stream being analyzed</value></data>
  <data name="AdjustableStream_Tooltip_TotalFunctionalGap" xml:space="preserve"><value>Sum of all gap components for this stream</value></data>
  <data name="AdjustableStream_Tooltip_IncludeExclude" xml:space="preserve"><value>Include this stream in the reform plan or exclude it</value></data>
  <data name="AdjustableStream_Tooltip_AdjustRank" xml:space="preserve"><value>Override the default rank based on local priorities</value></data>
  <data name="AdjustableStream_Placeholder" xml:space="preserve"><value>Loading stream data from Gap Analysis...</value></data>

