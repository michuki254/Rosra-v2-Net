  <data name="FinalStream_Col_StreamName" xml:space="preserve"><value>Stream Name</value></data>
  <data name="FinalStream_Col_TotalFunctionalGap" xml:space="preserve"><value>Total Functional Gap</value></data>
  <data name="FinalStream_Col_ShareOfTotalGap" xml:space="preserve"><value>Share of Total Gap</value></data>
  <data name="FinalStream_Col_Status" xml:space="preserve"><value>Status</value></data>
  <data name="FinalStream_Tooltip_FinalRank" xml:space="preserve"><value>Final rank after adjustments (only included streams)</value></data>
  <data name="FinalStream_Tooltip_StreamName" xml:space="preserve"><value>The name of the revenue stream</value></data>
  <data name="FinalStream_Tooltip_TotalFunctionalGap" xml:space="preserve"><value>Total functional gap for this stream</value></data>
  <data name="FinalStream_Tooltip_ShareOfTotalGap" xml:space="preserve"><value>This stream's gap as a percentage of the total gap across all included streams</value></data>
  <data name="FinalStream_Tooltip_Status" xml:space="preserve"><value>Stream status in the reform plan</value></data>
  <data name="FinalStream_Placeholder" xml:space="preserve"><value>Final rankings will appear after selecting streams above</value></data>
  <data name="FinalStream_Footer_Total" xml:space="preserve"><value>Total (Included Streams)</value></data>

  <!-- Charts -->
  <data name="Chart_BarTitle" xml:space="preserve"><value>Total Functional Gap by Stream</value></data>
  <data name="Chart_PieTitle" xml:space="preserve"><value>Share of Total Gap</value></data>
  <data name="Chart_Placeholder" xml:space="preserve"><value>Complete Gap Analysis to see chart data</value></data>

  <!-- Summary Statistics -->
  <data name="Stats_TotalStreamsAnalyzed" xml:space="preserve"><value>Total Streams Analyzed</value></data>
  <data name="Stats_StreamsIncluded" xml:space="preserve"><value>Streams Included</value></data>
